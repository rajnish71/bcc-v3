---
/**
 * PhotoCard.astro
 * A single photo in the justified grid.
 * Renders the image inside a viewfinder-framed container.
 * Displays photographer name + photo title on hover.
 *
 * The `width` and `height` props are computed by the justified-layout
 * algorithm client-side; this component receives them as inline style strings
 * when the grid is reconstructed. For SSR placeholder rendering they can be
 * omitted (the grid script will apply correct sizes after hydration).
 *
 * Viewfinder crop-mark corners are implemented via global .vf-card CSS.
 */

interface Props {
  /** Public URL of the image (ImageKit CDN) */
  src: string;
  /** Alt text */
  alt: string;
  /** Original aspect ratio (width / height) — stored as data-aspect for client grid */
  aspect: number;
  /** Photographer display name */
  photographer?: string;
  /** Photo title */
  title?: string;
  /** Link destination — defaults to photo detail page */
  href?: string;
  /** Blur-up placeholder (tiny base64 or low-res URL) */
  placeholder?: string;
  /** Lazy loading — true by default */
  lazy?: boolean;
}

const {
  src,
  alt,
  aspect,
  photographer,
  title,
  href = '#',
  placeholder,
  lazy = true,
} = Astro.props;
---

<a
  href={href}
  class="photo-card vf-card"
  data-aspect={aspect}
  aria-label={title ? `${title}${photographer ? ` by ${photographer}` : ''}` : alt}
>
  {/* Blur-up placeholder */}
  {placeholder && (
    <img
      src={placeholder}
      alt=""
      aria-hidden="true"
      class="photo-card__blur"
      width="32"
      height={Math.round(32 / aspect)}
    />
  )}

  {/* Main image */}
  <img
    src={src}
    alt={alt}
    class="photo-card__img"
    loading={lazy ? 'lazy' : 'eager'}
    decoding="async"
  />

  {/* Hover overlay */}
  <div class="photo-overlay" aria-hidden="true"></div>

  {/* Info overlay (visible on hover) */}
  {(title || photographer) && (
    <div class="photo-card__info" aria-hidden="true">
      {title && <div class="photo-card__title">{title}</div>}
      {photographer && <div class="photo-card__photographer">{photographer}</div>}
    </div>
  )}

  {/* Viewfinder crop-mark corner spans */}
  <span class="vf-br" aria-hidden="true"></span>
  <span class="vf-bl" aria-hidden="true"></span>
</a>

<style>
.photo-card {
  position: relative;
  display: block;
  overflow: hidden;
  background: var(--surface);
  /* width + height set by justified-layout.js at runtime */
  flex-shrink: 0;
  cursor: pointer;
  border-radius: 2px;
}

/* Blur-up placeholder — fills while main image loads */
.photo-card__blur {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: blur(12px);
  transform: scale(1.05); /* hide blur edges */
  z-index: 0;
  transition: opacity 0.4s;
}
.photo-card__img.loaded + .photo-card__blur,
.photo-card:has(.photo-card__img.loaded) .photo-card__blur {
  opacity: 0;
}

.photo-card__img {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.photo-card:hover .photo-card__img {
  transform: scale(1.04);
}

/* Caption overlay */
.photo-card__info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--space-3) var(--space-4) var(--space-4);
  z-index: 8;
  opacity: 0;
  transform: translateY(4px);
  transition: opacity 0.25s ease, transform 0.25s ease;
}
.photo-card:hover .photo-card__info {
  opacity: 1;
  transform: translateY(0);
}
.photo-card__title {
  font-family: var(--font-display);
  font-size: var(--text-sm);
  font-weight: 600;
  color: #fff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 2px;
}
.photo-card__photographer {
  font-size: 11px;
  color: rgba(255,255,255,0.65);
}
</style>
