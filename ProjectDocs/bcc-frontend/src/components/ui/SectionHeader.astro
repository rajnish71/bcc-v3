---
/**
 * SectionHeader.astro
 * Standard section heading pattern: eyebrow label + display title + optional subtitle.
 * Used consistently across all public pages.
 */

interface Props {
  /** Small ALL-CAPS amber label above the title */
  eyebrow?: string;
  /** Main section title (Outfit font) */
  title: string;
  /** Optional subtitle / lead paragraph */
  subtitle?: string;
  /** Heading element — defaults to h2 */
  as?: 'h1' | 'h2' | 'h3';
  /** Text alignment */
  align?: 'left' | 'center';
  /** Bottom margin size */
  spacing?: 'sm' | 'md' | 'lg';
  /** Optional extra classes */
  class?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  as: Tag = 'h2',
  align = 'left',
  spacing = 'md',
  class: cls = '',
} = Astro.props;
---

<div class:list={['section-header', `section-header--${align}`, `section-header--${spacing}`, cls]}>
  {eyebrow && <div class="eyebrow section-header__eyebrow">{eyebrow}</div>}
  <Tag class="section-header__title">{title}</Tag>
  {subtitle && <p class="section-header__subtitle">{subtitle}</p>}
</div>

<style>
.section-header { max-width: 640px; }
.section-header--center {
  margin: 0 auto;
  text-align: center;
}
.section-header--sm  { margin-bottom: var(--space-8); }
.section-header--md  { margin-bottom: var(--space-10); }
.section-header--lg  { margin-bottom: var(--space-12); }

.section-header__eyebrow { margin-bottom: var(--space-2); }

.section-header__title {
  font-family: var(--font-display);
  font-size: clamp(var(--text-h3), 4vw, var(--text-h2));
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.15;
  color: var(--text);
}

.section-header__subtitle {
  margin-top: var(--space-4);
  font-size: var(--text-base);
  color: var(--text-2);
  line-height: 1.7;
  max-width: 520px;
}
.section-header--center .section-header__subtitle {
  margin-left: auto;
  margin-right: auto;
}
</style>
