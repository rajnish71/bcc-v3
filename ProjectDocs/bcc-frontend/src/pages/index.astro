---
/**
 * index.astro — Home Page
 *
 * Sections:
 * 1. Hero — full-bleed spotlight photo, title, CTAs, aperture deco
 * 2. Stats bar — live member count, photos, events, exhibitions (GSAP counter)
 * 3. Gallery Wall — justified photo grid ("On the Wall")
 * 4. Featured Activities — upcoming events
 * 5. Membership CTA — three public classes (Basic, Student, Individual)
 * 6. Photographers strip — top contributor thumbnails
 *
 * Data strategy for Phase 1:
 * - Stats: client-side fetch from /api/v1/stats with numeric fallback
 * - Photos: client-side fetch from /api/v1/photos?limit=12&showcase=true
 *   with empty-state handling (gallery wall shows placeholder grid if API
 *   returns nothing — Module 05 / Gallery is Phase 2a)
 * - Events: client-side fetch from /api/v1/events?upcoming=true&limit=3
 *
 * MEM-006 public domain: only Basic, Student, Individual membership classes
 * appear on this page. No constitutional classes referenced.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
---

<BaseLayout
  title="Home"
  description="Bhopal Camera Club — Photography community since 2016. Explore member portfolios, upcoming events, and join Bhopal's most active photography club."
>

  <!-- ══════════════════════════════════════════════════
       1. HERO
       ══════════════════════════════════════════════════ -->
  <section class="hero" id="hero" aria-label="Featured photograph">

    <!-- Background image -->
    <div class="hero-bg" id="hero-bg" aria-hidden="true">
      <!-- Replaced at runtime by spotlight API; static fallback is a dark gradient -->
      <div class="hero-bg__gradient"></div>
      <img
        id="hero-img"
        src=""
        alt=""
        class="hero-bg__img"
        loading="eager"
        decoding="async"
        aria-hidden="true"
      />
    </div>

    <!-- Gradient overlay -->
    <div class="hero-overlay" aria-hidden="true"></div>

    <!-- Spotlight badge -->
    <div class="hero-spotlight-badge" aria-label="BCC Spotlight">
      <span class="hero-spotlight-dot" aria-hidden="true"></span>
      <span class="hero-spotlight-label">BCC Spotlight</span>
    </div>

    <!-- Hero content -->
    <div class="hero-content container-wide">
      <div class="hero-text">
        <div class="hero-photo-meta" id="hero-meta">
          <span id="hero-photographer-label">by <a href="#" class="hero-photographer-link" id="hero-photographer-href"></a></span>
          <span class="hero-meta-sep" aria-hidden="true">·</span>
          <span class="hero-activity" id="hero-activity"></span>
        </div>
        <h1 class="hero-title" id="hero-title">
          Light, Frame,<br/>Moment.
        </h1>
        <p class="hero-body" id="hero-body">
          Bhopal Camera Club brings together photographers who see the world differently. Explore our members' work, join an upcoming photowalk, or become a member.
        </p>
        <div class="hero-ctas">
          <a href="/showcase/" class="btn btn-primary btn-lg">
            Explore Showcase
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/membership/" class="btn btn-ghost btn-lg">Become a Member</a>
        </div>
      </div>
    </div>

    <!-- Aperture deco ring (GSAP slow rotation) -->
    <div class="hero-aperture aperture-deco" aria-hidden="true">
      <div class="aperture-deco-ring" style="width:88px;height:88px;"></div>
    </div>

  </section>


  <!-- ══════════════════════════════════════════════════
       2. STATS BAR
       ══════════════════════════════════════════════════ -->
  <section class="stats-bar" aria-label="Club statistics">
    <div class="container-wide">
      <div class="stats-inner">

        <div class="stat">
          <div class="stat-value" data-stat="members">—</div>
          <div class="stat-label">Active Members</div>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>

        <div class="stat">
          <div class="stat-value" data-stat="photos">—</div>
          <div class="stat-label">Portfolio Photographs</div>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>

        <div class="stat">
          <div class="stat-value" data-stat="events">—</div>
          <div class="stat-label">Events Hosted</div>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>

        <div class="stat">
          <div class="stat-value" data-stat="exhibitions">—</div>
          <div class="stat-label">Exhibitions Curated</div>
        </div>

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       3. GALLERY WALL — Justified grid
       ══════════════════════════════════════════════════ -->
  <section class="section gallery-wall" id="gallery-wall" aria-label="Member portfolio highlights">
    <div class="container">
      <div class="gallery-wall__header">
        <SectionHeader
          eyebrow="On the Wall"
          title="Our members, on the wall"
          subtitle="A curated selection from our members' portfolios — original aspect ratios preserved, as the photographer composed them."
        />
        <a href="/showcase/" class="btn btn-ghost-amber">
          View all in Showcase
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2.5 7h9M8 3l3.5 4L8 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- Grid populated by justified-layout.js — shows skeleton while loading -->
      <div class="justified-grid" id="gallery-grid" aria-label="Photo grid" data-target-height="240" data-gap="8">
        <!-- Skeleton rows shown until JS populates real photos -->
        <div class="grid-skeleton" id="grid-skeleton" aria-busy="true" aria-label="Loading photos">
          <div class="skel-row">
            <div class="skel-photo" style="flex:3.2"></div>
            <div class="skel-photo" style="flex:1.5"></div>
            <div class="skel-photo" style="flex:4"></div>
            <div class="skel-photo" style="flex:1"></div>
          </div>
          <div class="skel-row">
            <div class="skel-photo" style="flex:1"></div>
            <div class="skel-photo" style="flex:2.5"></div>
            <div class="skel-photo" style="flex:1.2"></div>
            <div class="skel-photo" style="flex:2"></div>
            <div class="skel-photo" style="flex:1.8"></div>
          </div>
          <div class="skel-row">
            <div class="skel-photo" style="flex:2.4"></div>
            <div class="skel-photo" style="flex:1.5"></div>
            <div class="skel-photo" style="flex:3"></div>
            <div class="skel-photo" style="flex:1"></div>
          </div>
        </div>
        <!-- Real photos injected here by gallery-wall.js -->
      </div>

      <!-- Empty state (shown if API returns nothing / Phase 2a not built) -->
      <div class="gallery-empty" id="gallery-empty" hidden>
        <div class="gallery-empty__icon" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
            <circle cx="24" cy="24" r="22.5" stroke="rgba(255,255,255,0.1)" stroke-width="1.5"/>
            <circle cx="24" cy="24" r="8" stroke="rgba(245,168,42,0.4)" stroke-width="1.5"/>
            <circle cx="24" cy="24" r="2" fill="rgba(245,168,42,0.6)"/>
          </svg>
        </div>
        <p class="gallery-empty__text">Member portfolios are on their way.</p>
        <p class="gallery-empty__sub">The gallery will appear here once it's populated.</p>
      </div>

    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       4. FEATURED ACTIVITIES
       ══════════════════════════════════════════════════ -->
  <section class="section section--alt activities-section" aria-label="Upcoming activities">
    <div class="container">

      <div class="activities-header">
        <SectionHeader
          eyebrow="What's On"
          title="Upcoming activities"
          subtitle="Photowalks, workshops, and more — open to all members."
        />
        <a href="/events/" class="btn btn-ghost">
          All events
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2.5 7h9M8 3l3.5 4L8 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- Events grid — populated by JS -->
      <div class="events-grid" id="events-grid">
        <!-- Loading skeletons -->
        {[1,2,3].map(() => (
          <div class="event-card-skel glass-panel">
            <div class="skel-line skel-line--short"></div>
            <div class="skel-line skel-line--long" style="margin-top:8px"></div>
            <div class="skel-line" style="margin-top:16px; width:60%"></div>
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       5. MEMBERSHIP CTA
       MEM-006: only Basic, Student, Individual visible publicly
       ══════════════════════════════════════════════════ -->
  <section class="section membership-cta" aria-label="Join Bhopal Camera Club">
    <div class="container">

      <SectionHeader
        eyebrow="Membership"
        title="Join Bhopal Camera Club"
        subtitle="We offer membership for everyone — from casual enthusiasts to serious practitioners."
        align="center"
      />

      <div class="membership-cards">

        <!-- Basic -->
        <div class="mem-card glass-panel">
          <div class="mem-card__badge" style="--class-color: var(--badge-basic)">Basic</div>
          <div class="mem-card__title">Basic Member</div>
          <div class="mem-card__price">Free</div>
          <p class="mem-card__desc">Platform access, public showcase, and the ability to follow club activities. The starting point for every member.</p>
          <ul class="mem-card__features">
            <li>Platform profile</li>
            <li>Public showcase access</li>
            <li>Event announcements</li>
            <li>BCC newsletter</li>
          </ul>
          <a href="/membership/#apply" class="btn btn-ghost mem-card__cta">Apply for Membership</a>
        </div>

        <!-- Student -->
        <div class="mem-card glass-panel mem-card--featured">
          <div class="mem-card__badge" style="--class-color: var(--badge-student)">Student</div>
          <div class="mem-card__title">Student Member</div>
          <div class="mem-card__price">Annual fee</div>
          <p class="mem-card__desc">For photography students and learners. Access to workshops, mentored sessions, and club events at a reduced fee.</p>
          <ul class="mem-card__features">
            <li>Everything in Basic</li>
            <li>Workshop participation</li>
            <li>Mentored feedback sessions</li>
            <li>Event participation (reduced fee)</li>
            <li>Portfolio display on Showcase</li>
          </ul>
          <a href="/membership/#apply" class="btn btn-primary mem-card__cta">Apply for Membership</a>
        </div>

        <!-- Individual -->
        <div class="mem-card glass-panel">
          <div class="mem-card__badge" style="--class-color: var(--badge-individual)">Individual</div>
          <div class="mem-card__title">Individual Member</div>
          <div class="mem-card__price">Annual fee</div>
          <p class="mem-card__desc">For active photography practitioners. Full participation in club events, contests, and exhibitions.</p>
          <ul class="mem-card__features">
            <li>Everything in Student</li>
            <li>Contest submissions</li>
            <li>Exhibition participation</li>
            <li>Voting rights</li>
            <li>Digital membership card</li>
          </ul>
          <a href="/membership/#apply" class="btn btn-ghost mem-card__cta">Apply for Membership</a>
        </div>

      </div>

      <p class="membership-footnote">
        <a href="/membership/" class="btn-text">Learn more about membership →</a>
      </p>

    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       6. PHOTOGRAPHER STRIP
       ══════════════════════════════════════════════════ -->
  <section class="section photographers-strip" aria-label="Featured photographers">
    <div class="container">
      <div class="phstrip-header">
        <SectionHeader
          eyebrow="Our Photographers"
          title="The people behind the lens"
        />
        <a href="/photographers/" class="btn btn-ghost">
          All photographers
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2.5 7h9M8 3l3.5 4L8 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <div class="phstrip-grid" id="phstrip-grid">
        <!-- Populated by JS — photographer avatars + names -->
        {[...Array(8)].map((_, i) => (
          <div class="phstrip-card-skel" aria-hidden="true">
            <div class="phstrip-avatar-skel"></div>
            <div class="skel-line" style="width:70%;margin-top:8px"></div>
          </div>
        ))}
      </div>

    </div>
  </section>

</BaseLayout>


<style>
/* ── Hero ── */
.hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  align-items: flex-end;
  padding-bottom: var(--space-20);
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.hero-bg__gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--bg) 0%, #1A1420 50%, var(--bg-2) 100%);
}
.hero-bg__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0;
  transition: opacity 0.8s ease;
}
.hero-bg__img.loaded { opacity: 1; }

.hero-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background:
    linear-gradient(to top, rgba(11,11,14,0.88) 0%, rgba(11,11,14,0.3) 40%, transparent 65%),
    linear-gradient(to right, rgba(11,11,14,0.5) 0%, transparent 60%);
}

.hero-spotlight-badge {
  position: absolute;
  top: calc(var(--nav-h) + var(--space-6));
  left: var(--space-10);
  z-index: 10;
  display: flex;
  align-items: center;
  gap: var(--space-2);
  background: rgba(255,255,255,0.08);
  border: 1px solid var(--border-md);
  border-radius: var(--radius-full);
  padding: 5px 12px;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}
.hero-spotlight-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--amber);
  animation: livePulse 2s infinite;
}
.hero-spotlight-label {
  font-size: var(--text-label);
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-2);
}

.hero-content {
  position: relative;
  z-index: 10;
}
.hero-text { max-width: 560px; }

.hero-photo-meta {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-bottom: var(--space-3);
  font-size: var(--text-sm);
  color: var(--text-2);
  min-height: 1.4em;
}
.hero-photo-meta:empty { display: none; }
.hero-photographer-link {
  color: var(--text-2);
  text-decoration: underline;
  text-underline-offset: 3px;
  transition: color 0.2s;
}
.hero-photographer-link:hover { color: var(--text); }
.hero-meta-sep { opacity: 0.4; }
.hero-activity { color: var(--text-3); }

.hero-title {
  font-family: var(--font-display);
  font-size: clamp(var(--text-h1), 6vw, var(--text-display));
  font-weight: 800;
  letter-spacing: -0.04em;
  line-height: 1.0;
  color: var(--text);
  margin-bottom: var(--space-6);
}

.hero-body {
  font-size: var(--text-base);
  color: var(--text-2);
  line-height: 1.7;
  max-width: 480px;
  margin-bottom: var(--space-8);
}

.hero-ctas {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  flex-wrap: wrap;
}

.hero-aperture {
  position: absolute;
  bottom: var(--space-12);
  right: var(--space-12);
  z-index: 10;
  opacity: 0.7;
}

/* ── Stats bar ── */
.stats-bar {
  background: var(--surface);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: var(--space-6) 0;
}
.stats-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
}
.stat {
  flex: 1;
  text-align: center;
  padding: var(--space-4) var(--space-6);
}
.stat-value {
  font-family: var(--font-display);
  font-size: var(--text-h3);
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.02em;
  line-height: 1;
  margin-bottom: var(--space-1);
}
.stat-label {
  font-size: var(--text-xs);
  color: var(--text-3);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  font-weight: 500;
}
.stat-divider {
  width: 1px;
  height: 36px;
  background: var(--border-md);
  flex-shrink: 0;
}

/* ── Gallery wall ── */
.gallery-wall__header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--space-6);
  margin-bottom: var(--space-8);
}

.justified-grid {
  width: 100%;
  min-height: 200px;
  position: relative;
}
.justified-grid.grid-ready { min-height: unset; }

/* Skeleton */
.grid-skeleton { display: flex; flex-direction: column; gap: 8px; }
.skel-row { display: flex; gap: 8px; height: 220px; }
.skel-photo {
  background: var(--surface-2);
  border-radius: 2px;
  animation: shimmer 1.6s ease-in-out infinite;
}
@keyframes shimmer { 0%,100% { opacity:.4; } 50% { opacity:.7; } }

/* Real grid — rows built by JS */
.grid-row {
  display: flex;
  gap: 8px;
  margin-bottom: 8px;
}
.grid-row:last-child { margin-bottom: 0; }

.gallery-empty {
  text-align: center;
  padding: var(--space-20) 0;
  color: var(--text-3);
}
.gallery-empty__icon { margin-bottom: var(--space-4); display: flex; justify-content: center; }
.gallery-empty__text { font-size: var(--text-base); color: var(--text-2); margin-bottom: var(--space-2); }
.gallery-empty__sub  { font-size: var(--text-sm); }

/* ── Activities section ── */
.section--alt { background: var(--bg-2); }
.activities-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--space-6);
  margin-bottom: var(--space-8);
}
.events-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-5);
}
.event-card-skel {
  padding: var(--space-6);
  min-height: 160px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.skel-line {
  height: 10px;
  background: var(--surface-2);
  border-radius: 4px;
  width: 100%;
  animation: shimmer 1.6s ease-in-out infinite;
}
.skel-line--short { width: 40%; }
.skel-line--long  { width: 80%; }

/* ── Membership CTA ── */
.membership-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-5);
  margin-bottom: var(--space-8);
}
.mem-card {
  padding: var(--space-8);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  border-radius: var(--radius-lg);
  transition: border-color 0.2s;
}
.mem-card--featured {
  border-color: var(--border-amber);
  box-shadow: 0 0 0 1px var(--amber-muted), 0 24px 48px -12px rgba(0,0,0,0.5);
}

.mem-card__badge {
  display: inline-block;
  width: fit-content;
  padding: 3px 10px;
  border-radius: var(--radius-full);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--class-color);
  background: color-mix(in srgb, var(--class-color) 18%, transparent);
  border: 1px solid color-mix(in srgb, var(--class-color) 35%, transparent);
}
.mem-card__title {
  font-family: var(--font-display);
  font-size: var(--text-h4);
  font-weight: 700;
  color: var(--text);
}
.mem-card__price {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--amber);
  font-family: var(--font-display);
}
.mem-card__desc {
  font-size: var(--text-sm);
  color: var(--text-2);
  line-height: 1.6;
  flex: 1;
}
.mem-card__features {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  margin-bottom: var(--space-2);
}
.mem-card__features li {
  font-size: var(--text-sm);
  color: var(--text-2);
  padding-left: var(--space-5);
  position: relative;
}
.mem-card__features li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 8px;
  width: 12px;
  height: 1px;
  background: var(--amber);
  opacity: 0.6;
}
.mem-card__cta { width: 100%; justify-content: center; margin-top: auto; }
.membership-footnote { text-align: center; }

/* ── Photographers strip ── */
.phstrip-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--space-6);
  margin-bottom: var(--space-8);
}
.phstrip-grid {
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  gap: var(--space-4);
}
.phstrip-card-skel {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
}
.phstrip-avatar-skel {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: var(--surface-2);
  animation: shimmer 1.6s ease-in-out infinite;
}

/* ── Responsive ── */
@media (max-width: 1024px) {
  .events-grid { grid-template-columns: repeat(2, 1fr); }
  .membership-cards { grid-template-columns: repeat(2, 1fr); }
  .phstrip-grid { grid-template-columns: repeat(5, 1fr); }
}
@media (max-width: 768px) {
  .hero-spotlight-badge { left: var(--space-4); }
  .gallery-wall__header,
  .activities-header,
  .phstrip-header { flex-direction: column; align-items: flex-start; }
  .events-grid { grid-template-columns: 1fr; }
  .membership-cards { grid-template-columns: 1fr; }
  .phstrip-grid { grid-template-columns: repeat(4, 1fr); }
  .stats-inner { flex-wrap: wrap; }
  .stat-divider { display: none; }
  .stat { flex: 1 1 50%; border-bottom: 1px solid var(--border); }
  .stat:nth-child(n+5) { border-bottom: none; }
}
@media (max-width: 480px) {
  .phstrip-grid { grid-template-columns: repeat(3, 1fr); }
}
</style>


<script>
  /**
   * Home page scripts:
   * 1. Hero — load spotlight photo from API
   * 2. Stats bar — fetch + GSAP counter animation
   * 3. Gallery wall — fetch photos + justified layout algorithm
   * 4. Events — fetch upcoming events
   * 5. Photographers strip — fetch top contributors
   * 6. Aperture deco — GSAP entrance animation
   */
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  /* ── Aperture ring slow rotation ── */
  gsap.to('.aperture-deco-ring', {
    rotation: 360,
    duration: 40,
    repeat: -1,
    ease: 'none',
  });

  /* ── Hero entrance ── */
  const heroTl = gsap.timeline({ delay: 0.1 });
  heroTl
    .from('.hero-title', { opacity: 0, y: 40, duration: 0.9, ease: 'power3.out' })
    .from('.hero-body',  { opacity: 0, y: 24, duration: 0.7, ease: 'power3.out' }, '-=0.5')
    .from('.hero-ctas',  { opacity: 0, y: 20, duration: 0.6, ease: 'power3.out' }, '-=0.4')
    .from('.hero-spotlight-badge', { opacity: 0, x: -16, duration: 0.5, ease: 'power2.out' }, '-=0.7')
    .from('.hero-aperture', { opacity: 0, scale: 0.8, rotation: -20, duration: 1.2, ease: 'power3.out' }, '-=0.8');

  /* ── 1. Hero spotlight ── */
  (async () => {
    try {
      const res = await fetch('/api/v1/photos/spotlight');
      if (!res.ok) return;
      const { data } = await res.json();
      if (!data?.imageUrl) return;

      const img = document.getElementById('hero-img') as HTMLImageElement | null;
      if (img) {
        img.src = data.imageUrl;
        img.alt = data.title ?? 'BCC Spotlight';
        img.onload = () => img.classList.add('loaded');
      }
      const titleEl = document.getElementById('hero-title');
      if (titleEl && data.title) titleEl.textContent = data.title;

      const href = document.getElementById('hero-photographer-href') as HTMLAnchorElement | null;
      if (href && data.photographer) {
        href.textContent = data.photographer.displayName;
        href.href = `/photographers/${data.photographer.userid}/`;
      }
      const actEl = document.getElementById('hero-activity');
      if (actEl && data.activity) actEl.textContent = `From: ${data.activity}`;
    } catch {
      // Spotlight unavailable — fallback to gradient background (already shown)
    }
  })();

  /* ── 2. Stats ── */
  const STATS_FALLBACK = { members: 20, photos: 311, events: 47, exhibitions: 4 };

  (async () => {
    let stats = STATS_FALLBACK;
    try {
      const res = await fetch('/api/v1/stats');
      if (res.ok) {
        const { data } = await res.json();
        stats = { ...STATS_FALLBACK, ...data };
      }
    } catch { /* Use fallback */ }

    document.querySelectorAll<HTMLElement>('[data-stat]').forEach((el) => {
      const key = el.dataset.stat as keyof typeof stats;
      const target = stats[key] ?? 0;
      const counter = { val: 0 };
      gsap.to(counter, {
        val: target,
        duration: 2,
        ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 80%', once: true },
        onUpdate: () => { el.textContent = Math.round(counter.val).toLocaleString(); },
      });
    });
  })();

  /* ── 3. Gallery wall — justified layout ── */
  function buildJustifiedLayout(
    photos: Array<{ aspect: number }>,
    containerWidth: number,
    targetHeight = 240,
    gap = 8
  ) {
    const rows: Array<{ height: number; photos: Array<{ aspect: number; width: number }> }> = [];
    let row: typeof photos = [];
    let rowWidth = 0;

    const flush = (isLast = false) => {
      if (row.length === 0) return;
      const totalGap = gap * (row.length - 1);
      const scale = isLast
        ? Math.min(1, (containerWidth - totalGap) / rowWidth)
        : (containerWidth - totalGap) / rowWidth;
      const height = targetHeight * scale;
      rows.push({ height, photos: row.map((p) => ({ ...p, width: p.aspect * height })) });
      row = [];
      rowWidth = 0;
    };

    for (const photo of photos) {
      const idealW = photo.aspect * targetHeight;
      row.push(photo);
      rowWidth += idealW;
      const withGaps = rowWidth + gap * (row.length - 1);
      if (withGaps >= containerWidth * 0.88) flush();
    }
    flush(true);
    return rows;
  }

  (async () => {
    const grid    = document.getElementById('gallery-grid');
    const skel    = document.getElementById('grid-skeleton');
    const empty   = document.getElementById('gallery-empty');
    if (!grid) return;

    let photos: any[] = [];
    try {
      const res = await fetch('/api/v1/photos?showcase=true&limit=12');
      if (res.ok) {
        const { data } = await res.json();
        photos = Array.isArray(data) ? data : [];
      }
    } catch { /* stay empty */ }

    skel?.remove();

    if (photos.length === 0) {
      empty?.removeAttribute('hidden');
      grid.classList.add('grid-ready');
      return;
    }

    const containerWidth = grid.clientWidth;
    const rows = buildJustifiedLayout(photos, containerWidth);

    rows.forEach((row) => {
      const rowEl = document.createElement('div');
      rowEl.className = 'grid-row';
      row.photos.forEach((p: any) => {
        const link = document.createElement('a');
        link.href = p.href ?? `/showcase/${p.id}/`;
        link.className = 'photo-card vf-card';
        link.style.width  = `${p.width}px`;
        link.style.height = `${row.height}px`;
        link.setAttribute('data-aspect', String(p.aspect));

        const img = document.createElement('img');
        img.src     = p.imageUrl ?? '';
        img.alt     = p.title ?? p.alt ?? 'Photo by BCC member';
        img.loading = 'lazy';
        img.decoding = 'async';
        img.className = 'photo-card__img';
        img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
        img.onload = () => img.classList.add('loaded');

        const overlay = document.createElement('div');
        overlay.className = 'photo-overlay';
        overlay.setAttribute('aria-hidden', 'true');

        if (p.title || p.photographer) {
          const info = document.createElement('div');
          info.className = 'photo-card__info';
          info.setAttribute('aria-hidden', 'true');
          if (p.title) {
            const t = document.createElement('div');
            t.className = 'photo-card__title';
            t.textContent = p.title;
            info.appendChild(t);
          }
          if (p.photographer) {
            const ph = document.createElement('div');
            ph.className = 'photo-card__photographer';
            ph.textContent = p.photographer;
            info.appendChild(ph);
          }
          link.appendChild(info);
        }

        const br = document.createElement('span');
        br.className = 'vf-br';
        br.setAttribute('aria-hidden', 'true');
        const bl = document.createElement('span');
        bl.className = 'vf-bl';
        bl.setAttribute('aria-hidden', 'true');

        link.appendChild(img);
        link.appendChild(overlay);
        link.appendChild(br);
        link.appendChild(bl);
        rowEl.appendChild(link);
      });
      grid.appendChild(rowEl);
    });

    grid.classList.add('grid-ready');

    // GSAP scroll reveal for each photo card
    gsap.from('.grid-row .photo-card', {
      opacity: 0,
      y: 30,
      duration: 0.6,
      stagger: { amount: 0.4, from: 'random' },
      ease: 'power3.out',
      scrollTrigger: { trigger: grid, start: 'top 80%', once: true },
    });
  })();

  /* ── 4. Events ── */
  (async () => {
    const evGrid = document.getElementById('events-grid');
    if (!evGrid) return;

    let events: any[] = [];
    try {
      const res = await fetch('/api/v1/events?upcoming=true&limit=3');
      if (res.ok) {
        const { data } = await res.json();
        events = Array.isArray(data) ? data : [];
      }
    } catch { /* stay skeleton */ }

    if (events.length === 0) {
      evGrid.innerHTML = `<div class="events-empty" style="grid-column:1/-1;text-align:center;padding:var(--space-12) 0;color:var(--text-3);font-size:var(--text-sm);">
        No upcoming events right now. <a href="/events/" style="color:var(--amber);text-decoration:underline;text-underline-offset:3px;">Check the full events page →</a>
      </div>`;
      return;
    }

    evGrid.innerHTML = '';
    events.forEach((ev: any) => {
      const card = document.createElement('a');
      card.href  = `/events/${ev.slug ?? ev.id}/`;
      card.className = 'event-card glass-panel';
      card.innerHTML = `
        <div class="event-card__tag">${ev.type ?? 'Event'}</div>
        <div class="event-card__title">${ev.title ?? 'Upcoming Event'}</div>
        <div class="event-card__meta">
          <span>${ev.dateFormatted ?? ev.date ?? ''}</span>
          ${ev.location ? `<span>· ${ev.location}</span>` : ''}
        </div>
      `;
      evGrid.appendChild(card);
    });

    gsap.from('.event-card', {
      opacity: 0,
      y: 24,
      duration: 0.6,
      stagger: 0.1,
      ease: 'power3.out',
      scrollTrigger: { trigger: evGrid, start: 'top 80%', once: true },
    });
  })();

  /* ── 5. Photographers strip ── */
  (async () => {
    const strip = document.getElementById('phstrip-grid');
    if (!strip) return;

    let photographers: any[] = [];
    try {
      const res = await fetch('/api/v1/photographers?featured=true&limit=8');
      if (res.ok) {
        const { data } = await res.json();
        photographers = Array.isArray(data) ? data : [];
      }
    } catch { /* stay skeleton */ }

    if (photographers.length === 0) return; // keep skeleton visible

    strip.innerHTML = '';
    photographers.forEach((ph: any) => {
      const card = document.createElement('a');
      card.href = `/photographers/${ph.userid}/`;
      card.className = 'phstrip-card';
      const initials = (ph.displayName ?? '?').slice(0, 2).toUpperCase();
      card.innerHTML = `
        <div class="phstrip-avatar">${
          ph.avatarUrl
            ? `<img src="${ph.avatarUrl}" alt="${ph.displayName}" loading="lazy" width="72" height="72" />`
            : `<span>${initials}</span>`
        }</div>
        <div class="phstrip-name">${ph.displayName}</div>
      `;
      strip.appendChild(card);
    });

    gsap.from('.phstrip-card', {
      opacity: 0,
      y: 16,
      duration: 0.5,
      stagger: 0.06,
      ease: 'power2.out',
      scrollTrigger: { trigger: strip, start: 'top 85%', once: true },
    });
  })();
</script>

<style>
/* Event cards (real, not skeleton) */
.event-card {
  padding: var(--space-6);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  text-decoration: none;
  border-radius: var(--radius-lg);
  transition: transform 0.2s, border-color 0.2s;
  min-height: 160px;
}
.event-card:hover {
  transform: translateY(-2px);
  border-color: var(--border-md);
}
.event-card__tag {
  font-size: var(--text-label);
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--amber);
}
.event-card__title {
  font-family: var(--font-display);
  font-size: var(--text-h4);
  font-weight: 600;
  color: var(--text);
  line-height: 1.3;
  flex: 1;
}
.event-card__meta {
  font-size: var(--text-xs);
  color: var(--text-3);
  display: flex;
  gap: var(--space-2);
}

/* Photographer strip cards */
.phstrip-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  text-decoration: none;
  cursor: pointer;
}
.phstrip-avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  overflow: hidden;
  background: var(--surface-2);
  border: 1.5px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: var(--text-base);
  color: var(--text-2);
  transition: border-color 0.2s;
  flex-shrink: 0;
}
.phstrip-avatar img { width: 100%; height: 100%; object-fit: cover; }
.phstrip-card:hover .phstrip-avatar { border-color: var(--amber); }
.phstrip-name {
  font-size: var(--text-xs);
  color: var(--text-2);
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
}
</style>
