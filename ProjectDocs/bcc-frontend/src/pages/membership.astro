---
/**
 * membership.astro — Public Membership Page
 *
 * MEM-006 ABSOLUTE PUBLIC DOMAIN POLICY:
 * - Only Basic Member, Student Member, and Individual Member may appear here.
 * - Full Member, Life Member, Patron Member, and Founding Member must NEVER
 *   appear on this page — not in copy, FAQ, footnotes, or CTAs.
 * - No "upgrade pathway" language that implies the existence of further classes.
 *
 * MEM-006 P1 — Three CTA distinction:
 * - "Register" = free platform identity (in Nav)
 * - "Sign In" = returning registered users (in Nav)
 * - "Apply for Membership" = this page's action — sequential, separate step
 *
 * FAQ NOTE: The wireframe FAQ contained upgrade pathway language referencing
 * constitutional classes. That copy is intentionally replaced below with
 * constitutionally compliant FAQ content. This divergence from the wireframe
 * is a required MEM-006 fix, documented here for the record.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';

const CLASSES = [
  {
    id: 'basic',
    label: 'Basic',
    title: 'Basic Member',
    cssVar: 'var(--badge-basic)',
    price: 'Free',
    priceSub: 'No annual fee',
    description: 'The starting point for every member of BCC. Create your platform profile, access the public showcase, and follow club activities — at no cost.',
    features: [
      'Platform profile and identity',
      'Access to public showcase',
      'Event announcements and newsletter',
      'BCC community forum access',
    ],
    cta: 'Apply as Basic Member',
    featured: false,
  },
  {
    id: 'student',
    label: 'Student',
    title: 'Student Member',
    cssVar: 'var(--badge-student)',
    price: 'Annual fee',
    priceSub: 'Fee disclosed on application',
    description: 'Designed for photography students and active learners. Participate in mentored sessions, workshops, and club events — at a concession fee.',
    features: [
      'Everything in Basic',
      'Workshop and photowalk participation',
      'Mentored feedback sessions',
      'Event participation (student concession)',
      'Portfolio display on Showcase',
      'Club activities and meetups',
    ],
    cta: 'Apply as Student Member',
    featured: false,
  },
  {
    id: 'individual',
    label: 'Individual',
    title: 'Individual Member',
    cssVar: 'var(--badge-individual)',
    price: 'Annual fee',
    priceSub: 'Fee disclosed on application',
    description: 'For active photography practitioners who want full participation in BCC activities — events, contests, exhibitions, and community governance.',
    features: [
      'Everything in Student',
      'Contest submission rights',
      'Exhibition participation',
      'Voting rights in club governance',
      'Digital BCC membership card',
      'Priority registration for events',
    ],
    cta: 'Apply as Individual Member',
    featured: true,
  },
];

const FAQS = [
  {
    q: 'What membership classes does BCC offer?',
    a: 'BCC offers three membership classes open to new applicants: Basic Member (free platform access), Student Member (for photography students and learners), and Individual Member (for active photography practitioners). Each class has different participation rights and annual fees — see the cards above for a full comparison.',
  },
  {
    q: 'Do I need to register before applying for membership?',
    a: 'Yes. Registration and membership are two separate steps. Registration creates your free platform identity — your BCC profile, login, and access to public content. Membership application is the next step, done after you have registered. You cannot apply for membership without first registering.',
  },
  {
    q: 'What is the difference between Basic, Student, and Individual membership?',
    a: 'Basic Membership is free and gives you a platform identity and access to public club content. Student Membership adds participation in workshops, photowalks, and mentored sessions — at a fee appropriate for learners. Individual Membership adds full participation rights including contest submissions, exhibition eligibility, voting in governance, and a digital membership card.',
  },
  {
    q: 'Is there a fee for Basic Membership?',
    a: 'No. Basic Membership is entirely free. There is no annual fee and no payment required. For Student and Individual Membership, an annual fee applies. The exact fee is disclosed during the membership application process.',
  },
  {
    q: 'How long does the membership application take?',
    a: 'Applications are reviewed by the club committee. You will receive a decision by email within a few business days of submitting a complete application. Incomplete applications may require additional information before review begins.',
  },
  {
    q: 'Can I participate in events without a membership?',
    a: 'Public events are open to all registered users. Some events — such as workshops, mentored sessions, and contests — are restricted to members with the appropriate membership class. The event listing page indicates which membership class is required for each activity.',
  },
  {
    q: 'How do I renew my membership?',
    a: 'Memberships are renewed annually. You will receive a renewal notice by email before your membership expires. Renewal is done through your Member Hub once you are logged in. Basic Membership does not require renewal as it has no annual fee.',
  },
  {
    q: 'I have more questions. Who should I contact?',
    a: 'You can reach the BCC membership team via the Contact Us page, or write to us through the email address listed in the footer. We are happy to answer questions about the membership process, class eligibility, and club activities.',
  },
];
---

<BaseLayout
  title="Membership"
  description="Join Bhopal Camera Club. We offer three membership classes — Basic, Student, and Individual — open to photography enthusiasts at all levels."
>

  <!-- ── Hero ── -->
  <div class="mem-hero">
    <div class="container">
      <SectionHeader
        eyebrow="Membership"
        title="Join Bhopal Camera Club"
        subtitle="We welcome photographers at every level — from those just starting out to seasoned practitioners."
        as="h1"
        align="center"
      />

      <!-- Two-step process callout -->
      <div class="process-callout glass-panel">
        <div class="process-step">
          <div class="process-step__num">1</div>
          <div>
            <div class="process-step__title">Register (free)</div>
            <div class="process-step__desc">Create your BCC platform identity. No cost, no commitment.</div>
          </div>
        </div>
        <div class="process-arrow" aria-hidden="true">→</div>
        <div class="process-step">
          <div class="process-step__num">2</div>
          <div>
            <div class="process-step__title">Apply for Membership</div>
            <div class="process-step__desc">Choose a class and submit your application. Committee reviews within a few business days.</div>
          </div>
        </div>
        <div class="process-ctas">
          <a href="/auth/register/" class="btn btn-ghost btn-sm">Register first</a>
          <a href="#apply" class="btn btn-primary btn-sm">Apply for Membership</a>
        </div>
      </div>
    </div>
    <div class="mem-hero__line" aria-hidden="true"></div>
  </div>


  <!-- ── Class cards ── -->
  <section class="section" aria-label="Membership classes" id="classes">
    <div class="container">

      <SectionHeader
        eyebrow="Classes"
        title="Choose your membership class"
        subtitle="All three classes are open to new applicants. Registration is a required first step before applying."
        align="center"
      />

      <div class="class-grid">
        {CLASSES.map((cls) => (
          <div class:list={['class-card glass-panel', cls.featured && 'class-card--featured']}>
            {cls.featured && (
              <div class="class-card__popular" aria-label="Most popular">Most Popular</div>
            )}

            <div class="class-card__badge" style={`--class-color: ${cls.cssVar};`}>
              {cls.label}
            </div>

            <div class="class-card__title">{cls.title}</div>

            <div class="class-card__price">
              <span class="class-card__price-main">{cls.price}</span>
              <span class="class-card__price-sub">{cls.priceSub}</span>
            </div>

            <p class="class-card__desc">{cls.description}</p>

            <ul class="class-card__features">
              {cls.features.map((f) => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M2 7l3.5 3.5L12 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            <a
              href={`#apply?class=${cls.id}`}
              class:list={['btn', cls.featured ? 'btn-primary' : 'btn-ghost', 'class-card__cta']}
            >
              {cls.cta}
            </a>
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ── Application anchor / CTA block ── -->
  <section class="section section--alt apply-section" id="apply" aria-label="Start your application">
    <div class="container">
      <div class="apply-block glass-panel">
        <div class="apply-block__text">
          <div class="eyebrow">Ready to join?</div>
          <h2 class="apply-block__title">Start your application</h2>
          <p class="apply-block__body">
            Already registered? Sign in and head to your Member Hub to begin your membership application. Not registered yet? Create your free account first — it only takes a moment.
          </p>
        </div>
        <div class="apply-block__ctas">
          <a href="/auth/signin/?next=/hub/membership/apply/" class="btn btn-primary btn-lg">
            Sign in &amp; Apply
          </a>
          <a href="/auth/register/" class="btn btn-ghost btn-lg">
            Register first →
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- ── FAQ ── -->
  <section class="section faq-section" aria-label="Frequently asked questions" id="faq">
    <div class="container">

      <SectionHeader
        eyebrow="FAQ"
        title="Frequently asked questions"
        align="center"
      />

      <div class="faq-grid">
        {FAQS.map((item, i) => (
          <details class="faq-item glass-panel" id={`faq-${i}`}>
            <summary class="faq-question">
              <span>{item.q}</span>
              <svg class="faq-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="faq-answer">{item.a}</div>
          </details>
        ))}
      </div>

      <p class="faq-footer">
        Have a question not answered here?{' '}
        <a href="/contact/" class="btn-text">Contact us →</a>
      </p>

    </div>
  </section>

</BaseLayout>


<style>
/* ── Hero ── */
.mem-hero {
  padding-top: calc(var(--nav-h) + var(--space-12));
  padding-bottom: var(--space-10);
  position: relative;
}
.mem-hero__line {
  position: absolute;
  bottom: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(to right, transparent, var(--amber) 30%, var(--cyan) 70%, transparent);
  opacity: 0.25;
}

/* ── Process callout ── */
.process-callout {
  display: flex;
  align-items: center;
  gap: var(--space-6);
  padding: var(--space-6) var(--space-8);
  margin-top: var(--space-10);
  max-width: 800px;
  margin-left: auto;
  margin-right: auto;
  flex-wrap: wrap;
}
.process-step {
  display: flex;
  align-items: flex-start;
  gap: var(--space-4);
  flex: 1;
  min-width: 200px;
}
.process-step__num {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--amber-muted);
  border: 1.5px solid var(--border-amber);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--amber);
  flex-shrink: 0;
}
.process-step__title {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--text);
  margin-bottom: 3px;
}
.process-step__desc {
  font-size: var(--text-xs);
  color: var(--text-3);
  line-height: 1.6;
}
.process-arrow {
  font-size: var(--text-lg);
  color: var(--text-3);
  flex-shrink: 0;
}
.process-ctas {
  display: flex;
  gap: var(--space-3);
  align-items: center;
  flex-wrap: wrap;
  flex-shrink: 0;
}

/* ── Class grid ── */
.class-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-5);
  align-items: start;
}
.class-card {
  padding: var(--space-8);
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  border-radius: var(--radius-lg);
  position: relative;
}
.class-card--featured {
  border-color: var(--border-amber);
  box-shadow: 0 0 0 1px var(--amber-muted), 0 32px 64px -12px rgba(0,0,0,0.6);
}
.class-card__popular {
  position: absolute;
  top: -13px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--amber);
  color: var(--bg);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 4px 14px;
  border-radius: var(--radius-full);
  white-space: nowrap;
}
.class-card__badge {
  display: inline-block;
  width: fit-content;
  padding: 3px 10px;
  border-radius: var(--radius-full);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--class-color);
  background: color-mix(in srgb, var(--class-color) 18%, transparent);
  border: 1px solid color-mix(in srgb, var(--class-color) 35%, transparent);
}
.class-card__title {
  font-family: var(--font-display);
  font-size: var(--text-h4);
  font-weight: 700;
  color: var(--text);
}
.class-card__price { display: flex; flex-direction: column; gap: 2px; }
.class-card__price-main {
  font-family: var(--font-display);
  font-size: var(--text-h3);
  font-weight: 700;
  color: var(--amber);
  line-height: 1;
}
.class-card__price-sub {
  font-size: var(--text-xs);
  color: var(--text-3);
}
.class-card__desc {
  font-size: var(--text-sm);
  color: var(--text-2);
  line-height: 1.7;
}
.class-card__features {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  flex: 1;
}
.class-card__features li {
  display: flex;
  align-items: flex-start;
  gap: var(--space-2);
  font-size: var(--text-sm);
  color: var(--text-2);
  line-height: 1.5;
}
.class-card__features svg { flex-shrink: 0; margin-top: 2px; color: var(--success); }
.class-card__cta { width: 100%; justify-content: center; margin-top: var(--space-2); }

/* ── Apply section ── */
.section--alt { background: var(--bg-2); }
.apply-block {
  display: flex;
  align-items: center;
  gap: var(--space-12);
  padding: var(--space-10) var(--space-12);
  border-radius: var(--radius-xl);
  flex-wrap: wrap;
}
.apply-block__text { flex: 1; min-width: 280px; }
.apply-block__title {
  font-family: var(--font-display);
  font-size: var(--text-h2);
  font-weight: 700;
  color: var(--text);
  margin: var(--space-2) 0 var(--space-4);
  letter-spacing: -0.02em;
}
.apply-block__body {
  font-size: var(--text-base);
  color: var(--text-2);
  line-height: 1.7;
  max-width: 480px;
}
.apply-block__ctas {
  display: flex;
  gap: var(--space-4);
  align-items: center;
  flex-wrap: wrap;
  flex-shrink: 0;
}

/* ── FAQ ── */
.faq-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-4);
  max-width: 920px;
  margin: 0 auto var(--space-8);
}
.faq-item {
  border-radius: var(--radius-md);
  overflow: hidden;
}
.faq-question {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-4);
  padding: var(--space-5) var(--space-6);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--text);
  cursor: pointer;
  list-style: none;
  user-select: none;
  line-height: 1.5;
}
.faq-question::-webkit-details-marker { display: none; }
.faq-question span { flex: 1; }
.faq-chevron {
  flex-shrink: 0;
  color: var(--text-3);
  margin-top: 2px;
  transition: transform 0.2s ease;
}
details[open] .faq-chevron { transform: rotate(180deg); }
details[open] .faq-question { color: var(--amber); }

.faq-answer {
  padding: 0 var(--space-6) var(--space-5);
  font-size: var(--text-sm);
  color: var(--text-2);
  line-height: 1.7;
  border-top: 1px solid var(--border);
  padding-top: var(--space-4);
  margin-top: 0;
}

.faq-footer {
  text-align: center;
  font-size: var(--text-sm);
  color: var(--text-3);
}

/* ── Responsive ── */
@media (max-width: 900px) {
  .class-grid { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; }
  .faq-grid   { grid-template-columns: 1fr; }
  .apply-block { padding: var(--space-8); gap: var(--space-8); }
}
@media (max-width: 640px) {
  .process-callout { flex-direction: column; align-items: flex-start; }
  .process-arrow { display: none; }
  .apply-block__ctas { flex-direction: column; width: 100%; }
  .apply-block__ctas .btn { width: 100%; justify-content: center; }
}
</style>


<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  /* ── Page entrance ── */
  gsap.from('.mem-hero .section-header', { opacity: 0, y: 24, duration: 0.6, ease: 'power3.out', delay: 0.1 });
  gsap.from('.process-callout', { opacity: 0, y: 20, duration: 0.6, ease: 'power3.out', delay: 0.3 });

  /* ── Class cards scroll reveal ── */
  gsap.from('.class-card', {
    opacity: 0, y: 32, duration: 0.7, stagger: 0.12, ease: 'power3.out',
    scrollTrigger: { trigger: '.class-grid', start: 'top 80%', once: true },
  });

  /* ── FAQ scroll reveal ── */
  gsap.from('.faq-item', {
    opacity: 0, y: 20, duration: 0.5, stagger: 0.07, ease: 'power2.out',
    scrollTrigger: { trigger: '.faq-grid', start: 'top 80%', once: true },
  });

  /* ── Smooth scroll for #apply anchor from class card CTAs ── */
  document.querySelectorAll<HTMLAnchorElement>('a[href^="#apply"]').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById('apply')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>
