---
/**
 * photographers.astro — Photographers Directory
 *
 * Grid of photographer profile cards with avatar, name, photo count, class badge.
 * Search bar + sort controls.
 * MEM-006: only public class badges (Basic, Student, Individual) shown publicly.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
---

<BaseLayout
  title="Photographers"
  description="Meet the photographers of Bhopal Camera Club. Browse member profiles, explore their portfolios, and discover the people behind the lens."
>

  <!-- Page header -->
  <div class="page-hero">
    <div class="container">
      <SectionHeader
        eyebrow="Our Photographers"
        title="The people behind the lens"
        subtitle="BCC is its members. Browse our photographers' profiles and explore their portfolios."
        as="h1"
      />

      <!-- Search -->
      <div class="search-wrap">
        <div class="search-field">
          <svg class="search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M11 11l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <input
            type="search"
            id="photographer-search"
            class="bcc-input search-input"
            placeholder="Search photographers…"
            aria-label="Search photographers"
          />
        </div>

        <select class="filter-select" id="ph-sort" aria-label="Sort photographers">
          <option value="name">Name A–Z</option>
          <option value="photos">Most Photos</option>
          <option value="joined">Newest Members</option>
        </select>
      </div>
    </div>
    <div class="page-hero__line" aria-hidden="true"></div>
  </div>

  <!-- Results info -->
  <div class="container">
    <div class="results-bar">
      <span id="ph-count" class="results-count" aria-live="polite">— photographers</span>
    </div>
  </div>

  <!-- Photographer grid -->
  <div class="container" style="margin-bottom: var(--space-20)">
    <div class="ph-grid" id="ph-grid" aria-label="Photographer directory">

      <!-- Skeleton cards -->
      {[...Array(12)].map((_, i) => (
        <div class="ph-card-skel glass-panel" aria-hidden="true">
          <div class="ph-skel-avatar"></div>
          <div class="skel-line" style="width:60%;margin:0 auto var(--space-2)"></div>
          <div class="skel-line" style="width:40%;margin:0 auto"></div>
        </div>
      ))}

    </div>

    <!-- Empty state -->
    <div id="ph-empty" hidden class="ph-empty">
      <p>No photographers match your search.</p>
      <button class="btn btn-ghost" id="ph-clear-search">Clear search</button>
    </div>

  </div>

</BaseLayout>


<style>
/* ── Page hero ── */
.page-hero {
  padding-top: calc(var(--nav-h) + var(--space-12));
  padding-bottom: var(--space-8);
  position: relative;
}
.page-hero__line {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(to right, transparent, var(--amber) 30%, var(--cyan) 70%, transparent);
  opacity: 0.25;
}

/* ── Search ── */
.search-wrap {
  display: flex;
  gap: var(--space-3);
  margin-top: var(--space-6);
  max-width: 520px;
}
.search-field {
  position: relative;
  flex: 1;
}
.search-icon {
  position: absolute;
  left: 14px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-3);
  pointer-events: none;
}
.search-input { padding-left: 40px !important; }

.filter-select {
  padding: 14px 16px;
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text-2);
  font-size: var(--text-sm);
  font-family: var(--font-body);
  outline: none;
  cursor: pointer;
  -webkit-appearance: none;
  transition: border-color 0.2s;
}
.filter-select:focus { border-color: var(--amber); }

/* ── Results bar ── */
.results-bar {
  padding: var(--space-5) 0 var(--space-6);
}
.results-count { font-size: var(--text-sm); color: var(--text-3); }

/* ── Photographer grid ── */
.ph-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-5);
}

/* ── Photographer card ── */
.ph-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-8) var(--space-5);
  text-decoration: none;
  border-radius: var(--radius-lg);
  transition: transform 0.2s, border-color 0.2s;
  text-align: center;
}
.ph-card:hover { transform: translateY(-3px); border-color: var(--border-md); }

.ph-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  overflow: hidden;
  background: var(--surface-2);
  border: 2px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-size: var(--text-h4);
  font-weight: 700;
  color: var(--text-2);
  flex-shrink: 0;
  transition: border-color 0.2s;
}
.ph-avatar img { width: 100%; height: 100%; object-fit: cover; }
.ph-card:hover .ph-avatar { border-color: var(--amber); }

.ph-name {
  font-family: var(--font-display);
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--text);
}
.ph-meta {
  font-size: var(--text-xs);
  color: var(--text-3);
}
.ph-photos { color: var(--text-2); font-weight: 500; }

/* ── Skeleton ── */
.ph-card-skel {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-8) var(--space-5);
  border-radius: var(--radius-lg);
  text-align: center;
}
.ph-skel-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: var(--surface-2);
  animation: shimmer 1.6s ease-in-out infinite;
}
.skel-line {
  height: 10px;
  background: var(--surface-2);
  border-radius: 4px;
  animation: shimmer 1.6s ease-in-out infinite;
  width: 60%;
}
@keyframes shimmer { 0%,100% { opacity:.4; } 50% { opacity:.7; } }

/* ── Empty ── */
.ph-empty {
  text-align: center;
  padding: var(--space-20) 0;
  color: var(--text-3);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-6);
}
.ph-empty p { font-size: var(--text-base); color: var(--text-2); }

/* ── Responsive ── */
@media (max-width: 1024px) { .ph-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 768px)  { .ph-grid { grid-template-columns: repeat(2, 1fr); } .search-wrap { flex-direction: column; max-width: none; } }
@media (max-width: 480px)  { .ph-grid { grid-template-columns: 1fr 1fr; } }
</style>


<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  let allPhotographers: any[] = [];
  let searchTerm = '';
  let sortOrder = 'name';

  async function loadPhotographers() {
    const grid    = document.getElementById('ph-grid')!;
    const countEl = document.getElementById('ph-count')!;
    const emptyEl = document.getElementById('ph-empty')!;

    try {
      const params = new URLSearchParams({ limit: '100', sort: sortOrder });
      const res = await fetch(`/api/v1/photographers?${params}`);
      if (!res.ok) throw new Error();
      const { data, meta } = await res.json();
      allPhotographers = Array.isArray(data) ? data : [];
      const total = meta?.total_count ?? allPhotographers.length;
      countEl.textContent = `${total.toLocaleString()} photographer${total !== 1 ? 's' : ''}`;
    } catch {
      countEl.textContent = '—';
    }

    render();
  }

  function render() {
    const grid    = document.getElementById('ph-grid')!;
    const emptyEl = document.getElementById('ph-empty')!;

    // Remove skeleton + old cards
    grid.innerHTML = '';

    const filtered = allPhotographers.filter(ph => {
      if (!searchTerm) return true;
      return (ph.displayName ?? '').toLowerCase().includes(searchTerm.toLowerCase());
    });

    if (filtered.length === 0) {
      emptyEl.removeAttribute('hidden');
      return;
    }
    emptyEl.setAttribute('hidden', '');

    filtered.forEach(ph => {
      const initials = (ph.displayName ?? '?').slice(0, 2).toUpperCase();
      const card = document.createElement('a');
      card.href = `/photographers/${ph.userid}/`;
      card.className = 'ph-card glass-panel';
      card.innerHTML = `
        <div class="ph-avatar">${
          ph.avatarUrl
            ? `<img src="${ph.avatarUrl}" alt="${ph.displayName}" loading="lazy" width="80" height="80" />`
            : initials
        }</div>
        <div class="ph-name">${ph.displayName ?? ''}</div>
        <div class="ph-meta">
          <span class="ph-photos">${ph.photoCount ?? 0}</span> photos
        </div>
      `;
      grid.appendChild(card);
    });

    gsap.from('.ph-card', {
      opacity: 0, y: 20, duration: 0.5, stagger: 0.04, ease: 'power2.out',
    });
  }

  /* ── Search ── */
  let searchTimer: ReturnType<typeof setTimeout>;
  document.getElementById('photographer-search')?.addEventListener('input', (e) => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => {
      searchTerm = (e.target as HTMLInputElement).value;
      render();
    }, 180);
  });

  /* ── Sort ── */
  document.getElementById('ph-sort')?.addEventListener('change', (e) => {
    sortOrder = (e.target as HTMLSelectElement).value;
    loadPhotographers();
  });

  /* ── Clear search ── */
  document.getElementById('ph-clear-search')?.addEventListener('click', () => {
    const searchEl = document.getElementById('photographer-search') as HTMLInputElement | null;
    if (searchEl) searchEl.value = '';
    searchTerm = '';
    render();
  });

  /* ── Init ── */
  loadPhotographers();

  gsap.from('.page-hero .section-header', { opacity: 0, y: 24, duration: 0.6, ease: 'power3.out', delay: 0.1 });
</script>
