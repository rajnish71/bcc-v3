NODE_ENV=development
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bcc_v3
DB_USER=bcc_v3_app
DB_PASSWORD=changeme
JWT_ACCESS_SECRET=changeme_generate_a_long_random_value

# Frontend base URL -- used to build links inside verification/magic-link/
# invitation emails. Defaults to the production domain if unset.
FRONTEND_BASE_URL=https://v3bcc.bhopal.info

# Resend (email) -- https://resend.com, free tier: 3,000/mo, 100/day, no
# card required. Leave RESEND_API_KEY unset to fall back to console logging
# instead of sending (registration still works, email just doesn't go out).
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=BCC Bhopal <onboarding@resend.dev>
CONTACT_EMAIL=hello@bcc.bhopal.info

# Google OAuth -- console.cloud.google.com -> APIs & Services -> Credentials
# -> Create OAuth client ID (Web application). Redirect URI must exactly
# match what's registered there.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://v3bcc.bhopal.info/api/v1/registration/social/google/callback

# Facebook OAuth -- developers.facebook.com -> Create App -> Facebook Login
# product -> Settings -> Valid OAuth Redirect URIs.
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=https://v3bcc.bhopal.info/api/v1/registration/social/facebook/callback

# Phone/WhatsApp OTP -- off by default, no provider chosen/paid for yet
# (MSG91/Interakt both charge per message, no free tier worth relying on).
# Flip to true once a provider is wired in oauth.service.ts's neighbour,
# registration.service.ts's requestPhoneOtp/verifyPhoneOtpAndRegister.
PHONE_OTP_ENABLED=false
