---
import { aboutPhotos, photoSrc, photoSrcset } from '../../data/photoRegistry';

const img = aboutPhotos.communityPhotowalk;
---

<section class="invitation-section" aria-labelledby="invitation-heading">
  <div class="container">
    <div class="invitation-frame" data-gsap="reveal">

      <!-- Left: Community photograph (45%) — object-fit:cover, layout use -->
      <div class="invitation-photo-col">
        <img
          src={photoSrc(img, 960)}
          srcset={photoSrcset(img, [480, 720, 960])}
          sizes="(max-width: 900px) 100vw, 45vw"
          alt={img.alt}
          class="invitation-photo"
          loading="lazy"
        />
        <div class="invitation-photo-caption" aria-hidden="true">
          {img.caption}
        </div>
        <div class="invitation-photo-credit" aria-hidden="true">
          <span class="photo-credit__by">Photo by</span>
          <span class="photo-credit__name">{img.photographer}</span>
        </div>
      </div>

      <!-- Right: Invitation text + CTAs (55%) -->
      <div class="invitation-body">
        <div class="invitation-kicker">You Belong Here</div>
        <h2 class="invitation-title" id="invitation-heading">Ready to Tell<br/>Your Story?</h2>
        <p class="invitation-copy">Whether you have been shooting for twenty years or you just picked up your first camera last week — there is a place for you in Bhopal Camera Club.</p>
        <p class="invitation-copy">Every outstanding photograph in our gallery, every workshop that changed the way someone sees, every friendship that began at a photowalk — all of it started with someone deciding to show up.</p>

        <!-- CTAs — "Become a Member" hidden for authenticated members -->
        <div class="invitation-ctas">
          <a href="/join/" class="btn btn-gold btn-lg invitation-cta-primary guest-only" aria-label="Become a member of Bhopal Camera Club">
            Become a Member
          </a>
          <a href="/activities/" class="invitation-cta-secondary">
            Explore Activities
          </a>
          <a href="/showcase/" class="invitation-cta-tertiary">
            Browse Showcase <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
.invitation-section {
  border-top: 1px solid var(--hairline);
  padding: var(--s-12) 0;
  background: var(--surface-0);
}

/* Two-column frame: photo 45% · CTA 55% */
.invitation-frame {
  display: grid;
  grid-template-columns: 45fr 55fr;
  border: 1px solid var(--hairline);
  overflow: hidden;
  background: var(--surface-0);
}

/* Left: photograph column */
.invitation-photo-col {
  position: relative;
  overflow: hidden;
  border-right: 1px solid var(--hairline);
  min-height: 480px;
}
.invitation-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.invitation-photo-caption {
  position: absolute;
  bottom: 28px;
  left: 0;
  right: 0;
  padding: 0 20px;
  font-family: var(--font-mono);
  font-size: 9px;
  color: rgba(255, 255, 255, 0.55);
  letter-spacing: 0.08em;
  background: linear-gradient(transparent, rgba(20, 18, 16, 0.55));
  padding-top: 24px;
}
.invitation-photo-credit {
  position: absolute;
  bottom: 10px;
  right: 14px;
  display: flex;
  align-items: center;
  gap: 4px;
}
.photo-credit__by {
  font-family: var(--font-mono);
  font-size: 8px;
  color: rgba(255, 255, 255, 0.35);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.photo-credit__name {
  font-family: var(--font-mono);
  font-size: 8px;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 0.04em;
}

/* Right: invitation body */
.invitation-body {
  padding: 64px 56px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.invitation-kicker {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: var(--weight-semibold);
  margin-bottom: var(--s-2);
}
.invitation-title {
  font-family: var(--font-display);
  font-size: clamp(28px, 3vw, 40px);
  font-weight: var(--weight-bold);
  letter-spacing: -0.025em;
  line-height: 1.05;
  color: var(--ink-900);
  margin-bottom: var(--s-4);
}
.invitation-copy {
  font-family: var(--font-body);
  font-size: 15px;
  line-height: 1.85;
  color: var(--ink-600);
  margin-bottom: var(--s-2);
  text-wrap: pretty;
}
.invitation-copy:last-of-type {
  margin-bottom: var(--s-7);
}

/* CTAs — stacked column, left-aligned */
.invitation-ctas {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12px;
}
.invitation-cta-primary {
  /* extends .btn.btn-gold.btn-lg */
}
.invitation-cta-secondary {
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: var(--weight-semibold);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  border: 1px solid var(--hairline-strong);
  color: var(--ink-900);
  padding: 15px 28px;
  display: inline-block;
  text-decoration: none;
  background: var(--surface-0);
  transition: border-color var(--m-fast), color var(--m-fast);
}
.invitation-cta-secondary:hover {
  border-color: var(--ink-900);
}
.invitation-cta-tertiary {
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 500;
  color: var(--gold-600);
  letter-spacing: 0.04em;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 0;
  text-decoration: none;
  transition: color var(--m-fast);
}
.invitation-cta-tertiary:hover {
  color: var(--gold-500);
}

/* Responsive */
@media (max-width: 900px) {
  .invitation-frame {
    grid-template-columns: 1fr;
  }
  .invitation-photo-col {
    border-right: none;
    border-bottom: 1px solid var(--hairline);
    min-height: 320px;
  }
  .invitation-body {
    padding: 40px 32px;
  }
}
@media (max-width: 480px) {
  .invitation-section {
    padding: var(--s-8) 0;
  }
  .invitation-body {
    padding: 32px 20px;
  }
  .invitation-ctas {
    align-items: stretch;
  }
  .invitation-cta-secondary {
    text-align: center;
  }
}
</style>
