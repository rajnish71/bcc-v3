---
import { aboutImages } from '../../data/aboutImages';

const img = aboutImages.communityPhotowalk;
---

<section class="invitation-section" aria-labelledby="invitation-heading">
  <!-- Community photograph -->
  <div class="invitation-photo-wrap">
    <img
      src={img.src}
      alt={img.alt}
      class="invitation-photo"
      loading="lazy"
    />
    <div class="invitation-photo-caption-bar" aria-hidden="true">
      <span class="invitation-photo-caption">{img.caption}</span>
    </div>
  </div>

  <!-- Invitation copy and CTAs -->
  <div class="invitation-body">
    <div class="invitation-inner">
      <div class="invitation-kicker">You Belong Here</div>
      <h2 class="invitation-title" id="invitation-heading">Ready to Tell Your Story?</h2>
      <p class="invitation-copy">Whether you have been shooting for twenty years or you just picked up your first camera last week — there is a place for you in Bhopal Camera Club. We have never asked anyone to be better than they are before they join us. We only ask that they love photography and bring it honestly.</p>
      <p class="invitation-copy">Every outstanding photograph in our gallery, every workshop that changed the way someone sees, every friendship that began at a photowalk — all of it started with someone deciding to show up. Come and find your community.</p>

      <!-- CTAs — "Become a Member" hidden for authenticated members -->
      <div class="invitation-ctas">
        <a href="/join/" class="btn btn-gold btn-lg invitation-cta-primary guest-only" aria-label="Become a member of Bhopal Camera Club">
          Become a Member
        </a>
        <a href="/activities/" class="invitation-cta-secondary">
          Explore Activities
        </a>
        <a href="/showcase/" class="invitation-cta-tertiary">
          Browse Showcase <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
.invitation-section {
  border-top: 1px solid var(--hairline);
}

/* Photo */
.invitation-photo-wrap {
  position: relative;
  overflow: hidden;
  border-bottom: none;
}
.invitation-photo {
  width: 100%;
  height: auto;
  display: block;
}
.invitation-photo-caption-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(20, 18, 16, 0.6));
  padding: 20px 28px 14px;
}
.invitation-photo-caption {
  font-family: var(--font-mono);
  font-size: 10px;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 0.08em;
}

/* Invitation body */
.invitation-body {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-top: none;
  padding: 64px 0;
}
.invitation-inner {
  max-width: 760px;
  margin: 0 auto;
  text-align: center;
  padding: 0 var(--gutter);
}
.invitation-kicker {
  font-family: var(--font-body);
  font-size: 10px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: 600;
  margin-bottom: 20px;
}
.invitation-title {
  font-family: var(--font-display);
  font-size: clamp(32px, 4vw, 48px);
  font-weight: 700;
  letter-spacing: -0.025em;
  line-height: 1.05;
  margin-bottom: 28px;
  color: var(--ink-900);
}
.invitation-copy {
  font-size: 16px;
  line-height: 1.85;
  color: var(--ink-600);
  margin-bottom: 16px;
  text-wrap: pretty;
}
.invitation-copy:last-of-type {
  margin-bottom: 40px;
}

/* CTAs */
.invitation-ctas {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
}
.invitation-cta-primary {
  /* extends .btn.btn-gold.btn-lg */
}
.invitation-cta-secondary {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  border: 1px solid var(--hairline-strong);
  color: var(--ink-900);
  padding: 15px 28px;
  display: inline-block;
  text-decoration: none;
  transition: border-color var(--m-fast), color var(--m-fast);
}
.invitation-cta-secondary:hover {
  border-color: var(--ink-900);
  color: var(--ink-900);
}
.invitation-cta-tertiary {
  font-size: 12px;
  font-weight: 500;
  color: var(--gold-600);
  letter-spacing: 0.04em;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  text-decoration: none;
  transition: color var(--m-fast);
}
.invitation-cta-tertiary:hover {
  color: var(--gold-500);
}

/* Responsive */
@media (max-width: 480px) {
  .invitation-body {
    padding: 48px 0;
  }
  .invitation-ctas {
    flex-direction: column;
    align-items: stretch;
  }
  .invitation-cta-primary,
  .invitation-cta-secondary {
    width: 100%;
    text-align: center;
  }
}
</style>
