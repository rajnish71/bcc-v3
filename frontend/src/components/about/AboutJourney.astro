---
import { chapters } from '../../data/timeline';
---

<section class="journey-section" aria-labelledby="journey-heading">
  <div class="container">

    <div class="journey-header" data-gsap="reveal">
      <div class="journey-kicker">Our Journey</div>
      <h2 class="journey-title" id="journey-heading">Seven Chapters</h2>
      <p class="journey-intro">Every community has a beginning. Ours began with a shared love for photography and a belief that the best way to learn was to explore together.</p>
    </div>

    <!-- Documentary mandate callout -->
    <div class="doc-mandate" role="note">
      <div class="doc-mandate__rule" aria-hidden="true"></div>
      <div>
        <div class="doc-mandate__heading">Documentary Mandate — Journey Section</div>
        <p class="doc-mandate__body">All dates are exact as documented in BCC records. All photographs are authentic BCC archival images. Photo captions include date and location exactly as recorded. Chapters without photographs show a typographic placeholder — never a stock image.</p>
      </div>
    </div>

    <!-- Editorial timeline — all chapters always visible -->
    <div class="journey-timeline" role="list">
      {chapters.map((ch) => (
        <div class="journey-entry" role="listitem" id={ch.id}>
          <!-- Year column -->
          <div class="entry-year" aria-hidden="true">
            <span class="entry-year__text">{ch.year}</span>
          </div>

          <!-- Content column -->
          <div class="entry-content">
            <div class="entry-date">{ch.year}</div>
            <h3 class="entry-title">{ch.title}</h3>
            <div class="entry-subtitle">{ch.subtitle}</div>
            <p class="entry-story">{ch.story}</p>

            {ch.hasPhoto && ch.photo ? (
              <div class="entry-photo-wrap">
                <div class="entry-photo-frame">
                  <img
                    src={ch.photo}
                    alt={ch.photoAlt || ''}
                    class="entry-photo"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="entry-photo-bar">
                  <span class="entry-photo-label">{ch.photoLabel}</span>
                  {ch.photographer && (
                    <span class="entry-photo-credit">
                      <span class="entry-photo-credit__by">Photo by</span>
                      <span class="entry-photo-credit__name">{ch.photographer}</span>
                    </span>
                  )}
                </div>
              </div>
            ) : (
              <div class="entry-placeholder">
                <div class="entry-placeholder__label">{ch.placeholderLabel}</div>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
.journey-section {
  background: var(--surface-1);
  border-top: 1px solid var(--hairline);
  border-bottom: 1px solid var(--hairline);
  padding: var(--s-10) 0;
}

.journey-header {
  margin-bottom: var(--s-6);
}
.journey-kicker {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: var(--weight-semibold);
  margin-bottom: var(--s-1);
}
.journey-title {
  font-family: var(--font-display);
  font-size: clamp(28px, 3.5vw, 40px);
  font-weight: var(--weight-bold);
  letter-spacing: -0.025em;
  color: var(--ink-900);
  margin-bottom: 12px;
}
.journey-intro {
  font-family: var(--font-body);
  font-size: 15px;
  line-height: 1.7;
  color: var(--ink-600);
  max-width: 680px;
  font-style: italic;
}

/* Documentary mandate callout */
.doc-mandate {
  display: flex;
  align-items: flex-start;
  gap: var(--s-3);
  background: var(--ink-900);
  color: var(--surface-1);
  padding: 20px 28px;
  margin-bottom: var(--s-5);
}
.doc-mandate__rule {
  width: 3px;
  background: var(--gold-500);
  flex-shrink: 0;
  align-self: stretch;
}
.doc-mandate__heading {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold-500);
  font-weight: var(--weight-semibold);
  margin-bottom: 6px;
}
.doc-mandate__body {
  font-family: var(--font-body);
  font-size: 12px;
  line-height: 1.8;
  color: var(--dark-muted, rgba(216, 210, 198, 0.85));
}

/* Editorial timeline */
.journey-timeline {
  border-top: 1px solid var(--hairline);
}

.journey-entry {
  display: grid;
  grid-template-columns: 96px 1fr;
  gap: var(--s-6);
  padding: var(--s-6) 0;
  border-bottom: 1px solid var(--hairline);
}

/* Year column */
.entry-year {
  padding-top: 2px;
}
.entry-year__text {
  font-family: var(--font-mono);
  font-size: 22px;
  font-weight: 500;
  color: var(--gold-500);
  line-height: 1.2;
  white-space: pre-line;
}

/* Content column */
.entry-content {
  max-width: 680px;
}
.entry-date {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-400);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-bottom: 10px;
}
.entry-title {
  font-family: var(--font-display);
  font-size: 26px;
  font-weight: var(--weight-bold);
  letter-spacing: -0.015em;
  line-height: 1.1;
  color: var(--ink-900);
  margin-bottom: 6px;
}
.entry-subtitle {
  font-family: var(--font-body);
  font-size: 13px;
  color: var(--ink-400);
  font-style: italic;
  margin-bottom: 20px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--hairline-soft, #F0EBE0);
}
.entry-story {
  font-family: var(--font-body);
  font-size: 15px;
  line-height: 1.85;
  color: var(--ink-600);
  margin-bottom: var(--s-3);
}

/* Photo — editorial scale, not full-width */
.entry-photo-wrap {
  max-width: 480px;
}
.entry-photo-frame {
  border: 1px solid var(--hairline);
  overflow: hidden;
}
.entry-photo {
  width: 100%;
  height: auto;
  display: block;
}
.entry-photo-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--s-3);
  background: var(--surface-1);
  border: 1px solid var(--hairline);
  border-top: none;
  padding: 10px 14px;
}
.entry-photo-label {
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--ink-400);
  letter-spacing: 0.08em;
  line-height: 1.6;
}
.entry-photo-credit {
  display: flex;
  align-items: center;
  gap: 5px;
  flex-shrink: 0;
}
.entry-photo-credit__by {
  font-family: var(--font-mono);
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--ink-400);
}
.entry-photo-credit__name {
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--gold-600);
  font-weight: 500;
  letter-spacing: 0.04em;
}

/* Placeholder — no archival photo */
.entry-placeholder {
  max-width: 360px;
  border: 1px solid var(--hairline);
  padding: 20px 24px;
  background: var(--surface-1);
}
.entry-placeholder__label {
  font-family: var(--font-mono);
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--ink-400);
  line-height: 1.8;
}

/* Responsive */
@media (max-width: 720px) {
  .journey-entry {
    grid-template-columns: 1fr;
    gap: var(--s-2);
  }
  .entry-year {
    display: none;
  }
  .entry-content {
    max-width: 100%;
  }
}
@media (max-width: 480px) {
  .journey-section {
    padding: var(--s-6) 0;
  }
  .entry-title {
    font-size: 20px;
  }
  .entry-photo-wrap {
    max-width: 100%;
  }
}
</style>
