---
const milestones = [
  {
    year: "2015",
    date: "May 2015",
    title: "First informal grouping",
    story: "A group of local photography enthusiasts began meeting informally in Bhopal to share critiques and capture the lakes together."
  },
  {
    year: "2016",
    date: "Apr 2016",
    title: "First Organized Photowalk",
    story: "Held on Heritage Day, our first structured walk took place at the historic Taj-ul-Masajid, establishing our core focus on documentation."
  },
  {
    year: "2016",
    date: "Jun 2016",
    title: "Facebook Group Created",
    story: "On June 8th, 2016, our official Facebook group was created, serving as the digital foundation for our growing community."
  },
  {
    year: "2019",
    date: "Oct 2019",
    title: "Formal Society Registration",
    story: "Bhopal Camera Club was formally registered as an official society under the MP Society Registrikaran Adhiniyam 1973."
  },
  {
    year: "2026",
    date: "Jun 2026",
    title: "New Platform Launch",
    story: "We launched the bcc.bhopal.info portal, expanding our school curriculum and preparing for our 10th anniversary next year."
  }
];
---

<section class="journey-section" aria-labelledby="journey-heading">
  <div class="container">

    <div class="journey-header" data-gsap="reveal">
      <div class="journey-kicker">Our Story</div>
      <h2 class="journey-title" id="journey-heading">A Legacy of Light</h2>
      <p class="journey-intro">Every community has a beginning. Ours began with a shared love for photography and a belief that the best way to learn was to explore together.</p>
    </div>

    <!-- Editorial timeline — all milestones always visible -->
    <div class="journey-timeline" role="list">
      {milestones.map((m, index) => (
        <div class="journey-entry" role="listitem" id={`milestone-${index}`}>
          <!-- Year column -->
          <div class="entry-year" aria-hidden="true">
            <span class="entry-year__text">{m.year}</span>
          </div>

          <!-- Content column -->
          <div class="entry-content">
            <div class="entry-date">{m.date}</div>
            <h3 class="entry-title">{m.title}</h3>
            <p class="entry-story">{m.story}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
.journey-section {
  background: var(--surface-1);
  border-top: 1px solid var(--hairline);
  border-bottom: 1px solid var(--hairline);
  padding: var(--s-10) 0;
}

.journey-header {
  margin-bottom: var(--s-6);
}
.journey-kicker {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: var(--weight-semibold);
  margin-bottom: var(--s-1);
}
.journey-title {
  font-family: var(--font-display);
  font-size: clamp(28px, 3.5vw, 40px);
  font-weight: var(--weight-bold);
  letter-spacing: -0.025em;
  color: var(--ink-900);
  margin-bottom: 12px;
}
.journey-intro {
  font-family: var(--font-body);
  font-size: 15px;
  line-height: 1.7;
  color: var(--ink-600);
  max-width: 680px;
  font-style: italic;
}

/* Editorial timeline */
.journey-timeline {
  border-top: 1px solid var(--hairline);
}

.journey-entry {
  display: grid;
  grid-template-columns: 96px 1fr;
  gap: var(--s-6);
  padding: var(--s-6) 0;
  border-bottom: 1px solid var(--hairline);
}

/* Year column */
.entry-year {
  padding-top: 2px;
}
.entry-year__text {
  font-family: var(--font-mono);
  font-size: 22px;
  font-weight: 500;
  color: var(--gold-500);
  line-height: 1.2;
  white-space: pre-line;
}

/* Content column */
.entry-content {
  max-width: 680px;
}
.entry-date {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-400);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-bottom: 10px;
}
.entry-title {
  font-family: var(--font-display);
  font-size: 26px;
  font-weight: var(--weight-bold);
  letter-spacing: -0.015em;
  line-height: 1.1;
  color: var(--ink-900);
  margin-bottom: 6px;
}
.entry-story {
  font-family: var(--font-body);
  font-size: 15px;
  line-height: 1.85;
  color: var(--ink-600);
}

/* Responsive */
@media (max-width: 720px) {
  .journey-entry {
    grid-template-columns: 1fr;
    gap: var(--s-2);
  }
  .entry-year {
    display: none;
  }
  .entry-content {
    max-width: 100%;
  }
}
@media (max-width: 480px) {
  .journey-section {
    padding: var(--s-6) 0;
  }
  .entry-title {
    font-size: 20px;
  }
}
</style>
