---
import type { PersonViewModel } from '../../lib/view-models/PersonViewModel';
import PersonCard from '../ui/PersonCard.astro';

interface Props {
  leaders: PersonViewModel[];
}

const { leaders } = Astro.props;
---

<section class="leadership-section" aria-labelledby="leadership-heading">
  <div class="container">
    <div class="leadership-header" data-gsap="reveal">
      <div class="leadership-kicker">Leadership</div>
      <h2 class="leadership-title" id="leadership-heading">The Minds Behind the Club</h2>
      <p class="leadership-intro">BCC is built by its members, governed by volunteers, and run by people who believe in it. Every activity, every photowalk, every workshop has been organised by someone who showed up because they love photography and this club.</p>
    </div>

    <div class="leadership-grid" data-gsap="stagger">
      {leaders.map((person) => (
        <div class="leader-card">
          <PersonCard
            name={person.name}
            eyebrow={person.eyebrow}
            subtitle={person.subtitle}
            bio={person.bio}
            avatar={person.avatar}
            avatarSize={80}
            layout="vertical"
            placeholderVariant="forest"
            profileHref={person.profileHref}
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.leadership-section {
  background: var(--surface-0);
  border-top: 1px solid var(--hairline);
  border-bottom: 1px solid var(--hairline);
  padding: var(--s-12) 0;
}
.leadership-header {
  margin-bottom: var(--s-5);
}
.leadership-kicker {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: var(--weight-semibold);
  margin-bottom: var(--s-1);
}
.leadership-title {
  font-family: var(--font-display);
  font-size: clamp(28px, 3.5vw, 40px);
  font-weight: var(--weight-bold);
  letter-spacing: var(--ls-h1);
  color: var(--ink-900);
  margin-bottom: 12px;
}
.leadership-intro {
  font-family: var(--font-body);
  font-size: 15px;
  line-height: 1.7;
  color: var(--ink-600);
  max-width: 680px;
  font-style: italic;
}

/* 3+3 grid — canonical Profile Card family */
.leadership-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border: 1px solid var(--hairline);
  background: var(--surface-0);
  overflow: hidden;
}
.leader-card {
  padding: 36px;
  border-right: 1px solid var(--hairline);
  border-bottom: 1px solid var(--hairline);
}
.leader-card:nth-child(3n) {
  border-right: none;
}
.leader-card:nth-last-child(-n+3) {
  border-bottom: none;
}
/* Alternate background on second row */
.leader-card:nth-child(n+4) {
  background: var(--surface-1);
}

/* Responsive */
@media (max-width: 900px) {
  .leadership-grid {
    grid-template-columns: 1fr 1fr;
  }
  .leader-card:nth-child(3n) {
    border-right: 1px solid var(--hairline);
  }
  .leader-card:nth-child(even) {
    border-right: none;
  }
  .leader-card:nth-last-child(-n+3) {
    border-bottom: 1px solid var(--hairline);
  }
  .leader-card:nth-last-child(-n+2) {
    border-bottom: none;
  }
  .leader-card {
    padding: 28px;
  }
}
@media (max-width: 540px) {
  .leadership-grid {
    grid-template-columns: 1fr;
  }
  .leader-card,
  .leader-card:nth-child(3n),
  .leader-card:nth-child(even) {
    border-right: none;
    border-bottom: 1px solid var(--hairline);
  }
  .leader-card:last-child {
    border-bottom: none;
  }
  .leader-card:nth-last-child(-n+2) {
    border-bottom: 1px solid var(--hairline);
  }
}
</style>
