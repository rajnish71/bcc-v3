---
import { mentors } from '../../data/aboutPeople';
import PersonCard from '../ui/PersonCard.astro';
---

<section class="mentors-section" aria-labelledby="mentors-heading">
  <div class="container">
    <div class="mentors-header" data-gsap="reveal">
      <div class="mentors-kicker">Learning From Masters</div>
      <h2 class="mentors-title" id="mentors-heading">Learning From Masters</h2>
      <p class="mentors-intro">Senior photographers whose experience and generosity have shaped BCC's creative direction. Each mentor brings a distinct mastery to the club — and a willingness to share it. One individual may appear in both Leadership and Mentors; leadership and mentoring are distinct responsibilities.</p>
    </div>

    <div class="mentors-grid" data-gsap="stagger">
      {mentors.map((mentor) => (
        <div class:list={['mentor-card', mentor._pending && 'mentor-card--pending']}>
          <PersonCard
            name={mentor.name}
            eyebrow={mentor.role}
            subtitle={mentor.since ? `Since ${mentor.since}` : undefined}
            bio={mentor._pending ? undefined : mentor.bio}
            avatar={mentor.avatar}
            avatarSize={80}
            layout="vertical"
            placeholderVariant="forest"
            profileHref={mentor.profileHref}
          >
            {/* Contribution to BCC — mentor-specific extension, omitted when pending */}
            {mentor.contribution && !mentor._pending && (
              <div class="mentor-contribution">
                <div class="contribution-heading">Contribution to BCC</div>
                <p class="contribution-body">{mentor.contribution}</p>
              </div>
            )}
          </PersonCard>
        </div>
      ))}
    </div>

    <div class="mentors-note">
      <div class="mentors-note__text">V6 02 used distinct avatar colours for mentors and coordinators — Ver2 uses the same Profile Card family for both. The distinction between sections is carried by the section heading and the Contribution field.</div>
    </div>
  </div>
</section>

<style>
.mentors-section {
  background: var(--surface-1);
  border-top: 1px solid var(--hairline);
  border-bottom: 1px solid var(--hairline);
  padding: var(--s-12) 0;
}
.mentors-header {
  margin-bottom: var(--s-5);
}
.mentors-kicker {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: var(--weight-semibold);
  margin-bottom: var(--s-1);
}
.mentors-title {
  font-family: var(--font-display);
  font-size: clamp(28px, 3.5vw, 40px);
  font-weight: var(--weight-bold);
  letter-spacing: var(--ls-h1);
  color: var(--ink-900);
  margin-bottom: 12px;
}
.mentors-intro {
  font-family: var(--font-body);
  font-size: 15px;
  line-height: 1.7;
  color: var(--ink-600);
  max-width: 680px;
}

/* 3-col grid — same Profile Card family as Leadership */
.mentors-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border: 1px solid var(--hairline);
  background: var(--surface-0);
  overflow: hidden;
  margin-bottom: var(--s-3);
}
.mentor-card {
  padding: 36px;
  border-right: 1px solid var(--hairline);
}
.mentor-card:last-child {
  border-right: none;
}

/* Contribution section — mentor-specific slot content */
:global(.mentor-contribution) {
  border-top: 1px solid var(--hairline);
  padding-top: var(--s-2);
  margin-bottom: 20px;
}
:global(.contribution-heading) {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--ink-400);
  font-weight: var(--weight-semibold);
  margin-bottom: var(--s-1);
}
:global(.contribution-body) {
  font-family: var(--font-body);
  font-size: var(--text-ui);
  line-height: 1.8;
  color: var(--ink-600);
}

/* Component family note — internal design annotation */
.mentors-note {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  padding: 22px 26px;
}
.mentors-note__text {
  font-family: var(--font-body);
  font-size: 13px;
  line-height: 1.8;
  color: var(--ink-600);
  max-width: 720px;
}

/* Responsive */
@media (max-width: 900px) {
  .mentors-grid {
    grid-template-columns: 1fr 1fr;
  }
  .mentor-card:nth-child(2n) {
    border-right: none;
  }
  .mentor-card:nth-child(2n+1) {
    border-right: 1px solid var(--hairline);
  }
  .mentor-card {
    padding: 28px;
  }
}
@media (max-width: 540px) {
  .mentors-grid {
    grid-template-columns: 1fr;
  }
  .mentor-card,
  .mentor-card:nth-child(2n+1) {
    border-right: none;
    border-bottom: 1px solid var(--hairline);
  }
  .mentor-card:last-child {
    border-bottom: none;
  }
}
</style>
