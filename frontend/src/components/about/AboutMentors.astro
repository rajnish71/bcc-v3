---
import { mentors } from '../../data/leadership';
import PersonCard from '../ui/PersonCard.astro';
---

<section class="mentors-section" aria-labelledby="mentors-heading">
  <div class="container">
    <div class="mentors-header" data-gsap="reveal">
      <div class="mentors-kicker">Learning From Masters</div>
      <h2 class="mentors-title" id="mentors-heading">Learning From Masters</h2>
      <p class="mentors-intro">Senior photographers whose experience and generosity have shaped BCC's creative direction. Each mentor brings a distinct mastery to the club — and a willingness to share it.</p>
    </div>

    <div class="mentors-grid" data-gsap="stagger">
      {mentors.map((mentor, i) => (
        <div class:list={['mentor-card', i % 2 === 1 && 'mentor-card--alt']}>
          <PersonCard
            name={mentor.name}
            eyebrow={mentor.expertise}
            subtitle={`${mentor.role} · Bhopal`}
            bio={mentor.bio}
            avatar={mentor.avatar}
            avatarSize={96}
            layout="horizontal"
            placeholderVariant="gold"
            profileHref={mentor.username ? `/photographers/${mentor.username}/` : undefined}
          >
            <div class="mentor-contribution">
              <div class="contribution-heading">Contribution to BCC</div>
              <p class="contribution-body">{mentor.contribution}</p>
            </div>
          </PersonCard>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.mentors-section {
  background: var(--surface-1);
  border-top: 1px solid var(--hairline);
  border-bottom: 1px solid var(--hairline);
  padding: var(--s-12) 0;
}
.mentors-header {
  margin-bottom: var(--s-5);
}
.mentors-kicker {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: var(--weight-semibold);
  margin-bottom: var(--s-1);
}
.mentors-title {
  font-family: var(--font-display);
  font-size: clamp(28px, 3.5vw, 40px);
  font-weight: var(--weight-bold);
  letter-spacing: var(--ls-h1);
  color: var(--ink-900);
  margin-bottom: 12px;
}
.mentors-intro {
  font-size: 15px;
  line-height: 1.7;
  color: var(--ink-600);
  max-width: 680px;
}

/* Mentor grid */
.mentors-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  border: 1px solid var(--hairline);
  background: var(--surface-0);
}
.mentor-card {
  padding: var(--s-6);
  border-right: 1px solid var(--hairline);
}
.mentor-card:last-child {
  border-right: none;
}
.mentor-card--alt {
  background: var(--surface-1);
}

/* Contribution section (mentor-specific extra content) */
.mentor-contribution {
  border-top: 1px solid var(--hairline);
  padding-top: var(--s-2);
  margin-bottom: 20px;
}
.contribution-heading {
  font-size: var(--text-micro);
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--ink-400);
  font-weight: var(--weight-semibold);
  margin-bottom: var(--s-1);
  font-family: var(--font-body);
}
.contribution-body {
  font-size: var(--text-ui);
  line-height: 1.8;
  color: var(--ink-600);
}

/* Responsive */
@media (max-width: 768px) {
  .mentors-grid {
    grid-template-columns: 1fr;
  }
  .mentor-card {
    border-right: none;
    border-bottom: 1px solid var(--hairline);
    padding: var(--s-4) 28px;
  }
  .mentor-card:last-child {
    border-bottom: none;
  }
}
</style>
