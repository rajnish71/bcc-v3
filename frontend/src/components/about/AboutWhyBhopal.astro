---
import { aboutPhotos, photoSrc, photoSrcset } from '../../data/photoRegistry';

const primary = aboutPhotos.whyBhopalPrimary;
const secondary = aboutPhotos.whyBhopalSecondary;
---

<section class="why-section" aria-labelledby="why-heading" data-gsap="reveal">
  <div class="container">

    <div class="why-header">
      <div class="why-kicker">Why Bhopal</div>
      <h2 class="why-title" id="why-heading">A City Worth Photographing</h2>
    </div>

    <!-- 1. Boxed panoramic photograph — canonical credit bar below -->
    <div class="why-primary-frame">
      <div class="why-primary-photo-wrap">
        <img
          src={photoSrc(primary, 1140)}
          srcset={photoSrcset(primary, [700, 900, 1140])}
          sizes="(max-width: 1200px) 100vw, 1140px"
          alt={primary.alt}
          class="why-primary-photo"
          loading="lazy"
        />
      </div>
      <!-- Canonical Photo Credit Component — below photo -->
      <div class="photo-credit-bar">
        <span class="photo-credit-bar__caption">{primary.caption}</span>
        <span class="photo-credit-bar__right">
          <span class="photo-credit-bar__by">Photo by</span>
          <span class="photo-credit-bar__name">{primary.photographer}</span>
        </span>
      </div>
    </div>

    <!-- 2. Two-column editorial -->
    <div class="why-editorial">
      <div class="why-col-left">
        <div class="why-col-kicker">A City Worth Photographing</div>
        <p class="why-body">Bhopal is one of India's most underrated cities for photography. Its two lakes — Bada Talab and Chota Talab — offer golden-hour reflections that few cities can match. The Upper Lake at dawn, when the light is still low and the water is still, is one of the finest photographic situations in central India.</p>
        <p class="why-body">Van Vihar National Park sits at the edge of the city. Winter brings migratory birds to the Bhoj Wetland. The Old City — dense, alive, historically layered — rewards the street photographer who is willing to walk slowly and look carefully.</p>
        <p class="why-body">Across every season and every light condition, Bhopal offers something exceptional. This is why we have been photographing it for a decade, and why we will still be photographing it a decade from now.</p>
      </div>

      <div class="why-col-right">
        <div class="why-col-kicker">What Bhopal Offers the Photographer</div>
        <div class="bhopal-subjects" role="list">
          <div class="subject-item" role="listitem">
            <div class="subject-name">Upper Lake</div>
            <div class="subject-desc">Dawn reflections · boat silhouettes</div>
          </div>
          <div class="subject-item" role="listitem">
            <div class="subject-name">Van Vihar</div>
            <div class="subject-desc">Wildlife · forest light · seasons</div>
          </div>
          <div class="subject-item" role="listitem">
            <div class="subject-name">Taj-ul-Masajid</div>
            <div class="subject-desc">Heritage · Mughal architecture · night</div>
          </div>
          <div class="subject-item" role="listitem">
            <div class="subject-name">Old City</div>
            <div class="subject-desc">Street · portraits · layered history</div>
          </div>
          <div class="subject-item" role="listitem">
            <div class="subject-name">Bhoj Wetland</div>
            <div class="subject-desc">Migratory birds · winter mornings</div>
          </div>
          <div class="subject-item" role="listitem">
            <div class="subject-name">Festivals</div>
            <div class="subject-desc">Ganesh Chaturthi · Eid · Navratri</div>
          </div>
          <div class="subject-item" role="listitem">
            <div class="subject-name">Monsoon</div>
            <div class="subject-desc">Dramatic skies · saturated greens</div>
          </div>
          <div class="subject-item" role="listitem">
            <div class="subject-name">Architecture</div>
            <div class="subject-desc">Temples · mosques · colonial layers</div>
          </div>
        </div>
      </div>
    </div>

    <!-- 3. Supporting photograph — editorial scale (max-width 520px), not full-width -->
    <div class="why-secondary-section">
      <div class="why-secondary-wrap">
        <div class="why-secondary-frame">
          <img
            src={photoSrc(secondary, 720)}
            srcset={photoSrcset(secondary, [480, 720])}
            sizes="(max-width: 900px) 100vw, 520px"
            alt={secondary.alt}
            class="why-secondary-photo"
            loading="lazy"
          />
        </div>
        <!-- Canonical Photo Credit Component -->
        <div class="photo-credit-bar photo-credit-bar--sm">
          <span class="photo-credit-bar__caption">{secondary.caption}</span>
          <span class="photo-credit-bar__right">
            <span class="photo-credit-bar__by">Photo by</span>
            <span class="photo-credit-bar__name">{secondary.photographer}</span>
          </span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
.why-section {
  background: var(--surface-0);
  border-top: 1px solid var(--hairline);
  border-bottom: 1px solid var(--hairline);
  padding: var(--s-12) 0;
}
.why-header {
  margin-bottom: var(--s-6);
}
.why-kicker {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: var(--weight-semibold);
  margin-bottom: var(--s-1);
}
.why-title {
  font-family: var(--font-display);
  font-size: clamp(28px, 3.5vw, 40px);
  font-weight: var(--weight-bold);
  letter-spacing: -0.025em;
  color: var(--ink-900);
}

/* 1. Boxed panoramic — no aspect-ratio constraint (natural ratio) */
.why-primary-frame {
  border: 1px solid var(--hairline);
  overflow: hidden;
  margin-bottom: 0;
}
.why-primary-photo-wrap {
  overflow: hidden;
}
.why-primary-photo {
  width: 100%;
  height: auto;
  display: block;
}

/* Canonical Photo Credit Bar */
.photo-credit-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--s-3);
  background: var(--surface-1);
  border-top: 1px solid var(--hairline);
  padding: 12px 20px;
}
.photo-credit-bar--sm {
  padding: 10px 14px;
}
.photo-credit-bar__caption {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--ink-400);
  letter-spacing: 0.06em;
}
.photo-credit-bar__right {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}
.photo-credit-bar__by {
  font-family: var(--font-mono);
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--ink-400);
}
.photo-credit-bar__name {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--gold-600);
  font-weight: 500;
  letter-spacing: 0.04em;
}
/* 2. Two-column editorial */
.why-editorial {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 56px;
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-top: none;
  padding: 56px 56px;
}
.why-col-kicker {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: var(--weight-semibold);
  margin-bottom: var(--s-3);
}
.why-body {
  font-family: var(--font-body);
  font-size: 15px;
  line-height: 1.9;
  color: var(--ink-600);
  margin-bottom: var(--s-3);
}
.why-body:last-child {
  margin-bottom: 0;
}

/* Bhopal subjects grid */
.bhopal-subjects {
  display: grid;
  grid-template-columns: 1fr 1fr;
  border: 1px solid var(--hairline);
}
.subject-item {
  padding: 14px 16px;
  border-bottom: 1px solid var(--hairline);
  border-right: 1px solid var(--hairline);
}
.subject-item:nth-child(even) {
  border-right: none;
}
.subject-item:nth-last-child(-n+2) {
  border-bottom: none;
}
.subject-name {
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: var(--weight-semibold);
  color: var(--ink-900);
  margin-bottom: 3px;
}
.subject-desc {
  font-family: var(--font-body);
  font-size: 11px;
  color: var(--ink-400);
  line-height: 1.5;
}

/* 3. Supporting photograph — editorial scale, not full-width */
.why-secondary-section {
  background: var(--surface-1);
  border: 1px solid var(--hairline);
  border-top: none;
  padding: 40px 56px;
}
.why-secondary-wrap {
  max-width: 520px;
}
.why-secondary-frame {
  border: 1px solid var(--hairline);
  overflow: hidden;
}
.why-secondary-photo {
  width: 100%;
  height: auto;
  display: block;
}

/* Responsive */
@media (max-width: 900px) {
  .why-editorial {
    grid-template-columns: 1fr;
    gap: 40px;
    padding: 40px 32px;
  }
  .why-secondary-section {
    padding: 32px;
  }
  .why-secondary-wrap {
    max-width: 100%;
  }
}
@media (max-width: 480px) {
  .why-section {
    padding: var(--s-8) 0;
  }
  .photo-credit-bar {
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }
}
</style>
