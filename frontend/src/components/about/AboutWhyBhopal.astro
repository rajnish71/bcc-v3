---
import { aboutPhotos, photoSrc, photoSrcset, getPhotographerProfileUrl } from '../../data/photoRegistry';

const primary = aboutPhotos.whyBhopalPrimary;
const secondary = aboutPhotos.whyBhopalSecondary;
---

<section class="why-section" aria-labelledby="why-heading" data-gsap="reveal">
  <div class="container">

    <div class="why-header">
      <div class="why-kicker">Why Bhopal</div>
      <h2 class="why-title" id="why-heading">A City Worth Photographing</h2>
    </div>

    <!-- 1. Boxed panoramic photograph — canonical credit bar below -->
    <div class="why-primary-frame">
      <div class="why-primary-photo-wrap">
        <img
          src={photoSrc(primary, 1140)}
          srcset={photoSrcset(primary, [700, 900, 1140])}
          sizes="(max-width: 1200px) 100vw, 1140px"
          alt={primary.alt}
          class="why-primary-photo"
          loading="lazy"
        />
      </div>
      <!-- Canonical Photo Credit Component — below photo -->
      <div class="photo-credit-bar">
        <span class="photo-credit-bar__caption">{primary.caption}</span>
        <span class="photo-credit-bar__right">
          <span class="photo-credit-bar__by">Photo by</span>
          <a href={getPhotographerProfileUrl(primary.photographer)} class="photo-credit-bar__name">{primary.photographer}</a>
        </span>
      </div>
    </div>

    <!-- 2. Two-column editorial -->
    <div class="why-editorial">
      <div class="why-col-left">
        <div class="why-col-kicker">A City Worth Photographing</div>
        <p class="why-body">Bhopal is one of India's most underrated cities for photography. Its two lakes — Bada Talab and Chota Talab — offer golden-hour reflections that few cities can match. The Upper Lake at dawn, when the light is still low and the water is still, is one of the finest photographic situations in central India.</p>
        <p class="why-body">Van Vihar National Park sits at the edge of the city. Winter brings migratory birds to the Bhoj Wetland. The Old City — dense, alive, historically layered — rewards the street photographer who is willing to walk slowly and look carefully.</p>
        <p class="why-body">Across every season and every light condition, Bhopal offers something exceptional. This is why we have been photographing it for a decade, and why we will still be photographing it a decade from now.</p>
      </div>

      <div class="why-col-right">
        <!-- Supporting photograph — aligned beside the editorial text -->
        <div class="why-secondary-frame">
          <img
            src={photoSrc(secondary, 720)}
            srcset={photoSrcset(secondary, [480, 720])}
            sizes="(max-width: 900px) 100vw, 560px"
            alt={secondary.alt}
            class="why-secondary-photo"
            loading="lazy"
          />
        </div>
        <div class="photo-credit-bar photo-credit-bar--sm">
          <span class="photo-credit-bar__caption">{secondary.caption}</span>
          <span class="photo-credit-bar__right">
            <span class="photo-credit-bar__by">Photo by</span>
            <a href={getPhotographerProfileUrl(secondary.photographer)} class="photo-credit-bar__name">{secondary.photographer}</a>
          </span>
        </div>
      </div>

      <!-- 3. What Bhopal Offers — Full-width editorial strip -->
      <div class="why-offers-strip">
        <div class="why-offers-kicker">What Bhopal Offers the Photographer</div>
        <div class="why-offers-ribbon" role="list">
          <div class="offers-item" role="listitem">
            <svg class="offers-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M2 6c2.4 0 2.4 2 4.8 2s4.8-2 7.2-2 4.8 2 7.2 2 4.8-2 7.2-2"/>
              <path d="M2 12c2.4 0 2.4 2 4.8 2s4.8-2 7.2-2 4.8 2 7.2 2 4.8-2 7.2-2"/>
              <path d="M2 18c2.4 0 2.4 2 4.8 2s4.8-2 7.2-2 4.8 2 7.2 2 4.8-2 7.2-2"/>
            </svg>
            <div class="offers-name">Upper Lake</div>
            <div class="offers-desc">Dawn reflections · boat silhouettes</div>
          </div>
          <div class="offers-item" role="listitem">
            <svg class="offers-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m12 19 7-7H5l7 7Z"/>
              <path d="m12 13 5.5-5.5H6.5L12 13Z"/>
              <path d="m12 7 4-4H8l4 4Z"/>
              <path d="M12 19v3"/>
            </svg>
            <div class="offers-name">Van Vihar</div>
            <div class="offers-desc">Wildlife · forest light · seasons</div>
          </div>
          <div class="offers-item" role="listitem">
            <svg class="offers-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="3" y1="22" x2="21" y2="22" />
              <line x1="6" y1="18" x2="18" y2="18" />
              <path d="m12 2-8 4v2h16V6l-8-4Z" />
              <path d="M5 10v8M9 10v8M13 10v8M17 10v8" />
            </svg>
            <div class="offers-name">Taj-ul-Masajid</div>
            <div class="offers-desc">Heritage · Mughal architecture · night</div>
          </div>
          <div class="offers-item" role="listitem">
            <svg class="offers-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18" />
              <path d="M6 12H4a2 2 0 0 0-2 2v8" />
              <path d="M18 16h2a2 2 0 0 1 2 2v4" />
              <path d="M10 6h4M10 10h4M10 14h4M10 18h4" />
            </svg>
            <div class="offers-name">Old City</div>
            <div class="offers-desc">Street · portraits · layered history</div>
          </div>
          <div class="offers-item" role="listitem">
            <svg class="offers-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 18c3-3 7-3 10 0M11 18c3-3 7-3 10 0"/>
            </svg>
            <div class="offers-name">Bhoj Wetland</div>
            <div class="offers-desc">Migratory birds · winter mornings</div>
          </div>
          <div class="offers-item" role="listitem">
            <svg class="offers-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z" />
            </svg>
            <div class="offers-name">Festivals</div>
            <div class="offers-desc">Ganesh Chaturthi · Eid · Navratri</div>
          </div>
          <div class="offers-item" role="listitem">
            <svg class="offers-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242" />
              <path d="M16 14v6" />
              <path d="M8 14v6" />
              <path d="M12 16v6" />
            </svg>
            <div class="offers-name">Monsoon</div>
            <div class="offers-desc">Dramatic skies · saturated greens</div>
          </div>
          <div class="offers-item" role="listitem">
            <svg class="offers-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="3" y1="21" x2="21" y2="21"/>
              <line x1="3" y1="3" x2="21" y2="3"/>
              <path d="M6 3v18M10 3v18M14 3v18M18 3v18"/>
            </svg>
            <div class="offers-name">Architecture</div>
            <div class="offers-desc">Temples · mosques · colonial layers</div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
.why-section {
  background: var(--surface-0);
  border-top: 1px solid var(--hairline);
  border-bottom: 1px solid var(--hairline);
  padding: var(--s-12) 0;
}
.why-header {
  margin-bottom: var(--s-6);
}
.why-kicker {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: var(--weight-semibold);
  margin-bottom: var(--s-1);
}
.why-title {
  font-family: var(--font-display);
  font-size: clamp(28px, 3.5vw, 40px);
  font-weight: var(--weight-bold);
  letter-spacing: -0.025em;
  color: var(--ink-900);
}

/* 1. Boxed panoramic — no aspect-ratio constraint (natural ratio) */
.why-primary-frame {
  border: 1px solid var(--hairline);
  overflow: hidden;
  margin-bottom: 0;
}
.why-primary-photo-wrap {
  overflow: hidden;
}
.why-primary-photo {
  width: 100%;
  height: auto;
  display: block;
}

/* Canonical Photo Credit Bar */
.photo-credit-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--s-3);
  background: var(--surface-1);
  border-top: 1px solid var(--hairline);
  padding: 12px 20px;
}
.photo-credit-bar--sm {
  padding: 10px 14px;
}
.photo-credit-bar__caption {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--ink-400);
  letter-spacing: 0.06em;
}
.photo-credit-bar__right {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}
.photo-credit-bar__by {
  font-family: var(--font-mono);
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--ink-400);
}
.photo-credit-bar__name {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--gold-600);
  font-weight: 500;
  letter-spacing: 0.04em;
  text-decoration: none;
}
.photo-credit-bar__name:hover {
  text-decoration: underline;
}

/* 2. Two-column editorial */
.why-editorial {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 56px;
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-top: none;
  padding: 56px 56px;
}
.why-col-kicker {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: var(--weight-semibold);
  margin-bottom: var(--s-3);
}
.why-body {
  font-family: var(--font-body);
  font-size: 15px;
  line-height: 1.9;
  color: var(--ink-600);
  margin-bottom: var(--s-3);
}
.why-body:last-child {
  margin-bottom: 0;
}

/* 3. Supporting photograph — anchored in right editorial column */
.why-secondary-frame {
  border: 1px solid var(--hairline);
  border-bottom: none;
  overflow: hidden;
}
.why-secondary-photo {
  width: 100%;
  height: auto;
  display: block;
}

/* 4. Editorial Information Ribbon */
.why-offers-strip {
  grid-column: 1 / -1;
  border-top: 1px solid var(--hairline);
  padding-top: 40px;
  margin-top: 16px;
}
.why-offers-kicker {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: var(--weight-semibold);
  margin-bottom: 24px;
}
.why-offers-ribbon {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px 0;
}
.offers-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 0 24px;
  border-right: 1px solid var(--hairline);
}
.offers-item:first-child {
  padding-left: 0;
}
.offers-item:nth-child(4n) {
  border-right: none;
  padding-right: 0;
}
.offers-item:nth-child(4n + 1) {
  padding-left: 0;
}
.offers-name {
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: var(--weight-semibold);
  color: var(--ink-900);
  margin-bottom: 3px;
}
.offers-desc {
  font-family: var(--font-body);
  font-size: 11px;
  color: var(--ink-400);
  line-height: 1.5;
}
.offers-icon {
  color: var(--gold-600);
  margin-bottom: 8px;
  flex-shrink: 0;
}

/* Responsive */
@media (max-width: 1024px) {
  .why-offers-ribbon {
    grid-template-columns: repeat(2, 1fr);
  }
  .offers-item {
    border-right: 1px solid var(--hairline);
    padding: 0 16px;
  }
  .offers-item:nth-child(2n) {
    border-right: none;
    padding-right: 0;
  }
  .offers-item:nth-child(2n + 1) {
    padding-left: 0;
  }
}

@media (max-width: 900px) {
  .why-editorial {
    grid-template-columns: 1fr;
    gap: 40px;
    padding: 40px 32px;
  }
  .why-offers-strip {
    padding-top: 32px;
  }
}

@media (max-width: 480px) {
  .why-section {
    padding: var(--s-8) 0;
  }
  .photo-credit-bar {
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }
  .why-offers-ribbon {
    grid-template-columns: 1fr;
    gap: 20px;
  }
  .offers-item {
    border-right: none;
    border-bottom: 1px solid var(--hairline);
    padding: 0 0 16px 0;
  }
  .offers-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
}
</style>
