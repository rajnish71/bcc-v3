---
interface Props {
  id: string;
  name?: string;
  required?: boolean;
  class?: string;
}
const { id, name, required = false, class: className = '' } = Astro.props;
---
<label class:list={['f-checkbox-label', className]}>
  <input
    type="checkbox"
    id={id}
    name={name}
    required={required || undefined}
    class="f-checkbox"
  />
  <span><slot /></span>
</label>

<style>
.f-checkbox-label {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 13px;
  color: var(--ink-600);
  line-height: 1.55;
  cursor: pointer;
  font-family: var(--font-body);
}
.f-checkbox {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
  margin-top: 2px;
  accent-color: var(--gold-600);
}
</style>
