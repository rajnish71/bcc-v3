/* ── T&C scroll status ── */
.maf-tc-status { display: flex; align-items: center; padding: 10px 14px; border-radius: var(--r-1); border: 1px solid; margin-bottom: var(--s-3); font-size: 13px; }
.maf-tc-status--unread { background: var(--surface-2); border-color: var(--hairline); color: var(--ink-400); }
.maf-tc-status--read { background: #F0F5F2; border-color: #C4D8CB; color: #2A3E32; }

/* ── Checkboxes ── */
.maf-cb-wrap { margin-bottom: 12px; }
.maf-cb-wrap--locked { opacity: 0.45; pointer-events: none; }
.maf-cb-wrap--locked.is-unlocked { opacity: 1; pointer-events: auto; }
.maf-cb {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  width: 100%;
  padding: 16px 18px;
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-radius: var(--r-2);
  cursor: pointer;
  text-align: left;
  font-family: var(--font-body);
  font-size: 14px;
  color: var(--ink-900);
  line-height: 1.6;
  transition: border-color var(--m-fast), box-shadow var(--m-fast);
}
.maf-cb:not(:disabled):hover { border-color: var(--gold-500); }
.maf-cb__box {
  width: 20px;
  height: 20px;
  border-radius: 4px;
  background: var(--surface-0);
  border: 2px solid var(--hairline-strong);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 1px;
  transition: background var(--m-fast), border-color var(--m-fast);
}
.maf-cb__box::after { content: ''; display: none; width: 6px; height: 10px; border: 2px solid #fff; border-top: none; border-left: none; transform: rotate(45deg) translate(-1px,-1px); }
.maf-cb[aria-checked="true"] .maf-cb__box { background: var(--gold-600); border-color: var(--gold-600); }
.maf-cb[aria-checked="true"] .maf-cb__box::after { display: block; }
.maf-cb__label { flex: 1; }

/* ── Review table ── */
.maf-review-table { background: var(--surface-0); border: 1px solid var(--hairline); border-radius: var(--r-2); overflow: hidden; margin-bottom: var(--s-3); }
.maf-review-table__header { padding: 14px 20px; background: var(--surface-1); border-bottom: 1px solid var(--hairline); font-size: 11px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--ink-400); font-weight: 600; }
.maf-review-row { display: flex; align-items: baseline; gap: 16px; padding: 12px 20px; border-bottom: 1px solid var(--surface-2); }
.maf-review-row:last-child { border-bottom: none; }
.maf-review-row--readonly { background: #FDFBF7; }
.maf-review-row__key { font-family: var(--font-mono); font-size: 11px; color: var(--ink-400); text-transform: uppercase; letter-spacing: 0.06em; min-width: 160px; flex-shrink: 0; }
.maf-review-row__val { font-size: 14px; color: var(--ink-900); font-weight: 500; }
.maf-review-row__val--muted { color: var(--ink-400); font-weight: 400; }

/* ── Membership badge ── */
.maf-membership-badge { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; background: var(--surface-0); border: 1px solid var(--hairline); border-radius: var(--r-2); padding: var(--s-3); margin-bottom: var(--s-3); }
.maf-membership-badge__label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--ink-400); font-weight: 600; margin-bottom: 8px; }
.maf-membership-badge__name { font-family: var(--font-display); font-size: 18px; font-weight: 700; color: var(--ink-900); margin-bottom: 4px; }
.maf-membership-badge__term { font-size: 12px; color: var(--ink-400); }
.maf-membership-badge__tag { background: rgba(201,169,97,0.1); border: 1px solid var(--gold-light); padding: 8px 18px; border-radius: var(--r-1); font-size: 12px; font-weight: 600; color: var(--gold-700); white-space: nowrap; }

/* ── Renewal meta ── */
.maf-renewal-meta { background: #F0F5F2; border: 1px solid #C4D8CB; border-radius: var(--r-2); padding: 18px 20px; margin-bottom: var(--s-3); }
.maf-renewal-meta__label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--forest-600); font-weight: 600; margin-bottom: 12px; }
.maf-renewal-meta__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.maf-renewal-meta__key { font-size: 11px; color: var(--ink-400); margin-bottom: 4px; }
.maf-renewal-meta__val--expiry { color: #C0392B; font-weight: 600; }
.maf-renewal-meta__val--projected { color: var(--forest-600); font-weight: 600; }

/* ── Review note ── */
.maf-review-note { font-size: 13px; line-height: 1.7; color: var(--ink-400); font-style: italic; margin-bottom: var(--s-3); }

/* ── Error banner ── */
.maf-error-banner { padding: 12px 16px; background: #FEF2F2; border: 1px solid #FCA5A5; border-radius: var(--r-2); font-size: 14px; color: #B91C1C; margin-bottom: var(--s-3); }

/* ── Submit btn spinner ── */
.maf-submit-btn { display: inline-flex; align-items: center; gap: 8px; }

/* ── Pending screen ── */
.maf-pending { background: var(--surface-1); border: 1px solid var(--hairline); border-radius: var(--r-2); overflow: hidden; }
.maf-pending__header { background: var(--surface-2); border-bottom: 1px solid var(--hairline); padding: 20px 24px; display: flex; align-items: center; gap: 12px; }
.maf-pending__icon { font-size: 20px; color: var(--gold-600); }
.maf-pending__title { font-family: var(--font-display); font-size: 17px; font-weight: 700; color: var(--ink-900); }
.maf-pending__sub { font-size: 13px; color: var(--ink-600); margin-top: 2px; }
.maf-pending__body { padding: var(--s-4); }
.maf-pending__meta { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: var(--s-3); }
.maf-pending__meta-card { background: var(--surface-0); border: 1px solid var(--hairline); border-radius: var(--r-1); padding: 14px 16px; }
.maf-meta-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--ink-400); margin-bottom: 6px; }
.maf-meta-value { font-size: 13px; font-weight: 600; color: var(--ink-900); }
.maf-status-pending { color: var(--gold-700); display: flex; align-items: center; gap: 6px; }
.maf-status-dot { width: 8px; height: 8px; border-radius: 999px; background: var(--gold-500); display: inline-block; }
.maf-pending__note { font-size: 13px; line-height: 1.7; color: var(--ink-600); margin-bottom: var(--s-3); }
.maf-pending__actions { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
.maf-contact { font-size: 13px; color: var(--ink-400); }
.maf-contact a { color: var(--gold-600); }

/* ── Prefill banner ── */
.maf-prefill-banner { display: flex; align-items: flex-start; gap: 12px; background: #F0F5F2; border: 1px solid #C4D8CB; border-radius: var(--r-2); padding: 14px 18px; margin-bottom: var(--s-4); }
.maf-prefill-banner__icon { font-size: 16px; color: var(--forest-600); flex-shrink: 0; margin-top: 1px; }
.maf-prefill-banner__title { font-size: 13px; font-weight: 600; color: var(--forest-700); margin-bottom: 3px; }
.maf-prefill-banner__body { font-size: 12px; color: var(--forest-600); line-height: 1.6; }

/* ── Success screen ── */
.maf-success { text-align: center; padding: 60px 40px; }
.maf-success__icon { width: 72px; height: 72px; border-radius: 999px; background: var(--gold-gradient); display: flex; align-items: center; justify-content: center; margin: 0 auto var(--s-4); box-shadow: 0 4px 20px rgba(168,132,60,0.35); font-size: 32px; color: var(--ink-inverse); }
.maf-success__heading { font-family: var(--font-display); font-size: 28px; font-weight: 700; letter-spacing: -0.02em; color: var(--ink-900); margin-bottom: 12px; }
.maf-success__status { display: inline-block; background: var(--surface-2); border: 1px solid var(--hairline); padding: 6px 16px; border-radius: var(--r-1); font-size: 11px; color: var(--ink-600); margin-bottom: 20px; }
.maf-success__body { font-size: 15px; line-height: 1.75; color: var(--ink-600); margin-bottom: 8px; }
.maf-success__note { font-size: 13px; line-height: 1.7; color: var(--ink-400); margin-bottom: 32px; font-style: italic; }
.maf-success__next { background: var(--surface-1); border: 1px solid var(--hairline); border-radius: var(--r-2); padding: 16px 20px; margin-bottom: var(--s-4); text-align: left; }
.maf-success__next-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--ink-400); font-weight: 600; margin-bottom: 10px; }
.maf-success__next-item { display: flex; gap: 10px; font-size: 13px; line-height: 2; color: var(--ink-600); }
.maf-gold { color: var(--gold-600); flex-shrink: 0; }

/* ── Utility ── */
.maf-mono { font-family: var(--font-mono); }
.maf-screen {}

/* ── Buttons ── */
.btn-outline {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 600;
  color: var(--ink-600);
  border: 1px solid var(--hairline-strong);
  padding: 12px 28px;
  border-radius: var(--r-1);
  cursor: pointer;
  text-decoration: none;
  font-family: var(--font-body);
  transition: border-color var(--m-fast), color var(--m-fast);
}
.btn-outline:hover { border-color: var(--ink-600); color: var(--ink-900); }
</style>

<script>
  (function() {
    const root = document.getElementById('maf-root') as HTMLElement;
    const variant = root.dataset.variant as 'apply' | 'renew';
    const API = '/api/v1';

    // ── State ──────────────────────────────────────────────────────────────
    let currentStep = 1;
    let tcScrolled = false;
    let cb1Checked = false;
    let cb2Checked = false;
    let prefill: Record<string, any> = {};

    // ── DOM refs ───────────────────────────────────────────────────────────
    const loading      = document.getElementById('maf-loading') as HTMLElement;
    const steps        = document.getElementById('maf-steps') as HTMLElement;
    const pendingScreen= document.getElementById('maf-pending-screen') as HTMLElement;
    const successScreen= document.getElementById('maf-success-screen') as HTMLElement;
    const prefillBanner= document.getElementById('maf-prefill-banner') as HTMLElement;
    const step1        = document.getElementById('maf-step1') as HTMLElement;
    const step2        = document.getElementById('maf-step2') as HTMLElement;
    const step3        = document.getElementById('maf-step3') as HTMLElement;
    const tcPanel      = document.getElementById('maf-tc-panel') as HTMLElement;
    const tcStatus     = document.getElementById('maf-tc-status') as HTMLElement;
    const tcStatusText = document.getElementById('maf-tc-status-text') as HTMLElement;
    const cb1Wrap      = document.getElementById('maf-cb1-wrap') as HTMLElement;
    const cb1Btn       = document.getElementById('maf-cb1') as HTMLButtonElement;
    const cb1Box       = document.getElementById('maf-cb1-box') as HTMLElement;
    const cb2Btn       = document.getElementById('maf-cb2') as HTMLButtonElement;
    const cb2Box       = document.getElementById('maf-cb2-box') as HTMLElement;
    const btnNext2     = document.getElementById('maf-btn-next2') as HTMLButtonElement;
    const submitBtn    = document.getElementById('maf-btn-submit') as HTMLButtonElement;
    const submitLabel  = document.getElementById('maf-submit-label') as HTMLElement;
    const submitSpinner= document.getElementById('maf-submit-spinner') as HTMLElement;
    const submitError  = document.getElementById('maf-submit-error') as HTMLElement;

    function token(): string | null { return localStorage.getItem('bcc_token'); }

    // ── Step indicator rendering ───────────────────────────────────────────
    function renderStepIndicator(active: number) {
      for (let i = 1; i <= 3; i++) {
        const circle = document.getElementById(`maf-sc-${i}`) as HTMLElement;
        const label  = circle.nextElementSibling as HTMLElement;
        circle.classList.remove('is-active', 'is-done');
        label.classList.remove('is-active');
        if (i < active) { circle.classList.add('is-done'); circle.textContent = '✓'; }
        else if (i === active) { circle.classList.add('is-active'); circle.textContent = String(i); label.classList.add('is-active'); }
        else { circle.textContent = String(i); }
      }
      const conn12 = document.getElementById('maf-conn-12') as HTMLElement;
      const conn23 = document.getElementById('maf-conn-23') as HTMLElement;
      conn12.classList.toggle('is-done', active > 1);
      conn23.classList.toggle('is-done', active > 2);
    }

    // ── Show/hide state screens ────────────────────────────────────────────
    function showStep(n: number) {
      currentStep = n;
      loading.style.display = 'none';
      steps.style.display   = 'flex';
      pendingScreen.style.display = 'none';
      successScreen.style.display = 'none';
      step1.style.display   = n === 1 ? '' : 'none';
      step2.style.display   = n === 2 ? '' : 'none';
      step3.style.display   = n === 3 ? '' : 'none';
      renderStepIndicator(n);
      if (n === 3) populateReviewStep();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function showPendingScreen(submittedAt: string | null) {
      loading.style.display  = 'none';
      steps.style.display    = 'none';
      step1.style.display    = 'none';
      step2.style.display    = 'none';
      step3.style.display    = 'none';
      pendingScreen.style.display = '';
      const dateEl = document.getElementById('maf-pending-date') as HTMLElement;
      dateEl.textContent = submittedAt
        ? new Date(submittedAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })
        : '—';
    }

    function showSuccessScreen(email: string) {
      loading.style.display  = 'none';
      steps.style.display    = 'none';
      step1.style.display    = 'none';
      step2.style.display    = 'none';
      step3.style.display    = 'none';
      successScreen.style.display = '';
      pendingScreen.style.display = 'none';

      const heading = document.getElementById('maf-success-heading') as HTMLElement;
      const body    = document.getElementById('maf-success-body') as HTMLElement;
      const returnLink = document.getElementById('maf-success-return') as HTMLAnchorElement;

      if (variant === 'renew') {
        heading.textContent = 'Renewal Request Submitted';
        body.textContent    = `We'll email you at ${email} once your renewal is reviewed by the BCC committee.`;
        returnLink.textContent = '← Return to Member Hub';
        returnLink.href = '/hub/';
      } else {
        heading.textContent = 'Application Submitted';
        body.textContent    = `We'll email you at ${email} once your application is reviewed by the BCC committee.`;
        returnLink.textContent = '← Return to Home';
        returnLink.href = '/';
      }
    }

    // ── Pre-populate fields ────────────────────────────────────────────────
    function populateFields(data: Record<string, any>) {
      prefill = data;
      (document.getElementById('maf-identity-name') as HTMLElement).textContent = data.fullName ?? '—';
      (document.getElementById('maf-identity-email') as HTMLElement).textContent = data.email ?? '—';
      (document.getElementById('maf-dob') as HTMLInputElement).value = data.dateOfBirth ?? '';
      const genderSel = document.getElementById('maf-gender') as HTMLSelectElement;
      if (data.gender) genderSel.value = data.gender;
      (document.getElementById('maf-phone') as HTMLInputElement).value = data.phone ?? '';
      (document.getElementById('maf-addr1') as HTMLInputElement).value = data.addressLine1 ?? '';
      (document.getElementById('maf-addr2') as HTMLInputElement).value = data.addressLine2 ?? '';
      (document.getElementById('maf-city') as HTMLInputElement).value = data.city ?? '';
      (document.getElementById('maf-state') as HTMLInputElement).value = data.state ?? '';
      (document.getElementById('maf-pin') as HTMLInputElement).value = data.pinCode ?? '';

      // Variant B: populate renewal meta
      if (variant === 'renew' && data.expiresAt) {
        (document.getElementById('maf-renewal-meta') as HTMLElement).style.display = '';
        const expiry = new Date(data.expiresAt);
        const now = new Date();
        const isExpired = expiry < now;
        const expiryEl = document.getElementById('maf-renewal-expiry') as HTMLElement;
        expiryEl.textContent = expiry.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) + (isExpired ? ' — EXPIRED' : '');
        if (isExpired) expiryEl.classList.add('maf-renewal-meta__val--expiry');

        if (data.projectedNewExpiry) {
          const projected = new Date(data.projectedNewExpiry);
          (document.getElementById('maf-renewal-projected') as HTMLElement).textContent =
            projected.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
        }
      }
    }

    // ── Populate review step ───────────────────────────────────────────────
    function populateReviewStep() {
      const dob   = (document.getElementById('maf-dob') as HTMLInputElement).value;
      const gender= (document.getElementById('maf-gender') as HTMLSelectElement).value;
      const phone = (document.getElementById('maf-phone') as HTMLInputElement).value;
      const addr1 = (document.getElementById('maf-addr1') as HTMLInputElement).value;
      const addr2 = (document.getElementById('maf-addr2') as HTMLInputElement).value;
      const city  = (document.getElementById('maf-city') as HTMLInputElement).value;
      const state = (document.getElementById('maf-state') as HTMLInputElement).value;
      const pin   = (document.getElementById('maf-pin') as HTMLInputElement).value;

      (document.getElementById('maf-rev-name') as HTMLElement).textContent = prefill.fullName ?? '—';
      (document.getElementById('maf-rev-email') as HTMLElement).textContent = prefill.email ?? '—';
      (document.getElementById('maf-rev-dob') as HTMLElement).textContent = dob
        ? new Date(dob + 'T00:00:00').toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })
        : '—';
      const genderLabels: Record<string,string> = { MALE: 'Male', FEMALE: 'Female', OTHER: 'Other', PREFER_NOT_TO_SAY: 'Prefer not to say' };
      (document.getElementById('maf-rev-gender') as HTMLElement).textContent = genderLabels[gender] ?? '—';
      (document.getElementById('maf-rev-phone') as HTMLElement).textContent = phone || '—';
      (document.getElementById('maf-rev-addr1') as HTMLElement).textContent = addr1 || '—';
      const addr2Row = document.getElementById('maf-rev-addr2-row') as HTMLElement;
      if (addr2) {
        addr2Row.style.display = '';
        (document.getElementById('maf-rev-addr2') as HTMLElement).textContent = addr2;
      } else {
        addr2Row.style.display = 'none';
      }
      (document.getElementById('maf-rev-city') as HTMLElement).textContent = city || '—';
      (document.getElementById('maf-rev-state') as HTMLElement).textContent = state || '—';
      (document.getElementById('maf-rev-pin') as HTMLElement).textContent = pin || '—';

      // Submit button label
      submitLabel.textContent = variant === 'renew' ? 'Submit Renewal Request' : 'Submit Application';
    }

    // ── Validation ────────────────────────────────────────────────────────
    function showError(fieldId: string, msg: string) {
      const el = document.getElementById(fieldId);
      if (!el) return;
      el.textContent = '⚠ ' + msg;
      el.style.display = 'flex';
      const input = document.getElementById(fieldId.replace('maf-err-', 'maf-'));
      if (input) input.classList.add('has-error');
    }
    function clearErrors() {
      document.querySelectorAll<HTMLElement>('.maf-field__error').forEach(e => { e.style.display = 'none'; e.textContent = ''; });
      document.querySelectorAll<HTMLElement>('.maf-input').forEach(e => e.classList.remove('has-error'));
    }

    function validateStep1(): boolean {
      clearErrors();
      let valid = true;
      const dob   = (document.getElementById('maf-dob') as HTMLInputElement).value;
      const gender= (document.getElementById('maf-gender') as HTMLSelectElement).value;
      const phone = (document.getElementById('maf-phone') as HTMLInputElement).value.trim();
      const addr1 = (document.getElementById('maf-addr1') as HTMLInputElement).value.trim();
      const city  = (document.getElementById('maf-city') as HTMLInputElement).value.trim();
      const state = (document.getElementById('maf-state') as HTMLInputElement).value.trim();
      const pin   = (document.getElementById('maf-pin') as HTMLInputElement).value.trim();

      if (!dob) { showError('maf-err-dob', 'Date of birth is required'); valid = false; }
      if (!gender) { showError('maf-err-gender', 'Please select a gender'); valid = false; }
      if (!phone) { showError('maf-err-phone', 'Phone number is required'); valid = false; }
      else if (!/^(\+91)?[6-9]\d{9}$/.test(phone.replace(/\s/g,''))) { showError('maf-err-phone', 'Enter a valid 10-digit Indian mobile number'); valid = false; }
      if (!addr1 || addr1.length < 5) { showError('maf-err-addr1', 'Address is required'); valid = false; }
      if (!city || city.length < 2) { showError('maf-err-city', 'City is required'); valid = false; }
      if (!state || state.length < 2) { showError('maf-err-state', 'State is required'); valid = false; }
      if (!pin) { showError('maf-err-pin', 'PIN code is required'); valid = false; }
      else if (!/^\d{6}$/.test(pin)) { showError('maf-err-pin', 'Enter a valid 6-digit PIN code'); valid = false; }

      return valid;
    }

    // ── T&C scroll detection ──────────────────────────────────────────────
    function checkTcScrolled() {
      const { scrollTop, clientHeight, scrollHeight } = tcPanel;
      if (!tcScrolled && scrollTop + clientHeight >= scrollHeight - 10) {
        tcScrolled = true;
        tcStatus.className = 'maf-tc-status maf-tc-status--read';
        tcStatusText.textContent = '✓ You have read the Terms and Conditions';
        cb1Wrap.classList.add('is-unlocked');
        cb1Btn.disabled = false;
      }
    }
    tcPanel.addEventListener('scroll', checkTcScrolled, { passive: true });

    // ── Checkbox logic ────────────────────────────────────────────────────
    cb1Btn.addEventListener('click', () => {
      if (cb1Btn.disabled) return;
      cb1Checked = !cb1Checked;
      cb1Btn.setAttribute('aria-checked', String(cb1Checked));
      updateNext2State();
    });
    cb2Btn.addEventListener('click', () => {
      cb2Checked = !cb2Checked;
      cb2Btn.setAttribute('aria-checked', String(cb2Checked));
      updateNext2State();
    });

    function updateNext2State() {
      const canProceed = cb1Checked && cb2Checked;
      btnNext2.disabled = !canProceed;
      if (canProceed) {
        btnNext2.classList.remove('btn--disabled');
      }
    }

    // ── Navigation ────────────────────────────────────────────────────────
    (document.getElementById('maf-btn-next1') as HTMLButtonElement).addEventListener('click', () => {
      if (validateStep1()) showStep(2);
    });
    (document.getElementById('maf-btn-back2') as HTMLButtonElement).addEventListener('click', () => showStep(1));
    (document.getElementById('maf-btn-next2') as HTMLButtonElement).addEventListener('click', () => {
      if (cb1Checked && cb2Checked) showStep(3);
    });
    (document.getElementById('maf-btn-back3') as HTMLButtonElement).addEventListener('click', () => showStep(2));

    // ── Submit ────────────────────────────────────────────────────────────
    submitBtn.addEventListener('click', async () => {
      submitBtn.disabled = true;
      submitLabel.style.opacity = '0.6';
      submitSpinner.style.display = 'inline';
      submitError.style.display = 'none';

      const dob   = (document.getElementById('maf-dob') as HTMLInputElement).value;
      const gender= (document.getElementById('maf-gender') as HTMLSelectElement).value;
      const phone = (document.getElementById('maf-phone') as HTMLInputElement).value.trim();
      const addr1 = (document.getElementById('maf-addr1') as HTMLInputElement).value.trim();
      const addr2 = (document.getElementById('maf-addr2') as HTMLInputElement).value.trim();
      const city  = (document.getElementById('maf-city') as HTMLInputElement).value.trim();
      const state = (document.getElementById('maf-state') as HTMLInputElement).value.trim();
      const pin   = (document.getElementById('maf-pin') as HTMLInputElement).value.trim();

      const endpoint = variant === 'renew' ? `${API}/hub/membership/renewal` : `${API}/hub/membership/application`;

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${token() ?? ''}`,
          },
          body: JSON.stringify({
            dateOfBirth: dob,
            gender,
            phone,
            addressLine1: addr1,
            addressLine2: addr2 || undefined,
            city,
            state,
            pinCode: pin,
            termsVersion: 'v1.0',
          }),
        });

        if (res.status === 409) {
          const err = await res.json().catch(() => ({})) as { message?: string };
          submitError.textContent = typeof err.message === 'string' ? err.message : 'A duplicate application already exists.';
          submitError.style.display = '';
          submitBtn.disabled = false;
          submitLabel.style.opacity = '';
          submitSpinner.style.display = 'none';
          return;
        }
        if (!res.ok) {
          const err = await res.json().catch(() => ({})) as { message?: string };
          submitError.textContent = typeof err.message === 'string' ? err.message : 'Submission failed. Please try again.';
          submitError.style.display = '';
          submitBtn.disabled = false;
          submitLabel.style.opacity = '';
          submitSpinner.style.display = 'none';
          return;
        }

        showSuccessScreen(prefill.email ?? '');
      } catch {
        submitError.textContent = 'A network error occurred. Please check your connection and try again.';
        submitError.style.display = '';
        submitBtn.disabled = false;
        submitLabel.style.opacity = '';
        submitSpinner.style.display = 'none';
      }
    });

    // ── Load prefill ──────────────────────────────────────────────────────
    async function loadPrefill() {
      const t = token();
      if (!t) {
        window.location.replace(`/auth/signin/?next=${encodeURIComponent(window.location.pathname)}`);
        return;
      }

      const endpoint = variant === 'renew'
        ? `${API}/hub/membership/renewal`
        : `${API}/hub/membership/application`;

      try {
        const res = await fetch(endpoint, {
          headers: { Authorization: `Bearer ${t}` },
        });

        if (res.status === 401) {
          window.location.replace(`/auth/signin/?next=${encodeURIComponent(window.location.pathname)}`);
          return;
        }
        if (res.status === 403) {
          window.location.replace('/hub/');
          return;
        }
        if (!res.ok) {
          window.location.replace('/hub/');
          return;
        }

        const data = await res.json() as Record<string, any>;

        // Variant A: check application status
        if (variant === 'apply') {
          if (data.applicationStatus === 'ACTIVE') {
            window.location.replace('/hub/');
            return;
          }
          if (data.applicationStatus === 'PENDING') {
            populateFields(data);
            showPendingScreen(data.submittedAt);
            return;
          }
        }

        // Variant B: check renewal eligibility
        if (variant === 'renew' && !data.renewalEligible) {
          window.location.replace('/hub/');
          return;
        }

        populateFields(data);
        if (variant === 'renew') prefillBanner.style.display = 'flex';
        showStep(1);
      } catch {
        window.location.replace('/hub/');
      }
    }

    loadPrefill();
  })();
</script>
