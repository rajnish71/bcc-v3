/* ── T&C panel ── */
.maf-tc-panel {
  height: 320px;
  overflow-y: scroll;
  background: var(--surface-1);
  border: 1px solid var(--hairline);
  border-radius: var(--r-2);
  padding: 28px 32px;
  margin-bottom: 14px;
  scroll-behavior: smooth;
}
@media (max-width: 600px) { .maf-tc-panel { height: 240px; padding: 20px 18px; } }
.maf-tc-content { font-family: Georgia, 'Times New Roman', serif; font-size: 14px; line-height: 1.9; color: var(--ink-700); }
.maf-tc-h4 { font-family: var(--font-display); font-size: 16px; font-weight: 700; color: var(--ink-900); margin-bottom: 10px; letter-spacing: -0.01em; }
.maf-tc-meta { font-family: var(--font-mono); font-size: 11px; color: var(--ink-400); margin-bottom: 20px; }
.maf-tc-h5 { font-family: var(--font-display); font-size: 14px; font-weight: 600; color: var(--ink-900); margin: 18px 0 6px; }
