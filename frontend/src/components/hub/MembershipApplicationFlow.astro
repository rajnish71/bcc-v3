  .maf-grid-2 { grid-template-columns: 1fr 1fr; }
  .maf-grid-3 { grid-template-columns: 1fr; }
}

/* ── Nav ── */
.maf-nav { display: flex; padding-top: 20px; border-top: 1px solid var(--hairline); margin-top: var(--s-2); }
.maf-nav--end { justify-content: flex-end; }
.maf-nav--between { justify-content: space-between; align-items: center; }
.maf-back-link { font-size: 14px; font-weight: 500; color: var(--ink-600); background: none; border: none; cursor: pointer; padding: 0; font-family: var(--font-body); }
