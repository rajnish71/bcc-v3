---
/**
 * FeaturedCategoryStories.astro — Journal §06 (conditional)
 * Context-sensitive 2×2 grid of featured articles.
 * ALL → mixed featured stories. Selected category → filtered.
 * Hidden entirely when stories array is empty (no DOM node, no placeholder).
 * "Featured" badge on image overlay.
 * Wireframe authority: V6 07 Journal Home §06.
 */

interface Story {
  slug: string;
  category: string;
  headline: string;
  deck: string;
  author: string;
  authorInitials: string;
  date: string;
  readTime: string;
  imageUrl?: string;
}

interface Props {
  stories: Story[];
  viewAllHref?: string;
}

const { stories, viewAllHref = '/journal/' } = Astro.props;
---

{stories.length > 0 && (
  <div class="fcs__grid" data-gsap="stagger">
    {stories.map((story) => (
      <a href={`/journal/${story.slug}/`} class="fcs__card">
        <div class="fcs__img-wrap" aria-hidden="true">
          {story.imageUrl
            ? <img src={story.imageUrl} alt={story.headline} class="fcs__img" loading="lazy" decoding="async" />
            : <div class="fcs__placeholder"></div>
          }
          <span class="fcs__badge">Featured</span>
        </div>
        <div class="fcs__body">
          <div class="fcs__kicker">
            <span class="fcs__kicker-line" aria-hidden="true"></span>
            {story.category}
          </div>
          <h3 class="fcs__headline">{story.headline}</h3>
          <p class="fcs__deck">{story.deck}</p>
          <footer class="fcs__footer">
            <div class="fcs__avatar" aria-hidden="true">
              <span class="fcs__avatar-initials">{story.authorInitials}</span>
            </div>
            <span class="fcs__author-name">{story.author}</span>
            <span class="fcs__sep" aria-hidden="true">·</span>
            <span class="fcs__meta">{story.date}</span>
            <span class="fcs__sep" aria-hidden="true">·</span>
            <span class="fcs__meta">{story.readTime} read</span>
          </footer>
        </div>
      </a>
    ))}
  </div>
)}

<style>
.fcs__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
}

.fcs__card {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  transition: box-shadow 0.15s;
}
.fcs__card:hover { box-shadow: 0 4px 16px rgba(20, 18, 16, 0.08); }

.fcs__img-wrap {
  height: 250px;
  flex-shrink: 0;
  overflow: hidden;
  position: relative;
}
.fcs__placeholder {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    135deg,
    #1A1816 0px, #1A1816 28px,
    #141210 28px, #141210 56px
  );
}
.fcs__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.fcs__badge {
  position: absolute;
  top: 14px;
  left: 16px;
  background: rgba(20, 18, 16, 0.65);
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--gold-light);
  text-transform: uppercase;
  letter-spacing: 0.14em;
  padding: 3px 8px;
  font-weight: 600;
}

.fcs__body {
  padding: 24px 28px;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.fcs__kicker {
  font-family: var(--font-mono);
  font-size: var(--text-micro);
  color: var(--gold-600);
  text-transform: uppercase;
  letter-spacing: 0.18em;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.fcs__kicker-line {
  display: block;
  width: 14px;
  height: 1px;
  background: var(--gold-600);
  flex-shrink: 0;
}

.fcs__headline {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 600;
  letter-spacing: -0.01em;
  line-height: 1.25;
  color: var(--ink-900);
  margin-bottom: 10px;
  text-wrap: pretty;
  flex: 1;
}

.fcs__deck {
  font-size: 13px;
  line-height: 1.7;
  color: var(--ink-600);
  margin-bottom: 18px;
}

.fcs__footer {
  display: flex;
  align-items: center;
  gap: 10px;
  padding-top: 14px;
  border-top: 1px solid var(--hairline-soft);
  flex-wrap: wrap;
}
.fcs__avatar {
  width: 26px;
  height: 26px;
  border-radius: var(--r-full);
  background: var(--forest-gradient);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.fcs__avatar-initials {
  font-family: var(--font-mono);
  font-size: 8px;
  color: #FFFFFF;
  font-weight: 500;
}
.fcs__author-name {
  font-size: 12px;
  font-weight: 500;
  color: var(--ink-700);
}
.fcs__sep { font-size: 12px; color: var(--ink-200); }
.fcs__meta { font-size: 12px; color: var(--ink-400); }

/* Responsive */
@media (max-width: 768px) {
  .fcs__grid { grid-template-columns: 1fr; }
}
</style>
