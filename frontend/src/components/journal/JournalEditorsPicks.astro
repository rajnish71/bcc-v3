---
/**
 * JournalEditorsPicks.astro — Journal §05 (Editor's Picks)
 * Three manually curated Editorial Cards. CMS editor_pick flag (future phase).
 * Independent of category selection — always shown.
 * 3-column equal grid, 24px gap.
 * Wireframe authority: V6 07 Journal Home §05.
 */

interface Pick {
  slug: string;
  category: string;
  headline: string;
  deck: string;
  author: string;
  authorInitials: string;
  date: string;
  readTime: string;
  imageUrl?: string;
}

interface Props {
  picks: Pick[];
}

const { picks } = Astro.props;
---

<div class="ep__grid" data-gsap="stagger">
  {picks.map((pick) => (
    <a href={`/journal/${pick.slug}/`} class="ep__card">
      <div class="ep__img-wrap" aria-hidden="true">
        {pick.imageUrl
          ? <img src={pick.imageUrl} alt={pick.headline} class="ep__img" loading="lazy" decoding="async" />
          : <div class="ep__placeholder"></div>
        }
      </div>
      <div class="ep__body">
        <div class="ep__kicker">
          <span class="ep__kicker-line" aria-hidden="true"></span>
          {pick.category}
        </div>
        <h3 class="ep__headline">{pick.headline}</h3>
        <p class="ep__deck">{pick.deck}</p>
        <footer class="ep__footer">
          <div class="ep__avatar" aria-hidden="true">
            <span class="ep__avatar-initials">{pick.authorInitials}</span>
          </div>
          <span class="ep__author-name">{pick.author}</span>
          <span class="ep__sep" aria-hidden="true">·</span>
          <span class="ep__meta">{pick.date}</span>
          <span class="ep__sep" aria-hidden="true">·</span>
          <span class="ep__meta">{pick.readTime} read</span>
        </footer>
      </div>
    </a>
  ))}
</div>

<style>
.ep__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.ep__card {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  transition: box-shadow 0.15s;
}
.ep__card:hover { box-shadow: 0 4px 16px rgba(20, 18, 16, 0.08); }

.ep__img-wrap {
  height: 210px;
  flex-shrink: 0;
  overflow: hidden;
  position: relative;
}
.ep__placeholder {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    135deg,
    #1A1816 0px, #1A1816 28px,
    #141210 28px, #141210 56px
  );
}
.ep__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.ep__body {
  padding: 24px 28px;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.ep__kicker {
  font-family: var(--font-mono);
  font-size: var(--text-micro);
  color: var(--gold-600);
  text-transform: uppercase;
  letter-spacing: 0.18em;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.ep__kicker-line {
  display: block;
  width: 14px;
  height: 1px;
  background: var(--gold-600);
  flex-shrink: 0;
}

.ep__headline {
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 600;
  letter-spacing: -0.01em;
  line-height: 1.3;
  color: var(--ink-900);
  margin-bottom: 10px;
  text-wrap: pretty;
  flex: 1;
}

.ep__deck {
  font-size: 13px;
  line-height: 1.7;
  color: var(--ink-600);
  margin-bottom: 18px;
}

.ep__footer {
  display: flex;
  align-items: center;
  gap: 10px;
  padding-top: 14px;
  border-top: 1px solid var(--hairline-soft);
  flex-wrap: wrap;
}
.ep__avatar {
  width: 26px;
  height: 26px;
  border-radius: var(--r-full);
  background: var(--forest-gradient);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ep__avatar-initials {
  font-family: var(--font-mono);
  font-size: 8px;
  color: #FFFFFF;
  font-weight: 500;
}
.ep__author-name {
  font-size: 12px;
  font-weight: 500;
  color: var(--ink-700);
}
.ep__sep { font-size: 12px; color: var(--ink-200); }
.ep__meta { font-size: 12px; color: var(--ink-400); }

/* Responsive */
@media (max-width: 900px) {
  .ep__grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .ep__grid { grid-template-columns: 1fr; }
}
</style>
