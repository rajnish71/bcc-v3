---
/**
 * Footer.astro — Canonical site footer
 * Surface: --surface-2 (recessed warm cream plate)
 * Structure: FIP badge + social strip → 4-column grid → copyright bar
 *
 * MEM-006 public domain: only Basic, Student, Individual appear in Membership link copy.
 */

const year = new Date().getFullYear();

const navigate = [
  { label: 'Home',        href: '/' },
  { label: 'About',       href: '/about/' },
  { label: 'Activities',  href: '/activities/' },
  { label: 'Showcase',    href: '/showcase/' },
  { label: 'Journal',     href: '/journal/' },
];

const explore = [
  { label: 'Photowalks',         href: '/activities/?type=photowalk' },
  { label: 'Workshops',          href: '/activities/?type=workshop' },
  { label: 'Exhibitions',        href: '/activities/?type=exhibition' },
  { label: 'Photography School', href: '#', disabled: true },
  { label: 'Photo Contests',     href: '#', disabled: true },
];

const guidelines = [
  { label: 'Privacy Policy',    href: '/privacy/' },
  { label: 'Terms of Use',      href: '/terms/' },
  { label: 'Code of Conduct',   href: '/conduct/' },
  { label: 'Membership',        href: '/join/' },
  { label: 'Contact Us',        href: '/contact/' },
];

type SocialIcon = 'ig' | 'fb' | 'fbg' | 'x' | 'yt';

const socials: Array<{ label: string; href: string; icon: SocialIcon }> = [
  { label: 'Instagram',      href: 'https://instagram.com/bhopalcameraclub', icon: 'ig'  },
  { label: 'Facebook Page',  href: 'https://facebook.com/bhopalcameraclub',  icon: 'fb'  },
  { label: 'Facebook Group', href: '#',                                       icon: 'fbg' },
  { label: 'X (Twitter)',    href: 'https://x.com/bhopalcameraclub',          icon: 'x'   },
  { label: 'YouTube',        href: '#',                                       icon: 'yt'  },
];
---

<footer class="footer" aria-label="Site footer">
  <div class="container">

    <!-- ── FIP strip + social ── -->
    <div class="footer-strip">

      <div class="fip-badge" aria-label="Federation of Indian Photography, Corporate Member CM 1098">
        <!-- FIP logo placeholder — replace with official badge image when available -->
        <div class="fip-logo" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
            <rect width="40" height="40" rx="2" fill="var(--surface-0)" stroke="var(--hairline)" stroke-width="1"/>
            <text x="20" y="14" text-anchor="middle" font-family="Outfit,sans-serif" font-size="8" font-weight="700" fill="var(--gold-600)">FIP</text>
            <text x="20" y="23" text-anchor="middle" font-family="Inter,sans-serif" font-size="5.5" fill="var(--ink-400)">INDIA</text>
            <text x="20" y="33" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="5" fill="var(--ink-400)">CM 1098</text>
          </svg>
        </div>
        <div class="fip-text">
          <div class="fip-title">Corporate Member</div>
          <div class="fip-sub">Federation of Indian Photography · CM 1098</div>
        </div>
      </div>

      <div class="social-row" aria-label="Social media links">
        {socials.map((s) => (
          <a href={s.href} class="social-btn" aria-label={s.label} target="_blank" rel="noopener noreferrer">
            {s.icon === 'ig' && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".5" fill="currentColor"/>
              </svg>
            )}
            {s.icon === 'fb' && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
              </svg>
            )}
            {s.icon === 'fbg' && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
              </svg>
            )}
            {s.icon === 'x' && (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            )}
            {s.icon === 'yt' && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.4a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58z"/>
                <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/>
              </svg>
            )}
          </a>
        ))}
      </div>

    </div>

    <!-- ── 4-column grid ── -->
    <div class="footer-grid">

      <!-- Brand column -->
      <div class="footer-col footer-col--brand">
        <img src="/images/bcc-logo-default.png" alt="Bhopal Camera Club" class="footer-logo" width="160" height="42" loading="lazy" />
        <p class="footer-tagline">
          Bhopal's photography community — bringing together photographers to learn, shoot, and exhibit since June 2016.
        </p>
        <div class="footer-established">Est. June 2016 · FIP CM 1098</div>
      </div>

      <!-- Navigate -->
      <div class="footer-col">
        <div class="footer-col-title">Navigate</div>
        <ul class="footer-links">
          {navigate.map(l => <li><a href={l.href} class="footer-link">{l.label}</a></li>)}
        </ul>
      </div>

      <!-- Explore -->
      <div class="footer-col">
        <div class="footer-col-title">Explore</div>
        <ul class="footer-links">
          {explore.map(l => (
            <li>
              {l.disabled
                ? <span class="footer-link footer-link--dim">{l.label}</span>
                : <a href={l.href} class="footer-link">{l.label}</a>
              }
            </li>
          ))}
        </ul>
      </div>

      <!-- Guidelines -->
      <div class="footer-col">
        <div class="footer-col-title">Guidelines</div>
        <ul class="footer-links">
          {guidelines.map(l => <li><a href={l.href} class="footer-link">{l.label}</a></li>)}
        </ul>
      </div>

    </div>

    <!-- ── Copyright bar ── -->
    <div class="footer-bar">
      <span>&copy; {year} Bhopal Camera Club. All rights reserved.</span>
      <span class="footer-mono">v3bcc.bhopal.info</span>
    </div>

  </div>
</footer>

<style>
.footer {
  background: var(--surface-2);
  border-top: 1px solid var(--hairline);
  margin-top: auto;
}

/* ── Strip ── */
.footer-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--s-3) 0;
  border-bottom: 1px solid var(--hairline);
  gap: var(--s-4);
}
.fip-badge { display: flex; align-items: center; gap: var(--s-2); }
.fip-logo { flex-shrink: 0; }
.fip-title { font-size: var(--text-label); font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-600); margin-bottom: 2px; }
.fip-sub   { font-size: 10px; color: var(--ink-600); font-family: var(--font-mono); letter-spacing: 0.04em; }

.social-row { display: flex; align-items: center; gap: var(--s-1); }
.social-btn {
  width: 32px; height: 32px;
  display: flex; align-items: center; justify-content: center;
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-radius: var(--r-1);
  color: var(--ink-600);
  text-decoration: none;
  transition: color var(--m-fast), border-color var(--m-fast);
}
.social-btn:hover { color: var(--ink-900); border-color: var(--hairline-strong); }

/* ── Grid ── */
.footer-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr 1fr;
  gap: var(--s-8);
  padding: var(--s-8) 0;
  border-bottom: 1px solid var(--hairline);
}
.footer-logo { height: 38px; width: auto; object-fit: contain; margin-bottom: var(--s-3); }
.footer-tagline { font-size: 13px; color: var(--ink-600); line-height: 1.7; margin-bottom: var(--s-2); }
.footer-established { font-family: var(--font-mono); font-size: 10px; color: var(--ink-600); letter-spacing: 0.06em; margin-bottom: var(--s-2); }

.brand-dots { display: flex; gap: 6px; margin-top: var(--s-2); }
.brand-dot { width: 10px; height: 10px; border-radius: var(--r-full); }

.footer-col-title {
  font-size: var(--text-label);
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-900);
  margin-bottom: var(--s-3);
}
.footer-links { list-style: none; display: flex; flex-direction: column; gap: var(--s-1); }
.footer-link  { font-size: 13px; color: var(--ink-600); text-decoration: none; transition: color var(--m-fast); }
.footer-link:hover { color: var(--ink-900); }
.footer-link--dim { color: var(--ink-400); opacity: 0.45; cursor: not-allowed; }

/* ── Bar ── */
.footer-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--s-3) 0;
  font-size: 11px;
  color: var(--ink-600);
  gap: var(--s-4);
}
.footer-mono { font-family: var(--font-mono); letter-spacing: 0.04em; }

/* ── Responsive ── */
@media (max-width: 900px) {
  .footer-grid { grid-template-columns: 1fr 1fr; gap: var(--s-6); }
  .footer-col--brand { grid-column: 1 / -1; }
}
@media (max-width: 600px) {
  .footer-grid { grid-template-columns: 1fr; }
  .footer-strip { flex-direction: column; align-items: flex-start; }
  .footer-bar { flex-direction: column; text-align: center; gap: var(--s-2); }
}
</style>
