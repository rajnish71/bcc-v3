---
/**
 * Footer.astro
 * Single shared footer — rendered identically on every page.
 * Structure: FIP trust badge + social strip → 4-column grid → copyright bar.
 *
 * Per MEM-006 public domain policy:
 * - "Membership Classes" footer link routes to /membership/
 * - That page describes ONLY Basic, Student, and Individual classes
 * - No constitutional class names (Full, Life, Patron, Founding) appear here
 */

const year = new Date().getFullYear();

const navigate = [
  { label: 'Home',          href: '/' },
  { label: 'About',         href: '/about/' },
  { label: 'Showcase',      href: '/showcase/' },
  { label: 'Photographers', href: '/photographers/' },
  { label: 'Events',        href: '/events/' },
  { label: 'Membership',    href: '/membership/' },
  { label: 'Journal',       href: '/journal/' },
];

const explore = [
  { label: 'Photowalks',          href: '/events/?type=photowalk' },
  { label: 'Workshops',           href: '/events/?type=workshop' },
  { label: 'Contests',            href: '#', disabled: true },
  { label: 'Exhibitions',         href: '#', disabled: true },
  { label: 'Photography School',  href: '#', disabled: true },
];

const guidelines = [
  { label: 'Privacy Policy',    href: '/privacy/' },
  { label: 'Terms of Use',      href: '/terms/' },
  { label: 'Code of Conduct',   href: '/conduct/' },
  { label: 'Membership Classes',href: '/membership/' },
  { label: 'Contact Us',        href: '/contact/' },
  { label: 'Partner with Us',   href: '/partner/' },
];

const socials = [
  { label: 'Instagram',      href: 'https://instagram.com/bhopalkameraclub', icon: 'ig'  },
  { label: 'Facebook Page',  href: 'https://facebook.com/bhopalkameraclub',  icon: 'fb'  },
  { label: 'Facebook Group', href: '#',                                       icon: 'fbg' },
  { label: 'X (Twitter)',    href: 'https://x.com/bhopalkameraclub',          icon: 'x'   },
  { label: 'YouTube',        href: '#',                                       icon: 'yt'  },
];
---

<footer class="footer" aria-label="Site footer">
  <div class="container">

    <!-- ── Trust + Social strip ── -->
    <div class="footer-strip">

      <!-- FIP Corporate Member badge -->
      <div class="fip-badge" aria-label="Federation of Indian Photography — Corporate Member CM 1098">
        <div class="fip-logo" aria-hidden="true">
          <!-- FIP logo placeholder — replace with actual FIP badge image -->
          <svg width="44" height="44" viewBox="0 0 44 44" fill="none">
            <rect width="44" height="44" rx="3" fill="rgba(255,255,255,0.05)" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
            <text x="22" y="16" text-anchor="middle" font-family="Outfit,sans-serif" font-size="9" font-weight="700" fill="#F5A82A">FIP</text>
            <text x="22" y="27" text-anchor="middle" font-family="Inter,sans-serif" font-size="6" fill="rgba(255,255,255,0.4)">INDIA</text>
            <text x="22" y="37" text-anchor="middle" font-family="Inter,sans-serif" font-size="5" fill="rgba(255,255,255,0.3)">CM 1098</text>
          </svg>
        </div>
        <div>
          <div class="fip-label">Corporate Member</div>
          <div class="fip-sub">Federation of Indian Photography · CM 1098</div>
        </div>
      </div>

      <!-- Social icons -->
      <div class="social-strip" aria-label="Social media links">
        {socials.map((s) => (
          <a
            href={s.href}
            class="social-icon"
            aria-label={s.label}
            target="_blank"
            rel="noopener noreferrer"
          >
            {s.icon === 'ig'  && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
              </svg>
            )}
            {s.icon === 'fb' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
              </svg>
            )}
            {s.icon === 'fbg' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
              </svg>
            )}
            {s.icon === 'x' && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            )}
            {s.icon === 'yt' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.4a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58z"/>
                <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/>
              </svg>
            )}
          </a>
        ))}
      </div>

    </div>

    <!-- ── 4-Column grid ── -->
    <div class="footer-grid">

      <!-- Col 1: Brand -->
      <div class="footer-col footer-col--brand">
        <div class="footer-brand">
          <svg width="24" height="24" viewBox="0 0 36 36" fill="none" aria-hidden="true">
            <circle cx="18" cy="18" r="16.5" stroke="#F5A82A" stroke-width="1.5"/>
            <circle cx="18" cy="18" r="3.5" fill="#F5A82A"/>
          </svg>
          <span class="footer-brand-name">Bhopal Camera Club</span>
        </div>
        <p class="footer-tagline">
          Bhopal's photography community — bringing together photographers to learn, shoot, and exhibit since June 2016.
        </p>
        <div class="footer-meta">Est. June 2016 · FIP CM 1098</div>
      </div>

      <!-- Col 2: Navigate -->
      <div class="footer-col">
        <div class="footer-col-title">Navigate</div>
        <ul class="footer-links">
          {navigate.map((l) => (
            <li><a href={l.href} class="footer-link">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Explore -->
      <div class="footer-col">
        <div class="footer-col-title">Explore</div>
        <ul class="footer-links">
          {explore.map((l) => (
            <li>
              {l.disabled
                ? <span class="footer-link footer-link--disabled">{l.label}</span>
                : <a href={l.href} class="footer-link">{l.label}</a>
              }
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Guidelines -->
      <div class="footer-col">
        <div class="footer-col-title">Guidelines</div>
        <ul class="footer-links">
          {guidelines.map((l) => (
            <li><a href={l.href} class="footer-link">{l.label}</a></li>
          ))}
        </ul>
      </div>

    </div>

    <!-- ── Copyright bar ── -->
    <div class="footer-bar">
      <span>&copy; {year} Bhopal Camera Club. All rights reserved.</span>
      <span>v3bcc.bhopal.info</span>
    </div>

  </div>
</footer>

<style>
.footer {
  background: var(--bg-2);
  border-top: 1px solid var(--border);
  margin-top: auto;
}

/* ── Strip ── */
.footer-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-6) 0;
  border-bottom: 1px solid var(--border);
  gap: var(--space-6);
}

.fip-badge {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}
.fip-logo { flex-shrink: 0; }
.fip-label {
  font-size: var(--text-xs);
  color: var(--text-3);
  font-weight: 500;
  margin-bottom: 2px;
}
.fip-sub  { font-size: 10px; color: var(--text-3); }

.social-strip {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}
.social-icon {
  width: 34px;
  height: 34px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text-3);
  transition: color 0.2s, border-color 0.2s, background 0.2s;
  text-decoration: none;
}
.social-icon:hover {
  color: var(--text-2);
  border-color: var(--border-md);
  background: rgba(255,255,255,0.06);
}

/* ── Grid ── */
.footer-grid {
  display: grid;
  grid-template-columns: 1.6fr 1fr 1fr 1fr;
  gap: var(--space-12);
  padding: var(--space-10) 0;
  border-bottom: 1px solid var(--border);
}

.footer-brand {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-bottom: var(--space-3);
}
.footer-brand-name {
  font-family: var(--font-display);
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--text-2);
}
.footer-tagline {
  font-size: var(--text-xs);
  color: var(--text-3);
  line-height: 1.7;
  margin-bottom: var(--space-3);
}
.footer-meta {
  font-size: 10px;
  color: var(--text-3);
  letter-spacing: 0.05em;
}

.footer-col-title {
  font-size: var(--text-label);
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-3);
  margin-bottom: var(--space-4);
}

.footer-links {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}
.footer-link {
  font-size: var(--text-xs);
  color: var(--text-3);
  text-decoration: none;
  transition: color 0.2s;
  display: inline-block;
}
.footer-link:hover { color: var(--text-2); }
.footer-link--disabled { color: var(--text-3); opacity: 0.5; cursor: not-allowed; }

/* ── Copyright bar ── */
.footer-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4) 0;
  font-size: 10px;
  color: var(--text-3);
  gap: var(--space-4);
}

/* ── Mobile ── */
@media (max-width: 900px) {
  .footer-grid {
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }
  .footer-col--brand {
    grid-column: 1 / -1;
  }
}
@media (max-width: 600px) {
  .footer-grid { grid-template-columns: 1fr; }
  .footer-strip { flex-direction: column; align-items: flex-start; gap: var(--space-4); }
  .footer-bar { flex-direction: column; text-align: center; gap: var(--space-2); }
}
</style>
