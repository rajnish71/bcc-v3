---
/**
 * Nav.astro — Main Navigation
 * Design system: BCC_V3_Design_System.md §13 (frozen)
 *
 * Desktop:
 *   Left:   BCC logo (full lockup — /images/bcc-logo-default.png)
 *   Centre: Home · About · Activities · Showcase · Journal
 *   Right (Guest):  "Sign In" [text link] + "Become a Member" [gold CTA]
 *   Right (Member): Avatar [forest-gradient] + Name + Bell + "Member Hub" [outline gold]
 *
 * Behaviour:
 *   - Rest height: 96px. Condenses to 64px after 80px scroll (GSAP header-condense).
 *   - Active link: 2px gold-500 underline.
 *   - Mobile: hamburger -> full-height drawer.
 *   - Auth state: defaults to Guest; client script swaps if bcc_user in localStorage.
 *
 * Token convention (established here):
 *   localStorage 'bcc_user'  = { displayName, initials, username }   -- set on sign-in
 *   localStorage 'bcc_token' = JWT access token string               -- set on sign-in
 *   Auth pages must write BOTH keys on successful authentication.
 *
 * MEM-006 P1 note: "Become a Member" -> /join -> that page explains the Register ->
 * Apply distinction. The nav CTA is the top-of-funnel entry point; it does not
 * collapse the two steps into one.
 */

import NotificationBell from '../ui/NotificationBell.astro';

const p = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? p === '/' : p === href || p.startsWith(href.replace(/\/$/, '') + '/');

const NAV_LINKS = [
  { label: 'Home',       href: '/' },
  { label: 'About',      href: '/about/' },
  { label: 'Activities', href: '/activities/' },
  { label: 'Showcase',   href: '/showcase/' },
  { label: 'Journal',    href: '/journal/' },
];
---

<header id="site-nav" class="nav" data-gsap="header-condense">
  <div class="nav-inner container">

    <!-- Logo -->
    <a href="/" class="nav-brand" aria-label="Bhopal Camera Club — Home">
      <img
        src="/brand/BCC New Logo Full Black Text.png"
        alt="Bhopal Camera Club"
        class="nav-logo"
        width="172"
        height="56"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Desktop nav links -->
    <nav class="nav-links" aria-label="Main navigation">
      <a href="/" class:list={['nav-link', isActive('/') && 'nav-link--active']} aria-current={isActive('/') ? 'page' : undefined}>Home</a>
      <a href="/about/" class:list={['nav-link', isActive('/about/') && 'nav-link--active']} aria-current={isActive('/about/') ? 'page' : undefined}>About</a>
      <a href="/showcase/" class:list={['nav-link', isActive('/showcase/') && 'nav-link--active']} aria-current={isActive('/showcase/') ? 'page' : undefined}>Showcase</a>

      <!-- Activities Dropdown -->
      <div class="nav-dropdown" id="nav-dropdown-activities">
        <button
          type="button"
          class:list={['nav-link', 'nav-dropdown-trigger', isActive('/activities/') && 'nav-link--active']}
          aria-haspopup="true"
          aria-expanded="false"
        >
          Activities <span class="nav-caret">▾</span>
        </button>
        <div class="nav-dropdown-panel" hidden>
          <div class="nav-dropdown-group">
            <a href="/activities/?type=photowalk" class="nav-dropdown-item">
              <span class="nav-dropdown-arrow">→</span>Photowalks
            </a>
            <a href="/activities/?type=workshop" class="nav-dropdown-item">
              <span class="nav-dropdown-arrow">→</span>Workshops
            </a>
            <a href="/activities/?type=meetup" class="nav-dropdown-item">
              <span class="nav-dropdown-arrow">→</span>Meetups
            </a>
            <div class="nav-dropdown-divider"></div>
            <div class="nav-dropdown-item nav-dropdown-item--disabled">
              <span>Contests</span>
              <span class="nav-dropdown-badge">COMING SOON</span>
            </div>
            <div class="nav-dropdown-item nav-dropdown-item--disabled">
              <span>Exhibitions</span>
              <span class="nav-dropdown-badge">COMING SOON</span>
            </div>
          </div>
          <div class="nav-dropdown-footer">
            Coming Soon items: opacity 0.45 · cursor:default · never hidden
          </div>
        </div>
      </div>

      <!-- Learn Dropdown -->
      <div class="nav-dropdown" id="nav-dropdown-learn">
        <button
          type="button"
          class="nav-link nav-dropdown-trigger nav-dropdown-trigger--disabled"
          aria-haspopup="true"
          aria-expanded="false"
        >
          Learn <span class="nav-caret">▾</span>
        </button>
        <div class="nav-dropdown-panel" hidden>
          <div class="nav-dropdown-group">
            <div class="nav-dropdown-item nav-dropdown-item--disabled">
              <span>Photography School</span>
              <span class="nav-dropdown-badge">COMING SOON</span>
            </div>
          </div>
          <div class="nav-dropdown-footer">
            Phase 4 · Entire Learn section Coming Soon · Greyed, non-interactive · Visible for awareness only
          </div>
        </div>
      </div>

      <a href="/journal/" class:list={['nav-link', isActive('/journal/') && 'nav-link--active']} aria-current={isActive('/journal/') ? 'page' : undefined} id="nav-link-journal">Journal</a>
      <a href="/hub/" class="nav-link nav-admin-link" id="nav-link-admin" hidden><span class="nav-admin-dot"></span>Admin</a>
    </nav>

    <!-- Zone 3: Right Rail -->
    <div class="nav-right">
      <!-- Right rail: auth CTAs -->
      <!--
        Default: Guest state (server-rendered).
        Client script swaps to Member state when bcc_user is found in localStorage.
        Primary gold CTA ("Become a Member") is the ONE gold CTA on this view.
      -->
      <div class="nav-auth" id="nav-auth">

        <!-- Guest state (default, server-rendered) -->
        <div id="nav-guest" class="nav-auth__guest">
          <a href="/auth/signin/" class="nav-signin">Sign In</a>
          <a href="/join/" class="btn btn-gold btn-md">Become a Member</a>
        </div>

        <!-- Member state (hidden until client confirms JWT) -->
        <div id="nav-member" class="nav-auth__member" hidden>
          <div class="nav-avatar-container" id="nav-avatar-dropdown">
            <button
              type="button"
              class="nav-avatar-trigger"
              id="nav-avatar-trigger"
              aria-haspopup="true"
              aria-expanded="false"
              aria-label="User menu"
            >
              <div class="nav-avatar avatar avatar-forest" id="nav-avatar">
                <span id="nav-initials">?</span>
              </div>
              <span class="nav-avatar-caret">▾</span>
            </button>
            <div class="nav-avatar-panel" id="nav-avatar-panel" hidden>
              <!-- Identity header -->
              <div class="nav-avatar-panel__head">
                <div class="nav-avatar avatar avatar-forest" id="nav-avatar-menu">
                  <span id="nav-initials-menu">?</span>
                </div>
                <div class="nav-avatar-panel__info">
                  <div class="nav-avatar-panel__name" id="nav-name-menu"></div>
                  <div class="nav-avatar-panel__role" id="nav-role-menu"></div>
                </div>
              </div>
              <!-- Menu items -->
              <div class="nav-avatar-panel__body">
                <!-- Admin Console -->
                <a href="/hub/" class="nav-avatar-panel__item nav-avatar-panel__item--admin" id="nav-menu-admin-console">
                  <span class="nav-avatar-panel__bullet">◆</span>Admin Console
                </a>
                <!-- Member Hub -->
                <a href="/hub/" class="nav-avatar-panel__item" id="nav-menu-member-hub">Member Hub</a>
                <!-- Profile -->
                <a href="/photographers/" class="nav-avatar-panel__item" id="nav-menu-profile">Profile</a>
                <!-- My Gallery -->
                <a href="/gallery/photographer/" class="nav-avatar-panel__item" id="nav-menu-gallery">My Gallery</a>
                <!-- Journal CMS -->
                <a href="/hub/" class="nav-avatar-panel__item nav-avatar-panel__item--editor" id="nav-menu-journal-cms">
                  <span class="nav-avatar-panel__bullet">✎</span>Journal CMS
                </a>
                <!-- Moderation Queue -->
                <a href="/hub/" class="nav-avatar-panel__item nav-avatar-panel__item--moderator" id="nav-menu-moderation-queue">
                  <span>Moderation Queue</span>
                  <span class="nav-avatar-panel__dot"></span>
                </a>
                <!-- Account Settings -->
                <a href="/hub/" class="nav-avatar-panel__item nav-avatar-panel__item--user" id="nav-menu-account-settings">Account Settings</a>
                <!-- Renewals -->
                <a href="/hub/membership/" class="nav-avatar-panel__item" id="nav-menu-renewals">Renewals</a>
              </div>
              <div class="nav-avatar-panel__divider"></div>
              <div class="nav-avatar-panel__footer">
                <button type="button" class="nav-avatar-panel__signout" id="nav-menu-signout">Sign Out</button>
              </div>
            </div>
          </div>

          <span class="nav-name" id="nav-name"></span>
          <NotificationBell />
          <a id="nav-profile-link" href="/photographers/" class="nav-profile-link" hidden>My Profile</a>
          <button id="nav-signout-btn" type="button" class="nav-profile-link">Sign Out</button>
          <a href="/hub/" class="btn btn-outline-gold btn-md" id="nav-hub-btn">Member Hub</a>
          <a href="/hub/membership/apply/" class="btn btn-outline-neutral btn-md" id="nav-apply-btn" hidden>Apply for Membership</a>
          <a href="/hub/" class="btn btn-dark btn-md" id="nav-admin-btn" hidden>Admin Console</a>
        </div>

        <!-- Mobile Right Rail Auth Elements (visible only on mobile breakpoint) -->
        <div class="nav-mobile-auth" id="nav-mobile-auth">
          <!-- Mobile Guest: Join Chip -->
          <a href="/join/" class="mobile-join-chip" id="mobile-join-chip" hidden>Join</a>

          <!-- Mobile Admin: Console Chip -->
          <span class="mobile-console-chip" id="mobile-console-chip" hidden>Console</span>

          <!-- Mobile Authenticated: Avatar -->
          <div class="nav-avatar avatar avatar-forest" id="nav-mobile-avatar" style="width:32px;height:32px;font-size:10px;" hidden>
            <span id="nav-mobile-initials">?</span>
          </div>
        </div>

      </div>

      <!-- Hamburger (mobile) -->
      <button
        class="nav-hamburger"
        id="nav-hamburger"
        aria-label="Open navigation"
        aria-expanded="false"
        aria-controls="nav-drawer"
      >
        <span class="ham-bar"></span>
        <span class="ham-bar"></span>
        <span class="ham-bar"></span>
      </button>
    </div>

  </div><!-- /nav-inner -->
</header>


<!-- ═══════════════════════════════════════════════════════════════
     MOBILE DRAWER
     ═══════════════════════════════════════════════════════════════ -->
<div
  id="nav-drawer"
  class="drawer"
  role="dialog"
  aria-label="Navigation menu"
  aria-hidden="true"
>
  <div class="drawer__overlay" id="drawer-overlay" aria-hidden="true"></div>

  <div class="drawer__panel">

    <div class="drawer__head">
      <a href="/" class="nav-brand">
        <img src="/brand/BCC New Logo Full Black Text.png" alt="Bhopal Camera Club" class="nav-logo nav-logo--sm" width="105" height="34" loading="lazy" />
      </a>
      <button class="drawer__close" id="drawer-close" aria-label="Close navigation">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M4 4l12 12M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <nav class="drawer__nav" aria-label="Mobile navigation">
      {NAV_LINKS.map(({ label, href }) => (
        <a
          href={href}
          class:list={['drawer__link', isActive(href) && 'drawer__link--active']}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
      <a href="/hub/" class="drawer__link drawer-admin-link" id="drawer-link-admin" hidden>
        <span class="drawer-admin-dot"></span>Admin
      </a>
    </nav>

    <div class="drawer__hairline" aria-hidden="true"></div>

    <!-- Mobile auth -->
    <div class="drawer__auth" id="drawer-auth">

      <div id="drawer-guest" class="drawer__auth-guest">
        <a href="/auth/signin/" class="btn btn-outline btn-lg" style="width:100%;justify-content:center;">Sign In</a>
        <a href="/join/" class="btn btn-gold btn-lg" style="width:100%;justify-content:center;margin-top:8px;">Become a Member</a>
      </div>

      <div id="drawer-member" class="drawer__auth-member" hidden>
        <!-- Identity strip -->
        <div class="drawer__identity" id="drawer-identity">
          <div class="nav-avatar avatar" id="drawer-avatar" style="width:36px;height:36px;font-size:11px;flex-shrink:0;">
            <span id="drawer-initials">?</span>
          </div>
          <div class="drawer__identity-info">
            <div class="drawer__identity-name" id="drawer-name"></div>
            <div class="drawer__identity-role" id="drawer-role"></div>
          </div>
        </div>

        <!-- Role Actions -->
        <div class="drawer__actions" id="drawer-actions">
          <a href="/photographers/" class="drawer__action-item" id="drawer-act-profile">Profile</a>
          <a href="/gallery/photographer/" class="drawer__action-item" id="drawer-act-gallery">My Gallery</a>
          <a href="/hub/" class="drawer__action-item" id="drawer-act-settings">Account Settings</a>
          <a href="/hub/membership/" class="drawer__action-item" id="drawer-act-renewals">Renewals</a>
        </div>

        <!-- CTA Buttons Area -->
        <div class="drawer__cta-area">
          <a href="/hub/" class="drawer__cta-btn" id="drawer-btn-hub">Member Hub</a>
          <a href="/hub/membership/apply/" class="drawer__cta-btn drawer__cta-btn--outline" id="drawer-btn-apply">Apply for Membership</a>
          <a href="/hub/" class="drawer__cta-btn drawer__cta-btn--admin" id="drawer-btn-admin">
            <span class="drawer__bullet">◆</span>Admin Console
          </a>
          <button id="drawer-signout-btn" type="button" class="drawer__signout-btn">Sign Out</button>
        </div>

        <!-- Notifications link in mobile drawer -->
        <a href="/hub/#notifications" class="drawer__notif-link" id="drawer-notif-link">
          <svg width="14" height="14" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M9 2a5.5 5.5 0 0 0-5.5 5.5v2.25L2 12h14l-1.5-2.25V7.5A5.5 5.5 0 0 0 9 2Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
            <path d="M7 12v.5a2 2 0 0 0 4 0V12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          Notifications
          <span class="drawer__notif-badge" id="drawer-notif-badge" hidden>0</span>
        </a>
      </div>

    </div>

  </div>
</div>


<style>
/* Nav shell */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: var(--nav-h);
  background: rgba(255, 255, 255, 0.97);
  border-bottom: 1px solid var(--hairline);
  z-index: 900;
  transition: height var(--m-med), background-color var(--m-med), border-color var(--m-med), box-shadow var(--m-med), backdrop-filter var(--m-med);
  will-change: height;
  backdrop-filter: none;
}
.nav--condensed {
  height: var(--nav-h-min);
  background-color: rgba(20, 18, 16, 0.92);
  border-bottom-color: transparent;
  box-shadow: 0 8px 32px rgba(20, 18, 16, 0.22);
  backdrop-filter: blur(14px) saturate(180%);
}

.nav-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 40px;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-right {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-shrink: 0;
}

/* Logo */
.nav-brand { display: flex; align-items: center; flex-shrink: 0; text-decoration: none; }
.nav-logo {
  height: 56px;
  width: auto;
  object-fit: contain;
  transition: height var(--m-med), filter var(--m-med);
}
.nav--condensed .nav-logo {
  height: 44px;
  filter: brightness(0) invert(1);
}
.nav-logo--sm {
  height: 34px;
}

/* Desktop nav links */
.nav-links {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24px;
}

.nav-link {
  display: inline-flex;
  align-items: center;
  padding: 6px 0;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  color: var(--ink-600);
  text-decoration: none;
  border-bottom: 2px solid transparent;
  transition: color var(--m-fast), border-color var(--m-fast);
  white-space: nowrap;
}
.nav-link:hover { color: var(--ink-900); }
.nav-link--active {
  color: var(--ink-900);
  border-bottom-color: #A8843C;
}
.nav--condensed .nav-link {
  color: #C8C0B8;
}
.nav--condensed .nav-link:hover {
  color: #FFFFFF;
}
.nav--condensed .nav-link--active {
  color: #FFFFFF;
}

/* Auth area */
.nav-auth { flex-shrink: 0; }
.nav-auth__guest { display: flex; align-items: center; gap: var(--s-2); }
.nav-auth__member { display: flex; align-items: center; gap: var(--s-2); }

.nav-profile-link {
  display: none !important;
}

.nav-signin {
  font-family: var(--font-body);
  font-size: var(--text-small);
  font-weight: 500;
  color: var(--ink-600);
  text-decoration: none;
  transition: color var(--m-fast);
  white-space: nowrap;
}
.nav-signin:hover { color: var(--gold-600); }

.nav-avatar {
  width: 32px;
  height: 32px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.02em;
}
.avatar-grey {
  background: #6B6460 !important;
  color: #FFFFFF !important;
}
.avatar-teal {
  background: #2A5A7A !important;
  color: #FFFFFF !important;
}
.avatar-amber {
  background: #8B5A2B !important;
  color: #FFFFFF !important;
}
.btn-outline-neutral {
  border: 1px solid var(--hairline-strong);
  color: var(--ink-600);
  background: transparent;
  padding: 11px 18px;
  border-radius: 2px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.03em;
  text-decoration: none;
  white-space: nowrap;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.btn-outline-neutral:hover {
  border-color: var(--ink-600);
  color: var(--ink-900);
}
/* Avatar Dropdown Panel CSS */
.nav-avatar-container {
  position: relative;
}
.nav-avatar-trigger {
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 7px;
}
.nav-avatar-caret {
  font-size: 10px;
  color: var(--ink-600);
  opacity: 0.6;
}
.nav--condensed .nav-avatar-caret {
  color: #C8C0B8 !important;
}
.nav--condensed .nav-avatar-trigger:hover .nav-avatar-caret {
  color: #FFFFFF !important;
}
.nav-avatar-panel {
  position: absolute;
  top: calc(100% + 12px);
  right: 0;
  background: #FFFFFF;
  border: 1px solid #E7E1D6;
  box-shadow: 0 8px 32px rgba(20,18,16,0.14);
  min-width: 210px;
  z-index: 300;
  text-align: left;
}
.nav-avatar-panel[hidden] {
  display: none !important;
}
.nav-avatar-panel__head {
  padding: 14px 18px;
  border-bottom: 1px solid #F0EBE0;
  display: flex;
  align-items: center;
  gap: 12px;
  background: #FAF8F4;
}
.nav-avatar-panel__info {
  display: flex;
  flex-direction: column;
}
.nav-avatar-panel__name {
  font-size: 13px;
  font-weight: 600;
  color: #141210;
  line-height: 1.3;
  font-family: var(--font-body);
}
.nav-avatar-panel__role {
  font-family: var(--font-mono);
  font-size: 10px;
  color: #8B8378;
  text-transform: capitalize;
}
.nav-avatar-panel__body {
  padding: 6px 0;
  display: flex;
  flex-direction: column;
}
.nav-avatar-panel__item {
  padding: 11px 18px;
  font-size: 13px;
  color: #141210;
  cursor: pointer;
  text-decoration: none;
  font-family: var(--font-body);
  transition: background-color var(--m-fast), color var(--m-fast);
  display: block;
  text-align: left;
}
.nav-avatar-panel__item:hover {
  background-color: var(--surface-1);
  color: var(--gold-600);
}
.nav-avatar-panel__item--admin {
  font-weight: 600;
  color: #C9A961;
  background: #141210;
  display: flex;
  align-items: center;
  gap: 10px;
}
.nav-avatar-panel__item--admin:hover {
  background: #2E2A24;
  color: #FFFFFF;
}
.nav-avatar-panel__item--editor {
  color: #2A5A7A;
  display: flex;
  align-items: center;
  gap: 8px;
}
.nav-avatar-panel__item--moderator {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.nav-avatar-panel__bullet {
  font-size: 10px;
  font-family: var(--font-mono);
}
.nav-avatar-panel__dot {
  width: 7px;
  height: 7px;
  border-radius: var(--r-full);
  background: #C9A961;
  display: inline-block;
}
.nav-avatar-panel__divider {
  height: 1px;
  background: #F0EBE0;
}
.nav-avatar-panel__footer {
  padding: 6px 0;
}
.nav-avatar-panel__signout {
  width: 100%;
  padding: 11px 18px;
  font-size: 13px;
  color: #8B8378;
  cursor: pointer;
  text-align: left;
  transition: background-color var(--m-fast), color var(--m-fast);
  font-family: var(--font-body);
  border: none;
  background: transparent;
  display: block;
}
.nav-avatar-panel__signout:hover {
  background-color: var(--surface-1);
  color: var(--ink-900);
}
.avatar-admin {
  background: #141210 !important;
  color: #C9A961 !important;
}
.btn-dark {
  background: #141210;
  color: #C9A961;
  border: 1px solid #141210;
  padding: 11px 18px;
  border-radius: 2px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.03em;
  text-decoration: none;
  white-space: nowrap;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: background var(--m-fast), color var(--m-fast);
}
.btn-dark:hover {
  background: #2E2A24;
  color: #FFFFFF;
}
.nav-admin-link {
  color: #C9A961 !important;
  font-weight: 600 !important;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.nav-admin-dot {
  width: 5px;
  height: 5px;
  border-radius: var(--r-full);
  background: #C9A961;
  display: inline-block;
}
.nav-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--ink-600);
  max-width: 120px;
