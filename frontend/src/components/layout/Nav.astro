            avatarEl.classList.add('avatar-forest');
          }
          if (hubBtn)   hubBtn.removeAttribute('hidden');
          if (applyBtn) applyBtn.setAttribute('hidden', '');
          if (adminBtn) adminBtn.setAttribute('hidden', '');
          if (journalLink) journalLink.textContent = 'Journal';
          if (adminLink)   adminLink.setAttribute('hidden', '');

          if (nrMenu) nrMenu.textContent = 'Member';
          if (menuAdminConsole)    menuAdminConsole.style.display = 'none';
          if (menuMemberHub)       menuMemberHub.style.display = 'block';
          if (menuProfile)         menuProfile.style.display = 'block';
          if (menuGallery)         menuGallery.style.display = 'block';
          if (menuJournalCms)      menuJournalCms.style.display = 'none';
          if (menuModeration)      menuModeration.style.display = 'none';
          if (menuAccountSettings) menuAccountSettings.style.display = 'none';
          if (menuRenewals)        menuRenewals.style.display = 'block';
        } else {
          // Configure Right Rail for default V3 state (behaving as MEMBER)
          if (avatarEl) {
            avatarEl.classList.remove('avatar-grey', 'avatar-teal', 'avatar-amber', 'avatar-admin');
            avatarEl.classList.add('avatar-forest');
          }
          if (hubBtn)   hubBtn.removeAttribute('hidden');
