        if (dg) dg.hidden = true;
        if (dm) dm.hidden = false;

        const drawerIdentity = document.getElementById('drawer-identity');
        const drawerAvatar = document.getElementById('drawer-avatar');
        const drawerInitials = document.getElementById('drawer-initials');
        const drawerName = document.getElementById('drawer-name');
        const drawerRole = document.getElementById('drawer-role');
        const drawerLinkAdmin = document.getElementById('drawer-link-admin');

        // Action menu links
        const actProfile = document.getElementById('drawer-act-profile');
        const actGallery = document.getElementById('drawer-act-gallery');
        const actSettings = document.getElementById('drawer-act-settings');
        const actRenewals = document.getElementById('drawer-act-renewals');

        // CTA buttons
        const btnHub = document.getElementById('drawer-btn-hub');
        const btnApply = document.getElementById('drawer-btn-apply');
        const btnAdmin = document.getElementById('drawer-btn-admin');

        if (drawerInitials) drawerInitials.textContent = initials;
        if (drawerName) drawerName.textContent = user.displayName;

        if (user.username) {
          if (actProfile) (actProfile as HTMLAnchorElement).href = `/photographers/${user.username}/`;
          if (actGallery) (actGallery as HTMLAnchorElement).href = `/gallery/photographer/${user.username}/`;
        }

        // Reset styling classes
        if (drawerIdentity) {
          drawerIdentity.className = 'drawer__identity';
        }
        if (drawerAvatar) {
          drawerAvatar.className = 'nav-avatar avatar';
        }

        if (portalState === 'USER') {
          if (drawerAvatar) drawerAvatar.classList.add('avatar-grey');
          if (drawerRole) drawerRole.textContent = 'User';

          if (actProfile)  actProfile.style.display = 'block';
          if (actGallery)  actGallery.style.display = 'none';
          if (actSettings) actSettings.style.display = 'block';
          if (actRenewals) actRenewals.style.display = 'none';

          if (btnHub)   btnHub.style.display = 'none';
          if (btnApply) btnApply.style.display = 'block';
          if (btnAdmin) btnAdmin.style.display = 'none';

          if (drawerLinkAdmin) drawerLinkAdmin.setAttribute('hidden', '');
        } else if (portalState === 'EDITOR') {
          if (drawerAvatar) drawerAvatar.classList.add('avatar-teal');
          if (drawerRole) drawerRole.textContent = 'Content Editor';

          if (actProfile)  actProfile.style.display = 'block';
          if (actGallery)  actGallery.style.display = 'block';
          if (actSettings) actSettings.style.display = 'none';
          if (actRenewals) actRenewals.style.display = 'block';

          if (btnHub)   btnHub.style.display = 'block';
          if (btnApply) btnApply.style.display = 'none';
          if (btnAdmin) btnAdmin.style.display = 'none';

          if (drawerLinkAdmin) drawerLinkAdmin.setAttribute('hidden', '');
        } else if (portalState === 'MODERATOR') {
          if (drawerAvatar) drawerAvatar.classList.add('avatar-amber');
          if (drawerRole) drawerRole.textContent = 'Moderator';

          if (actProfile)  actProfile.style.display = 'block';
          if (actGallery)  actGallery.style.display = 'block';
          if (actSettings) actSettings.style.display = 'none';
          if (actRenewals) actRenewals.style.display = 'block';

          if (btnHub)   btnHub.style.display = 'block';
          if (btnApply) btnApply.style.display = 'none';
          if (btnAdmin) btnAdmin.style.display = 'none';

          if (drawerLinkAdmin) drawerLinkAdmin.setAttribute('hidden', '');
        } else if (portalState === 'ADMIN') {
          if (drawerIdentity) drawerIdentity.classList.add('drawer__identity--admin');
          if (drawerAvatar) drawerAvatar.classList.add('avatar-admin');
          if (drawerRole) drawerRole.textContent = 'admin';

          if (actProfile)  actProfile.style.display = 'none';
          if (actGallery)  actGallery.style.display = 'none';
          if (actSettings) actSettings.style.display = 'none';
          if (actRenewals) actRenewals.style.display = 'none';

          if (btnHub)   btnHub.style.display = 'none';
          if (btnApply) btnApply.style.display = 'none';
          if (btnAdmin) btnAdmin.style.display = 'flex';

          if (drawerLinkAdmin) drawerLinkAdmin.removeAttribute('hidden');
        } else {
          // Default MEMBER state
          if (drawerAvatar) drawerAvatar.classList.add('avatar-forest');
          if (drawerRole) drawerRole.textContent = 'Active Member';

          if (actProfile)  actProfile.style.display = 'block';
          if (actGallery)  actGallery.style.display = 'block';
          if (actSettings) actSettings.style.display = 'none';
          if (actRenewals) actRenewals.style.display = 'block';

          if (btnHub)   btnHub.style.display = 'block';
          if (btnApply) btnApply.style.display = 'none';
          if (btnAdmin) btnAdmin.style.display = 'none';

          if (drawerLinkAdmin) drawerLinkAdmin.setAttribute('hidden', '');
        }

        // Mirror unread badge to mobile drawer (populated by NotificationBell script)
        const bellBadge   = document.getElementById('bell-badge');
        const drawerBadge = document.getElementById('drawer-notif-badge');
        if (bellBadge && drawerBadge) {
          const mirrorBadge = () => {
            const hidden = bellBadge.hidden;
            drawerBadge.hidden = hidden;
            if (!hidden) drawerBadge.textContent = bellBadge.textContent;
          };
          mirrorBadge();
          setInterval(mirrorBadge, 2000);
        }
      } else {
        showMobileGuest();
      }
    } else {
      showMobileGuest();
    }
  } catch {
    showMobileGuest();
  }

  function showMobileGuest() {
    const mobileJoin = document.getElementById('mobile-join-chip');
    const mobileAvatar = document.getElementById('nav-mobile-avatar');
    const mobileConsole = document.getElementById('mobile-console-chip');
    if (mobileJoin) mobileJoin.removeAttribute('hidden');
    if (mobileAvatar) mobileAvatar.setAttribute('hidden', '');
    if (mobileConsole) mobileConsole.setAttribute('hidden', '');

    const dg = document.getElementById('drawer-guest');
    const dm = document.getElementById('drawer-member');
    if (dg) dg.hidden = false;
    if (dm) dm.hidden = true;

    const drawerLinkAdmin = document.getElementById('drawer-link-admin');
    if (drawerLinkAdmin) drawerLinkAdmin.setAttribute('hidden', '');
  }

  /* -- Dropdowns toggle -- */
  const activitiesTrigger = document.querySelector('#nav-dropdown-activities .nav-dropdown-trigger');
  const activitiesPanel   = document.querySelector('#nav-dropdown-activities .nav-dropdown-panel');
  const learnTrigger      = document.querySelector('#nav-dropdown-learn .nav-dropdown-trigger');
  const learnPanel        = document.querySelector('#nav-dropdown-learn .nav-dropdown-panel');

  const toggleActivities = (open?: boolean) => {
    if (!activitiesTrigger || !activitiesPanel) return;
    const show = open ?? activitiesPanel.hasAttribute('hidden');
    if (show) {
      activitiesPanel.removeAttribute('hidden');
      activitiesTrigger.setAttribute('aria-expanded', 'true');
    } else {
      activitiesPanel.setAttribute('hidden', '');
      activitiesTrigger.setAttribute('aria-expanded', 'false');
    }
  };

  const toggleLearn = (open?: boolean) => {
    if (!learnTrigger || !learnPanel) return;
    const show = open ?? learnPanel.hasAttribute('hidden');
    if (show) {
      learnPanel.removeAttribute('hidden');
      learnTrigger.setAttribute('aria-expanded', 'true');
    } else {
      learnPanel.setAttribute('hidden', '');
      learnTrigger.setAttribute('aria-expanded', 'false');
    }
  };

  /* Avatar Dropdown panel toggle */
  const avatarTrigger = document.getElementById('nav-avatar-trigger');
  const avatarPanel   = document.getElementById('nav-avatar-panel');

  const toggleAvatarMenu = (open?: boolean) => {
    if (!avatarTrigger || !avatarPanel) return;
    const show = open ?? avatarPanel.hasAttribute('hidden');
    if (show) {
      avatarPanel.removeAttribute('hidden');
      avatarTrigger.setAttribute('aria-expanded', 'true');
    } else {
      avatarPanel.setAttribute('hidden', '');
      avatarTrigger.setAttribute('aria-expanded', 'false');
    }
  };

  if (activitiesTrigger && activitiesPanel) {
    activitiesTrigger.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleLearn(false);
      toggleAvatarMenu(false);
      toggleActivities();
    });
  }

  if (learnTrigger && learnPanel) {
    learnTrigger.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleActivities(false);
      toggleAvatarMenu(false);
      toggleLearn();
    });
  }

  if (avatarTrigger && avatarPanel) {
    avatarTrigger.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleActivities(false);
      toggleLearn(false);
      toggleAvatarMenu();
    });

    avatarPanel.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).tagName === 'A') {
        toggleAvatarMenu(false);
      }
    });
  }

  // Close on outside click
  document.addEventListener('click', () => {
    toggleActivities(false);
    toggleLearn(false);
    toggleAvatarMenu(false);
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      toggleActivities(false);
      toggleLearn(false);
      toggleAvatarMenu(false);
    }
  });

  /* -- Sign out handlers -- */
  document.getElementById('nav-signout-btn')?.addEventListener('click', logout);
  document.getElementById('drawer-signout-btn')?.addEventListener('click', logout);
  document.getElementById('nav-menu-signout')?.addEventListener('click', logout);
</script>
