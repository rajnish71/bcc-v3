---
/**
 * Nav.astro
 * Sticky navigation bar. Used on every page via BaseLayout.
 *
 * Behaviour:
 * - Desktop: transparent at top → glassmorphic dark after 60px scroll (GSAP ScrollTrigger)
 * - Desktop: dropdown menus on hover for Showcase, Activities, Learn
 * - Desktop: Sign In + Register when logged out; avatar + Member Hub when logged in
 * - Mobile: hamburger button → full-height slide-in drawer with accordion groups
 * - Learn nav item is greyed/disabled (Phase 4)
 * - Activities › Contests + Exhibitions are greyed with COMING SOON pill
 * - Auth state: defaults to logged-out; client script checks localStorage for JWT
 *
 * MEM-006 P1: Nav CTAs are Sign In + Register only. "Apply for Membership"
 * appears exclusively on /membership/ — never in the nav.
 */

const p = Astro.url.pathname;
const active = (href: string) =>
  href === '/' ? p === '/' : p === href || p.startsWith(href.replace(/\/$/, '') + '/');
---

<header id="main-nav" class="nav">
  <div class="nav-inner container-wide">

    <!-- ── Brand ── -->
    <a href="/" class="nav-brand" aria-label="Bhopal Camera Club — Home">
      <!-- Aperture iris logotype placeholder -->
      <svg class="nav-logo-svg" width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
        <circle cx="18" cy="18" r="16.5" stroke="#F5A82A" stroke-width="1.5"/>
        <circle cx="18" cy="18" r="9"    stroke="rgba(245,168,42,0.35)" stroke-width="1"/>
        <circle cx="18" cy="18" r="3.5"  fill="#F5A82A"/>
        <!-- Tick marks -->
        <line x1="18" y1="1.5" x2="18" y2="5"   stroke="#F5A82A" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="18" y1="31"  x2="18" y2="34.5" stroke="#F5A82A" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="1.5" y1="18" x2="5"   y2="18"  stroke="#F5A82A" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="31"  y1="18" x2="34.5" y2="18" stroke="#F5A82A" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <span class="nav-brand-name">Bhopal Camera Club</span>
    </a>

    <!-- ── Desktop nav links ── -->
    <nav class="nav-links" aria-label="Main">

      <a href="/" class:list={['nav-link', active('/') && 'nav-link--active']}>Home</a>

      <!-- Showcase dropdown -->
      <div class="nav-item" data-dropdown>
        <button class:list={['nav-link nav-link--trigger', (active('/showcase/') || active('/photographers/')) && 'nav-link--active']}
                aria-haspopup="true" aria-expanded="false">
          Showcase
          <svg class="nav-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
            <path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="dropdown" role="menu">
          <a href="/showcase/"      role="menuitem" class:list={['dropdown-item', active('/showcase/') && 'dropdown-item--active']}>Showcase</a>
          <a href="/photographers/" role="menuitem" class:list={['dropdown-item', active('/photographers/') && 'dropdown-item--active']}>Photographers</a>
        </div>
      </div>

      <!-- Activities dropdown -->
      <div class="nav-item" data-dropdown>
        <button class:list={['nav-link nav-link--trigger', active('/events/') && 'nav-link--active']}
                aria-haspopup="true" aria-expanded="false">
          Activities
          <svg class="nav-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
            <path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="dropdown" role="menu">
          <a href="/events/" role="menuitem" class:list={['dropdown-item', active('/events/') && 'dropdown-item--active']}>
            Events <span class="pill pill-live">Live</span>
          </a>
          <span class="dropdown-item dropdown-item--disabled" aria-disabled="true">
            Contests <span class="pill pill-soon">Coming Soon</span>
          </span>
          <span class="dropdown-item dropdown-item--disabled" aria-disabled="true">
            Exhibitions <span class="pill pill-soon">Coming Soon</span>
          </span>
        </div>
      </div>

      <!-- Learn — greyed, Phase 4 -->
      <div class="nav-item" data-dropdown>
        <button class="nav-link nav-link--trigger nav-link--disabled"
                aria-haspopup="true" aria-expanded="false" aria-disabled="true">
          Learn
          <svg class="nav-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
            <path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="nav-phase-badge">Phase 4</span>
        </button>
        <div class="dropdown" role="menu">
          <span class="dropdown-item dropdown-item--disabled" aria-disabled="true">
            Photography School <span class="pill pill-soon">Coming Soon</span>
          </span>
        </div>
      </div>

      <a href="/membership/" class:list={['nav-link', active('/membership/') && 'nav-link--active']}>Membership</a>
      <a href="/journal/"    class:list={['nav-link', active('/journal/')    && 'nav-link--active']}>Journal</a>

    </nav>

    <!-- ── Auth CTAs ── -->
    <!-- Rendered server-side as logged-out; client script swaps to logged-in if JWT found -->
    <div class="nav-auth" id="nav-auth">
      <!-- Logged-out state (default) -->
      <div id="nav-auth-out" class="nav-auth-out">
        <a href="/auth/signin/"    class="btn btn-ghost btn-sm">Sign In</a>
        <a href="/auth/register/"  class="btn btn-primary btn-sm">Register</a>
      </div>
      <!-- Logged-in state (hidden until client confirms auth) -->
      <div id="nav-auth-in" class="nav-auth-in" hidden>
        <div class="nav-user">
          <div class="nav-avatar" id="nav-avatar" aria-label="User avatar">
            <span id="nav-avatar-initials">?</span>
          </div>
          <span class="nav-display-name" id="nav-display-name"></span>
          <a href="/hub/" class="nav-hub-link">Member Hub</a>
        </div>
      </div>
    </div>

    <!-- ── Hamburger (mobile only) ── -->
    <button class="nav-hamburger" id="nav-hamburger"
            aria-label="Open navigation menu"
            aria-expanded="false"
            aria-controls="mobile-drawer">
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
    </button>

  </div><!-- /nav-inner -->
</header>


<!-- ══════════════════════════════════════════════════════
     MOBILE DRAWER
     Full-height slide-in overlay. Accordion sub-groups.
     ══════════════════════════════════════════════════════ -->
<div id="mobile-drawer" class="mobile-drawer" aria-hidden="true" role="dialog" aria-label="Navigation menu">

  <div class="drawer-overlay" id="drawer-overlay" aria-hidden="true"></div>

  <div class="drawer-panel" id="drawer-panel">

    <!-- Drawer header -->
    <div class="drawer-header">
      <a href="/" class="nav-brand">
        <svg width="28" height="28" viewBox="0 0 36 36" fill="none" aria-hidden="true">
          <circle cx="18" cy="18" r="16.5" stroke="#F5A82A" stroke-width="1.5"/>
          <circle cx="18" cy="18" r="3.5" fill="#F5A82A"/>
        </svg>
        <span class="nav-brand-name">Bhopal Camera Club</span>
      </a>
      <button class="drawer-close" id="drawer-close" aria-label="Close navigation menu">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M4 4l12 12M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- Drawer nav -->
    <nav class="drawer-nav" aria-label="Mobile navigation">

      <a href="/" class:list={['drawer-link', active('/') && 'drawer-link--active']}>Home</a>

      <!-- Showcase accordion (open by default — most visited) -->
      <div class="drawer-accordion" data-open="true">
        <button class="drawer-acc-trigger" aria-expanded="true">
          Showcase
          <svg class="drawer-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="drawer-acc-content">
          <a href="/showcase/"      class:list={['drawer-sub', active('/showcase/')      && 'drawer-sub--active']}>Showcase</a>
          <a href="/photographers/" class:list={['drawer-sub', active('/photographers/') && 'drawer-sub--active']}>Photographers</a>
        </div>
      </div>

      <!-- Activities accordion -->
      <div class="drawer-accordion">
        <button class="drawer-acc-trigger" aria-expanded="false">
          Activities
          <svg class="drawer-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="drawer-acc-content" hidden>
          <a href="/events/" class:list={['drawer-sub', active('/events/') && 'drawer-sub--active']}>
            Events <span class="pill pill-live">Live</span>
          </a>
          <span class="drawer-sub drawer-sub--disabled">Contests <span class="pill pill-soon">Coming Soon</span></span>
          <span class="drawer-sub drawer-sub--disabled">Exhibitions <span class="pill pill-soon">Coming Soon</span></span>
        </div>
      </div>

      <!-- Learn (disabled) -->
      <div class="drawer-accordion drawer-accordion--disabled">
        <button class="drawer-acc-trigger drawer-acc-trigger--disabled" aria-disabled="true">
          Learn
          <svg class="drawer-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <a href="/membership/" class:list={['drawer-link', active('/membership/') && 'drawer-link--active']}>Membership</a>
      <a href="/journal/"    class:list={['drawer-link', active('/journal/')    && 'drawer-link--active']}>Journal</a>

      <div class="drawer-divider"></div>

      <!-- Mobile auth -->
      <div id="drawer-auth">
        <div id="drawer-auth-out" class="drawer-auth-out">
          <a href="/auth/signin/"   class="btn btn-ghost">Sign In</a>
          <a href="/auth/register/" class="btn btn-primary">Register</a>
        </div>
        <div id="drawer-auth-in" class="drawer-auth-in" hidden>
          <div class="nav-user">
            <div class="nav-avatar">
              <span id="drawer-avatar-initials">?</span>
            </div>
            <div>
              <div class="nav-display-name" id="drawer-display-name"></div>
              <a href="/hub/" class="nav-hub-link">Member Hub →</a>
            </div>
          </div>
        </div>
      </div>

    </nav>
  </div>
</div>


<style>
/* ── Nav shell ── */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: var(--nav-h);
  z-index: 900;
  transition: background 0.3s ease, backdrop-filter 0.3s ease, box-shadow 0.3s ease;
  /* Transparent at top; JS adds .nav--scrolled after 60px */
}
.nav--scrolled {
  background: rgba(11,11,14,0.88);
  backdrop-filter: blur(18px) saturate(160%);
  -webkit-backdrop-filter: blur(18px) saturate(160%);
  box-shadow: 0 1px 0 0 rgba(255,255,255,0.06);
}

.nav-inner {
  height: 100%;
  display: flex;
  align-items: center;
  gap: var(--space-8);
}

/* ── Brand ── */
.nav-brand {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-shrink: 0;
  text-decoration: none;
}
.nav-logo-svg { flex-shrink: 0; }
.nav-brand-name {
  font-family: var(--font-display);
  font-size: 0.9375rem;
  font-weight: 700;
  color: var(--text);
  white-space: nowrap;
  letter-spacing: -0.01em;
}

/* ── Desktop nav links ── */
.nav-links {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-1);
}

.nav-link {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 6px 12px;
  font-size: var(--text-sm);
  color: var(--text-2);
  border: none;
  background: none;
  border-radius: var(--radius);
  cursor: pointer;
  transition: color 0.2s, background 0.2s;
  text-decoration: none;
  white-space: nowrap;
  font-family: var(--font-body);
  line-height: 1;
}
.nav-link:hover { color: var(--text); background: rgba(255,255,255,0.04); }
.nav-link--active { color: var(--text); font-weight: 500; }
.nav-link--disabled { color: var(--text-3); cursor: not-allowed; }
.nav-link--disabled:hover { background: none; color: var(--text-3); }

.nav-chevron {
  transition: transform 0.2s ease;
  color: var(--text-3);
}
.nav-item[data-dropdown]:hover .nav-chevron,
.nav-item[data-dropdown] .nav-link--trigger[aria-expanded="true"] .nav-chevron {
  transform: rotate(180deg);
}

.nav-phase-badge {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-3);
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--border);
  border-radius: var(--radius-full);
  padding: 2px 6px;
  margin-left: 2px;
}

/* ── Dropdown ── */
.nav-item { position: relative; }

.dropdown {
  position: absolute;
  top: calc(100% + 8px);
  left: 50%;
  transform: translateX(-50%);
  min-width: 180px;
  background: var(--surface);
  border: 1px solid var(--border-md);
  border-radius: var(--radius-md);
  padding: 6px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  opacity: 0;
  visibility: hidden;
  transform: translateX(-50%) translateY(-4px);
  transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
  pointer-events: none;
  z-index: 910;
}

.nav-item[data-dropdown]:hover .dropdown {
  opacity: 1;
  visibility: visible;
  transform: translateX(-50%) translateY(0);
  pointer-events: auto;
}

.dropdown-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-2);
  padding: 9px 12px;
  font-size: var(--text-sm);
  color: var(--text-2);
  border-radius: var(--radius);
  text-decoration: none;
  cursor: pointer;
  transition: color 0.15s, background 0.15s;
  white-space: nowrap;
}
.dropdown-item:hover,
.dropdown-item--active { color: var(--text); background: rgba(255,255,255,0.05); }
.dropdown-item--disabled {
  color: var(--text-3);
  cursor: not-allowed;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-2);
  padding: 9px 12px;
  font-size: var(--text-sm);
  border-radius: var(--radius);
}
.dropdown-item--disabled:hover { background: none; }

/* ── Auth area ── */
.nav-auth { flex-shrink: 0; }
.nav-auth-out { display: flex; align-items: center; gap: var(--space-2); }
.nav-auth-in  { display: flex; align-items: center; }

.nav-user {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}
.nav-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--amber-muted);
  border: 1.5px solid var(--border-amber);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--text-xs);
  font-weight: 700;
  color: var(--amber);
  flex-shrink: 0;
}
.nav-display-name {
  font-size: var(--text-sm);
  color: var(--text-2);
  max-width: 100px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.nav-hub-link {
  font-size: var(--text-sm);
  color: var(--cyan);
  font-weight: 500;
  transition: color 0.2s;
  text-decoration: none;
}
.nav-hub-link:hover { color: var(--cyan-dim); }

/* ── Hamburger ── */
.nav-hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5px;
  width: 40px;
  height: 40px;
  background: none;
  border: 1px solid var(--border-md);
  border-radius: var(--radius);
  cursor: pointer;
  flex-shrink: 0;
  padding: 0;
}
.ham-bar {
  display: block;
  width: 18px;
  height: 1.5px;
  background: var(--text-2);
  border-radius: 1px;
  transition: transform 0.2s, opacity 0.2s;
}

/* ── Mobile drawer ── */
.mobile-drawer {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 950;
}
.mobile-drawer[aria-hidden="false"] { display: block; }

.drawer-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  opacity: 0;
  transition: opacity 0.3s ease;
}
.mobile-drawer[aria-hidden="false"] .drawer-overlay { opacity: 1; }

.drawer-panel {
  position: absolute;
  top: 0; right: 0; bottom: 0;
  width: min(360px, 88vw);
  background: var(--surface);
  border-left: 1px solid var(--border-md);
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.32s cubic-bezier(0.22, 0.61, 0.36, 1);
  overflow-y: auto;
}
.mobile-drawer[aria-hidden="false"] .drawer-panel { transform: translateX(0); }

.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--space-4);
  height: var(--nav-h);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.drawer-close {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: 1px solid var(--border-md);
  border-radius: var(--radius);
  color: var(--text-2);
  cursor: pointer;
  transition: color 0.2s, border-color 0.2s;
}
.drawer-close:hover { color: var(--text); border-color: var(--border-strong); }

.drawer-nav {
  flex: 1;
  padding: var(--space-2) var(--space-4) var(--space-8);
  display: flex;
  flex-direction: column;
}

.drawer-link {
  display: block;
  padding: 13px 0;
  font-size: var(--text-base);
  color: var(--text-2);
  border-bottom: 1px solid var(--border);
  text-decoration: none;
  transition: color 0.15s;
}
.drawer-link:hover,
.drawer-link--active { color: var(--text); }

/* Accordion */
.drawer-accordion { border-bottom: 1px solid var(--border); }
.drawer-accordion--disabled { opacity: 0.4; pointer-events: none; }

.drawer-acc-trigger {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 13px 0;
  font-size: var(--text-base);
  color: var(--text-2);
  background: none;
  border: none;
  cursor: pointer;
  text-align: left;
  font-family: var(--font-body);
  transition: color 0.15s;
}
.drawer-acc-trigger:hover { color: var(--text); }
.drawer-acc-trigger--disabled { color: var(--text-3); cursor: not-allowed; }

.drawer-chevron {
  color: var(--text-3);
  transition: transform 0.2s ease;
  flex-shrink: 0;
}
.drawer-accordion[data-open="true"] .drawer-chevron { transform: rotate(180deg); }

.drawer-acc-content {
  background: rgba(255,255,255,0.02);
  margin: 0 calc(-1 * var(--space-4));
  padding: 2px var(--space-8);
}
.drawer-acc-content[hidden] { display: none; }

.drawer-sub {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: 10px 0;
  font-size: var(--text-sm);
  color: var(--text-2);
  text-decoration: none;
  border-bottom: 1px solid var(--border);
  transition: color 0.15s;
}
.drawer-sub:last-child { border-bottom: none; }
.drawer-sub:hover,
.drawer-sub--active { color: var(--text); }
.drawer-sub--disabled { color: var(--text-3); cursor: not-allowed; }

.drawer-divider {
  height: 1px;
  background: var(--border);
  margin: var(--space-5) 0;
}

.drawer-auth-out {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

/* ── Mobile breakpoint ── */
@media (max-width: 900px) {
  .nav-links, .nav-auth { display: none; }
  .nav-hamburger { display: flex; }
}
@media (max-width: 900px) {
  .mobile-drawer { display: block; } /* always in DOM; aria-hidden controls visibility */
}
</style>


<script>
  /**
   * Nav behaviours:
   * 1. GSAP ScrollTrigger — glassmorphic effect on scroll
   * 2. Desktop dropdown toggle (keyboard + mouse)
   * 3. Mobile hamburger / drawer
   * 4. Mobile accordion groups
   * 5. Auth state check (JWT in localStorage)
   */
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  /* ── 1. Scroll behaviour ── */
  const nav = document.getElementById('main-nav');
  if (nav) {
    ScrollTrigger.create({
      start: 'top -60px',
      onUpdate: (self) => {
        nav.classList.toggle('nav--scrolled', self.scroll() > 60);
      },
    });
  }

  /* ── 2. Desktop dropdowns ── */
  document.querySelectorAll<HTMLElement>('.nav-item[data-dropdown]').forEach((item) => {
    const trigger = item.querySelector<HTMLButtonElement>('.nav-link--trigger');
    const dropdown = item.querySelector<HTMLElement>('.dropdown');
    if (!trigger || !dropdown) return;

    const open  = () => trigger.setAttribute('aria-expanded', 'true');
    const close = () => trigger.setAttribute('aria-expanded', 'false');

    item.addEventListener('mouseenter', open);
    item.addEventListener('mouseleave', close);
    trigger.addEventListener('click', () => {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      isOpen ? close() : open();
    });
    // Close on Escape
    item.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  });

  /* ── 3. Mobile drawer ── */
  const hamburger   = document.getElementById('nav-hamburger');
  const drawer      = document.getElementById('mobile-drawer');
  const overlay     = document.getElementById('drawer-overlay');
  const drawerClose = document.getElementById('drawer-close');

  const openDrawer = () => {
    if (!drawer || !hamburger) return;
    drawer.setAttribute('aria-hidden', 'false');
    hamburger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    drawerClose?.focus();
  };
  const closeDrawer = () => {
    if (!drawer || !hamburger) return;
    drawer.setAttribute('aria-hidden', 'true');
    hamburger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    hamburger.focus();
  };

  hamburger?.addEventListener('click', openDrawer);
  drawerClose?.addEventListener('click', closeDrawer);
  overlay?.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer?.getAttribute('aria-hidden') === 'false') closeDrawer();
  });

  /* ── 4. Mobile accordion ── */
  document.querySelectorAll<HTMLElement>('.drawer-accordion:not(.drawer-accordion--disabled)').forEach((acc) => {
    const trigger = acc.querySelector<HTMLButtonElement>('.drawer-acc-trigger');
    const content = acc.querySelector<HTMLElement>('.drawer-acc-content');
    if (!trigger || !content) return;

    // Restore open state from data attribute (Showcase is open by default)
    const isOpen = acc.dataset.open === 'true';
    if (isOpen) { content.removeAttribute('hidden'); }
    else         { content.setAttribute('hidden', ''); trigger.setAttribute('aria-expanded', 'false'); }

    trigger.addEventListener('click', () => {
      const open = trigger.getAttribute('aria-expanded') !== 'false';
      if (open) {
        trigger.setAttribute('aria-expanded', 'false');
        content.setAttribute('hidden', '');
        acc.removeAttribute('data-open');
      } else {
        trigger.setAttribute('aria-expanded', 'true');
        content.removeAttribute('hidden');
        acc.dataset.open = 'true';
      }
    });
  });

  /* ── 5. Auth state ── */
  function updateAuthUI() {
    try {
      const raw = localStorage.getItem('bcc_user');
      if (!raw) return;
      const user = JSON.parse(raw) as { displayName?: string; initials?: string };
      if (!user?.displayName) return;

      const initials = user.initials || user.displayName.slice(0, 2).toUpperCase();

      // Desktop
      const authOut = document.getElementById('nav-auth-out');
      const authIn  = document.getElementById('nav-auth-in');
      if (authOut) authOut.hidden = true;
      if (authIn)  authIn.hidden  = false;
      const el = document.getElementById('nav-avatar-initials');
      if (el) el.textContent = initials;
      const name = document.getElementById('nav-display-name');
      if (name) name.textContent = user.displayName;

      // Mobile drawer
      const dOut = document.getElementById('drawer-auth-out');
      const dIn  = document.getElementById('drawer-auth-in');
      if (dOut) dOut.hidden = true;
      if (dIn)  dIn.hidden  = false;
      const di = document.getElementById('drawer-avatar-initials');
      if (di) di.textContent = initials;
      const dn = document.getElementById('drawer-display-name');
      if (dn) dn.textContent = user.displayName;
    } catch {
      // Malformed localStorage — stay logged-out
    }
  }

  updateAuthUI();
</script>
