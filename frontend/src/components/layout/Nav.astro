        }

        // Mobile Header Auth State Synchronization
        const mobileAvatar = document.getElementById('nav-mobile-avatar');
        const mobileInitials = document.getElementById('nav-mobile-initials');
        const mobileConsole = document.getElementById('mobile-console-chip');
        const mobileJoin = document.getElementById('mobile-join-chip');

