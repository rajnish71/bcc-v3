<script>
  import { logout } from '../../lib/auth';

  /**
   * Nav scripts:
   * 1. GSAP header-condense (96px -> 64px after 80px scroll)
   * 2. Mobile drawer toggle + overlay close + escape key
   * 3. Auth state from localStorage (bcc_user + bcc_token)
   */
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  /* 1. Header condense */
  const nav = document.getElementById('site-nav');
  if (nav) {
    ScrollTrigger.create({
      start: 'top -60px',
      onUpdate: (self) => {
        nav.classList.toggle('nav--condensed', self.scroll() > 60);
      },
    });
  }

  /* 2. Mobile drawer */
  const hamburger   = document.getElementById('nav-hamburger');
  const drawer      = document.getElementById('nav-drawer');
  const overlay     = document.getElementById('drawer-overlay');
  const closeBtn    = document.getElementById('drawer-close');

  const openDrawer = () => {
    drawer?.setAttribute('aria-hidden', 'false');
    hamburger?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  };
  const closeDrawer = () => {
    drawer?.setAttribute('aria-hidden', 'true');
    hamburger?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    hamburger?.focus();
  };

  hamburger?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  overlay?.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer?.getAttribute('aria-hidden') === 'false') closeDrawer();
  });

  /* 3. Auth state */
  try {
    const raw = localStorage.getItem('bcc_user');
    if (raw) {
      const user = JSON.parse(raw) as {
        displayName?: string;
        initials?: string;
        username?: string;
        ui?: { portalState: string };
      };
      if (user?.displayName) {
        const initials = user.initials || user.displayName.slice(0, 2).toUpperCase();
        const portalState = user.ui?.portalState || 'MEMBER';

        // Desktop
        const guest  = document.getElementById('nav-guest');
        const member = document.getElementById('nav-member');
        if (guest)  guest.hidden  = true;
        if (member) member.hidden = false;
        const ni = document.getElementById('nav-initials');
        if (ni) ni.textContent = initials;
        const nn = document.getElementById('nav-name');
        if (nn) nn.textContent = user.displayName;

        const avatarEl = document.getElementById('nav-avatar');
        const hubBtn   = document.getElementById('nav-hub-btn');
        const applyBtn = document.getElementById('nav-apply-btn');
        const adminBtn = document.getElementById('nav-admin-btn');

        const journalLink = document.getElementById('nav-link-journal');
        const adminLink   = document.getElementById('nav-link-admin');

        // Avatar menu items
        const avatarMenuEl = document.getElementById('nav-avatar-menu');
        const niMenu       = document.getElementById('nav-initials-menu');
        const nnMenu       = document.getElementById('nav-name-menu');
        const nrMenu       = document.getElementById('nav-role-menu');

        const menuAdminConsole   = document.getElementById('nav-menu-admin-console');
        const menuMemberHub      = document.getElementById('nav-menu-member-hub');
        const menuProfile        = document.getElementById('nav-menu-profile');
        const menuGallery        = document.getElementById('nav-menu-gallery');
        const menuJournalCms     = document.getElementById('nav-menu-journal-cms');
        const menuModeration     = document.getElementById('nav-menu-moderation-queue');
        const menuAccountSettings = document.getElementById('nav-menu-account-settings');
        const menuRenewals       = document.getElementById('nav-menu-renewals');

        if (niMenu) niMenu.textContent = initials;
        if (nnMenu) nnMenu.textContent = user.displayName;

        if (avatarMenuEl) {
          avatarMenuEl.className = 'nav-avatar avatar';
          if (portalState === 'USER') {
            avatarMenuEl.classList.add('avatar-grey');
          } else if (portalState === 'EDITOR') {
            avatarMenuEl.classList.add('avatar-teal');
          } else if (portalState === 'MODERATOR') {
            avatarMenuEl.classList.add('avatar-amber');
          } else if (portalState === 'ADMIN') {
            avatarMenuEl.classList.add('avatar-admin');
          } else {
            avatarMenuEl.classList.add('avatar-forest');
          }
        }

        if (user.username) {
          if (menuProfile) (menuProfile as HTMLAnchorElement).href = `/photographers/${user.username}/`;
          if (menuGallery) (menuGallery as HTMLAnchorElement).href = `/gallery/photographer/${user.username}/`;
        }

        if (portalState === 'USER') {
          // Configure Right Rail for USER state
          if (avatarEl) {
            avatarEl.classList.remove('avatar-forest', 'avatar-teal', 'avatar-amber', 'avatar-admin');
            avatarEl.classList.add('avatar-grey');
          }
          if (hubBtn)   hubBtn.setAttribute('hidden', '');
          if (applyBtn) applyBtn.removeAttribute('hidden');
          if (adminBtn) adminBtn.setAttribute('hidden', '');
          if (journalLink) journalLink.textContent = 'Journal';
          if (adminLink)   adminLink.setAttribute('hidden', '');

          if (nrMenu) nrMenu.textContent = 'User';
          if (menuAdminConsole)    menuAdminConsole.style.display = 'none';
          if (menuMemberHub)       menuMemberHub.style.display = 'none';
          if (menuProfile)         menuProfile.style.display = 'block';
          if (menuGallery)         menuGallery.style.display = 'none';
          if (menuJournalCms)      menuJournalCms.style.display = 'none';
          if (menuModeration)      menuModeration.style.display = 'none';
          if (menuAccountSettings) menuAccountSettings.style.display = 'block';
          if (menuRenewals)        menuRenewals.style.display = 'none';
        } else if (portalState === 'EDITOR') {
          // Configure Right Rail for EDITOR state
          if (avatarEl) {
            avatarEl.classList.remove('avatar-forest', 'avatar-grey', 'avatar-amber', 'avatar-admin');
            avatarEl.classList.add('avatar-teal');
          }
          if (hubBtn)   hubBtn.removeAttribute('hidden');
          if (applyBtn) applyBtn.setAttribute('hidden', '');
          if (adminBtn) adminBtn.setAttribute('hidden', '');
          if (journalLink) journalLink.textContent = 'Journal ✎';
          if (adminLink)   adminLink.setAttribute('hidden', '');

          if (nrMenu) nrMenu.textContent = 'Content Editor';
          if (menuAdminConsole)    menuAdminConsole.style.display = 'none';
          if (menuMemberHub)       menuMemberHub.style.display = 'block';
          if (menuProfile)         menuProfile.style.display = 'block';
          if (menuGallery)         menuGallery.style.display = 'block';
          if (menuJournalCms)      menuJournalCms.style.display = 'flex';
          if (menuModeration)      menuModeration.style.display = 'none';
          if (menuAccountSettings) menuAccountSettings.style.display = 'none';
          if (menuRenewals)        menuRenewals.style.display = 'block';
        } else if (portalState === 'MODERATOR') {
          // Configure Right Rail for MODERATOR state
          if (avatarEl) {
            avatarEl.classList.remove('avatar-forest', 'avatar-grey', 'avatar-teal', 'avatar-admin');
            avatarEl.classList.add('avatar-amber');
          }
          if (hubBtn)   hubBtn.removeAttribute('hidden');
          if (applyBtn) applyBtn.setAttribute('hidden', '');
          if (adminBtn) adminBtn.setAttribute('hidden', '');
          if (journalLink) journalLink.textContent = 'Journal';
          if (adminLink)   adminLink.setAttribute('hidden', '');

          if (nrMenu) nrMenu.textContent = 'Moderator';
          if (menuAdminConsole)    menuAdminConsole.style.display = 'none';
          if (menuMemberHub)       menuMemberHub.style.display = 'block';
          if (menuProfile)         menuProfile.style.display = 'block';
          if (menuGallery)         menuGallery.style.display = 'block';
          if (menuJournalCms)      menuJournalCms.style.display = 'none';
          if (menuModeration)      menuModeration.style.display = 'flex';
          if (menuAccountSettings) menuAccountSettings.style.display = 'none';
          if (menuRenewals)        menuRenewals.style.display = 'block';
        } else if (portalState === 'ADMIN') {
          // Configure Right Rail for ADMIN state
          if (avatarEl) {
            avatarEl.classList.remove('avatar-forest', 'avatar-grey', 'avatar-teal', 'avatar-amber');
            avatarEl.classList.add('avatar-admin');
          }
          if (hubBtn)   hubBtn.setAttribute('hidden', '');
          if (applyBtn) applyBtn.setAttribute('hidden', '');
          if (adminBtn) adminBtn.removeAttribute('hidden');
