          if (menuProfile)         menuProfile.style.display = 'block';
          if (menuGallery)         menuGallery.style.display = 'block';
          if (menuJournalCms)      menuJournalCms.style.display = 'none';
          if (menuModeration)      menuModeration.style.display = 'none';
          if (menuAccountSettings) menuAccountSettings.style.display = 'none';
          if (menuRenewals)        menuRenewals.style.display = 'block';
        } else if (portalState === 'MEMBER') {
          // Configure Right Rail for MEMBER state
