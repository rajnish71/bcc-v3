---
/**
 * Nav.astro — Main Navigation
 * Design system: BCC_V3_Design_System.md §13 (frozen)
 *
 * Desktop:
 *   Left: BCC logo (full lockup — /images/bcc-logo-default.png)
 *   Centre: Home · About · Activities · Showcase · Journal
 *   Right (Guest):  "Sign In" [text link] + "Become a Member" [gold CTA]
 *   Right (Member): Avatar [forest-gradient] + "Member Hub" [outline gold]
 *
 * Behaviour:
 *   - Rest height: 96px. Condenses to 64px after 80px scroll (GSAP header-condense).
 *   - Active link: 2px gold-500 underline.
 *   - Mobile: hamburger → full-height drawer.
 *   - Auth state: defaults to Guest; client script swaps if bcc_user in localStorage.
 *
 * MEM-006 P1 note: "Become a Member" → /join — that page explains the Register →
 * Apply distinction. The nav CTA is the top-of-funnel entry point; it does not
 * collapse the two steps into one.
 */

const p = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? p === '/' : p === href || p.startsWith(href.replace(/\/$/, '') + '/');

const NAV_LINKS = [
  { label: 'Home',       href: '/' },
  { label: 'About',      href: '/about/' },
  { label: 'Activities', href: '/activities/' },
  { label: 'Showcase',   href: '/showcase/' },
  { label: 'Journal',    href: '/journal/' },
];
---

<header id="site-nav" class="nav" data-gsap="header-condense">
  <div class="nav-inner container">

    <!-- ── Logo ── -->
    <a href="/" class="nav-brand" aria-label="Bhopal Camera Club — Home">
      <!-- Full lockup: coloured aperture mark + wordmark in black -->
      <img
        src="/images/bcc-logo-default.png"
        alt="Bhopal Camera Club"
        class="nav-logo"
        width="180"
        height="48"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- ── Desktop nav links ── -->
    <nav class="nav-links" aria-label="Main navigation">
      {NAV_LINKS.map(({ label, href }) => (
        <a
          href={href}
          class:list={['nav-link', isActive(href) && 'nav-link--active']}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- ── Right rail: auth CTAs ── -->
    <!--
      Default: Guest state.
      Client script swaps to Member state if localStorage.bcc_user is present.
      Primary gold CTA ("Become a Member") is the ONE gold CTA on this view.
    -->
    <div class="nav-auth" id="nav-auth">

      <!-- Guest state (default, server-rendered) -->
      <div id="nav-guest" class="nav-auth__guest">
        <a href="/auth/signin/" class="nav-signin">Sign In</a>
        <a href="/join/" class="btn btn-gold btn-md">Become a Member</a>
      </div>

      <!-- Member state (hidden until client confirms JWT) -->
      <div id="nav-member" class="nav-auth__member" hidden>
        <div class="nav-avatar avatar avatar-forest" id="nav-avatar" aria-label="Your profile">
          <span id="nav-initials">?</span>
        </div>
        <span class="nav-name" id="nav-name"></span>
        <a href="/hub/" class="btn btn-outline-gold btn-md">Member Hub</a>
      </div>

    </div>

    <!-- ── Hamburger (mobile) ── -->
    <button
      class="nav-hamburger"
      id="nav-hamburger"
      aria-label="Open navigation"
      aria-expanded="false"
      aria-controls="nav-drawer"
    >
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
    </button>

  </div><!-- /nav-inner -->
</header>


<!-- ════════════════════════════════════════════════════════
     MOBILE DRAWER
     ════════════════════════════════════════════════════════ -->
<div
  id="nav-drawer"
  class="drawer"
  role="dialog"
  aria-label="Navigation menu"
  aria-hidden="true"
>
  <div class="drawer__overlay" id="drawer-overlay" aria-hidden="true"></div>

  <div class="drawer__panel">

    <div class="drawer__head">
      <a href="/" class="nav-brand">
        <img src="/images/bcc-logo-default.png" alt="Bhopal Camera Club" class="nav-logo nav-logo--sm" width="140" height="38" loading="lazy" />
      </a>
      <button class="drawer__close" id="drawer-close" aria-label="Close navigation">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M4 4l12 12M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <nav class="drawer__nav" aria-label="Mobile navigation">
      {NAV_LINKS.map(({ label, href }) => (
        <a
          href={href}
          class:list={['drawer__link', isActive(href) && 'drawer__link--active']}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
    </nav>

    <div class="drawer__hairline" aria-hidden="true"></div>

    <!-- Mobile auth -->
    <div class="drawer__auth" id="drawer-auth">

      <div id="drawer-guest" class="drawer__auth-guest">
        <a href="/auth/signin/" class="btn btn-outline btn-lg" style="width:100%;justify-content:center;">Sign In</a>
        <a href="/join/" class="btn btn-gold btn-lg" style="width:100%;justify-content:center;">Become a Member</a>
      </div>

      <div id="drawer-member" class="drawer__auth-member" hidden>
        <div class="drawer__member-row">
          <div class="nav-avatar avatar avatar-forest" style="width:40px;height:40px;font-size:15px;">
            <span id="drawer-initials">?</span>
          </div>
          <div>
            <div class="nav-name" id="drawer-name" style="font-size:14px;"></div>
            <a href="/hub/" style="font-size:12px;color:var(--gold-600);">Member Hub →</a>
          </div>
        </div>
      </div>

    </div>

  </div>
</div>


<style>
/* ── Nav shell ── */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: var(--nav-h);
  background: var(--surface-0);
  border-bottom: 1px solid var(--hairline);
  z-index: 900;
  transition: height var(--m-med), box-shadow var(--m-med);
  will-change: height;
}
/* Condensed state — added by GSAP after 80px scroll */
.nav--condensed {
  height: var(--nav-h-min);
  box-shadow: var(--e-2);
}

.nav-inner {
  height: 100%;
  display: flex;
  align-items: center;
  gap: var(--s-4);
}

/* ── Logo ── */
.nav-brand { display: flex; align-items: center; flex-shrink: 0; text-decoration: none; }
.nav-logo {
  height: 44px;        /* Rest state */
  width: auto;
  object-fit: contain;
  transition: height var(--m-med);
}
.nav--condensed .nav-logo { height: 36px; }
.nav-logo--sm { height: 36px; }

/* ── Desktop nav links ── */
.nav-links {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
}

.nav-link {
  display: inline-flex;
  align-items: center;
  padding: 6px 14px;
  font-family: var(--font-body);
  font-size: var(--text-small);
  font-weight: 500;
  color: var(--ink-600);
  text-decoration: none;
  border-bottom: 2px solid transparent;
  transition: color var(--m-fast), border-color var(--m-fast);
  white-space: nowrap;
}
.nav-link:hover { color: var(--ink-900); }
.nav-link--active {
  color: var(--ink-900);
  border-bottom-color: var(--gold-500);
}

/* ── Auth area ── */
.nav-auth { flex-shrink: 0; }
.nav-auth__guest { display: flex; align-items: center; gap: var(--s-2); }
.nav-auth__member { display: flex; align-items: center; gap: var(--s-2); }

.nav-signin {
  font-family: var(--font-body);
  font-size: var(--text-small);
  font-weight: 500;
  color: var(--ink-600);
  text-decoration: none;
  transition: color var(--m-fast);
  white-space: nowrap;
}
.nav-signin:hover { color: var(--gold-600); }

.nav-avatar {
  width: 32px;
  height: 32px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.02em;
}
.nav-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--ink-600);
  max-width: 120px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ── Hamburger ── */
.nav-hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5px;
  width: 40px;
  height: 40px;
  background: none;
  border: 1px solid var(--hairline-strong);
  border-radius: var(--r-1);
  cursor: pointer;
  flex-shrink: 0;
  padding: 0;
}
.ham-bar {
  display: block;
  width: 18px;
  height: 1.5px;
  background: var(--ink-600);
  border-radius: 1px;
}

/* ── Drawer ── */
.drawer {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 950;
}
.drawer[aria-hidden="false"] { display: block; }

.drawer__overlay {
  position: absolute;
  inset: 0;
  background: rgba(20,18,16,.4);
  opacity: 0;
  transition: opacity 0.3s ease;
}
.drawer[aria-hidden="false"] .drawer__overlay { opacity: 1; }

.drawer__panel {
  position: absolute;
  top: 0; right: 0; bottom: 0;
  width: min(360px, 88vw);
  background: var(--surface-0);
  border-left: 1px solid var(--hairline);
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.32s cubic-bezier(0.22, 0.61, 0.36, 1);
  overflow-y: auto;
}
.drawer[aria-hidden="false"] .drawer__panel { transform: translateX(0); }

.drawer__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--gutter-mob);
  height: var(--nav-h-min);
  border-bottom: 1px solid var(--hairline);
  flex-shrink: 0;
}

.drawer__close {
  width: 36px; height: 36px;
  display: flex; align-items: center; justify-content: center;
  background: none;
  border: 1px solid var(--hairline);
  border-radius: var(--r-1);
  color: var(--ink-400);
  cursor: pointer;
  transition: color var(--m-fast), border-color var(--m-fast);
}
.drawer__close:hover { color: var(--ink-900); border-color: var(--hairline-strong); }

.drawer__nav {
  flex: 1;
  padding: var(--s-1) var(--gutter-mob) var(--s-4);
  display: flex;
  flex-direction: column;
}
.drawer__link {
  display: block;
  padding: 14px 0;
  font-size: 16px;
  font-weight: 500;
  color: var(--ink-600);
  text-decoration: none;
  border-bottom: 1px solid var(--hairline-soft);
  transition: color var(--m-fast);
}
.drawer__link:hover,
.drawer__link--active { color: var(--ink-900); }
.drawer__link--active { font-weight: 600; }

.drawer__hairline { height: 1px; background: var(--hairline); margin: 0 var(--gutter-mob); }

.drawer__auth { padding: var(--s-3) var(--gutter-mob) var(--s-6); }
.drawer__auth-guest { display: flex; flex-direction: column; gap: var(--s-2); }

.drawer__member-row { display: flex; align-items: center; gap: var(--s-2); }

/* ── Mobile breakpoint ── */
@media (max-width: 900px) {
  .nav-links, .nav-auth { display: none; }
  .nav-hamburger { display: flex; }
  .drawer { display: block; } /* always in DOM; aria-hidden controls visibility */
}
</style>


<script>
  /**
   * Nav scripts:
   * 1. GSAP header-condense (96px → 64px after 80px scroll)
   * 2. Mobile drawer toggle + overlay close + escape key
   * 3. Auth state from localStorage
   */
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  /* ── 1. Header condense ── */
  const nav = document.getElementById('site-nav');
  if (nav) {
    ScrollTrigger.create({
      start: 'top -80px',
      onUpdate: (self) => {
        nav.classList.toggle('nav--condensed', self.scroll() > 80);
      },
    });
  }

  /* ── 2. Mobile drawer ── */
  const hamburger   = document.getElementById('nav-hamburger');
  const drawer      = document.getElementById('nav-drawer');
  const overlay     = document.getElementById('drawer-overlay');
  const closeBtn    = document.getElementById('drawer-close');

  const openDrawer = () => {
    drawer?.setAttribute('aria-hidden', 'false');
    hamburger?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  };
  const closeDrawer = () => {
    drawer?.setAttribute('aria-hidden', 'true');
    hamburger?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    hamburger?.focus();
  };

  hamburger?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  overlay?.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer?.getAttribute('aria-hidden') === 'false') closeDrawer();
  });

  /* ── 3. Auth state ── */
  try {
    const raw = localStorage.getItem('bcc_user');
    if (raw) {
      const user = JSON.parse(raw) as { displayName?: string; initials?: string };
      if (user?.displayName) {
        const initials = user.initials || user.displayName.slice(0, 2).toUpperCase();

        // Desktop
        const guest = document.getElementById('nav-guest');
        const member = document.getElementById('nav-member');
        if (guest) guest.hidden = true;
        if (member) member.hidden = false;
        const ni = document.getElementById('nav-initials');
        if (ni) ni.textContent = initials;
        const nn = document.getElementById('nav-name');
        if (nn) nn.textContent = user.displayName;

        // Mobile
        const dg = document.getElementById('drawer-guest');
        const dm = document.getElementById('drawer-member');
        if (dg) dg.hidden = true;
        if (dm) dm.hidden = false;
        const di = document.getElementById('drawer-initials');
        if (di) di.textContent = initials;
        const dn = document.getElementById('drawer-name');
        if (dn) dn.textContent = user.displayName;
      }
    }
  } catch { /* Stay in guest state */ }
</script>
