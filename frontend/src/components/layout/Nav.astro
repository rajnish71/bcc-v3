            mobileConsole.removeAttribute('hidden');
          } else {
            mobileConsole.setAttribute('hidden', '');
          }
        }

        // Inject "My Profile" link if username is known
        if (user.username) {
          const profileLink = document.getElementById('nav-profile-link');
