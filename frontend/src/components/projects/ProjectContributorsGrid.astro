---
/**
 * ProjectContributorsGrid.astro — Dynamic grid of all project contributors.
 * V6 40 §07 — Contributors Grid
 *
 * Fetches contributors from /api/v1/projects/contributors at runtime.
 * Random order on every page load.
 * Card design matches AboutLeadership — same portrait size, label row, name,
 * stat line, and profile link — for visual consistency across the platform.
 */
interface Props {
  projectTag: string;
  projectTitle: string;
}
const { projectTag, projectTitle } = Astro.props;
const containerId = `pcg-cards-${projectTag.replace(/[^a-z0-9]/gi, '-')}`;
---

<section
  class="pcg container"
  aria-label={`All contributors to ${projectTitle}`}
>
  <div class="pcg-header">
    <div class="pcg-eyebrow">Contributors</div>
    <h2 class="pcg-title">Contributors of our {projectTitle} Project</h2>
  </div>

  <div
    class="pcg-grid"
    id={containerId}
    data-project-tag={projectTag}
    data-gsap="stagger"
    aria-label={`Contributor profiles for ${projectTitle}`}
  >
    <!-- Skeleton cards — replaced by client script -->
    {Array.from({ length: 3 }).map(() => (
      <div class="pcg-card pcg-card--skel" aria-hidden="true">
        <div class="pcg-portrait-wrap pcg-portrait-wrap--skel"></div>
        <div class="pcg-skel pcg-skel--label"></div>
        <div class="pcg-skel pcg-skel--name"></div>
        <div class="pcg-skel pcg-skel--count"></div>
        <div class="pcg-skel pcg-skel--link"></div>
      </div>
    ))}
  </div>
</section>

<style>
/* ── Section wrapper ── */
.pcg {
  padding-top: var(--s-6);
}

/* ── Header (bordered box above grid, consistent with ProjectGallery) ── */
.pcg-header {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-bottom: none;
  padding: 28px 32px 22px;
}
.pcg-eyebrow {
  font-family: var(--font-mono);
  font-size: var(--text-label);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: 600;
  margin-bottom: 10px;
}
.pcg-title {
  font-family: var(--font-display);
  font-size: 26px;
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.1;
  color: var(--ink-900);
  margin: 0;
}

/* ── Card grid — border pattern matches AboutLeadership ── */
.pcg-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  background: var(--surface-0);
  /* Top + left borders from the container; right + bottom from each card */
  border-top: 1px solid var(--hairline);
  border-left: 1px solid var(--hairline);
}

/* ── Individual card — :global because cards are created by JS at runtime
   (Astro §4.4: runtime DOM nodes never receive the scoped data attribute) ── */
:global(.pcg-card) {
  padding: 40px 36px;
  border-right: 1px solid var(--hairline);
  border-bottom: 1px solid var(--hairline);
  background: var(--surface-0);
}

/* ── Portrait — :global for same reason ── */
:global(.pcg-portrait-wrap) {
  width: 88px;
  height: 88px;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 24px;
  flex-shrink: 0;
}
:global(.pcg-portrait) {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
:global(.pcg-portrait-placeholder) {
  width: 100%;
  height: 100%;
  background: var(--forest-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
}
:global(.pcg-initials) {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 700;
  color: #ffffff;
}

/* ── Card text ── */
:global(.pcg-label) {
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: 600;
  margin-bottom: 8px;
  font-family: var(--font-body);
}
:global(.pcg-name) {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 700;
  letter-spacing: -0.01em;
  margin-bottom: 6px;
  color: var(--ink-900);
}
:global(.pcg-count) {
  font-size: 12px;
  color: var(--ink-400);
  margin-bottom: 20px;
  font-family: var(--font-body);
}

/* ── Profile link ── */
:global(.pcg-profile-link) {
  font-size: 12px;
  font-weight: 600;
  color: var(--gold-600);
  letter-spacing: 0.04em;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  text-decoration: none;
  transition: color var(--m-fast);
}
:global(.pcg-profile-link:hover) {
  color: var(--gold-500);
}

/* ── Skeleton shimmer ── */
.pcg-card--skel { pointer-events: none; }
.pcg-portrait-wrap--skel {
  background: var(--surface-2);
  animation: skelShimmer 1.6s ease-in-out infinite;
}
.pcg-skel {
  background: var(--surface-2);
  border-radius: 2px;
  animation: skelShimmer 1.6s ease-in-out infinite;
  margin-bottom: 10px;
}
.pcg-skel--label { height: 9px;  width: 55%; }
.pcg-skel--name  { height: 14px; width: 72%; margin-bottom: 8px; }
.pcg-skel--count { height: 10px; width: 45%; margin-bottom: 20px; }
.pcg-skel--link  { height: 11px; width: 38%; }

/* ── Responsive ── */
@media (max-width: 900px) {
  .pcg-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media (max-width: 480px) {
  .pcg-grid {
    grid-template-columns: 1fr;
  }
  .pcg-header { padding: 20px var(--gutter-mob); }
  .pcg-title  { font-size: 20px; }
  :global(.pcg-card) { padding: 32px 28px; }
}
</style>

<script>
  document.querySelectorAll<HTMLElement>('.pcg-grid[data-project-tag]').forEach(gridEl => {
    const projectTag = gridEl.dataset.projectTag ?? '';

    function getInitials(name: string): string {
      return name.split(' ').slice(0, 2).map(w => w[0] ?? '').join('').toUpperCase();
    }

    async function load() {
      try {
        const res = await fetch(`/api/v1/projects/contributors?tag=${encodeURIComponent(projectTag)}`);
        if (!res.ok) throw new Error('API error');
        const { contributors } = await res.json();

        if (!contributors || contributors.length === 0) {
          gridEl.innerHTML = '';
          return;
        }

        gridEl.innerHTML = '';

        contributors.forEach((c: any) => {
          const card = document.createElement('div');
          card.className = 'pcg-card';
          card.style.cssText = 'opacity:0;transform:translateY(16px)';

          /* Portrait */
          const portraitWrap = document.createElement('div');
          portraitWrap.className = 'pcg-portrait-wrap';
          portraitWrap.setAttribute('aria-hidden', 'true');
          if (c.avatarUrl) {
            const img = document.createElement('img');
            img.src       = c.avatarUrl;
            img.alt       = c.name;
            img.className = 'pcg-portrait';
            img.loading   = 'lazy';
            img.decoding  = 'async';
            portraitWrap.appendChild(img);
          } else {
            const placeholder = document.createElement('div');
            placeholder.className = 'pcg-portrait-placeholder';
            const initials = document.createElement('span');
            initials.className = 'pcg-initials';
            initials.setAttribute('aria-hidden', 'true');
            initials.textContent = getInitials(c.name);
            placeholder.appendChild(initials);
            portraitWrap.appendChild(placeholder);
          }
          card.appendChild(portraitWrap);

          /* Label */
          const label = document.createElement('div');
          label.className   = 'pcg-label';
          label.textContent = 'Contributor';
          card.appendChild(label);

          /* Name */
          const name = document.createElement('h4');
          name.className   = 'pcg-name';
          name.textContent = c.name;
          card.appendChild(name);

          /* Photo count */
          const count = document.createElement('div');
          count.className   = 'pcg-count';
          count.textContent = `${c.photoCount} ${c.photoCount === 1 ? 'Photograph' : 'Photographs'}`;
          card.appendChild(count);

          /* Profile link */
          if (c.username) {
            const link = document.createElement('a');
            link.href      = `/photographers/${c.username}?genre=${encodeURIComponent(projectTag)}`;
            link.className = 'pcg-profile-link';
            link.setAttribute('aria-label', `View ${c.name}'s profile`);
            link.textContent = 'View Profile ';
            const arrow = document.createElement('span');
            arrow.setAttribute('aria-hidden', 'true');
            arrow.textContent = '→';
            link.appendChild(arrow);
            card.appendChild(link);
          }

          gridEl.appendChild(card);
        });

        /* Animate in — staggered fade+rise matching About page behaviour */
        const cards = Array.from(gridEl.querySelectorAll<HTMLElement>('.pcg-card'));
        cards.forEach((card, i) => {
          setTimeout(() => {
            card.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
            card.style.opacity    = '1';
            card.style.transform  = 'translateY(0)';
          }, i * 60);
        });

      } catch {
        /* Leave skeleton visible on error — silent failure */
      }
    }

    load();
  });
</script>
