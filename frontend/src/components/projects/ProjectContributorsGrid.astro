---
/**
 * ProjectContributorsGrid.astro — Dynamic grid of all project contributors.
 * V6 40 §07 — Contributors Grid (Amendment 001: fully dynamic)
 *
 * Fetches contributors from /api/v1/projects/contributors at runtime.
 * Random order on every page load.
 * Each card links to the photographer's profile filtered to the project tag.
 */
interface Props {
  projectTag: string;
  projectTitle: string;
}
const { projectTag, projectTitle } = Astro.props;
const containerId = `pcg-cards-${projectTag.replace(/[^a-z0-9]/gi, '-')}`;
---

<section
  class="pcg container"
  aria-label={`All contributors to ${projectTitle}`}
>
  <div class="pcg-header">
    <div class="pcg-eyebrow">Contributors</div>
    <h2 class="pcg-title">Contributors of our {projectTitle} Project</h2>
  </div>

  <div
    class="pcg-grid"
    id={containerId}
    data-project-tag={projectTag}
    data-gsap="stagger"
  >
    <!-- Skeleton cards — replaced by client script -->
    {Array.from({ length: 4 }).map(() => (
      <div class="pcg-card pcg-card--skel" aria-hidden="true">
        <div class="pcg-avatar pcg-avatar--skel"></div>
        <div class="pcg-info">
          <div class="pcg-skel-line pcg-skel-name"></div>
          <div class="pcg-skel-line pcg-skel-count"></div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
.pcg {
  padding-top: var(--s-6);
}
.pcg-header {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-bottom: none;
  padding: 28px 32px 22px;
}
.pcg-eyebrow {
  font-family: var(--font-mono);
  font-size: var(--text-label);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: 600;
  margin-bottom: 10px;
}
.pcg-title {
  font-family: var(--font-display);
  font-size: 26px;
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.1;
  color: var(--ink-900);
  margin: 0;
}
.pcg-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  border: 1px solid var(--hairline);
}
.pcg-card {
  background: var(--surface-0);
  padding: 18px 20px;
  border-right: 1px solid var(--hairline-soft);
  border-bottom: 1px solid var(--hairline-soft);
  display: flex;
  align-items: center;
  gap: 14px;
  text-decoration: none;
  color: inherit;
  transition: background var(--m-fast);
  min-width: 0;
}
.pcg-card:hover { background: var(--surface-1); }
.pcg-avatar {
  width: 40px;
  height: 40px;
  border-radius: var(--r-full);
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--forest-gradient);
}
.pcg-avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.pcg-avatar-initials {
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}
.pcg-info {
  flex: 1;
  min-width: 0;
}
.pcg-name {
  font-size: 13px;
  font-weight: 600;
  color: var(--ink-900);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 2px;
  line-height: 1.3;
}
.pcg-count {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--ink-400);
  letter-spacing: 0.02em;
}
.pcg-arrow {
  font-size: 10px;
  font-weight: 600;
  color: var(--gold-600);
  flex-shrink: 0;
  letter-spacing: 0.04em;
}

/* Skeleton state */
.pcg-card--skel { pointer-events: none; }
.pcg-avatar--skel {
  background: var(--surface-2);
  animation: pcg-shimmer 1.6s ease-in-out infinite;
}
.pcg-skel-line {
  background: var(--surface-2);
  border-radius: 2px;
  animation: pcg-shimmer 1.6s ease-in-out infinite;
}
.pcg-skel-name { height: 12px; width: 70%; margin-bottom: 6px; }
.pcg-skel-count { height: 9px; width: 40%; }
@keyframes pcg-shimmer { 0%,100% { opacity:.4; } 50% { opacity:.7; } }

@media (max-width: 1024px) {
  .pcg-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 480px) {
  .pcg-grid { grid-template-columns: repeat(2, 1fr); }
  .pcg-title { font-size: 20px; }
}
</style>

<script>
  document.querySelectorAll<HTMLElement>('.pcg-grid[data-project-tag]').forEach(gridEl => {
    const projectTag = gridEl.dataset.projectTag ?? '';

    function getInitials(name: string): string {
      return name.split(' ').slice(0, 2).map(w => w[0] ?? '').join('').toUpperCase();
    }

    async function load() {
      try {
        const res = await fetch(`/api/v1/projects/contributors?tag=${encodeURIComponent(projectTag)}`);
        if (!res.ok) throw new Error('API error');
        const { contributors } = await res.json();

        if (!contributors || contributors.length === 0) {
          gridEl.innerHTML = '';
          return;
        }

        gridEl.innerHTML = '';

        contributors.forEach((c: any) => {
          const card = document.createElement('a');
          card.href = c.username
            ? `/photographers/${c.username}?genre=${encodeURIComponent(projectTag)}`
            : '#';
          card.className = 'pcg-card';
          card.setAttribute('aria-label', `${c.name} — ${c.photoCount} photographs`);
          card.style.cssText = 'opacity:0;transform:translateY(16px)';

          // Avatar
          const avatarDiv = document.createElement('div');
          avatarDiv.className = 'pcg-avatar';
          if (c.avatarUrl) {
            const img = document.createElement('img');
            img.src = c.avatarUrl;
            img.alt = c.name;
            img.className = 'pcg-avatar-img';
            img.loading = 'lazy';
            img.decoding = 'async';
            avatarDiv.appendChild(img);
          } else {
            const initials = document.createElement('span');
            initials.className = 'pcg-avatar-initials';
            initials.setAttribute('aria-hidden', 'true');
            initials.textContent = getInitials(c.name);
            avatarDiv.appendChild(initials);
          }
          card.appendChild(avatarDiv);

          // Info
          const info = document.createElement('div');
          info.className = 'pcg-info';
          const name = document.createElement('div');
          name.className = 'pcg-name';
          name.textContent = c.name;
          const count = document.createElement('div');
          count.className = 'pcg-count';
          count.textContent = `${c.photoCount} photo${c.photoCount === 1 ? '' : 's'}`;
          info.appendChild(name);
          info.appendChild(count);
          card.appendChild(info);

          // Arrow
          const arrow = document.createElement('span');
          arrow.className = 'pcg-arrow';
          arrow.setAttribute('aria-hidden', 'true');
          arrow.textContent = 'View →';
          card.appendChild(arrow);

          gridEl.appendChild(card);
        });

        // Animate in
        const cards = Array.from(gridEl.querySelectorAll<HTMLElement>('.pcg-card'));
        cards.forEach((card, i) => {
          setTimeout(() => {
            card.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
            card.style.opacity = '1';
            card.style.transform = 'translateY(0)';
          }, i * 60);
        });

      } catch {
        // Leave skeleton on error — silent failure
      }
    }

    load();
  });
</script>
