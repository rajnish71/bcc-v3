---
/**
 * ProjectContributorsGrid.astro — Compact grid of all project contributors.
 * V6 40 §07 — Contributors Grid
 * 4-col desktop / 3-col tablet / 2-col mobile.
 * Each card links to the contributor's Photographer Profile.
 */
import type { ProjectContributor } from '../../data/projects';

interface Props {
  projectTitle: string;
  contributors: ProjectContributor[];
}
const { projectTitle, contributors } = Astro.props;
if (!contributors || contributors.length === 0) return;
---

<section
  class="pcg container"
  aria-label={`All contributors to ${projectTitle}`}
>
  <div class="pcg-header">
    <div class="pcg-eyebrow">Contributors</div>
    <h2 class="pcg-title">Contributors of our {projectTitle} Project</h2>
  </div>

  <div class="pcg-grid" data-gsap="stagger">
    {contributors.map(c => (
      <a
        href={`/photographers/${c.username}`}
        class="pcg-card"
        aria-label={`${c.name} — ${c.photoCount} photographs`}
        style="opacity:0;transform:translateY(16px)"
      >
        <div class="pcg-avatar">
          {c.avatar
            ? <img src={c.avatar} alt={c.name} class="pcg-avatar-img" loading="lazy" decoding="async" />
            : <span class="pcg-avatar-initials" aria-hidden="true">{c.initials}</span>
          }
        </div>
        <div class="pcg-info">
          <div class="pcg-name">{c.name}</div>
          <div class="pcg-count">{c.photoCount} photos</div>
        </div>
        <span class="pcg-arrow" aria-hidden="true">View →</span>
      </a>
    ))}
  </div>
</section>

<style>
.pcg {
  padding-top: var(--s-6);
}
.pcg-header {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-bottom: none;
  padding: 28px 32px 22px;
}
.pcg-eyebrow {
  font-family: var(--font-mono);
  font-size: var(--text-label);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: 600;
  margin-bottom: 10px;
}
.pcg-title {
  font-family: var(--font-display);
  font-size: 26px;
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.1;
  color: var(--ink-900);
  margin: 0;
}
.pcg-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  border: 1px solid var(--hairline);
}
.pcg-card {
  background: var(--surface-0);
  padding: 18px 20px;
  border-right: 1px solid var(--hairline-soft);
  border-bottom: 1px solid var(--hairline-soft);
  display: flex;
  align-items: center;
  gap: 14px;
  text-decoration: none;
  color: inherit;
  transition: background var(--m-fast);
  min-width: 0;
}
.pcg-card:hover { background: var(--surface-1); }
.pcg-avatar {
  width: 40px;
  height: 40px;
  border-radius: var(--r-full);
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--forest-gradient);
}
.pcg-avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.pcg-avatar-initials {
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}
.pcg-info {
  flex: 1;
  min-width: 0;
}
.pcg-name {
  font-size: 13px;
  font-weight: 600;
  color: var(--ink-900);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 2px;
  line-height: 1.3;
}
.pcg-count {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--ink-400);
  letter-spacing: 0.02em;
}
.pcg-arrow {
  font-size: 10px;
  font-weight: 600;
  color: var(--gold-600);
  flex-shrink: 0;
  letter-spacing: 0.04em;
}

@media (max-width: 1024px) {
  .pcg-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 480px) {
  .pcg-grid { grid-template-columns: repeat(2, 1fr); }
  .pcg-title { font-size: 20px; }
}
</style>
