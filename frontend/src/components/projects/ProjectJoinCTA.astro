---
/**
 * ProjectJoinCTA.astro — Auth-conditional join call to action.
 * V6 40 §10 — Join This Project
 * Always rendered. Content changes based on visitor auth/membership state.
 *
 * Guest   → "Become a Member" — gold gradient → /join
 * User    → "Apply for Membership" — dark button → /hub/membership/apply
 * Member  → "Upload a Photograph" — gold gradient → /hub/upload?project={slug}
 *
 * This is the single gold CTA on the page — no other gold CTAs elsewhere.
 */
import CTASection from '../ui/CTASection.astro';

interface Props {
  slug: string;
}
const { slug } = Astro.props;
---

<CTASection
  eyebrow="Join This Project"
  heading="Become a Member"
  body="Become a member of Bhopal Camera Club to contribute your photographs to this growing archive."
  headingId="pjcta-heading"
  bodyId="pjcta-desc"
  ariaLabel="Join this project"
>
  <a class="pjcta-btn" id="pjcta-btn" href="/join">Become a Member</a>
</CTASection>

<script define:vars={{ slug }}>
  (function () {
    var heading = document.getElementById('pjcta-heading');
    var desc    = document.getElementById('pjcta-desc');
    var btn     = document.getElementById('pjcta-btn');
    if (!heading || !desc || !btn) return;

    var userData = null;
    try { userData = JSON.parse(localStorage.getItem('bcc_user') || 'null'); } catch (e) {}

    var portalState = userData && userData.ui && userData.ui.portalState;

    if (!userData) {
      // Guest — default state, already in HTML
    } else if (portalState === 'MEMBER' || portalState === 'EDITOR' || portalState === 'MODERATOR' || portalState === 'ADMIN') {
      heading.textContent = 'Upload a Photograph';
      desc.textContent    = 'As an active member, contribute your photographs to this project from your Hub.';
      btn.textContent     = 'Upload a Photograph';
      btn.href            = '/hub/upload?project=' + slug;
    } else {
      heading.textContent = 'Apply for Membership';
      desc.textContent    = 'Complete your membership application to gain full contributor access to this project.';
      btn.textContent     = 'Apply for Membership';
      btn.href            = '/hub/membership/apply';
      btn.classList.add('pjcta-btn--dark');
    }
  })();
</script>

<style>
.pjcta-btn {
  display: inline-block;
  font-family: var(--font-body);
  font-size: var(--text-ui);
  font-weight: var(--weight-semibold);
  letter-spacing: var(--ls-badge);
  text-transform: uppercase;
  background: var(--gold-gradient);
  color: #FFFFFF;
  padding: var(--s-2) var(--s-6);
  border: 1px solid transparent;
  border-radius: var(--r-1);
  box-shadow: var(--e-cta);
  text-decoration: none;
  transition: opacity var(--m-fast);
  cursor: pointer;
}
.pjcta-btn:hover { opacity: 0.92; color: #FFFFFF; }

.pjcta-btn--dark {
  background: transparent;
  border-color: rgba(250, 248, 244, 0.25);
  box-shadow: none;
}
.pjcta-btn--dark:hover { border-color: rgba(250, 248, 244, 0.5); opacity: 1; }

@media (max-width: 480px) {
  .pjcta-btn { padding: 14px var(--s-4); }
}
</style>
