---
/**
 * ProjectPage.astro — Reusable compositor for all BCC Special Project pages.
 * V6 40 Special Projects design authority.
 * Route: /projects/{slug}
 *
 * Section order (fixed per spec):
 *   01 ProjectHero          — always
 *   02 ProjectStatBand      — always
 *   03 ProjectAbout         — conditional (hidden if about is empty)
 *   04 ProjectFeaturedContributors — conditional (hidden if no contributors)
 *   05 ProjectContributorsGrid    — conditional (hidden if no contributors)
 *   06 ProjectGallery       — always
 *   07 ProjectRelated       — conditional (hidden if no related projects)
 *   08 ProjectJoinCTA       — always
 *
 * All variation is data-driven. No project-specific layouts or CSS.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectHero from './ProjectHero.astro';
import ProjectStatBand from './ProjectStatBand.astro';
import ProjectAbout from './ProjectAbout.astro';
import ProjectFeaturedContributors from './ProjectFeaturedContributors.astro';
import ProjectContributorsGrid from './ProjectContributorsGrid.astro';
import ProjectGallery from './ProjectGallery.astro';
import ProjectRelated from './ProjectRelated.astro';
import ProjectJoinCTA from './ProjectJoinCTA.astro';
import type { ProjectData } from '../../data/projects';
import { getRelatedProjects } from '../../data/projects';

interface Props {
  project: ProjectData;
}

const { project } = Astro.props;
const related = getRelatedProjects(project.slug);
---

<BaseLayout
  title={`${project.title} — BCC Special Project`}
  description={project.description}
>

  <!-- 01 Hero — always -->
  <ProjectHero
    title={project.title}
    description={project.description}
    heroImage={project.heroImage}
  />

  <!-- 02 StatBand — always -->
  <ProjectStatBand
    gridId={project.slug}
    contributorCount={project.contributors.length}
    subjectLabel={project.subjectLabel}
    subjectCount={project.subjectCount}
    lastUpdated={project.lastUpdated}
  />

  <!-- 03 About — conditional -->
  {project.about.length > 0 && (
    <ProjectAbout
      title={project.title}
      paragraphs={project.about}
    />
  )}

  <!-- 04 Featured Contributors — conditional -->
  {project.contributors.length > 0 && (
    <ProjectFeaturedContributors
      projectTitle={project.title}
      contributors={project.contributors}
    />
  )}

  <!-- 05 Contributors Grid — conditional -->
  {project.contributors.length > 0 && (
    <ProjectContributorsGrid
      projectTitle={project.title}
      contributors={project.contributors}
    />
  )}

  <!-- 06 Gallery — always -->
  <ProjectGallery
    id={project.slug}
    projectTitle={project.title}
    apiTag={project.apiTag}
  />

  <!-- 07 Related Projects — conditional -->
  {related.length > 0 && (
    <ProjectRelated projects={related} />
  )}

  <!-- 08 Join CTA — always -->
  <ProjectJoinCTA slug={project.slug} />

</BaseLayout>

<script define:vars={{ gridId: project.slug }}>
  /* Sync photo count stat from gallery to StatBand when grid loads */
  (function () {
    var gridEl       = document.getElementById(gridId + '-grid');
    var statPhotos   = document.getElementById(gridId + '-stat-photos');
    var galleryLabel = document.getElementById(gridId + '-gallery-count');

    if (!gridEl || !statPhotos) return;

    gridEl.addEventListener('bcc:grid-loaded', function (e) {
      var total = e.detail && e.detail.total;
      if (typeof total === 'number' && total > 0) {
        var fmt = total.toLocaleString('en-IN');
        statPhotos.textContent = fmt;
        if (galleryLabel) {
          galleryLabel.textContent = fmt + ' photograph' + (total === 1 ? '' : 's') + ' total';
        }
      }
    });
  })();
</script>
