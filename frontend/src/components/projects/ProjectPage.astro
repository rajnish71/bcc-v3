---
/**
 * ProjectPage.astro — Reusable compositor for all BCC Special Project pages.
 * V6 40 Special Projects design authority (Architecture Freeze).
 * Route: /projects/{slug}
 *
 * Section order:
 *   01 ProjectHero             — always
 *   02 ProjectStatBand         — always (all stats dynamic via client script)
 *   03 ProjectAbout            — conditional (hidden if about is empty)
 *   04 ProjectHighlights       — always (one photo per contributor, random order)
 *   05 ProjectContributorsGrid — always (fully dynamic)
 *   06 ProjectGallery          — always (all photos, no photographer limit)
 *   07 ProjectRelated          — conditional (hidden if no related projects)
 *   08 ProjectJoinCTA          — always
 *
 * All variation is data-driven. No project-specific layouts or CSS.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectHero from './ProjectHero.astro';
import ProjectStatBand from './ProjectStatBand.astro';
import ProjectAbout from './ProjectAbout.astro';
import ProjectHighlights from './ProjectHighlights.astro';
import ProjectContributorsGrid from './ProjectContributorsGrid.astro';
import ProjectGallery from './ProjectGallery.astro';
import ProjectRelated from './ProjectRelated.astro';
import ProjectJoinCTA from './ProjectJoinCTA.astro';
import type { ProjectData } from '../../data/projects';
import { getRelatedProjects } from '../../data/projects';

interface Props {
  project: ProjectData;
}

const { project } = Astro.props;
const related = getRelatedProjects(project.slug);
---

<BaseLayout
  title={`${project.title} — BCC Special Project`}
  description={project.description}
>

  <!-- 01 Hero — always -->
  <ProjectHero
    title={project.title}
    description={project.description}
    heroImage={project.heroImage}
  />

  <!-- 02 StatBand — always (populated by client script below) -->
  <ProjectStatBand
    gridId={project.slug}
  />

  <!-- 03 About — conditional -->
  {project.about.length > 0 && (
    <ProjectAbout
      title={project.title}
      paragraphs={project.about}
    />
  )}

  <!-- 04 Project Highlights — one photo per contributor, random order -->
  <ProjectHighlights
    gridId={project.slug}
    projectTag={project.projectTag}
    projectTitle={project.title}
  />

  <!-- 05 Contributors Grid — fully dynamic -->
  <ProjectContributorsGrid
    projectTag={project.projectTag}
    projectTitle={project.title}
  />

  <!-- 06 Gallery — all photos, no photographer limit -->
  <ProjectGallery
    id={project.slug}
    projectTitle={project.title}
    projectTag={project.projectTag}
  />

  <!-- 07 Related Projects — conditional -->
  {related.length > 0 && (
    <ProjectRelated projects={related} />
  )}

  <!-- 08 Join CTA — always -->
  <ProjectJoinCTA slug={project.slug} />

</BaseLayout>

<script define:vars={{ gridId: project.slug, projectTag: project.projectTag }}>
  (function () {
    /* ── Dynamic stats from /api/v1/projects/stats ── */
    var statPhotos       = document.getElementById(gridId + '-stat-photos');
    var statContributors = document.getElementById(gridId + '-stat-contributors');
    var statUpdated      = document.getElementById(gridId + '-stat-updated');

    if (statPhotos || statContributors || statUpdated) {
      fetch('/api/v1/projects/stats?tag=' + encodeURIComponent(projectTag))
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (data) {
          if (!data) return;
          if (statPhotos && data.photoCount > 0) {
            statPhotos.textContent = data.photoCount.toLocaleString('en-IN');
          }
          if (statContributors && data.contributorCount > 0) {
            statContributors.textContent = String(data.contributorCount);
          }
          if (statUpdated && data.lastUpdated) {
            statUpdated.textContent = data.lastUpdated;
          }
        })
        .catch(function () { /* silent — stats remain as "—" */ });
    }

    /* ── Gallery count label from bcc:grid-loaded ── */
    var gridEl       = document.getElementById(gridId + '-grid');
    var galleryLabel = document.getElementById(gridId + '-gallery-count');

    if (gridEl && galleryLabel) {
      gridEl.addEventListener('bcc:grid-loaded', function (e) {
        var total = e.detail && e.detail.total;
        if (typeof total === 'number' && total > 0) {
          galleryLabel.textContent =
            total.toLocaleString('en-IN') +
            ' photograph' + (total === 1 ? '' : 's') + ' total';
        }
      });
    }
  })();
</script>
