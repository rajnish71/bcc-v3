---
/**
 * ProjectRelated.astro — Related Special Projects grid.
 * V6 40 §09 — Related Projects (Conditional)
 * Omitted entirely from DOM when projects array is empty.
 * Current project is already excluded before this component receives data.
 * Card cover uses object-fit: cover (exception to natural-ratio rule, per spec).
 */
import type { ProjectData } from '../../data/projects';

interface Props {
  projects: ProjectData[];
}
const { projects } = Astro.props;
if (!projects || projects.length === 0) return;
---

<section
  class="prel container"
  aria-label="More BCC Special Projects"
  data-gsap="reveal"
  style="opacity:0;transform:translateY(24px)"
>
  <div class="prel-header">
    <div class="prel-eyebrow">More Special Projects</div>
    <h2 class="prel-title">Explore the BCC collection</h2>
  </div>

  <div class="prel-grid">
    {projects.map(p => (
      <a
        href={`/projects/${p.slug}`}
        class="prel-card"
        aria-label={`${p.title} — BCC Special Project`}
      >
        <div class="prel-cover" aria-hidden="true">
          <div class="prel-cover-fill"></div>
        </div>
        <div class="prel-body">
          <div class="prel-name">{p.title}</div>
          <div class="prel-meta">{p.description}</div>
          <div class="prel-cta" aria-hidden="true">Explore →</div>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
.prel {
  padding-top: var(--s-8);
}
.prel-header {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-bottom: none;
  padding: 24px 32px 20px;
}
.prel-eyebrow {
  font-family: var(--font-mono);
  font-size: var(--text-label);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: 600;
  margin-bottom: 10px;
}
.prel-title {
  font-family: var(--font-display);
  font-size: 26px;
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.1;
  color: var(--ink-900);
  margin: 0;
}
.prel-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  border: 1px solid var(--hairline);
}
.prel-card {
  background: var(--surface-0);
  border-right: 1px solid var(--hairline);
  border-bottom: 1px solid var(--hairline);
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  transition: background var(--m-fast);
}
.prel-card:hover { background: var(--surface-1); }
.prel-card:hover .prel-cta { color: var(--gold-500); }

/* Exception per V6 40 spec: card cover image uses object-fit: cover */
.prel-cover {
  height: 168px;
  background: var(--image-backdrop);
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
}
.prel-cover-fill {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    135deg,
    var(--image-backdrop) 0px, var(--image-backdrop) 24px,
    #1E1C1A 24px, #1E1C1A 48px
  );
}
.prel-body {
  padding: 16px 20px 20px;
  flex: 1;
  display: flex;
  flex-direction: column;
}
.prel-name {
  font-family: var(--font-display);
  font-size: 15px;
  font-weight: 600;
  color: var(--ink-900);
  margin-bottom: 5px;
  line-height: 1.25;
}
.prel-meta {
  font-size: 12px;
  line-height: 1.6;
  color: var(--ink-400);
  margin-bottom: 12px;
  flex: 1;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.prel-cta {
  font-size: 11px;
  font-weight: 600;
  color: var(--gold-600);
  letter-spacing: 0.04em;
  transition: color var(--m-fast);
}

@media (max-width: 768px) {
  .prel-grid { grid-template-columns: 1fr 1fr; }
  .prel-title { font-size: 20px; }
}
@media (max-width: 480px) {
  .prel-cover { height: 120px; }
}
</style>
