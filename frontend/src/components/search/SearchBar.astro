---
/**
 * SearchBar — canonical search input with icon and clear button.
 *
 * Emits a `bcc:search` CustomEvent on the element with `{ detail: { q: string } }`
 * after a 400ms debounce. Host pages can also read the input directly by its id.
 *
 * Usage in a live-search context:
 *   <SearchBar id="my-search" placeholder="Search…" />
 *   <script>
 *     document.querySelector('[data-sb]').addEventListener('bcc:search', e => { ... });
 *   </script>
 *
 * Usage inside a form-submit context: wrap in a <form> and provide a submit button
 * outside the SearchBar; the input id is still queryable by page JS.
 */
interface Props {
  id?: string;
  name?: string;
  placeholder?: string;
  value?: string;
  debounce?: number;
  class?: string;
}
const {
  id = 'search-input',
  name,
  placeholder = 'Search…',
  value = '',
  debounce: debounceMs = 400,
  class: className = '',
} = Astro.props;
---
<div class:list={['sb', className]} data-sb data-debounce={debounceMs}>
  <svg class="sb-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
    <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.5"/>
    <line x1="10" y1="10" x2="14" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  </svg>
  <input
    id={id}
    name={name}
    type="search"
    class="sb-input"
    placeholder={placeholder}
    value={value}
    autocomplete="off"
    aria-label={placeholder}
  />
  <button type="button" class="sb-clear" aria-label="Clear search" hidden>
    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
      <line x1="1" y1="1" x2="9" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="9" y1="1" x2="1" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>
</div>

<style>
.sb {
  position: relative;
  display: flex;
  align-items: center;
  background: var(--surface-0);
  border: 1px solid var(--hairline-strong);
  border-radius: var(--input-radius);
  transition: border-color var(--m-fast), box-shadow var(--m-fast);
}
.sb:focus-within {
  border-color: var(--gold-600);
  box-shadow: 0 0 0 3px rgba(168, 132, 60, 0.12);
}

.sb-icon {
  position: absolute;
  left: 12px;
  color: var(--ink-400);
  pointer-events: none;
  flex-shrink: 0;
  transition: color var(--m-fast);
}
.sb:focus-within .sb-icon { color: var(--ink-900); }

.sb-input {
  flex: 1;
  height: 44px;
  padding: 0 36px 0 36px;
  font-family: var(--font-body);
  font-size: 14px;
  color: var(--ink-900);
  background: transparent;
  border: none;
  outline: none;
  width: 100%;
  box-sizing: border-box;
}
.sb-input::placeholder { color: var(--ink-400); }
/* Hide browser-native clear button */
.sb-input::-webkit-search-cancel-button { display: none; }

.sb-clear {
  position: absolute;
  right: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  background: var(--surface-2);
  border: none;
  border-radius: 50%;
  cursor: pointer;
  color: var(--ink-600);
  padding: 0;
  transition: background var(--m-fast), color var(--m-fast);
}
.sb-clear:hover { background: var(--hairline-strong); color: var(--ink-900); }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-sb]').forEach(wrap => {
    const input   = wrap.querySelector<HTMLInputElement>('.sb-input');
    const clearBtn = wrap.querySelector<HTMLButtonElement>('.sb-clear');
    if (!input || !clearBtn) return;

    const delay = Number(wrap.dataset.debounce ?? 400);
    let timer = 0;

    function updateClear() {
      clearBtn!.hidden = input!.value.length === 0;
    }

    function fire() {
      wrap.dispatchEvent(new CustomEvent('bcc:search', {
        bubbles: true,
        detail: { q: input!.value.trim() },
      }));
    }

    input.addEventListener('input', () => {
      updateClear();
      clearTimeout(timer);
      timer = window.setTimeout(fire, delay);
    });

    clearBtn.addEventListener('click', () => {
      input.value = '';
      updateClear();
      clearTimeout(timer);
      fire();
      input.focus();
    });

    updateClear();
  });
</script>
