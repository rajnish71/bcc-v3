---
/**
 * NotificationBell.astro
 * In-app notification bell for logged-in members.
 *
 * Placement: inside #nav-member in Nav.astro (hidden for guests automatically).
 * Token convention: localStorage 'bcc_token' = JWT access token.
 *   Auth pages must store the access token under this key on sign-in.
 * API: /api/v1/notifications/* (same-origin, AccessTokenGuard).
 *
 * Behaviour:
 *   - On member detection (bcc_token present): fetch unread count, show badge.
 *   - On bell click: open panel, fetch 10 most recent notifications.
 *   - Each notification click: mark that item read, follow actionUrl if set.
 *   - "Mark all read" button: POST mark-all-read, clear badge.
 *   - Close on outside click or Escape.
 *   - No continuous polling (RAM-conscious single EC2). Re-fetches on open.
 *
 * Design system: BCC_V3_Design_System.md - "Refined Editorial Luxury".
 */
---

<!-- Bell root (always in DOM inside #nav-member; hidden via parent) -->
<div class="bell" id="bell-root">

  <!-- Trigger button -->
  <button
    class="bell__btn"
    id="bell-btn"
    type="button"
    aria-label="Notifications"
    aria-haspopup="dialog"
    aria-expanded="false"
  >
    <svg class="bell__icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
      <path
        d="M9 2a5.5 5.5 0 0 0-5.5 5.5v2.25L2 12h14l-1.5-2.25V7.5A5.5 5.5 0 0 0 9 2Z"
        stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"
      />
      <path d="M7 12v.5a2 2 0 0 0 4 0V12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </svg>
    <!-- Unread count badge -->
    <span class="bell__badge" id="bell-badge" hidden aria-live="polite" aria-label="unread notifications">0</span>
  </button>

  <!-- Dropdown panel -->
  <div
    class="bell__panel"
    id="bell-panel"
    role="dialog"
    aria-label="Notifications"
    aria-modal="false"
    hidden
  >
    <!-- Panel header -->
    <div class="bell__panel-head">
      <span class="bell__panel-title">Notifications</span>
      <button class="bell__mark-all" id="bell-mark-all" type="button">
        Mark all read
      </button>
    </div>

    <!-- Notification list -->
    <div class="bell__panel-body" id="bell-body" role="list">
      <!-- Populated by JS -->
      <div class="bell__loading" id="bell-loading" aria-live="polite">Loading...</div>
    </div>

    <!-- Footer -->
    <div class="bell__panel-foot">
      <a href="/hub/#notifications" class="bell__view-all">View all notifications</a>
    </div>
  </div>

</div>


<style>
/* ============================================================================
   Notification Bell -- BCC V3 Design System tokens
   ============================================================================ */

.bell {
  position: relative;
  flex-shrink: 0;
}

/* ---- Trigger button ---- */
.bell__btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: none;
  border: 1px solid var(--hairline);
  border-radius: var(--r-1);
  color: var(--ink-400);
  cursor: pointer;
  transition: color var(--m-fast), border-color var(--m-fast), background var(--m-fast);
  flex-shrink: 0;
}
.bell__btn:hover,
.bell__btn[aria-expanded="true"] {
  color: var(--ink-900);
  border-color: var(--hairline-strong);
  background: var(--surface-1);
}
.bell__btn:focus-visible {
  outline: 2px solid var(--gold-600);
  outline-offset: 3px;
}

/* ---- Unread badge ---- */
.bell__badge {
  position: absolute;
  top: -4px;
  right: -4px;
  min-width: 16px;
  height: 16px;
  padding: 0 4px;
  background: var(--gold-gradient);
  border-radius: var(--r-full);
  border: 2px solid var(--surface-0);
  font-family: var(--font-body);
  font-size: 9px;
  font-weight: 700;
  color: var(--ink-inverse);
  line-height: 12px;
  text-align: center;
  pointer-events: none;
  letter-spacing: 0;
}

/* ---- Dropdown panel ---- */
.bell__panel {
  position: absolute;
  top: calc(100% + 10px);
  right: 0;
  width: 360px;
  max-height: 480px;
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-radius: var(--r-2);
  box-shadow: var(--e-3);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  z-index: 910;
}
.bell__panel[hidden] { display: none; }

/* Panel header */
.bell__panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px 12px;
  border-bottom: 1px solid var(--hairline-soft);
  flex-shrink: 0;
}
.bell__panel-title {
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 600;
  color: var(--ink-900);
  letter-spacing: -0.01em;
}
.bell__mark-all {
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 500;
  color: var(--gold-600);
  background: none;
  border: none;
  cursor: pointer;
  padding: 2px 0;
  transition: color var(--m-fast);
  text-decoration: underline;
  text-underline-offset: 2px;
}
.bell__mark-all:hover { color: var(--ink-900); }

/* Panel body */
.bell__panel-body {
  flex: 1;
  overflow-y: auto;
  overscroll-behavior: contain;
}

/* Loading / empty states */
.bell__loading,
.bell__empty,
.bell__error {
  padding: 32px 16px;
  text-align: center;
  font-family: var(--font-body);
  font-size: 13px;
  color: var(--ink-400);
}

/* Individual notification item */
.bell__item {
  display: block;
  width: 100%;
  padding: 12px 16px 12px 20px;
  border: none;
  border-bottom: 1px solid var(--hairline-soft);
  background: none;
  cursor: default;
  text-align: left;
  position: relative;
  transition: background var(--m-fast);
}
.bell__item:last-child { border-bottom: none; }
.bell__item:hover { background: var(--surface-1); }
.bell__item[data-action] { cursor: pointer; }

/* Unread accent -- 2px gold left bar */
.bell__item--unread::before {
  content: '';
  position: absolute;
  left: 0;
  top: 10px;
  bottom: 10px;
  width: 2px;
  background: var(--gold-gradient);
  border-radius: 0 1px 1px 0;
}

.bell__item-title {
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 600;
  color: var(--ink-900);
  margin-bottom: 3px;
  line-height: 1.4;
}
.bell__item--read .bell__item-title {
  font-weight: 500;
  color: var(--ink-600);
}
.bell__item-body {
  font-family: var(--font-body);
  font-size: 12px;
  color: var(--ink-600);
  line-height: 1.5;
  margin-bottom: 5px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.bell__item-time {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--ink-400);
  letter-spacing: 0.04em;
}

/* Panel footer */
.bell__panel-foot {
  padding: 10px 16px;
  border-top: 1px solid var(--hairline-soft);
  text-align: center;
  flex-shrink: 0;
}
.bell__view-all {
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 500;
  color: var(--gold-600);
  text-decoration: none;
  transition: color var(--m-fast);
}
.bell__view-all:hover { color: var(--ink-900); }

/* Mobile: full-width panel, anchored top */
@media (max-width: 640px) {
  .bell__panel {
    position: fixed;
    top: var(--nav-h-min);
    left: 0;
    right: 0;
    width: 100%;
    max-height: 60vh;
    border-radius: 0;
    border-left: none;
    border-right: none;
  }
}
</style>


<script>
  // ===========================================================================
  // NotificationBell client script
  // Token key convention: localStorage 'bcc_token' = JWT access token.
  // Auth pages MUST store the token under this key on successful sign-in.
  // ===========================================================================

  const API = '/api/v1/notifications';

  // ---- DOM refs ----
  const bellRoot   = document.getElementById('bell-root');
  const bellBtn    = document.getElementById('bell-btn');
  const bellBadge  = document.getElementById('bell-badge');
  const bellPanel  = document.getElementById('bell-panel');
  const bellBody   = document.getElementById('bell-body');
  const bellMarkAll = document.getElementById('bell-mark-all');

  if (!bellRoot || !bellBtn || !bellBadge || !bellPanel || !bellBody || !bellMarkAll) {
    // Elements not present (component not rendered or wrong page) -- bail.
    throw new Error('Bell: DOM elements missing');
  }

  // ---- Auth ----
  function getToken(): string | null {
    try { return localStorage.getItem('bcc_token'); } catch { return null; }
  }

  function authHeaders(): Record<string, string> {
    const t = getToken();
    return t ? { Authorization: `Bearer ${t}` } : {};
  }

  // ---- API helpers ----
  async function apiFetch(path: string, opts: RequestInit = {}): Promise<Response> {
    return fetch(path, {
      ...opts,
      headers: { 'Content-Type': 'application/json', ...authHeaders(), ...(opts.headers ?? {}) },
    });
  }

  // ---- Relative time formatter ----
  function relativeTime(iso: string): string {
    const diff = Date.now() - new Date(iso).getTime();
    const mins = Math.floor(diff / 60_000);
    if (mins < 1) return 'just now';
    if (mins < 60) return `${mins}m ago`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24) return `${hrs}h ago`;
    const days = Math.floor(hrs / 24);
    if (days < 7) return `${days}d ago`;
    return new Date(iso).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' });
  }

  // ---- Badge ----
  function setBadge(count: number): void {
    if (count > 0) {
      bellBadge!.textContent = count > 99 ? '99+' : String(count);
      bellBadge!.hidden = false;
    } else {
      bellBadge!.hidden = true;
    }
  }

  // ---- Fetch unread count ----
  async function fetchCount(): Promise<void> {
    const token = getToken();
    if (!token) return;
    try {
      const res = await apiFetch(`${API}/unread-count`);
      if (!res.ok) return;
      const data = (await res.json()) as { count: number };
      setBadge(data.count ?? 0);
    } catch { /* Network error -- silently skip badge */ }
  }

  // ---- Render notification items ----
  interface NotificationItem {
    id: number;
    title: string;
    body: string;
    actionUrl: string | null;
    isRead: boolean;
    createdAt: string;
  }

  function renderItems(items: NotificationItem[]): void {
    if (items.length === 0) {
      bellBody!.innerHTML = '<div class="bell__empty">You are all caught up.</div>';
      return;
    }

    bellBody!.innerHTML = items.map((n) => {
      const readCls = n.isRead ? 'bell__item--read' : 'bell__item--unread';
      const actionAttr = n.actionUrl ? ` data-action="${n.actionUrl}"` : '';
      return `
        <button
          class="bell__item ${readCls}"
          data-id="${n.id}"
          ${actionAttr}
          role="listitem"
          type="button"
          aria-label="${n.isRead ? '' : 'Unread: '}${n.title}"
        >
          <div class="bell__item-title">${escapeHtml(n.title)}</div>
          <div class="bell__item-body">${escapeHtml(n.body)}</div>
          <div class="bell__item-time">${relativeTime(n.createdAt)}</div>
        </button>
      `.trim();
    }).join('');

    // Attach click handlers to each item
    bellBody!.querySelectorAll<HTMLElement>('.bell__item').forEach((el) => {
      el.addEventListener('click', async () => {
        const id = Number(el.dataset.id);
        const actionUrl = el.dataset.action ?? null;

        // Mark read (fire-and-forget -- don't block navigation)
        if (!el.classList.contains('bell__item--read')) {
          el.classList.remove('bell__item--unread');
          el.classList.add('bell__item--read');
          void apiFetch(`${API}/${id}/read`, { method: 'PATCH' }).then(fetchCount);
        }

        if (actionUrl) {
          closePanel();
          window.location.href = actionUrl;
        }
      });
    });
  }

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  // ---- Fetch and render notifications ----
  async function fetchAndRender(): Promise<void> {
    bellBody!.innerHTML = '<div class="bell__loading">Loading...</div>';
    try {
      const res = await apiFetch(`${API}?limit=10`);
      if (!res.ok) {
        bellBody!.innerHTML = '<div class="bell__error">Could not load notifications.</div>';
        return;
      }
      const data = (await res.json()) as { items: NotificationItem[]; unreadCount: number };
      setBadge(data.unreadCount ?? 0);
      renderItems(data.items ?? []);
    } catch {
      bellBody!.innerHTML = '<div class="bell__error">Could not load notifications.</div>';
    }
  }

  // ---- Panel open / close ----
  function openPanel(): void {
    bellPanel!.hidden = false;
    bellBtn!.setAttribute('aria-expanded', 'true');
    void fetchAndRender();
    // Trap focus loosely -- close on outside click
    setTimeout(() => document.addEventListener('click', outsideClick, { capture: true }), 10);
    document.addEventListener('keydown', escapeKey);
  }

  function closePanel(): void {
    bellPanel!.hidden = true;
    bellBtn!.setAttribute('aria-expanded', 'false');
    document.removeEventListener('click', outsideClick, { capture: true });
    document.removeEventListener('keydown', escapeKey);
  }

  function outsideClick(e: MouseEvent): void {
    if (!bellRoot!.contains(e.target as Node)) closePanel();
  }

  function escapeKey(e: KeyboardEvent): void {
    if (e.key === 'Escape') { closePanel(); bellBtn!.focus(); }
  }

  // ---- Mark all read ----
  bellMarkAll.addEventListener('click', async () => {
    try {
      await apiFetch(`${API}/mark-all-read`, { method: 'POST' });
      setBadge(0);
      // Re-render with all items toggled read
      bellBody!.querySelectorAll<HTMLElement>('.bell__item').forEach((el) => {
        el.classList.remove('bell__item--unread');
        el.classList.add('bell__item--read');
      });
    } catch { /* silent */ }
  });

  // ---- Bell button toggle ----
  bellBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = bellBtn.getAttribute('aria-expanded') === 'true';
    isOpen ? closePanel() : openPanel();
  });

  // ---- Initialise: fetch count when member is detected ----
  // Run immediately (script executes after DOM + Nav auth check have both run
  // since Astro bundles scripts in document order). Guard on bcc_token only.
  if (getToken()) {
    void fetchCount();
  }
</script>
