---
import { getPhotographerProfileUrl } from '../../data/photoRegistry';

/**
 * PageHero.astro — Consolidated page hero for all BCC pages.
 *
 * CANONICAL ARCHITECTURE:
 * home, journal, and overlay (About) share one structural implementation.
 * Shared classes: .ph-frame .ph-img .ph-gradient .ph-panel .ph-kicker .ph-heading .ph-body .ph-credit
 * Variants differ ONLY in: outer wrapper spacing, content slots (CTAs, stats), credit placement.
 * Responsive cascade is declared ONCE: 900 → 768 → 540px.
 *
 * project and standard use genuinely different layouts and remain independent.
 */
interface StatItem {
  label: string;
  value?: string | number;
  isWide?: boolean;
  target?: number;
}

interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  meta?: string;

  // Dynamic or static hero image & attribution
  heroImage?: string;
  heroCredit?: string;

  // Stats band (optional, for About style pages)
  stats?: StatItem[];

  // Layout variants: 'standard' | 'overlay' | 'project' | 'home' | 'journal'
  variant?: 'standard' | 'overlay' | 'project' | 'home' | 'journal';

  // Home variant CTAs
  primaryCtaText?: string;
  primaryCtaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  meta,
  heroImage,
  heroCredit,
  stats,
  variant = 'standard',
  primaryCtaText = 'Become a Member →',
  primaryCtaHref = '/join/',
  secondaryCtaText = 'Browse the Gallery',
  secondaryCtaHref = '/showcase/',
} = Astro.props;
---

{/* ── About (overlay) — static image, photo-credit bar below frame, stats band ── */}
{variant === 'overlay' && (
  <div class="about-hero" id="page-hero-container">
    <div class="container">
      <div class="ph-reveal" data-gsap="image-reveal">
        <div class="ph-frame">
          <img
            id="page-hero-img"
            src={heroImage}
            alt={title}
            class="ph-img"
            loading="eager"
            fetchpriority="high"
          />
          <div class="ph-gradient" aria-hidden="true"></div>
          <div class="ph-panel">
            <div class="ph-kicker">{eyebrow}</div>
            <h1 class="ph-heading" set:html={title}></h1>
            <p class="ph-body">{subtitle}</p>
          </div>
        </div>

        <div class="photo-credit-bar" id="page-hero-credit" style={heroCredit ? "" : "display: none;"}>
          <span class="photo-credit-bar__caption" id="page-hero-credit-caption">Taj-ul-Masajid at night · Bhopal</span>
          <span class="photo-credit-bar__right">
            <span class="photo-credit-bar__by">Photo by</span>
            <a href={heroCredit ? getPhotographerProfileUrl(heroCredit) : "#"} class="photo-credit-bar__name" id="page-hero-credit-name-link">
              <span id="page-hero-credit-name">{heroCredit}</span>
            </a>
          </span>
        </div>

        {stats && stats.length > 0 && (
          <div class="stats-band" aria-label="Club statistics">
            {stats.map(s => (
              <div class={`stat-item ${s.isWide ? 'stat-item--wide' : ''}`}>
                <div class="stat-label">{s.label}</div>
                <div class={`stat-value ${s.isWide ? 'stat-value--gold' : ''}`}>
                  {s.value === undefined ? (
                    <span class="stat-pending">—</span>
                  ) : s.target !== undefined ? (
                    <span data-gsap="counter" data-target={s.target}>{s.value}</span>
                  ) : (
                    <span>{s.value}</span>
                  )}
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
)}

{/* ── Projects — full-bleed, min-height based, no aspect-ratio ── */}
{variant === 'project' && (
  <div class="ph-hero" id="page-hero-container" data-gsap="image-reveal">
    <img
      class="ph-hero-img"
      id="page-hero-img"
      src={heroImage}
      alt={`${title} — BCC Special Project`}
      loading="eager"
      decoding="async"
      style={heroImage ? "" : "display: none;"}
    />
    <div class="ph-hero-gradient" aria-hidden="true"></div>
    <div class="ph-hero-content">
      <div class="ph-kicker-proj">
        <span class="ph-kicker-proj-line" aria-hidden="true"></span>
        {eyebrow}
      </div>
      <h1 class="ph-title-proj">{title}</h1>
      <p class="ph-desc-proj">{subtitle}</p>
    </div>
    <div class="hero-credit" id="page-hero-credit" style={heroCredit ? "position: absolute; bottom: 16px; right: 20px; display: flex; align-items: center; gap: 6px; z-index: 10;" : "display: none; position: absolute; bottom: 16px; right: 20px; align-items: center; gap: 6px; z-index: 10;"}>
      <span class="hero-credit__label" style="font-family: var(--font-mono); font-size: 9px; color: rgba(255, 255, 255, 0.4); letter-spacing: 0.08em; text-transform: uppercase;">Photo by</span>
      <span class="hero-credit__name" id="page-hero-credit-name" style="font-family: var(--font-mono); font-size: 9px; color: rgba(255, 255, 255, 0.6); letter-spacing: 0.06em;">{heroCredit}</span>
    </div>
  </div>
)}

{/* ── Home — dynamic image, CTAs, floating credit ── */}
{variant === 'home' && (
  <div class="home-hero" id="page-hero-container">
    <div class="container">
      <div class="ph-frame" data-gsap="image-reveal">
        <div class="ph-placeholder" id="home-hero-fallback" aria-hidden="true"></div>
        <img
          id="home-hero-img"
          src=""
          alt=""
          class="ph-img"
          loading="eager"
          decoding="async"
          aria-hidden="true"
        />
        <div class="ph-gradient" aria-hidden="true"></div>
        <div class="ph-panel">
          <div class="ph-kicker" id="home-hero-kicker">
            <span class="ph-kicker-line" aria-hidden="true"></span>
            <span id="home-hero-kicker-text">{eyebrow}</span>
          </div>
          <h1 class="ph-heading">{title}</h1>
          <p class="ph-body ph-body--home">{subtitle}</p>
          <div class="ph-ctas">
            <a href={primaryCtaHref} class="ph-cta-primary">{primaryCtaText}</a>
            <a href={secondaryCtaHref} class="ph-cta-secondary">{secondaryCtaText}</a>
          </div>
        </div>
        <div class="ph-credit" id="home-hero-credit" style="display: none;">
          <span class="ph-credit-label">Photo by</span>
          <a class="ph-credit-name" id="home-hero-credit-name" href="#"></a>
        </div>
      </div>
    </div>
  </div>
)}

{/* ── Journal — dynamic image, no CTAs, floating credit ── */}
{variant === 'journal' && (
  <div class="journal-hero" id="page-hero-container">
    <div class="container">
      <div class="ph-frame" data-gsap="image-reveal">
        <div class="ph-placeholder" id="journal-hero-fallback" aria-hidden="true"></div>
        <img
          id="page-hero-img"
          src=""
          alt=""
          class="ph-img"
          loading="eager"
          decoding="async"
        />
        <div class="ph-gradient" aria-hidden="true"></div>
        <div class="ph-panel">
          <div class="ph-kicker">
            <span class="ph-kicker-line" aria-hidden="true"></span>
            <span>{eyebrow}</span>
          </div>
          <h1 class="ph-heading">{title}</h1>
          <p class="ph-body">{subtitle}</p>
        </div>
        <div class="ph-credit" id="page-hero-credit" style="display: none;">
          <span class="ph-credit-label">Photo by</span>
          <a class="ph-credit-name" id="page-hero-credit-name" href="#"></a>
        </div>
      </div>
    </div>
  </div>
)}

{/* ── Standard — text below image (Showcase, Activities, etc.) ── */}
{variant === 'standard' && (
  <div class="page-hero surface-white" id="page-hero-container">
    <div class="container">
      {heroImage && (
        <div class="page-hero-banner-wrap" id="page-hero-banner">
          <img id="page-hero-img" src={heroImage} alt={title} />
          {heroCredit && (
            <div class="hero-credit" id="page-hero-credit">
              <span class="hero-credit__label">Photo by</span>
              <span class="hero-credit__name" id="page-hero-credit-name">{heroCredit}</span>
            </div>
          )}
        </div>
      )}
      <span class="eyebrow">{eyebrow}</span>
      <h1 class="page-hero__title"><slot name="title">{title}</slot></h1>
      <p class="page-hero__meta">
        {subtitle}
        {meta && <><br /><span class="page-hero__date">{meta}</span></>}
      </p>
    </div>
    <div class="hairline"></div>
  </div>
)}

<style>
/* ═══════════════════════════════════════════════════════════════
   CANONICAL PHOTO-OVERLAY FRAME
   Shared by: home, journal, overlay (About)
   ═══════════════════════════════════════════════════════════════ */

/* Variant wrappers — outer spacing ONLY. No layout rules here. */
.home-hero {
  padding-top: var(--nav-h);
  background: var(--surface-1);
}
.about-hero {
  padding-top: var(--nav-h, 64px);
  padding-bottom: var(--s-5);
  background: var(--surface-0);
}
.journal-hero {
  padding-top: var(--nav-h);
  background: var(--surface-1);
}

/* About: outer clip container for GSAP reveal (wraps frame + credit bar + stats) */
.ph-reveal {
  overflow: hidden;
}

/* The single frame — aspect-ratio, overflow, border */
.ph-frame {
  position: relative;
  aspect-ratio: 16 / 5;
  overflow: hidden;
  border: 1px solid var(--hairline);
  background: var(--dark-100);
}
/* About: ph-reveal provides the visual container; ph-frame needs no border of its own */
.ph-reveal .ph-frame {
  border: none;
}

/* Placeholder — visible until dynamic image loads (home, journal only) */
.ph-placeholder {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    135deg,
    #1A1816 0px, #1A1816 32px,
    #1E1C1A 32px, #1E1C1A 64px
  );
}

/* The single image rule */
.ph-img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}
/* Dynamic variants: image is injected by JS, fades in when loaded */
.home-hero .ph-img,
.journal-hero .ph-img {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.8s ease;
}
.home-hero .ph-img.loaded,
.journal-hero .ph-img.loaded {
  opacity: 1;
}

/* Atmospheric editorial veil — covers 100% of frame, photograph primary.
   Top zone: barely-there atmosphere (2–4%). Photo breathes.
   Bottom zone: guaranteed legibility for any text colour on any photograph.
   The long transition (32%→70%) reads as editorial gradient, not a dark band.
   Text-shadow on type elements carries the final legibility layer. */
.ph-gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(20, 18, 16, 0.04) 0%,
    rgba(20, 18, 16, 0.02) 32%,
    rgba(20, 18, 16, 0.42) 70%,
    rgba(20, 18, 16, 0.62) 100%
  );
  pointer-events: none;
}

/* Editorial text panel — additive certainty layer for the text zone.
   Gradient handles the atmospheric effect. Panel adds the baseline
   that ensures gold text is readable on any photograph colour. */
.ph-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 22px 48px 28px;
  background: rgba(20, 18, 16, 0.14);
}

.ph-kicker {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-light);
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 10px;
  text-shadow: 0 0 10px rgba(0, 0, 0, 0.80), 0 1px 3px rgba(0, 0, 0, 0.60);
}
.ph-kicker-line {
  display: block;
  width: 20px;
  height: 1px;
  background: var(--gold-light);
  flex-shrink: 0;
}

.ph-heading {
  font-family: var(--font-display);
  font-size: clamp(32px, 3.8vw, 52px);
  font-weight: 700;
  letter-spacing: -0.03em;
  color: #FFFFFF;
  line-height: 1.0;
  margin-bottom: 14px;
  text-wrap: pretty;
  text-shadow: 0 1px 4px rgba(0, 0, 0, 0.60), 0 2px 20px rgba(0, 0, 0, 0.35);
}

.ph-body {
  font-size: 15px;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.92);
  font-weight: 300;
  max-width: 540px;
  text-shadow: 0 1px 3px rgba(0, 0, 0, 0.45);
}
/* Home body needs margin below for CTAs */
.ph-body--home {
  margin-bottom: 22px;
}

/* Floating photo credit — inside frame, bottom-right */
.ph-credit {
  position: absolute;
  bottom: 14px;
  right: 18px;
  display: flex;
  align-items: center;
  gap: 6px;
  z-index: 1;
}
.ph-credit-label {
  font-family: var(--font-mono);
  font-size: 9px;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.ph-credit-name {
  font-family: var(--font-mono);
  font-size: 9px;
  color: rgba(255, 255, 255, 0.65);
  letter-spacing: 0.06em;
  text-decoration: none;
}
a.ph-credit-name:hover {
  color: var(--gold-light);
  text-decoration: underline;
}

/* Home CTAs */
.ph-ctas {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  align-items: center;
}
.ph-cta-primary {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--ink-900) !important;
  background: var(--gold-gradient);
  padding: 13px 30px;
  display: inline-block;
  border-radius: 2px;
  text-decoration: none;
  box-shadow: 0 2px 10px rgba(168, 132, 60, 0.30);
  transition: opacity var(--m-fast);
}
.ph-cta-primary:hover { opacity: 0.9; }
.ph-cta-secondary {
  font-size: 12px;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.9) !important;
  border: 1px solid rgba(255, 255, 255, 0.35);
  padding: 12px 26px;
  display: inline-block;
  border-radius: 2px;
  text-decoration: none;
  transition: background var(--m-fast);
}
.ph-cta-secondary:hover { background: rgba(255, 255, 255, 0.08); }

/* ═══════════════════════════════════════════════════════════════
   ONE CANONICAL RESPONSIVE CASCADE — applies to ALL three variants
   900 → 768 → 540px
   ═══════════════════════════════════════════════════════════════ */
@media (max-width: 900px) {
  .ph-frame          { aspect-ratio: 16 / 7; min-height: 280px; }
  .ph-panel          { padding: 18px 32px 22px; }
  .ph-body           { font-size: 14px; max-width: 100%; }
  .stats-band        { flex-wrap: wrap; }
  .stat-item         { flex: 1 0 33.33%; min-width: 0; border-bottom: 1px solid var(--hairline); }
  .stat-item--wide   { flex: 1 0 33.33%; }
  .stat-item:nth-child(3n) { border-right: none; }
}
@media (max-width: 768px) {
  .ph-frame          { aspect-ratio: 16 / 8; min-height: 300px; }
  .ph-panel          { padding: 16px 24px 20px; }
}
/* ═══════════════════════════════════════════════════════════════
   MOBILE EDITORIAL FRAME — ≤540px
   Architecture: stacked layout.
   Desktop: photograph as background, editorial text overlaid.
   Mobile:  photograph at full natural width, editorial band below.
   Same component. Same image. Same data model. Different frame.
   The interface adapts. The photograph does not.
   ═══════════════════════════════════════════════════════════════ */
@media (max-width: 540px) {

  /* Frame becomes a flex column: photograph then editorial band */
  .ph-frame {
    aspect-ratio: unset;
    min-height: unset;
    overflow: visible;
    display: flex;
    flex-direction: column;
  }

  /* ph-reveal (About variant) must not clip the stacked panel below the frame */
  .ph-reveal {
    overflow: visible;
  }

  /* ── PHOTOGRAPH ───────────────────────────────────────────────
     Show at natural proportions. No crop. No recomposition.
     The photograph dictates its own height on mobile.
  ────────────────────────────────────────────────────────────── */

  /* Overlay / About variant: image is statically positioned by default.
     Reset height and object-fit to natural proportions. */
  .about-hero .ph-img {
    height: auto;
    object-fit: unset;
    object-position: unset;
    flex-shrink: 0;
  }

  /* Home / Journal: image is position:absolute by default (JS-loaded).
     Pull into normal flex flow and present at natural proportions. */
  .home-hero .ph-img,
  .journal-hero .ph-img {
    position: static;
    inset: auto;
    opacity: 1;
    transition: none;
    height: auto;
    object-fit: unset;
    flex-shrink: 0;
  }

  /* Placeholder: pull into flex flow. Provides loading-state height
     before the dynamic image arrives. Removed by JS on image load. */
  .home-hero .ph-placeholder,
  .journal-hero .ph-placeholder {
    position: static;
    height: 220px;
    flex-shrink: 0;
  }

  /* Gradient: no semantic meaning on a stacked layout — suppress. */
  .ph-gradient { display: none; }

  /* Attribution bar — Principle 4 compliance.
     Appears between photograph and editorial band.
     Display is JS-controlled; position and style are set here.
     order: 5 places it between photo (order:0) and panel (order:10). */
  .ph-credit {
    position: static;
    inset: auto;
    order: 5;
    padding: 10px 16px;
    background: rgba(14, 12, 10, 0.90);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    z-index: auto;
  }
  .ph-credit-label {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.10em;
  }
  .ph-credit-name {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.80);
    letter-spacing: 0.04em;
  }

  /* ── EDITORIAL BAND ───────────────────────────────────────────
     Pulled from absolute overlay to a static band below the photograph.
     This is the mobile editorial frame — not a degraded desktop frame.
  ────────────────────────═───────────────────────────────────── */

  .ph-panel {
    position: static;
    padding: 18px 20px 22px;
    background: var(--dark-100);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    order: 10; /* ensure panel appears after photograph in flex order */
  }

  .ph-heading {
    font-size: clamp(24px, 6.5vw, 32px);
    margin-bottom: 10px;
  }

  /* Body: visible but bounded to 2 lines — mobile context demands brevity */
  .ph-body {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 13px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.72);
    margin-bottom: 0;
  }
  .ph-body--home { margin-bottom: 16px; }

  /* CTAs: both restored — the editorial band has room for them */
  .ph-cta-secondary { display: inline-block; font-size: 11px; padding: 10px 20px; }
  .ph-cta-primary   { font-size: 11px; padding: 11px 22px; }

  /* ── STATS BAND (About variant) ──────────────────────────────── */
  .stat-item         { flex: 1 0 50%; padding: 12px 16px; }
  .stat-item:nth-child(3n)   { border-right: 1px solid var(--hairline); }
  .stat-item:nth-child(even) { border-right: none; }
  .stat-value        { font-size: 17px; }
}

/* ═══════════════════════════════════════════════════════════════
   ABOUT-SPECIFIC: photo credit bar + stats band below frame
   ═══════════════════════════════════════════════════════════════ */
.photo-credit-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--s-3);
  background: var(--surface-1);
  border-top: 1px solid var(--hairline);
  padding: 12px 20px;
}
.photo-credit-bar__caption {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--ink-400);
  letter-spacing: 0.06em;
}
.photo-credit-bar__right {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}
.photo-credit-bar__by {
  font-family: var(--font-mono);
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--ink-400);
}
.photo-credit-bar__name {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--gold-600);
  font-weight: 500;
  letter-spacing: 0.04em;
  text-decoration: none;
}
.photo-credit-bar__name:hover { text-decoration: underline; }
@media (max-width: 480px) {
  .photo-credit-bar { flex-direction: column; align-items: flex-start; gap: 6px; }
}

.stats-band {
  display: flex;
  background: var(--surface-1);
  border-top: 1px solid var(--hairline);
}
.stat-item {
  flex: 1;
  padding: 18px 24px;
  border-right: 1px solid var(--hairline);
}
.stat-item:last-child { border-right: none; }
.stat-item--wide { flex: 2; }
.stat-label {
  font-family: var(--font-mono);
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--ink-400);
  margin-bottom: 5px;
}
.stat-value {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: var(--weight-bold);
  color: var(--ink-900);
  letter-spacing: -0.01em;
}
.stat-value--gold { color: var(--gold-600); }
.stat-pending { color: var(--ink-400); font-size: 18px; }

/* ═══════════════════════════════════════════════════════════════
   STANDARD VARIANT (Showcase, Activities — text below image)
   ═══════════════════════════════════════════════════════════════ */
.page-hero {
  padding-top: calc(var(--nav-h) + var(--s-6));
  padding-bottom: var(--s-4);
}
.page-hero-banner-wrap {
  margin-bottom: var(--s-6);
  border: 1px solid var(--hairline);
  overflow: hidden;
  position: relative;
  aspect-ratio: 16 / 5;
}
.page-hero-banner-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.page-hero-banner-wrap .hero-credit {
  position: absolute;
  bottom: 12px;
  right: 16px;
  display: flex;
  align-items: center;
  gap: 6px;
  background: rgba(20, 18, 16, 0.6);
  padding: 3px 8px;
}
.page-hero__title {
  font-family: var(--font-display);
  font-size: var(--text-h1);
  font-weight: 700;
  color: var(--ink-900);
  letter-spacing: var(--ls-h1);
  line-height: var(--lh-h1);
  margin-top: var(--s-1);
  margin-bottom: var(--s-2);
}
.page-hero__meta {
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  color: var(--ink-600);
  line-height: 1.65;
}
.page-hero__date {
  font-family: var(--font-mono);
  font-size: var(--text-caption);
