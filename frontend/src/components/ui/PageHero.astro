    135deg,
    #1A1816 0px, #1A1816 32px,
    #141210 32px, #141210 64px
  );
}
.journal-hero__photo {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  opacity: 0;
  transition: opacity 0.6s ease;
}
.journal-hero__photo.loaded { opacity: 1; }

/* Minimal depth gradient — editorial panel provides text contrast */
.journal-hero__gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 55%, rgba(20, 18, 16, 0.12) 100%);
  pointer-events: none;
}

/* Editorial text panel */
.journal-hero__overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 22px 48px 28px;
  background: rgba(20, 18, 16, 0.26);
  -webkit-backdrop-filter: blur(6px) saturate(1.1);
  backdrop-filter: blur(6px) saturate(1.1);
}
.journal-hero__kicker {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-light);
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.journal-hero__kicker-line {
  display: block;
  width: 20px;
  height: 1px;
  background: var(--gold-light);
  flex-shrink: 0;
}
.journal-hero__title {
  font-family: var(--font-display);
  font-size: clamp(32px, 4vw, 64px);
  font-weight: 700;
  letter-spacing: -0.03em;
  color: #FFFFFF;
  line-height: 0.98;
  margin-bottom: 16px;
  text-wrap: pretty;
  text-shadow: 0 1px 3px rgba(0, 0, 0, 0.30);
}
.journal-hero__copy {
  font-size: 15px;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.82);
  max-width: 580px;
  font-weight: 300;
}
.journal-hero__credit {
  position: absolute;
  bottom: 14px;
  right: 18px;
  display: flex;
  align-items: center;
  gap: 6px;
  z-index: 1;
}
.journal-hero__credit-label {
  font-family: var(--font-mono);
  font-size: 9px;
  color: rgba(255, 255, 255, 0.35);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.journal-hero__credit-name {
  font-family: var(--font-mono);
  font-size: 9px;
  color: rgba(255, 255, 255, 0.60);
  letter-spacing: 0.06em;
}

/* Unified responsive cascade — 900 → 768 → 540px */
@media (max-width: 900px) {
  .journal-hero__frame { aspect-ratio: 16 / 9; min-height: 280px; }
  .journal-hero__overlay { padding: 18px 32px 22px; }
  .journal-hero__copy { font-size: 14px; max-width: 100%; }
}
@media (max-width: 768px) {
  .journal-hero__frame { aspect-ratio: 16 / 9; min-height: 300px; }
  .journal-hero__overlay { padding: 16px 24px 20px; }
  .journal-hero__copy { display: none; }
}
@media (max-width: 540px) {
  .journal-hero__frame { aspect-ratio: unset; min-height: 320px; }
  .journal-hero__photo { object-fit: contain; } /* preserve composition on portrait/square photos */
  .journal-hero__overlay { padding: 14px 16px 18px; }
}

/* Standard PageHero Styles */
.page-hero {
  padding-top: calc(var(--nav-h) + var(--s-6));
  padding-bottom: var(--s-4);
}
.page-hero-banner-wrap {
  margin-bottom: var(--s-6);
  border: 1px solid var(--hairline);
  overflow: hidden;
  position: relative;
  aspect-ratio: 16 / 5;
}
.page-hero-banner-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.page-hero-banner-wrap .hero-credit {
  position: absolute;
  bottom: 12px;
  right: 16px;
  display: flex;
  align-items: center;
  gap: 6px;
  background: rgba(20, 18, 16, 0.6);
  padding: 3px 8px;
}
.page-hero__title {
  font-family: var(--font-display);
  font-size: var(--text-h1);
  font-weight: 700;
  color: var(--ink-900);
  letter-spacing: var(--ls-h1);
  line-height: var(--lh-h1);
  margin-top: var(--s-1);
  margin-bottom: var(--s-2);
}
.page-hero__meta {
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  color: var(--ink-600);
  line-height: 1.65;
}
.page-hero__date {
  font-family: var(--font-mono);
  font-size: var(--text-caption);
  color: var(--ink-400);
  letter-spacing: var(--ls-mono);
}

/* About Hero Styles (Overlay) */
.about-hero {
  padding-top: var(--nav-h, 64px);
  padding-bottom: var(--s-5);
  background: var(--surface-0);
}
.hero-frame-wrap {
  border: 1px solid var(--hairline);
  overflow: hidden;
}
.hero-frame {
  position: relative;
  aspect-ratio: 16 / 5;
  overflow: hidden;
}
.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

/* Minimal depth gradient — editorial panel provides text contrast */
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 55%, rgba(20, 18, 16, 0.12) 100%);
}

/* Editorial text panel */
.hero-text {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 22px 48px 28px;
  background: rgba(20, 18, 16, 0.26);
  -webkit-backdrop-filter: blur(6px) saturate(1.1);
  backdrop-filter: blur(6px) saturate(1.1);
}
.hero-eyebrow {
  font-family: var(--font-body);
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-500);
  font-weight: var(--weight-semibold);
  margin-bottom: 12px;
}
.hero-title {
  font-family: var(--font-display);
  font-size: clamp(32px, 3.8vw, 52px);
  font-weight: var(--weight-bold);
  letter-spacing: -0.03em;
  color: #ffffff;
  line-height: 1.0;
  margin-bottom: 14px;
  text-shadow: 0 1px 3px rgba(0, 0, 0, 0.30);
}
.hero-intro {
  font-family: var(--font-body);
  font-size: 15px;
  line-height: 1.75;
  color: rgba(255, 255, 255, 0.82);
  max-width: 540px;
  font-weight: 300;
}

/* Photographer attribution shared styles */
.hero-credit {
  position: absolute;
  bottom: 16px;
  right: 20px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.hero-credit__label {
  font-family: var(--font-mono);
  font-size: 9px;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.hero-credit__name {
  font-family: var(--font-mono);
  font-size: 9px;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 0.06em;
}

/* Photo Credit Bar styles (when rendered below image) */
.photo-credit-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--s-3);
  background: var(--surface-1);
  border-top: 1px solid var(--hairline);
  padding: 12px 20px;
}
.photo-credit-bar__caption {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--ink-400);
  letter-spacing: 0.06em;
}
.photo-credit-bar__right {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}
.photo-credit-bar__by {
  font-family: var(--font-mono);
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--ink-400);
}
.photo-credit-bar__name {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--gold-600);
  font-weight: 500;
  letter-spacing: 0.04em;
  text-decoration: none;
}
.photo-credit-bar__name:hover {
  text-decoration: underline;
}

@media (max-width: 480px) {
  .photo-credit-bar {
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }
}

/* Stats band */
.stats-band {
  display: flex;
  background: var(--surface-1);
  border-top: 1px solid var(--hairline);
}
.stat-item {
  flex: 1;
  padding: 18px 24px;
  border-right: 1px solid var(--hairline);
}
.stat-item:last-child {
  border-right: none;
}
.stat-item--wide {
  flex: 2;
}
.stat-label {
  font-family: var(--font-mono);
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--ink-400);
  margin-bottom: 5px;
}
.stat-value {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: var(--weight-bold);
  color: var(--ink-900);
  letter-spacing: -0.01em;
}
.stat-value--gold {
  color: var(--gold-600);
}
.stat-pending {
  color: var(--ink-400);
  font-size: 18px;
}

/* Project Hero Styles (Full bleed) */
.ph-hero {
  position: relative;
