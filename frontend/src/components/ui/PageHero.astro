---
import { getPhotographerProfileUrl } from '../../data/photoRegistry';

/**
 * PageHero.astro — Consolidated page hero for all BCC pages.
 * Supports standard text/banner, overlay (About page), and project (Special Projects) layouts.
 */
interface StatItem {
  label: string;
  value?: string | number;
  isWide?: boolean;
  target?: number;
}

interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  meta?: string;

  // Dynamic or static hero image & attribution
  heroImage?: string;
  heroCredit?: string;

  // Stats band (optional, for About style pages)
  stats?: StatItem[];

  // Layout variants: 'standard' | 'overlay' | 'project' | 'home' | 'journal'
  variant?: 'standard' | 'overlay' | 'project' | 'home' | 'journal';

  // Home variant CTAs
  primaryCtaText?: string;
  primaryCtaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  meta,
  heroImage,
  heroCredit,
  stats,
  variant = 'standard',
  primaryCtaText = 'Become a Member →',
  primaryCtaHref = '/join/',
  secondaryCtaText = 'Browse the Gallery',
  secondaryCtaHref = '/showcase/',
} = Astro.props;
---

{variant === 'overlay' && (
  <div class="about-hero" id="page-hero-container">
    <div class="container">
      <div class="hero-frame-wrap" data-gsap="image-reveal">
        <div class="hero-frame">
          <img
            id="page-hero-img"
            src={heroImage}
            alt={title}
            class="hero-img"
            loading="eager"
            fetchpriority="high"
          />
          <div class="hero-overlay" aria-hidden="true"></div>
          <div class="hero-text">
            <div class="hero-eyebrow">{eyebrow}</div>
            <h1 class="hero-title" set:html={title}></h1>
            <p class="hero-intro">{subtitle}</p>
          </div>
        </div>

        <div class="photo-credit-bar" id="page-hero-credit" style={heroCredit ? "" : "display: none;"}>
          <span class="photo-credit-bar__caption" id="page-hero-credit-caption">Taj-ul-Masajid at night · Bhopal</span>
          <span class="photo-credit-bar__right">
            <span class="photo-credit-bar__by">Photo by</span>
            <a href={heroCredit ? getPhotographerProfileUrl(heroCredit) : "#"} class="photo-credit-bar__name" id="page-hero-credit-name-link">
              <span id="page-hero-credit-name">{heroCredit}</span>
            </a>
          </span>
        </div>

        {stats && stats.length > 0 && (
          <div class="stats-band" aria-label="Club statistics">
            {stats.map(s => (
              <div class={`stat-item ${s.isWide ? 'stat-item--wide' : ''}`}>
                <div class="stat-label">{s.label}</div>
                <div class={`stat-value ${s.isWide ? 'stat-value--gold' : ''}`}>
                  {s.value === undefined ? (
                    <span class="stat-pending">—</span>
                  ) : s.target !== undefined ? (
                    <span data-gsap="counter" data-target={s.target}>{s.value}</span>
                  ) : (
                    <span>{s.value}</span>
                  )}
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
)}

{variant === 'project' && (
  <div class="ph-hero" id="page-hero-container" data-gsap="image-reveal">
    <img
      class="ph-hero-img"
      id="page-hero-img"
      src={heroImage}
      alt={`${title} — BCC Special Project`}
      loading="eager"
      decoding="async"
      style={heroImage ? "" : "display: none;"}
    />
    <div class="ph-hero-gradient" aria-hidden="true"></div>
    <div class="ph-hero-content">
      <div class="ph-kicker">
        <span class="ph-kicker-line" aria-hidden="true"></span>
        {eyebrow}
      </div>
      <h1 class="ph-title">{title}</h1>
      <p class="ph-desc">{subtitle}</p>
    </div>
    <div class="hero-credit" id="page-hero-credit" style={heroCredit ? "position: absolute; bottom: 16px; right: 20px; display: flex; align-items: center; gap: 6px; z-index: 10;" : "display: none; position: absolute; bottom: 16px; right: 20px; align-items: center; gap: 6px; z-index: 10;"}>
      <span class="hero-credit__label" style="font-family: var(--font-mono); font-size: 9px; color: rgba(255, 255, 255, 0.4); letter-spacing: 0.08em; text-transform: uppercase;">Photo by</span>
      <span class="hero-credit__name" id="page-hero-credit-name" style="font-family: var(--font-mono); font-size: 9px; color: rgba(255, 255, 255, 0.6); letter-spacing: 0.06em;">{heroCredit}</span>
    </div>
  </div>
)}

{variant === 'home' && (
  <div class="home-hero" id="page-hero-container">
    <div class="container">
      <div class="home-hero__frame" data-gsap="image-reveal">
        <div class="home-hero__placeholder" id="home-hero-fallback" aria-hidden="true"></div>
        <img
          id="home-hero-img"
          src=""
          alt=""
          class="home-hero__photo"
          loading="eager"
          decoding="async"
          aria-hidden="true"
        />
        <div class="home-hero__gradient" aria-hidden="true"></div>
        <div class="home-hero__overlay">
          <div class="home-hero__kicker" id="home-hero-kicker">
            <span class="home-hero__kicker-line" aria-hidden="true"></span>
            <span id="home-hero-kicker-text">{eyebrow}</span>
          </div>
          <h1 class="home-hero__title">{title}</h1>
          <p class="home-hero__copy">{subtitle}</p>
          <div class="home-hero__ctas">
            <a href={primaryCtaHref} class="home-hero__cta-primary">{primaryCtaText}</a>
            <a href={secondaryCtaHref} class="home-hero__cta-secondary">{secondaryCtaText}</a>
          </div>
        </div>
        <div class="home-hero__credit" id="home-hero-credit" style="display: none;">
          <span class="home-hero__credit-label">Photo by</span>
          <span class="home-hero__credit-name" id="home-hero-credit-name"></span>
        </div>
      </div>
    </div>
  </div>
)}

{variant === 'journal' && (
  <div class="journal-hero" id="page-hero-container">
    <div class="container">
      <div class="journal-hero__frame" data-gsap="image-reveal">
        <div class="journal-hero__placeholder" id="journal-hero-fallback" aria-hidden="true"></div>
        <img
          id="page-hero-img"
          src=""
          alt=""
          class="journal-hero__photo"
          loading="eager"
          decoding="async"
        />
        <div class="journal-hero__gradient" aria-hidden="true"></div>
        <div class="journal-hero__overlay">
          <div class="journal-hero__kicker">
            <span class="journal-hero__kicker-line" aria-hidden="true"></span>
            <span>{eyebrow}</span>
          </div>
          <h1 class="journal-hero__title">{title}</h1>
          <p class="journal-hero__copy">{subtitle}</p>
        </div>
        <div class="journal-hero__credit" id="page-hero-credit" style="display: none;">
          <span class="journal-hero__credit-label">Photo by</span>
          <span class="journal-hero__credit-name" id="page-hero-credit-name"></span>
        </div>
      </div>
    </div>
  </div>
)}

{variant === 'standard' && (
  <div class="page-hero surface-white" id="page-hero-container">
    <div class="container">
      {heroImage && (
        <div class="page-hero-banner-wrap" id="page-hero-banner">
          <img id="page-hero-img" src={heroImage} alt={title} />
          {heroCredit && (
            <div class="hero-credit" id="page-hero-credit">
              <span class="hero-credit__label">Photo by</span>
              <span class="hero-credit__name" id="page-hero-credit-name">{heroCredit}</span>
            </div>
          )}
        </div>
      )}
      <span class="eyebrow">{eyebrow}</span>
      <h1 class="page-hero__title"><slot name="title">{title}</slot></h1>
      <p class="page-hero__meta">
        {subtitle}
        {meta && <><br /><span class="page-hero__date">{meta}</span></>}
      </p>
    </div>
    <div class="hairline"></div>
  </div>
)}

<style>
/* ── Home Hero (variant="home") ── */
.home-hero {
  padding-top: var(--nav-h);
  background: var(--surface-1);
}
.home-hero__frame {
  position: relative;
  aspect-ratio: 16 / 5;
  overflow: hidden;
  border: 1px solid var(--hairline);
  background: var(--dark-100);
  margin-bottom: 0;
}
.home-hero__placeholder {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    135deg,
    #1A1816 0px, #1A1816 32px,
    #1E1C1A 32px, #1E1C1A 64px
  );
}
.home-hero__photo {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  opacity: 0;
  transition: opacity 0.8s ease;
}
.home-hero__photo.loaded { opacity: 1; }

/* Minimal depth gradient — editorial panel provides text contrast */
.home-hero__gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 55%, rgba(20, 18, 16, 0.12) 100%);
  pointer-events: none;
}

/* Editorial text panel — translucent, blurs photo through it (approved backdrop-filter for hero readability) */
.home-hero__overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 22px 48px 28px;
  background: rgba(20, 18, 16, 0.26);
  -webkit-backdrop-filter: blur(6px) saturate(1.1);
  backdrop-filter: blur(6px) saturate(1.1);
}
.home-hero__kicker {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-light);
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.home-hero__kicker-line {
  display: block;
  width: 20px;
  height: 1px;
  background: var(--gold-light);
  flex-shrink: 0;
}
.home-hero__title {
  font-family: var(--font-display);
  font-size: clamp(32px, 3.8vw, 52px);
  font-weight: 700;
  letter-spacing: -0.03em;
  color: #FFFFFF;
  line-height: 1.0;
  margin-bottom: 14px;
  text-wrap: pretty;
  text-shadow: 0 1px 3px rgba(0, 0, 0, 0.30);
}
.home-hero__copy {
  font-size: 15px;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.82);
  max-width: 520px;
  font-weight: 300;
  margin-bottom: 22px;
}
.home-hero__ctas {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  align-items: center;
}
.home-hero__cta-primary {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--ink-900) !important;
  background: var(--gold-gradient);
  padding: 13px 30px;
  display: inline-block;
  border-radius: 2px;
  text-decoration: none;
  box-shadow: 0 2px 10px rgba(168, 132, 60, 0.30);
  transition: opacity var(--m-fast);
}
.home-hero__cta-primary:hover { opacity: 0.9; }
.home-hero__cta-secondary {
  font-size: 12px;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.9) !important;
  border: 1px solid rgba(255, 255, 255, 0.35);
  padding: 12px 26px;
  display: inline-block;
  border-radius: 2px;
  text-decoration: none;
  transition: background var(--m-fast);
}
.home-hero__cta-secondary:hover { background: rgba(255, 255, 255, 0.08); }
.home-hero__credit {
  position: absolute;
  bottom: 14px;
  right: 18px;
  display: flex;
  align-items: center;
  gap: 6px;
  z-index: 1;
}
.home-hero__credit-label {
  font-family: var(--font-mono);
  font-size: 9px;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.home-hero__credit-name {
  font-family: var(--font-mono);
  font-size: 9px;
  color: rgba(255, 255, 255, 0.65);
  letter-spacing: 0.06em;
}

/* Unified responsive cascade — 900 → 768 → 540px (shared with journal and overlay) */
@media (max-width: 900px) {
  .home-hero__frame { aspect-ratio: 16 / 7; min-height: 280px; }
  .home-hero__overlay { padding: 18px 32px 22px; }
  .home-hero__copy { font-size: 14px; max-width: 100%; }
}
@media (max-width: 768px) {
  .home-hero__frame { aspect-ratio: 16 / 8; min-height: 300px; }
  .home-hero__overlay { padding: 16px 24px 20px; }
}
@media (max-width: 540px) {
  .home-hero__frame { aspect-ratio: unset; min-height: 320px; }
  .home-hero__photo { object-fit: contain; } /* preserve composition on portrait/square photos */
  .home-hero__overlay { padding: 14px 16px 18px; }
  .home-hero__copy { display: none; }
  .home-hero__cta-secondary { display: none; }
}

/* ── Journal Hero (variant="journal") — 16:9, editorial overlay, no CTA ── */
.journal-hero {
  padding-top: var(--nav-h);
  background: var(--surface-1);
}
.journal-hero__frame {
  position: relative;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  border: 1px solid var(--hairline);
  background: var(--dark-100);
}
.journal-hero__placeholder {
  position: absolute;
  inset: 0;
