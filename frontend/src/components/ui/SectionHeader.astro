---
/**
 * SectionHeader.astro — Eyebrow + title + optional subtitle.
 * Light editorial system: dark ink on light surfaces.
 */
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  as?: 'h1' | 'h2' | 'h3';
  align?: 'left' | 'center';
  spacing?: 'sm' | 'md' | 'lg';
  'data-gsap'?: string;
  class?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  as: Tag = 'h2',
  align = 'left',
  spacing = 'md',
  'data-gsap': dataGsap,
  class: cls = '',
} = Astro.props;
---

<div
  class:list={['sec-header', `sec-header--${align}`, `sec-header--${spacing}`, cls]}
  data-gsap={dataGsap}
>
  {eyebrow && <div class="eyebrow">{eyebrow}</div>}
  <Tag class="sec-header__title">{title}</Tag>
  {subtitle && <p class="sec-header__sub">{subtitle}</p>}
</div>

<style>
.sec-header { max-width: 600px; }
.sec-header--center { margin: 0 auto; text-align: center; }
.sec-header--left    { text-align: left; }

.sec-header--sm  { margin-bottom: var(--s-4); }
.sec-header--md  { margin-bottom: var(--s-6); }
.sec-header--lg  { margin-bottom: var(--s-8); }

.sec-header__title {
  font-family: var(--font-display);
  font-size: var(--text-h2);
  font-weight: 700;
  letter-spacing: -0.015em;
  line-height: 1.15;
  color: var(--ink-900);
}
:global(h1).sec-header__title {
  font-size: var(--text-h1);
  letter-spacing: -0.025em;
  line-height: 1.05;
}
.sec-header__sub {
  margin-top: var(--s-2);
  font-size: var(--text-body);
  color: var(--ink-600);
  line-height: 1.75;
  max-width: 520px;
}
.sec-header--center .sec-header__sub { margin-left: auto; margin-right: auto; }
</style>
