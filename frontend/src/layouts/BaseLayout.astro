---
/**
 * BaseLayout.astro — HTML shell for all public pages.
 * Imports design system CSS. Preloads fonts. Includes Nav + Footer.
 * Accessibility: skip link, aria-label on main.
 */
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/tokens.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  bodyClass?: string;
}

const {
  title,
  description = 'Bhopal Camera Club — photography community since 2016. Events, exhibitions, workshops, and a curated portfolio of member work.',
  ogImage = '/images/og-default.jpg',
  bodyClass = '',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://v3bcc.bhopal.info');
const fullTitle = `${title} | Bhopal Camera Club`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalURL.toString()} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={new URL(ogImage, Astro.site ?? 'https://v3bcc.bhopal.info').toString()} />
  <meta property="og:site_name"   content="Bhopal Camera Club" />
  <meta name="twitter:card"       content="summary_large_image" />

  <link rel="canonical" href={canonicalURL.toString()} />

  <!-- Favicon — real BCC aperture mark -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate icon" type="image/x-icon" href="/favicon.ico" />

  <!-- Fonts — preconnect then load Outfit + Inter + JetBrains Mono -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&family=Inter:ital,wght@0,300;0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500;600&display=swap"
    rel="stylesheet"
  />

  <title>{fullTitle}</title>
</head>
<body class={bodyClass}>

  <!-- Accessibility: skip to main content -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <Nav />

  <main id="main-content" tabindex="-1">
    <slot />
  </main>

  <Footer />

  <style is:global>
    body.bcc-is-authenticated .auth-hide,
    body.bcc-is-authenticated .guest-only {
      display: none !important;
    }
  </style>

  <script>
    try {
      if (localStorage.getItem('bcc_user')) {
        document.body.classList.add('bcc-is-authenticated');
      }
    } catch (e) {}
  </script>

  <!-- Central GSAP initialiser — runs after all page content is in DOM -->
  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    /**
     * data-gsap="reveal"
     * Fade + 24px rise on scroll entry — used on section headers, cards, etc.
     */
    document.querySelectorAll<HTMLElement>('[data-gsap="reveal"]').forEach((el) => {
      gsap.to(el, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 85%', once: true },
      });
    });

    /**
     * data-gsap="stagger"
     * Cascades children with --m-stagger (80ms) between each.
     */
    document.querySelectorAll<HTMLElement>('[data-gsap="stagger"]').forEach((parent) => {
      const children = parent.children;
      gsap.to(children, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        ease: 'power2.out',
        stagger: 0.08,
        scrollTrigger: { trigger: parent, start: 'top 85%', once: true },
      });
    });

    /**
     * data-gsap="counter"
     * Animates a numeric text value from 0 to its data-target on scroll entry.
     * Use: <span data-gsap="counter" data-target="311">311</span>
     */
    document.querySelectorAll<HTMLElement>('[data-gsap="counter"]').forEach((el) => {
      const target = parseFloat(el.dataset.target ?? el.textContent ?? '0');
      const suffix = el.dataset.suffix ?? '';
      const counter = { val: 0 };
      gsap.to(counter, {
        val: target,
        duration: 1.4,
        ease: 'power1.inOut',
        scrollTrigger: { trigger: el, start: 'top 85%', once: true },
        onUpdate: () => {
          el.textContent = Math.round(counter.val).toLocaleString('en-IN') + suffix;
        },
      });
    });

    /**
     * data-gsap="image-reveal"
     * Clip-path wipe from bottom to top — for featured / hero images.
     */
    document.querySelectorAll<HTMLElement>('[data-gsap="image-reveal"]').forEach((el) => {
      gsap.fromTo(el,
        { clipPath: 'inset(100% 0% 0% 0%)' },
        {
          clipPath: 'inset(0% 0% 0% 0%)',
          duration: 1.1,
          ease: 'expo.out',
          scrollTrigger: { trigger: el, start: 'top 90%', once: true },
        }
      );
    });

    /**
     * data-gsap="parallax-soft"
     * Background drifts at 0.92× scroll speed — subtle depth for full-bleed bands.
     */
    document.querySelectorAll<HTMLElement>('[data-gsap="parallax-soft"]').forEach((el) => {
      gsap.to(el, {
        yPercent: -8,
        ease: 'none',
        scrollTrigger: {
          trigger: el,
          start: 'top bottom',
          end: 'bottom top',
          scrub: true,
        },
      });
    });

    /**
     * data-gsap="aperture-spin"
     * Slow continuous rotation — for any aperture decorative mark.
     */
    document.querySelectorAll<HTMLElement>('[data-gsap="aperture-spin"]').forEach((el) => {
      gsap.to(el, { rotation: 360, duration: 40, repeat: -1, ease: 'none' });
    });
  </script>

</body>
</html>
