---
/**
 * HubLayout.astro -- Auth-gated layout for /hub/* pages.
 *
 * Behaviour:
 *   - Renders the full page server-side (SSG).
 *   - Client script checks for bcc_token in localStorage.
 *   - If absent or expired: attempts silent token refresh using bcc_refresh.
 *   - If refresh fails: redirects to /auth/signin/?next=<current-path>.
 *   - If valid: shows hub content and populates greeting from /api/v1/users/me.
 *
 * Slot: page content (rendered inside hub-shell, hidden until auth confirmed).
 */
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}

const { title, description, bodyClass = '' } = Astro.props;
---

<BaseLayout title={title} description={description} bodyClass={`hub-page ${bodyClass}`}>

  <!-- Hidden until client confirms auth -->
  <div id="hub-shell" class="hub-shell" style="display:none">
    <slot />
  </div>

  <!-- Shown while checking auth -->
  <div id="hub-loading" class="hub-loading" aria-live="polite">
    <span class="hub-loading__dot"></span>
    <span class="hub-loading__dot"></span>
    <span class="hub-loading__dot"></span>
  </div>

</BaseLayout>

<style>
/* Hub page overrides */
.hub-shell { min-height: 60vh; }

/* Auth-check loading dots */
.hub-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  min-height: 40vh;
  padding: var(--s-12) 0;
}
.hub-loading[hidden] { display: none; }

.hub-loading__dot {
  width: 8px; height: 8px;
  background: var(--hairline-strong);
  border-radius: var(--r-full);
  animation: hub-pulse 1.2s ease-in-out infinite both;
}
.hub-loading__dot:nth-child(2) { animation-delay: 0.2s; }
.hub-loading__dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes hub-pulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40%           { transform: scale(1);   opacity: 1;   }
}
</style>

<script>
  const API = '/api/v1';

  async function getValidToken(): Promise<string | null> {
    const token = localStorage.getItem('bcc_token');
    if (!token) return null;

    // Decode JWT payload (base64url -- no signature verification here,
    // the server validates on every request)
    try {
      const payload = JSON.parse(atob(token.split('.')[1].replace(/-/g, '+').replace(/_/g, '/')));
      const expiresAt = (payload.exp as number) * 1000;

      // Still valid for >60 s: use it as-is
      if (Date.now() < expiresAt - 60_000) return token;

      // Expired (or expiring soon): try refresh
      const refresh = localStorage.getItem('bcc_refresh');
      if (!refresh) return null;

      const res = await fetch(`${API}/auth/refresh`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ refreshToken: refresh }),
      });
      if (!res.ok) { clearAuth(); return null; }

      const data = await res.json() as { accessToken: string; refreshToken: string };
      localStorage.setItem('bcc_token', data.accessToken);
      localStorage.setItem('bcc_refresh', data.refreshToken);
      return data.accessToken;
    } catch {
      return null;
    }
  }

  function clearAuth(): void {
    localStorage.removeItem('bcc_token');
    localStorage.removeItem('bcc_refresh');
    localStorage.removeItem('bcc_user');
  }

  async function initHub(): Promise<void> {
    const token = await getValidToken();
    if (!token) {
      const next = encodeURIComponent(window.location.pathname + window.location.search);
      window.location.replace(`/auth/signin/?next=${next}`);
      return;
    }

    // Show hub content
    const shell = document.getElementById('hub-shell');
    const loading = document.getElementById('hub-loading');
    if (shell)   shell.style.display = '';
    if (loading) loading.hidden = true;

    // Refresh bcc_user in localStorage (in case display name changed)
    try {
      const res = await fetch(`${API}/users/me`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      if (res.ok) {
        const user = await res.json() as { fullName?: string; username?: string; ui?: { portalState: string } };
        if (user.fullName) {
          const initials = user.fullName.trim().split(/\s+/).map((w: string) => w[0]).join('').slice(0, 2).toUpperCase();
          localStorage.setItem('bcc_user', JSON.stringify({
            displayName: user.fullName,
            initials,
            username: user.username || '',
            ui: user.ui,
          }));
        }
      }
    } catch { /* non-critical */ }
  }

  initHub();
</script>
