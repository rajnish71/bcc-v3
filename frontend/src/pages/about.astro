---
/**
 * about.astro — /about
 * V6 02 About — "The Story of Bhopal Camera Club"
 * Implements Design Authority V6 02 About.dc.html exactly.
 * 10 sections, all unconditional.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutHero from '../components/about/AboutHero.astro';
import AboutPhilosophy from '../components/about/AboutPhilosophy.astro';
import AboutPillars from '../components/about/AboutPillars.astro';
import AboutJourney from '../components/about/AboutJourney.astro';
import AboutWhyBhopal from '../components/about/AboutWhyBhopal.astro';
import AboutTrust from '../components/about/AboutTrust.astro';
import AboutLeadership from '../components/about/AboutLeadership.astro';
import AboutMentors from '../components/about/AboutMentors.astro';
import AboutCommunityInvitation from '../components/about/AboutCommunityInvitation.astro';

// TODO: Replace with live API values when stats endpoints are available
// e.g. fetch('http://localhost:3001/api/v1/stats') → { members, activities, photos }
const membersCount: number | undefined = undefined;
const activitiesCount: number | undefined = undefined;
const photosCount: number | undefined = undefined;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'The Story of Bhopal Camera Club',
  description: 'Bhopal Camera Club — a registered photography society in Bhopal since 2015. Our story, our philosophy, our journey, and our community.',
  url: 'https://bcc.bhopal.info/about/',
  mainEntity: {
    '@type': 'Organization',
    name: 'Bhopal Camera Club',
    foundingDate: '2015',
    memberOf: {
      '@type': 'Organization',
      name: 'Federation of Indian Photography',
      identifier: 'CM1098',
    },
  },
};
---

<BaseLayout
  title="The Story of Bhopal Camera Club"
  description="Bhopal Camera Club — a registered photography society since 2015. Our story, our journey, our philosophy, and the community behind a decade of documenting Bhopal."
  bodyClass="about-page"
  jsonLd={jsonLd}
>

  <!-- 1. Hero — full-width photograph + stats band -->
  <AboutHero
    membersCount={membersCount}
    activitiesCount={activitiesCount}
    photosCount={photosCount}
  />

  <!-- 2. Our Philosophy — mission, vision, display quote -->
  <AboutPhilosophy />

  <!-- 3. Three Pillars — Community · Craft · City -->
  <section class="section-gap">
    <AboutPillars />
  </section>

  <!-- 4. Our Journey — interactive chapter timeline -->
  <AboutJourney />

  <!-- 5. Why Bhopal — full-width editorial feature -->
  <AboutWhyBhopal />

  <!-- 6. Trust & Recognition — registered society + FIP -->
  <AboutTrust />

  <!-- 7. Leadership — coordinator profiles -->
  <AboutLeadership />

  <!-- 8. Learning From Masters — mentor profiles -->
  <AboutMentors />

  <!-- 9. Community Invitation — photograph + CTAs -->
  <AboutCommunityInvitation />

</BaseLayout>

<style>
/* Reset top padding — hero handles its own padding-top (nav height) */
:global(.about-page main) {
  padding-top: 0;
}

/* Nav at rest — transparent over ivory page background; dark ink links (default) */
:global(.about-page #site-nav) {
  background: transparent;
  border-bottom-color: transparent;
}

/* Nav condensed (after scroll) — dark glass; switch to white links */
:global(.about-page #site-nav.nav--condensed) {
  background: rgba(20, 18, 16, 0.92);
  border-bottom-color: transparent;
}
:global(.about-page #site-nav.nav--condensed .nav-link) {
  color: rgba(255, 255, 255, 0.85);
}
:global(.about-page #site-nav.nav--condensed .nav-link:hover) {
  color: #ffffff;
}
:global(.about-page #site-nav.nav--condensed .nav-link--active) {
  color: #ffffff;
  border-bottom-color: var(--gold-500);
}
:global(.about-page #site-nav.nav--condensed .nav-logo) {
  filter: brightness(0) invert(1);
}
:global(.about-page #site-nav.nav--condensed .nav-signin) {
  color: rgba(255, 255, 255, 0.8);
}

/* Small gap remover between adjacent sections that share borders */
.section-gap {
  margin: 0;
}
</style>
