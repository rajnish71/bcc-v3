---
/**
 * about.astro — /about
 * V6 02 About — "The Story of Bhopal Camera Club"
 * Implements Design Authority V6 02 About.dc.html exactly.
 * 10 sections, all unconditional.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import { aboutPhotos, photoSrc } from '../data/photoRegistry';
import AboutPhilosophy from '../components/about/AboutPhilosophy.astro';
import AboutPillars from '../components/about/AboutPillars.astro';
import AboutJourney from '../components/about/AboutJourney.astro';
import AboutWhyBhopal from '../components/about/AboutWhyBhopal.astro';
import AboutTrust from '../components/about/AboutTrust.astro';
import AboutLeadership from '../components/about/AboutLeadership.astro';
import AboutMentors from '../components/about/AboutMentors.astro';
import AboutCommunityInvitation from '../components/about/AboutCommunityInvitation.astro';

let membersCount: number | undefined = undefined;
let activitiesCount: number | undefined = undefined;
let photosCount: number | undefined = undefined;

try {
  const res = await fetch('http://localhost:3001/api/v1/stats');
  if (res.ok) {
    const data = await res.json();
    if (data.members    > 0) membersCount    = data.members;
    if (data.activities > 0) activitiesCount = data.activities;
    if (data.photos     > 0) photosCount     = data.photos;
  }
} catch {
  // Backend unavailable at build time — stats band shows "—" fallback
}

const currentYear = new Date().getFullYear();
const yearsCount = currentYear - 2015;

const stats = [
  { label: 'Established', value: '2015' },
  { label: 'Registered', value: 'Oct 2019' },
  { label: 'Members', value: membersCount, target: membersCount },
  { label: 'Activities', value: activitiesCount, target: activitiesCount },
  { label: 'Photographs', value: photosCount, target: photosCount },
  { label: 'Years Documenting Bhopal', value: yearsCount, target: yearsCount, isWide: true }
];

const img = aboutPhotos.hero;
const defaultHeroImg = photoSrc(img, 1360);
const defaultHeroCredit = img.photographer;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'The Story of Bhopal Camera Club',
  description: 'Bhopal Camera Club — a registered photography society in Bhopal since 2015. Our story, our philosophy, our journey, and our community.',
  url: 'https://bcc.bhopal.info/about/',
  mainEntity: {
    '@type': 'Organization',
    name: 'Bhopal Camera Club',
    foundingDate: '2015',
    memberOf: {
      '@type': 'Organization',
      name: 'Federation of Indian Photography',
      identifier: 'CM1098',
    },
  },
};
---

<BaseLayout
  title="The Story of Bhopal Camera Club"
  description="Bhopal Camera Club — a registered photography society since 2015. Our story, our journey, our philosophy, and the community behind a decade of documenting Bhopal."
  bodyClass="about-page"
  jsonLd={jsonLd}
>

  <!-- 1. Hero — full-width photograph + stats band -->
  <PageHero
    variant="overlay"
    eyebrow="Bhopal Camera Club · Est. 2015"
    title="The Story of<br/>Bhopal Camera Club"
    subtitle="We began as a handful of photographers who loved Bhopal and believed the best way to learn was to go out and make photographs together. A decade later, we are a registered society, a community of hundreds, and a growing visual archive of one of India's most photogenic cities."
    heroImage={defaultHeroImg}
    heroCredit={defaultHeroCredit}
    stats={stats}
  />

  <script>
    (async () => {
      try {
        const res = await fetch('/api/v1/gallery/hero/location/about');
        if (res.ok) {
          const photo = await res.json();
          if (photo && photo.urls) {
            const imgEl = document.getElementById('page-hero-img') as HTMLImageElement | null;
            const creditNameEl = document.getElementById('page-hero-credit-name');
            const creditContainer = document.getElementById('page-hero-credit');
            if (imgEl) {
              imgEl.src = photo.urls.original ?? photo.urls.medium ?? '';
              imgEl.alt = photo.title ?? 'About BCC';
            }
            if (creditNameEl) {
              creditNameEl.textContent = photo.photographer ? photo.photographer.name : 'BCC Member';
            }
            if (creditContainer) {
              creditContainer.style.display = 'flex';
            }
          }
        }
      } catch (e) {
        console.error('Failed to load about page hero dynamically', e);
      }
    })();
  </script>

  <!-- 2. Our Philosophy — mission, vision, display quote -->
  <AboutPhilosophy />

  <!-- 3. Three Pillars — Community · Craft · City -->
  <section class="section-gap">
    <AboutPillars />
  </section>

  <!-- 4. Our Journey — interactive chapter timeline -->
  <AboutJourney />

  <!-- 5. Why Bhopal — full-width editorial feature -->
  <AboutWhyBhopal />

  <!-- 6. Trust & Recognition — registered society + FIP -->
  <AboutTrust />

  <!-- 7. Leadership — coordinator profiles -->
  <AboutLeadership />

  <!-- 8. Learning From Masters — mentor profiles -->
  <AboutMentors />

  <!-- 9. Community Invitation — photograph + CTAs -->
  <AboutCommunityInvitation />

</BaseLayout>

<style>
/* Reset top padding — hero handles its own padding-top (nav height) */
:global(.about-page main) {
  padding-top: 0;
}

/* Nav at rest — transparent over ivory page background; dark ink links (default) */
:global(.about-page #site-nav) {
  background: transparent;
  border-bottom-color: transparent;
}

/* Nav condensed (after scroll) — dark glass; switch to white links */
:global(.about-page #site-nav.nav--condensed) {
  background: rgba(20, 18, 16, 0.92);
  border-bottom-color: transparent;
}
:global(.about-page #site-nav.nav--condensed .nav-link) {
  color: rgba(255, 255, 255, 0.85);
}
:global(.about-page #site-nav.nav--condensed .nav-link:hover) {
  color: #ffffff;
}
:global(.about-page #site-nav.nav--condensed .nav-link--active) {
  color: #ffffff;
  border-bottom-color: var(--gold-500);
}
:global(.about-page #site-nav.nav--condensed .nav-logo) {
  filter: brightness(0) invert(1);
}
:global(.about-page #site-nav.nav--condensed .nav-signin) {
  color: rgba(255, 255, 255, 0.8);
}

/* Small gap remover between adjacent sections that share borders */
.section-gap {
  margin: 0;
}
</style>
