---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import { getUpcomingActivities, getPastActivities } from '../lib/services/activity.service';

const TYPES = [
  { value: 'all',         label: 'All' },
  { value: 'photowalk',   label: 'Photowalks' },
  { value: 'workshop',    label: 'Workshops' },
  { value: 'exhibition',  label: 'Exhibitions' },
  { value: 'meetup',      label: 'Meetups' },
];

// Fetch activities through the Service Layer contract
const upcomingActivities = await getUpcomingActivities();
const pastActivities = await getPastActivities();
---

<BaseLayout
  title="Activities"
  description="BCC activities — photowalks, workshops, exhibitions, and meetups across Bhopal."
>

  <PageHero
    eyebrow="Activities"
    title="Events & Activities"
    subtitle="Photowalks, workshops, exhibitions, and community meetups — open to members at every level."
  />

  <div class="container" style="padding-top:var(--s-6);padding-bottom:var(--s-12);">

    <!-- Filter chips -->
    <div class="filter-row" role="group" aria-label="Filter by type" id="type-filters" style="margin-bottom:var(--s-8);">
      {TYPES.map((t, i) => (
        <button
          class:list={['chip', i === 0 && 'active']}
          data-type={t.value}
          aria-pressed={i === 0 ? 'true' : 'false'}
        >
          {t.label}
        </button>
      ))}
    </div>

    <!-- Upcoming -->
    <div class="acts-section">
      <div class="acts-section__head">
        <h2 class="acts-section__title">Upcoming</h2>
        <span class="acts-live" aria-label="Live listing">● Live</span>
      </div>
      <div class="acts-list" id="upcoming-list" aria-label="Upcoming activities">
        {[1,2,3].map(() => (
          <div class="act-row-skel">
            <div class="skel" style="width:52px;height:60px;"></div>
            <div class="skel" style="flex:1;height:60px;"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- Past -->
    <div class="acts-section" style="margin-top:var(--s-12);">
      <div class="acts-section__head">
        <h2 class="acts-section__title">Past Activities</h2>
      </div>
      <div class="acts-list" id="past-list" aria-label="Past activities"></div>
      <div class="acts-load-more" id="load-more-wrap" hidden>
        <button class="btn btn-outline btn-md" id="load-more-btn">Load more</button>
      </div>
    </div>

    <div id="acts-empty" hidden class="acts-empty">
      <p>No activities match this filter.</p>
      <button class="btn btn-outline btn-md" id="clear-filter">Show all</button>
    </div>

  </div>
</BaseLayout>

<style>
.page-hero { padding-top: calc(var(--nav-h) + var(--s-6)); padding-bottom: var(--s-4); }
.filter-row { display: flex; flex-wrap: wrap; gap: var(--s-1); margin-top: var(--s-4); }

.acts-section__head {
  display: flex;
  align-items: center;
  gap: var(--s-2);
  padding-bottom: var(--s-3);
  border-bottom: 2px solid var(--ink-900);
  margin-bottom: var(--s-3);
}
.acts-section__title { font-family: var(--font-display); font-size: var(--text-h3); font-weight: 600; color: var(--ink-400); }
.acts-live { font-family: var(--font-body); font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--forest-600); }

.acts-list { display: flex; flex-direction: column; }

/* Activity row */
.act-row {
  display: grid;
  grid-template-columns: 72px auto 1fr auto;
  align-items: center;
  gap: var(--s-4);
  padding: var(--s-3) 0;
  border-bottom: 1px solid var(--hairline);
  text-decoration: none;
  color: inherit;
  transition: background var(--m-fast);
}
.act-row:first-child { border-top: 1px solid var(--hairline); }
.act-row:hover { background: rgba(201,169,97,.04); }

.act-date { text-align: center; }
.act-date__day   { font-family: var(--font-display); font-size: 30px; font-weight: 700; color: var(--ink-900); line-height: 1; }
.act-date__month { font-size: var(--text-label); font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-400); }

.act-thumb { width: 64px; height: 42px; overflow: hidden; background: var(--surface-2); border-radius: var(--r-0); flex-shrink: 0; }
.act-thumb img { width: 100%; height: 100%; object-fit: cover; }

.act-title { font-family: var(--font-display); font-size: var(--text-h3); font-weight: 600; color: var(--ink-900); }
.act-meta  { font-size: 12px; color: var(--ink-400); margin-top: 3px; }
.act-action { font-size: 12px; font-weight: 600; color: var(--gold-600); white-space: nowrap; }

.act-row-skel {
  display: flex;
  align-items: center;
  gap: var(--s-4);
  padding: var(--s-3) 0;
  border-bottom: 1px solid var(--hairline);
}

.acts-load-more { display: flex; justify-content: center; padding: var(--s-6) 0; }
.acts-empty { display: flex; flex-direction: column; align-items: center; gap: var(--s-4); padding: var(--s-12) 0; text-align: center; color: var(--ink-400); }

@media (max-width: 768px) {
  .act-row { grid-template-columns: 60px 1fr; }
  .act-thumb, .act-action { display: none; }
}
</style>

<script define:vars={{ upcomingActivities, pastActivities }}>
  const TAG_CLASSES = {
    photowalk:  'tag tag-photowalk',
    workshop:   'tag tag-workshop',
    exhibition: 'tag tag-exhibition',
  };

  let currentType = 'all';

  function formatDate(dateStr) {
    const d = new Date(dateStr);
    return { 
      day: d.getDate().toString().padStart(2, '0'), 
      month: d.toLocaleString('en-IN', { month: 'short' }).toUpperCase() 
    };
  }

  function createRow(ev) {
    const a = document.createElement('a');
    a.href = `/activities/${ev.slug ?? ev.id}/`;
    a.className = 'act-row';
    const { day, month } = ev.startDate ? formatDate(ev.startDate) : { day: '—', month: '—' };
    const tc = TAG_CLASSES[ev.category?.toLowerCase()] ?? '';
    a.innerHTML = `
      <div class="act-date"><div class="act-date__day">${day}</div><div class="act-date__month">${month}</div></div>
      <div class="act-thumb">${ev.coverImage ? `<img src="${ev.coverImage}" alt="" loading="lazy" width="64" height="42" />` : ''}</div>
      <div><div class="act-title">${ev.title ?? ''}</div><div class="act-meta">${[ev.duration, ev.venue].filter(Boolean).join(' · ')}</div></div>
      <div class="act-action">Details →</div>
    `;
    return a;
  }

  function loadUpcoming() {
    const list = document.getElementById('upcoming-list');
    if (!list) return;
    
    let filtered = upcomingActivities;
    if (currentType !== 'all') {
      filtered = upcomingActivities.filter(ev => {
        const cat = ev.category.toLowerCase();
        if (currentType === 'photowalk') {
          return cat.includes('walk') || cat.includes('birding') || cat.includes('street') || cat.includes('nature') || cat.includes('landscape');
        }
        return cat.includes(currentType);
      });
    }
    
    list.innerHTML = '';
    if (!filtered.length) {
      list.innerHTML = `<p style="padding:var(--s-4) 0;color:var(--ink-400);font-size:var(--text-small);">No upcoming activities right now. Check back soon!</p>`;
      return;
    }
    filtered.forEach(ev => list.appendChild(createRow(ev)));
  }

  function loadPast(reset = true) {
    const list = document.getElementById('past-list');
    const loadWrap = document.getElementById('load-more-wrap');
    if (!list) return;
    
    if (reset) {
      list.innerHTML = '';
    }
    
    let filtered = pastActivities;
    if (currentType !== 'all') {
      filtered = pastActivities.filter(ev => {
        const cat = ev.category.toLowerCase();
        if (currentType === 'photowalk') {
          return cat.includes('walk') || cat.includes('birding') || cat.includes('street') || cat.includes('nature') || cat.includes('landscape');
        }
        return cat.includes(currentType);
      });
    }
    
    list.innerHTML = '';
    if (!filtered.length) {
      list.innerHTML = `<p style="padding:var(--s-4) 0;color:var(--ink-400);font-size:var(--text-small);">No past activities match this filter.</p>`;
      if (loadWrap) loadWrap.setAttribute('hidden', '');
      return;
    }
    filtered.forEach(ev => list.appendChild(createRow(ev)));
    if (loadWrap) loadWrap.setAttribute('hidden', '');
  }

  async function updateHeroForType(type) {
    let locationKey = 'activities';
    if (type === 'workshop') locationKey = 'workshops';
    else if (type === 'photowalk') locationKey = 'photowalks';
    else if (type === 'contest') locationKey = 'contests';
    else if (type === 'exhibition') locationKey = 'exhibitions';

    try {
      const res = await fetch('/api/v1/gallery/hero/location/' + encodeURIComponent(locationKey));
      const banner = document.getElementById('page-hero-banner');
      const imgEl = document.getElementById('page-hero-img');
      const creditNameEl = document.getElementById('page-hero-credit-name');
      const creditContainer = document.getElementById('page-hero-credit');

      if (res.ok) {
        const photo = await res.json();
        if (photo && photo.urls) {
          if (imgEl && banner) {
            imgEl.src = photo.urls.original || photo.urls.medium || '';
            imgEl.alt = photo.title || 'Activities Hero';
            banner.style.display = 'block';
          }
          if (creditNameEl) {
            creditNameEl.textContent = photo.photographer ? photo.photographer.name : 'BCC Member';
          }
          if (creditContainer) {
            creditContainer.style.display = 'flex';
          }
        }
      } else {
        if (banner) banner.style.display = 'none';
        if (creditContainer) creditContainer.style.display = 'none';
      }
    } catch (e) {
      console.error('Failed to load activities page hero dynamically', e);
    }
  }

  document.querySelectorAll('.chip').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.chip').forEach(b => { 
        b.classList.remove('active'); 
        b.setAttribute('aria-pressed', 'false'); 
      });
      btn.classList.add('active'); 
      btn.setAttribute('aria-pressed', 'true');
      const type = btn.dataset.type ?? 'all';
      currentType = type;

      const url = new URL(window.location.href);
      if (type === 'all') url.searchParams.delete('type');
      else url.searchParams.set('type', type);
      window.history.replaceState({}, '', url);

      updateHeroForType(type);
      loadUpcoming(); 
      loadPast(true);
    });
  });

  document.getElementById('clear-filter')?.addEventListener('click', () => {
    currentType = 'all';
    document.querySelectorAll('.chip').forEach(b => {
      b.classList.toggle('active', b.dataset.type === 'all');
      b.setAttribute('aria-pressed', b.dataset.type === 'all' ? 'true' : 'false');
    });
    const url = new URL(window.location.href);
    url.searchParams.delete('type');
    window.history.replaceState({}, '', url);

    updateHeroForType('all');
    loadUpcoming(); 
    loadPast(true);
  });

  // Initial load alignment
  const params = new URLSearchParams(window.location.search);
  const initialType = params.get('type') || 'all';
  currentType = initialType;
  document.querySelectorAll('.chip').forEach(b => {
    const isAct = b.dataset.type === initialType;
    b.classList.toggle('active', isAct);
    b.setAttribute('aria-pressed', isAct ? 'true' : 'false');
  });

  updateHeroForType(initialType);
  loadUpcoming();
  loadPast(true);
</script>
