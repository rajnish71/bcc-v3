---
/**
 * auth/forgot-password.astro
 * Route: /auth/forgot-password/
 *
 * Accepts either an email address or a username.
 * Posts to POST /api/v1/auth/forgot-password.
 *
 * The endpoint always returns 200 regardless of whether the account
 * exists -- this page shows the same success state either way so the
 * form cannot be used to enumerate accounts.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Forgot Password"
  description="Reset your Bhopal Camera Club account password."
  bodyClass="auth-page"
>
  <section class="auth-section">
    <div class="auth-card" role="main" aria-label="Forgot password">

      <a href="/" class="auth-logo" aria-label="Bhopal Camera Club home">
        <img src="/images/bcc-logo-default.png" alt="Bhopal Camera Club" width="160" height="44" loading="eager" />
      </a>

      <!-- Initial state: form -->
      <div id="fp-form-state">
        <h1 class="auth-heading">Forgot your password?</h1>
        <p class="auth-sub">Enter your email address or username and we will send you a reset link.</p>

        <div id="fp-error" class="auth-banner auth-banner--error" hidden role="alert"></div>

        <div class="auth-field">
          <label class="auth-label" for="identifier">Email or username</label>
          <input
            id="identifier"
            type="text"
            name="identifier"
            class="auth-input"
            placeholder="you@example.com or yourusername"
            autocomplete="email"
            required
          />
        </div>

        <button id="fp-btn" type="button" class="btn btn-dark btn-lg auth-btn">
          Send Reset Link
        </button>

        <p class="auth-footer-text">
          Remember your password?
          <a href="/auth/signin/" class="auth-link">Sign in</a>
        </p>
      </div>

      <!-- Success state: shown after submit (regardless of whether account exists) -->
      <div id="fp-success-state" hidden>
        <div class="success-icon" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="20" fill="#F0FDF4"/>
            <path d="M12 20.5l5.5 5.5 10.5-11" stroke="#15803D" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h1 class="auth-heading">Check your inbox</h1>
        <p class="auth-sub success-sub">
          If an account exists with that email or username, a password reset link has been sent.
          The link expires in&nbsp;60&nbsp;minutes.
        </p>
        <p class="auth-sub" style="margin-top: 8px; font-size: 12px; color: var(--ink-400);">
          Didn't receive it? Check your spam folder, or
          <button id="fp-retry-btn" type="button" class="auth-link" style="background:none;border:none;padding:0;cursor:pointer;font-size:12px;">
            try again
          </button>.
        </p>
        <a href="/auth/signin/" class="btn btn-outline btn-md auth-btn" style="margin-top: var(--s-3);">
          Back to Sign In
        </a>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
.auth-page { background: var(--surface-1); }

.auth-section {
  min-height: calc(100vh - 96px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--s-8) var(--s-3);
}

.auth-card {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-radius: var(--r-1);
  box-shadow: var(--e-2);
  padding: var(--s-8) var(--s-6);
  width: 100%;
  max-width: 440px;
  display: flex;
  flex-direction: column;
  gap: var(--s-3);
}

.auth-logo {
  display: block;
  margin: 0 auto var(--s-1);
  width: fit-content;
}

.auth-heading {
  font-size: var(--text-h3);
  font-weight: 700;
  color: var(--ink-900);
  text-align: center;
  margin: 0;
}

.auth-sub {
  font-size: var(--text-small);
  color: var(--ink-400);
  text-align: center;
  margin: calc(-1 * var(--s-1)) 0 0;
}

.auth-banner {
  padding: 10px 14px;
  border-radius: var(--r-2);
  font-size: 13px;
  font-weight: 500;
}
.auth-banner--error {
  background: #FEF2F2;
  border: 1px solid #FCA5A5;
  color: #B91C1C;
}

.auth-field { display: flex; flex-direction: column; gap: 6px; }

.auth-label {
  font-size: 13px;
  font-weight: 500;
  color: var(--ink-600);
  font-family: var(--font-body);
}

.auth-input {
  height: 44px;
  padding: 0 12px;
  border: 1.5px solid var(--hairline-strong);
  border-radius: var(--r-2);
  background: var(--surface-0);
  color: var(--ink-900);
  font-size: 14px;
  font-family: var(--font-body);
  transition: border-color var(--m-fast);
}
.auth-input:focus {
  outline: none;
  border-color: var(--gold-600);
  box-shadow: 0 0 0 3px rgba(168,132,60,.15);
}
.auth-input::placeholder { color: var(--ink-400); }

.auth-btn {
  width: 100%;
  justify-content: center;
  margin-top: var(--s-1);
}

.auth-footer-text {
  font-size: 13px;
  color: var(--ink-400);
  text-align: center;
  margin: 0;
}
.auth-link {
  color: var(--gold-600);
  font-weight: 500;
  text-decoration: underline;
  text-underline-offset: 2px;
}

.success-icon {
  display: flex;
  justify-content: center;
  margin-bottom: var(--s-1);
}

.success-sub {
  line-height: 1.6;
}

@media (max-width: 480px) {
  .auth-card { padding: var(--s-6) var(--s-3); border: none; box-shadow: none; }
  .auth-section { padding: var(--s-4) var(--s-2); align-items: flex-start; }
}
</style>

<script>
  const API = '/api/v1';

  const formState    = document.getElementById('fp-form-state') as HTMLElement;
  const successState = document.getElementById('fp-success-state') as HTMLElement;
  const errorBanner  = document.getElementById('fp-error') as HTMLElement;
  const identifierEl = document.getElementById('identifier') as HTMLInputElement;
  const btn          = document.getElementById('fp-btn') as HTMLButtonElement;
  const retryBtn     = document.getElementById('fp-retry-btn') as HTMLButtonElement;

  function showError(msg: string): void {
    errorBanner.textContent = msg;
    errorBanner.hidden = false;
  }

  function hideError(): void {
    errorBanner.hidden = true;
  }

  async function submit(): Promise<void> {
    hideError();
    const identifier = identifierEl?.value.trim() ?? '';
    if (!identifier) {
      showError('Please enter your email address or username.');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      await fetch(`${API}/auth/forgot-password`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ identifier }),
      });
      // Show success state regardless of response -- never leak account existence.
      formState.hidden = true;
      successState.hidden = false;
    } catch {
      showError('A network error occurred. Please check your connection and try again.');
      btn.disabled = false;
      btn.textContent = 'Send Reset Link';
    }
  }

  btn?.addEventListener('click', submit);

  identifierEl?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter') submit();
  });

  retryBtn?.addEventListener('click', () => {
    formState.hidden = false;
    successState.hidden = true;
    btn.disabled = false;
    btn.textContent = 'Send Reset Link';
    identifierEl.value = '';
  });
</script>
