---
/**
 * auth/reset-password.astro
 * Route: /auth/reset-password/
 *
 * Reads ?token=RAW_TOKEN from the URL query string.
 * Posts { token, newPassword } to POST /api/v1/auth/reset-password.
 *
 * On success: shows confirmation + link to sign in.
 * On invalid/expired token: shows a clear error with link to request a new one.
 * If no token in URL: redirects to /auth/forgot-password/.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Reset Password"
  description="Set a new password for your Bhopal Camera Club account."
  bodyClass="auth-page"
>
  <section class="auth-section">
    <div class="auth-card" role="main" aria-label="Reset password">

      <a href="/" class="auth-logo" aria-label="Bhopal Camera Club home">
        <img src="/images/bcc-logo-default.png" alt="Bhopal Camera Club" width="160" height="44" loading="eager" />
      </a>

      <!-- Form state -->
      <div id="rp-form-state">
        <h1 class="auth-heading">Set a new password</h1>
        <p class="auth-sub">Choose a strong password with at least 8 characters.</p>

        <div id="rp-error" class="auth-banner auth-banner--error" hidden role="alert"></div>

        <div class="auth-field">
          <label class="auth-label" for="new-password">New password</label>
          <div class="password-wrap">
            <input
              id="new-password"
              type="password"
              name="new-password"
              class="auth-input"
              placeholder="At least 8 characters"
              autocomplete="new-password"
              required
            />
            <button type="button" class="toggle-pw" data-target="new-password" aria-label="Show password">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="auth-field">
          <label class="auth-label" for="confirm-password">Confirm new password</label>
          <div class="password-wrap">
            <input
              id="confirm-password"
              type="password"
              name="confirm-password"
              class="auth-input"
              placeholder="Repeat your new password"
              autocomplete="new-password"
              required
            />
            <button type="button" class="toggle-pw" data-target="confirm-password" aria-label="Show password">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <button id="rp-btn" type="button" class="btn btn-dark btn-lg auth-btn">
          Reset Password
        </button>
      </div>

      <!-- Success state -->
      <div id="rp-success-state" hidden>
        <div class="success-icon" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="20" fill="#F0FDF4"/>
            <path d="M12 20.5l5.5 5.5 10.5-11" stroke="#15803D" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h1 class="auth-heading">Password updated</h1>
        <p class="auth-sub">
          Your password has been changed. All previous sessions have been signed out for your security.
        </p>
        <a href="/auth/signin/" class="btn btn-dark btn-lg auth-btn" style="margin-top: var(--s-3);">
          Sign In
        </a>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
.auth-page { background: var(--surface-1); }

.auth-section {
  min-height: calc(100vh - 96px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--s-8) var(--s-3);
}

.auth-card {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-radius: var(--r-1);
  box-shadow: var(--e-2);
  padding: var(--s-8) var(--s-6);
  width: 100%;
  max-width: 440px;
  display: flex;
  flex-direction: column;
  gap: var(--s-3);
}

.auth-logo {
  display: block;
  margin: 0 auto var(--s-1);
  width: fit-content;
}

.auth-heading {
  font-size: var(--text-h3);
  font-weight: 700;
  color: var(--ink-900);
  text-align: center;
  margin: 0;
}

.auth-sub {
  font-size: var(--text-small);
  color: var(--ink-400);
  text-align: center;
  margin: calc(-1 * var(--s-1)) 0 0;
  line-height: 1.6;
}

.auth-banner {
  padding: 10px 14px;
  border-radius: var(--r-2);
  font-size: 13px;
  font-weight: 500;
  line-height: 1.5;
}
.auth-banner--error {
  background: #FEF2F2;
  border: 1px solid #FCA5A5;
  color: #B91C1C;
}

/* inline link inside error banner */
.auth-banner--error a {
  color: #B91C1C;
  font-weight: 600;
  text-decoration: underline;
  text-underline-offset: 2px;
}

.auth-field { display: flex; flex-direction: column; gap: 6px; }

.auth-label {
  font-size: 13px;
  font-weight: 500;
  color: var(--ink-600);
  font-family: var(--font-body);
}

/* Password input + toggle button wrapper */
.password-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.auth-input {
  height: 44px;
  padding: 0 40px 0 12px;
  border: 1.5px solid var(--hairline-strong);
  border-radius: var(--r-2);
  background: var(--surface-0);
  color: var(--ink-900);
  font-size: 14px;
  font-family: var(--font-body);
  transition: border-color var(--m-fast);
  width: 100%;
}
.auth-input:focus {
  outline: none;
  border-color: var(--gold-600);
  box-shadow: 0 0 0 3px rgba(168,132,60,.15);
}
.auth-input::placeholder { color: var(--ink-400); }
.auth-input.is-error { border-color: #EF4444; }

.toggle-pw {
  position: absolute;
  right: 12px;
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  color: var(--ink-400);
  display: flex;
  align-items: center;
}
.toggle-pw:hover { color: var(--ink-600); }

.auth-btn {
  width: 100%;
  justify-content: center;
  margin-top: var(--s-1);
}

.success-icon {
  display: flex;
  justify-content: center;
  margin-bottom: var(--s-1);
}

@media (max-width: 480px) {
  .auth-card { padding: var(--s-6) var(--s-3); border: none; box-shadow: none; }
  .auth-section { padding: var(--s-4) var(--s-2); align-items: flex-start; }
}
</style>

<script>
  const API = '/api/v1';

  // If no token in URL, send the user to forgot-password immediately.
  const params   = new URLSearchParams(window.location.search);
  const rawToken = params.get('token') ?? '';
  if (!rawToken) {
    window.location.replace('/auth/forgot-password/');
  }

  const formState    = document.getElementById('rp-form-state') as HTMLElement;
  const successState = document.getElementById('rp-success-state') as HTMLElement;
  const errorBanner  = document.getElementById('rp-error') as HTMLElement;
  const newPwEl      = document.getElementById('new-password') as HTMLInputElement;
  const confirmPwEl  = document.getElementById('confirm-password') as HTMLInputElement;
  const btn          = document.getElementById('rp-btn') as HTMLButtonElement;

  function showError(msg: string): void {
    errorBanner.innerHTML = msg;
    errorBanner.hidden = false;
  }

  function hideError(): void {
    errorBanner.hidden = true;
    newPwEl?.classList.remove('is-error');
    confirmPwEl?.classList.remove('is-error');
  }

  // Password visibility toggles
  document.querySelectorAll<HTMLButtonElement>('.toggle-pw').forEach(toggleBtn => {
    toggleBtn.addEventListener('click', () => {
      const targetId = toggleBtn.dataset.target ?? '';
      const input = document.getElementById(targetId) as HTMLInputElement | null;
      if (!input) return;
      input.type = input.type === 'password' ? 'text' : 'password';
    });
  });

  async function submit(): Promise<void> {
    hideError();

    const newPw     = newPwEl?.value ?? '';
    const confirmPw = confirmPwEl?.value ?? '';

    if (newPw.length < 8) {
      showError('Password must be at least 8 characters.');
      newPwEl?.classList.add('is-error');
      return;
    }

    if (newPw !== confirmPw) {
      showError('Passwords do not match.');
      confirmPwEl?.classList.add('is-error');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Updating...';

    try {
      const res = await fetch(`${API}/auth/reset-password`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token: rawToken, newPassword: newPw }),
      });

      if (res.ok) {
        formState.hidden = true;
        successState.hidden = false;
        return;
      }

      const body = await res.json().catch(() => ({})) as { message?: string };
      const msg = typeof body.message === 'string'
        ? body.message
        : 'Something went wrong. Please try again.';

      // For token errors, append a link to request a new one.
      const isTokenError = res.status === 400;
      showError(
        isTokenError
          ? `${msg} <a href="/auth/forgot-password/">Request a new link</a>`
          : msg,
      );

    } catch {
      showError('A network error occurred. Please check your connection and try again.');
    }

    btn.disabled = false;
    btn.textContent = 'Reset Password';
  }

  btn?.addEventListener('click', submit);

  [newPwEl, confirmPwEl].forEach(el =>
    el?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') submit();
    }),
  );
</script>
