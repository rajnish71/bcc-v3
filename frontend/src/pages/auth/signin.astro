---
/**
 * auth/signin.astro -- Sign In page
 * Route: /auth/signin/
 *
 * Supports:
 *   1. Email + password (POST /api/v1/auth/login)
 *   2. Google OAuth (fetches authorize-url, redirects)
 *   3. Facebook OAuth (fetches authorize-url, redirects)
 *
 * On success: stores bcc_token, bcc_refresh, bcc_user in localStorage,
 * then redirects to ?next= param (default /hub/).
 *
 * MEM-006 P1: Registration and Sign In are distinct actions.
 * This page never suggests membership -- it is purely an identity action.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Sign In" description="Sign in to your Bhopal Camera Club account." bodyClass="auth-page">
  <section class="auth-section">
    <div class="auth-card" role="main" aria-label="Sign in">

      <!-- Logo -->
      <a href="/" class="auth-logo" aria-label="Bhopal Camera Club home">
        <img src="/images/bcc-logo-default.png" alt="Bhopal Camera Club" width="160" height="44" loading="eager" />
      </a>

      <h1 class="auth-heading">Sign in to your account</h1>
      <p class="auth-sub">Welcome back to Bhopal Camera Club.</p>

      <!-- Error banner (shown on OAuth error or API failure) -->
      <div id="auth-error" class="auth-banner auth-banner--error" hidden role="alert"></div>

      <!-- Email + Password form -->
      <div id="auth-form-wrap">
        <div class="auth-field">
          <label class="auth-label" for="identifier">Email or username</label>
          <input
            id="identifier"
            type="text"
            name="identifier"
            class="auth-input"
            placeholder="Email or username"
            autocomplete="username email"
            spellcheck="false"
            required
          />
        </div>

        <div class="auth-field">
          <div class="auth-label-row">
            <label class="auth-label" for="password">Password</label>
            <a href="/auth/forgot-password/" class="auth-link auth-link--small">Forgot password?</a>
          </div>
          <input
            id="password"
            type="password"
            name="password"
            class="auth-input"
            placeholder="Your password"
            autocomplete="current-password"
            required
          />
        </div>

        <button id="signin-btn" type="button" class="btn btn-dark btn-lg auth-btn">
          Sign In
        </button>
      </div>

      <!-- Divider -->
      <div class="auth-divider" aria-hidden="true">
        <span class="auth-divider__line"></span>
        <span class="auth-divider__text">or continue with</span>
        <span class="auth-divider__line"></span>
      </div>

      <!-- Social buttons -->
      <div class="auth-social">
        <button id="google-btn" type="button" class="auth-social-btn">
          <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
            <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z" fill="#4285F4"/>
            <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z" fill="#34A853"/>
            <path d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/>
            <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z" fill="#EA4335"/>
          </svg>
          <span>Continue with Google</span>
        </button>

        <button id="facebook-btn" type="button" class="auth-social-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" fill="#1877F2">
            <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.313 0 2.686.236 2.686.236v2.97H15.83c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
          </svg>
          <span>Continue with Facebook</span>
        </button>
      </div>

      <!-- Footer links -->
      <p class="auth-footer-text">
        Don't have an account?
        <a href="/auth/register/" class="auth-link">Register free</a>
      </p>

    </div>
  </section>
</BaseLayout>

<style>
/* ---- Auth page shell ---- */
.auth-page { background: var(--surface-1); }

.auth-section {
  min-height: calc(100vh - 96px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--s-8) var(--s-3);
}

.auth-card {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-radius: var(--r-1);
  box-shadow: var(--e-2);
  padding: var(--s-8) var(--s-6);
  width: 100%;
  max-width: 440px;
  display: flex;
  flex-direction: column;
  gap: var(--s-3);
}

.auth-logo {
  display: block;
  margin: 0 auto var(--s-1);
  width: fit-content;
}

.auth-heading {
  font-size: var(--text-h3);
  font-weight: 700;
  color: var(--ink-900);
  text-align: center;
  margin: 0;
}

.auth-sub {
  font-size: var(--text-small);
  color: var(--ink-400);
  text-align: center;
  margin: calc(-1 * var(--s-1)) 0 0;
}

/* Error/success banner */
.auth-banner {
  padding: 10px 14px;
  border-radius: var(--r-2);
  font-size: 13px;
  font-weight: 500;
}
.auth-banner--error {
  background: #FEF2F2;
  border: 1px solid #FCA5A5;
  color: #B91C1C;
}
.auth-banner--success {
  background: #F0FDF4;
  border: 1px solid #86EFAC;
  color: #15803D;
}

/* Form fields */
.auth-field { display: flex; flex-direction: column; gap: 6px; }

.auth-label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.auth-label {
  font-size: 13px;
  font-weight: 500;
  color: var(--ink-600);
  font-family: var(--font-body);
}

.auth-input {
  height: 44px;
  padding: 0 12px;
  border: 1.5px solid var(--hairline-strong);
  border-radius: var(--r-2);
  background: var(--surface-0);
  color: var(--ink-900);
  font-size: 14px;
  font-family: var(--font-body);
  transition: border-color var(--m-fast);
}
.auth-input:focus {
  outline: none;
  border-color: var(--gold-600);
  box-shadow: 0 0 0 3px rgba(168,132,60,.15);
}
.auth-input::placeholder { color: var(--ink-400); }
.auth-input.is-error { border-color: #EF4444; }

.auth-btn {
  width: 100%;
  justify-content: center;
  margin-top: var(--s-1);
}

/* Divider */
.auth-divider {
  display: flex;
  align-items: center;
  gap: var(--s-2);
  margin: var(--s-1) 0;
}
.auth-divider__line {
  flex: 1;
  height: 1px;
  background: var(--hairline);
}
.auth-divider__text {
  font-size: 11px;
  color: var(--ink-400);
  white-space: nowrap;
  font-family: var(--font-body);
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

/* Social buttons */
.auth-social { display: flex; flex-direction: column; gap: var(--s-1); }

.auth-social-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  height: 44px;
  border: 1.5px solid var(--hairline-strong);
  border-radius: var(--r-2);
  background: var(--surface-0);
  color: var(--ink-900);
  font-size: 13px;
  font-weight: 500;
  font-family: var(--font-body);
  cursor: pointer;
  transition: background var(--m-fast), border-color var(--m-fast);
  width: 100%;
}
.auth-social-btn:hover {
  background: var(--surface-1);
  border-color: var(--ink-400);
}
.auth-social-btn:focus-visible { outline: 2px solid var(--gold-600); outline-offset: 3px; }

/* Footer */
.auth-footer-text {
  font-size: 13px;
  color: var(--ink-400);
  text-align: center;
  margin: 0;
}
.auth-link {
  color: var(--gold-600);
  font-weight: 500;
  text-decoration: underline;
  text-underline-offset: 2px;
}
.auth-link--small { font-size: 12px; font-weight: 400; }

@media (max-width: 480px) {
  .auth-card { padding: var(--s-6) var(--s-3); border: none; box-shadow: none; }
  .auth-section { padding: var(--s-4) var(--s-2); align-items: flex-start; }
}
</style>

<script>
  const API = '/api/v1';

  /* -- Helpers ---------------------------------------------------------- */
  function qs<T extends HTMLElement>(id: string): T | null {
    return document.getElementById(id) as T | null;
  }

  function showError(msg: string): void {
    const banner = qs<HTMLElement>('auth-error');
    if (!banner) return;
    banner.textContent = msg;
    banner.hidden = false;
  }

  function hideError(): void {
    const banner = qs<HTMLElement>('auth-error');
    if (banner) banner.hidden = true;
  }

  function setLoading(btn: HTMLButtonElement, loading: boolean): void {
    btn.disabled = loading;
    btn.textContent = loading ? 'Signing in...' : 'Sign In';
  }

  function storeSession(token: string, refresh: string, fullName: string, username = ''): void {
    const initials = fullName.trim().split(/\s+/).map(w => w[0]).join('').slice(0, 2).toUpperCase();
    localStorage.setItem('bcc_token', token);
    localStorage.setItem('bcc_refresh', refresh);
    localStorage.setItem('bcc_user', JSON.stringify({ displayName: fullName, initials, username }));
  }

  function getRedirectTarget(): string {
    const params = new URLSearchParams(window.location.search);
    const next = params.get('next');
    if (next && next.startsWith('/') && !next.startsWith('//')) return next;
    return '/hub/';
  }

  /* -- Check URL for OAuth errors --------------------------------------- */
  const urlError = new URLSearchParams(window.location.search).get('error');
  if (urlError) showError(`Sign-in failed: ${decodeURIComponent(urlError)}`);

  /* -- Email + password sign-in ----------------------------------------- */
  qs<HTMLButtonElement>('signin-btn')?.addEventListener('click', async () => {
    hideError();
    const emailEl  = qs<HTMLInputElement>('identifier');
    const passEl   = qs<HTMLInputElement>('password');
    const btn      = qs<HTMLButtonElement>('signin-btn');
    if (!emailEl || !passEl || !btn) return;

    const email    = emailEl.value.trim();
    const password = passEl.value;

    if (!email || !password) { showError('Please enter your email or username and password.'); return; }

    setLoading(btn, true);

    try {
      // Step 1: authenticate
      const loginRes = await fetch(`${API}/auth/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ identifier: email, password }),
      });

      if (!loginRes.ok) {
        const err = await loginRes.json().catch(() => ({})) as { message?: string };
        const msg = loginRes.status === 401
          ? 'Incorrect email or password.'
          : (err.message || 'Sign-in failed. Please try again.');
        showError(typeof msg === 'string' ? msg : JSON.stringify(msg));
        setLoading(btn, false);
        return;
      }

      const tokens = await loginRes.json() as { accessToken: string; refreshToken: string };

      // Step 2: fetch display name + username
      let fullName = 'Member';
      let username = '';
      const meRes = await fetch(`${API}/users/me`, {
        headers: { Authorization: `Bearer ${tokens.accessToken}` },
      });
      if (meRes.ok) {
        const me = await meRes.json() as { fullName?: string; username?: string };
        if (me.fullName) fullName = me.fullName;
        if (me.username) username = me.username;
      }

      storeSession(tokens.accessToken, tokens.refreshToken, fullName, username);
      window.location.replace(getRedirectTarget());

    } catch {
      showError('A network error occurred. Please check your connection.');
      setLoading(btn, false);
    }
  });

  /* -- Social login ----------------------------------------------------- */
  async function startSocialLogin(provider: 'google' | 'facebook'): Promise<void> {
    hideError();
    try {
      const res = await fetch(`${API}/registration/social/${provider}/authorize-url`);
      if (!res.ok) throw new Error('Could not start social login.');
      const data = await res.json() as { authorizeUrl?: string };
      if (!data.authorizeUrl) throw new Error('No authorize URL returned.');
      window.location.href = data.authorizeUrl;
    } catch (e) {
      showError(e instanceof Error ? e.message : 'Social login failed.');
    }
  }

  qs<HTMLButtonElement>('google-btn')?.addEventListener('click', () => startSocialLogin('google'));
  qs<HTMLButtonElement>('facebook-btn')?.addEventListener('click', () => startSocialLogin('facebook'));

  /* -- Redirect if already signed in ------------------------------------ */
  try {
    const token = localStorage.getItem('bcc_token');
    if (token) {
      const payload = JSON.parse(atob(token.split('.')[1].replace(/-/g, '+').replace(/_/g, '/')));
      if (payload.exp * 1000 > Date.now()) {
        window.location.replace(getRedirectTarget());
      }
    }
  } catch { /* ignore */ }
</script>
