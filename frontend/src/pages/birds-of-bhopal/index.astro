---
/**
 * birds-of-bhopal/index.astro — Birds of Bhopal Public Page
 * VS-41 Phase 0 Shell — justified gallery filtered to tag: birds-of-bhopal
 * Design authority: V6 00 BCC Design Principles
 * Architecture: PHOTO-ARCH-001 (canonical photos, no duplication)
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import JustifiedPhotoGrid from '../../components/gallery/JustifiedPhotoGrid.astro';
---

<BaseLayout
  title="Birds of Bhopal"
  description="Explore photographs of birds found in Bhopal, contributed by members of Bhopal Camera Club. An evolving archive documenting the city's birdlife through photography."
  ogImage="/images/og-default.jpg"
>

  <!-- ── Hero ── -->
  <div class="bob-hero container">
    <div class="bob-hero-inner">
      <div class="bob-hero-content">
        <div class="bob-kicker">
          <span class="bob-kicker-line"></span>
          Birds of Bhopal · /birds-of-bhopal
        </div>
        <h1 class="bob-title">Birds of Bhopal</h1>
        <p class="bob-lead">Exploring the avian diversity of the City of Lakes through the eyes of Bhopal Camera Club photographers.</p>
        <div class="bob-counts" id="bob-counts" hidden>
          <span class="bob-count-item" id="bob-count-photos"></span>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Editorial Introduction ── -->
  <div class="bob-editorial container">
    <div class="bob-editorial-inner">
      <div class="bob-editorial-body">
        <p class="bob-editorial-p">
          This is an evolving visual archive documenting birds photographed by members of Bhopal Camera Club across the lakes, forests, parks, and wetlands of Bhopal. Every image here was captured by a club member and represents a real encounter with the remarkable birdlife that thrives in and around the City of Lakes — from the migratory visitors that arrive each winter to the year-round residents of Van Vihar, Upper Lake, and the surrounding greenery.
        </p>
        <p class="bob-editorial-p">
          Future versions of this archive will include species identification, scientific names, habitat information, migration data, and detailed bird profiles — turning each photograph into a richer record of Bhopal's natural heritage. For now, we invite you to explore the collection as it grows, photograph by photograph, through the lenses of our members.
        </p>
      </div>
    </div>
  </div>

  <!-- ── Gallery ── -->
  <div class="container">

    <div class="gallery-wrap">
      <JustifiedPhotoGrid
        id="bob"
        ariaLabel="Birds of Bhopal photo gallery"
        apiTag="birds-of-bhopal"
        photoLinkSuffix="?genre=birds-of-bhopal"
        emptyText="No bird photographs have been published yet. Check back soon."
      />
    </div>

  </div>

</BaseLayout>


<style>
/* ── Hero ── */
.bob-hero {
  padding-top: calc(var(--nav-h) + var(--s-12));
  padding-bottom: var(--s-6);
}
.bob-hero-inner {
  background: #FFFFFF;
  border: 1px solid var(--hairline);
  border-top: 3px solid var(--gold-600);
  overflow: hidden;
}
.bob-hero-content {
  padding: 64px 72px 56px;
}
.bob-kicker {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: 600;
  margin-bottom: 18px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.bob-kicker-line {
  display: block;
  width: 28px;
  height: 1px;
  background: var(--gold-600);
}
.bob-title {
  font-family: var(--font-display);
  font-size: clamp(40px, 5vw, 64px);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.05;
  color: var(--ink-900);
  margin-bottom: 20px;
}
.bob-lead {
  font-size: 17px;
  line-height: 1.8;
  color: var(--ink-600);
  max-width: 520px;
  font-weight: 300;
}
.bob-counts {
  display: flex;
  align-items: center;
  gap: 24px;
  margin-top: 28px;
  flex-wrap: wrap;
}
.bob-count-item {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--gold-600);
  letter-spacing: 0.1em;
}

@media (max-width: 1024px) {
  .bob-hero-content { padding: 48px var(--gutter-mob); }
}
@media (max-width: 768px) {
  .bob-hero-content { padding: 32px var(--gutter-mob); }
}

/* ── Editorial Introduction ── */
.bob-editorial {
  padding-bottom: var(--s-6);
}
.bob-editorial-inner {
  background: #FFFFFF;
  border: 1px solid var(--hairline);
  border-top: none;
}
.bob-editorial-body {
  padding: 36px 72px 40px;
  max-width: 860px;
}
.bob-editorial-p {
  font-size: 15px;
  line-height: 1.85;
  color: var(--ink-600);
  font-weight: 300;
  margin: 0 0 20px 0;
}
.bob-editorial-p:last-child {
  margin-bottom: 0;
}

@media (max-width: 1024px) {
  .bob-editorial-body { padding: 28px var(--gutter-mob) 32px; }
}
@media (max-width: 768px) {
  .bob-editorial-body { padding: 24px var(--gutter-mob) 28px; }
}

/* ── Gallery wrap ── */
.gallery-wrap {
  border: 1px solid var(--hairline);
  margin-bottom: var(--s-8);
}
</style>


<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  /* ── Update photo count when the grid reports its first load ── */
  document.getElementById('bob-grid')?.addEventListener('bcc:grid-loaded', (e: Event) => {
    const total = (e as CustomEvent).detail?.total as number;
    if (total > 0) {
      const countEl   = document.getElementById('bob-count-photos');
      const countsWrap = document.getElementById('bob-counts');
      if (countEl && countsWrap) {
        countEl.textContent = `${total.toLocaleString('en-IN')} photograph${total === 1 ? '' : 's'}`;
        countsWrap.removeAttribute('hidden');
      }
    }
  });

  /* ── GSAP entrances ── */
  gsap.from('.bob-hero .bob-hero-content', {
    opacity: 0, y: 24, duration: 0.6, ease: 'power3.out', delay: 0.1,
  });
  gsap.from('.bob-editorial-body', {
    opacity: 0, y: 20, duration: 0.6, ease: 'power2.out',
    scrollTrigger: { trigger: '.bob-editorial', start: 'top 85%', once: true },
  });
</script>
