---
/**
 * butterflies-of-bhopal/index.astro — Butterflies of Bhopal Public Page
 * VS-42 Phase 0 Shell — justified gallery filtered to tag: butterflies-of-bhopal
 * Design authority: V6 00 BCC Design Principles
 * Architecture: PHOTO-ARCH-001 (canonical photos, no duplication)
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import JustifiedPhotoGrid from '../../components/gallery/JustifiedPhotoGrid.astro';
---

<BaseLayout
  title="Butterflies of Bhopal"
  description="Explore photographs of butterflies found in Bhopal, contributed by members of Bhopal Camera Club members."
  ogImage="/images/og-default.jpg"
>

  <!-- ── Hero ── -->
  <div class="bofb-hero container">
    <div class="bofb-hero-inner">
      <div class="bofb-hero-content">
        <div class="bofb-kicker">
          <span class="bofb-kicker-line"></span>
          Butterflies of Bhopal · /butterflies-of-bhopal
        </div>
        <h1 class="bofb-title">Butterflies of Bhopal</h1>
        <p class="bofb-lead">Documenting the butterfly diversity of the City of Lakes through the eyes of Bhopal Camera Club photographers.</p>
        <div class="bofb-counts" id="bofb-counts" hidden>
          <span class="bofb-count-item" id="bofb-count-photos"></span>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Editorial Introduction ── -->
  <div class="bofb-editorial container">
    <div class="bofb-editorial-inner">
      <div class="bofb-editorial-body">
        <p class="bofb-editorial-p">
          This is an evolving visual archive documenting butterflies photographed by members of Bhopal Camera Club across the gardens, forests, wetlands, and green corridors of Bhopal. Every image here was captured by a club member and represents a real encounter with the remarkable lepidopteran diversity that flourishes in and around the City of Lakes — from the common emigrants and jezebels that grace urban gardens to the rare and seasonal visitors found deep in the surrounding forests.
        </p>
        <p class="bofb-editorial-p">
          Future versions of this archive will include species identification, scientific names, habitat information, life cycle stages, host plant associations, seasonality data, and detailed identification guides — turning each photograph into a richer record of Bhopal's natural heritage. For now, we invite you to explore the collection as it grows, photograph by photograph, through the lenses of our members.
        </p>
      </div>
    </div>
  </div>

  <!-- ── Gallery ── -->
  <div class="container">

    <div class="gallery-wrap">
      <JustifiedPhotoGrid
        id="bofb"
        ariaLabel="Butterflies of Bhopal photo gallery"
        apiTag="butterflies-of-bhopal"
        photoLinkSuffix="?genre=butterflies-of-bhopal"
        emptyText="No butterfly photographs have been published yet. Check back soon."
      />
    </div>

  </div>

</BaseLayout>


<style>
/* ── Hero ── */
.bofb-hero {
  padding-top: calc(var(--nav-h) + var(--s-12));
  padding-bottom: var(--s-6);
}
.bofb-hero-inner {
  background: #FFFFFF;
  border: 1px solid var(--hairline);
  border-top: 3px solid var(--gold-600);
  overflow: hidden;
}
.bofb-hero-content {
  padding: 64px 72px 56px;
}
.bofb-kicker {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: 600;
  margin-bottom: 18px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.bofb-kicker-line {
  display: block;
  width: 28px;
  height: 1px;
  background: var(--gold-600);
}
.bofb-title {
  font-family: var(--font-display);
  font-size: clamp(40px, 5vw, 64px);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.05;
  color: var(--ink-900);
  margin-bottom: 20px;
}
.bofb-lead {
  font-size: 17px;
  line-height: 1.8;
  color: var(--ink-600);
  max-width: 520px;
  font-weight: 300;
}
.bofb-counts {
  display: flex;
  align-items: center;
  gap: 24px;
  margin-top: 28px;
  flex-wrap: wrap;
}
.bofb-count-item {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--gold-600);
  letter-spacing: 0.1em;
}

@media (max-width: 1024px) {
  .bofb-hero-content { padding: 48px var(--gutter-mob); }
}
@media (max-width: 768px) {
  .bofb-hero-content { padding: 32px var(--gutter-mob); }
}

/* ── Editorial Introduction ── */
.bofb-editorial {
  padding-bottom: var(--s-6);
}
.bofb-editorial-inner {
  background: #FFFFFF;
  border: 1px solid var(--hairline);
  border-top: none;
}
.bofb-editorial-body {
  padding: 36px 72px 40px;
  max-width: 860px;
}
.bofb-editorial-p {
  font-size: 15px;
  line-height: 1.85;
  color: var(--ink-600);
  font-weight: 300;
  margin: 0 0 20px 0;
}
.bofb-editorial-p:last-child {
  margin-bottom: 0;
}

@media (max-width: 1024px) {
  .bofb-editorial-body { padding: 28px var(--gutter-mob) 32px; }
}
@media (max-width: 768px) {
  .bofb-editorial-body { padding: 24px var(--gutter-mob) 28px; }
}

/* ── Gallery wrap ── */
.gallery-wrap {
  border: 1px solid var(--hairline);
  margin-bottom: var(--s-8);
}
</style>


<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  /* ── Update photo count when the grid reports its first load ── */
  document.getElementById('bofb-grid')?.addEventListener('bcc:grid-loaded', (e: Event) => {
    const total = (e as CustomEvent).detail?.total as number;
    if (total > 0) {
      const countEl    = document.getElementById('bofb-count-photos');
      const countsWrap = document.getElementById('bofb-counts');
      if (countEl && countsWrap) {
        countEl.textContent = `${total.toLocaleString('en-IN')} photograph${total === 1 ? '' : 's'}`;
        countsWrap.removeAttribute('hidden');
      }
    }
  });

  /* ── GSAP entrances ── */
  gsap.from('.bofb-hero .bofb-hero-content', {
    opacity: 0, y: 24, duration: 0.6, ease: 'power3.out', delay: 0.1,
  });
  gsap.from('.bofb-editorial-body', {
    opacity: 0, y: 20, duration: 0.6, ease: 'power2.out',
    scrollTrigger: { trigger: '.bofb-editorial', start: 'top 85%', once: true },
  });
</script>
