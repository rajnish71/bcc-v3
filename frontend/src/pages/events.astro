---
/**
 * events.astro — Events Listing
 *
 * Lists upcoming and past club events. Events data fetched client-side
 * from /api/v1/events. Filter by type (photowalk, workshop, contest, exhibition).
 * Contests and Exhibitions shown as disabled/coming-soon in nav but listed here
 * when they exist in the DB.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';

const EVENT_TYPES = [
  { value: 'all',          label: 'All Events' },
  { value: 'photowalk',    label: 'Photowalks' },
  { value: 'workshop',     label: 'Workshops' },
  { value: 'contest',      label: 'Contests' },
  { value: 'exhibition',   label: 'Exhibitions' },
  { value: 'meetup',       label: 'Meetups' },
];

const TYPE_COLORS: Record<string, string> = {
  photowalk:  'var(--cyan)',
  workshop:   'var(--amber)',
  contest:    'var(--iris-magenta)',
  exhibition: 'var(--iris-olive)',
  meetup:     'var(--iris-teal)',
};
---

<BaseLayout
  title="Events"
  description="Upcoming and past events from Bhopal Camera Club — photowalks, workshops, meetups, and more."
>

  <!-- Page header -->
  <div class="page-hero">
    <div class="container">
      <SectionHeader
        eyebrow="Activities"
        title="Events & Activities"
        subtitle="Join fellow photographers for photowalks, workshops, and community meetups across Bhopal."
        as="h1"
      />

      <!-- Type filters -->
      <div class="event-type-filters" role="group" aria-label="Filter by event type" id="type-filters">
        {EVENT_TYPES.map(t => (
          <button
            class:list={['type-chip', t.value === 'all' && 'active']}
            data-type={t.value}
            aria-pressed={t.value === 'all' ? 'true' : 'false'}
          >
            {t.label}
          </button>
        ))}
      </div>
    </div>
    <div class="page-hero__line" aria-hidden="true"></div>
  </div>

  <div class="container events-body">

    <!-- Upcoming events -->
    <div class="events-section" id="upcoming-section">
      <div class="events-section__heading">
        <h2 class="events-section__title">Upcoming</h2>
        <div class="upcoming-indicator">
          <span class="pill pill-live">Live</span>
        </div>
      </div>
      <div class="events-list" id="upcoming-list" aria-label="Upcoming events">
        <!-- Skeleton -->
        {[1,2,3].map(() => (
          <div class="event-row-skel glass-panel" aria-hidden="true">
            <div class="skel-date"></div>
            <div class="skel-content">
              <div class="skel-line skel-line--short"></div>
              <div class="skel-line" style="margin-top:6px;"></div>
              <div class="skel-line" style="margin-top:6px;width:45%;"></div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Past events -->
    <div class="events-section" id="past-section" style="margin-top:var(--space-16);">
      <div class="events-section__heading">
        <h2 class="events-section__title">Past Events</h2>
      </div>
      <div class="events-list" id="past-list" aria-label="Past events">
        <!-- Populated by JS -->
      </div>
      <div class="load-more-wrap" id="past-load-more" hidden>
        <button class="btn btn-ghost" id="past-load-more-btn">Load more past events</button>
      </div>
    </div>

    <!-- Empty state -->
    <div id="events-empty" hidden class="events-empty">
      <p>No events found for this filter.</p>
      <button class="btn btn-ghost" id="clear-type-filter">Show all events</button>
    </div>

  </div>

</BaseLayout>


<style>
/* ── Page hero ── */
.page-hero {
  padding-top: calc(var(--nav-h) + var(--space-12));
  padding-bottom: var(--space-8);
  position: relative;
}
.page-hero__line {
  position: absolute;
  bottom: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(to right, transparent, var(--amber) 30%, var(--cyan) 70%, transparent);
  opacity: 0.25;
}

/* ── Type filters ── */
.event-type-filters {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-top: var(--space-6);
}
.type-chip {
  padding: 7px 16px;
  font-size: var(--text-xs);
  font-weight: 500;
  letter-spacing: 0.04em;
  color: var(--text-3);
  background: transparent;
  border: 1px solid var(--border);
  border-radius: var(--radius-full);
  cursor: pointer;
  transition: color 0.15s, border-color 0.15s, background 0.15s;
  font-family: var(--font-body);
}
.type-chip:hover { color: var(--text-2); border-color: var(--border-md); }
.type-chip.active {
  color: var(--amber);
  border-color: var(--border-amber);
  background: var(--amber-muted);
}

/* ── Events body ── */
.events-body { padding: var(--space-10) 0 var(--space-20); }

/* ── Section heading ── */
.events-section__heading {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-bottom: var(--space-6);
  padding-bottom: var(--space-4);
  border-bottom: 1px solid var(--border);
}
.events-section__title {
  font-family: var(--font-display);
  font-size: var(--text-h4);
  font-weight: 600;
  color: var(--text-2);
  letter-spacing: -0.01em;
}

/* ── Event row ── */
.events-list { display: flex; flex-direction: column; gap: var(--space-3); }

.event-row {
  display: grid;
  grid-template-columns: 80px 1fr auto;
  gap: var(--space-6);
  padding: var(--space-5) var(--space-6);
  border-radius: var(--radius-lg);
  text-decoration: none;
  align-items: center;
  transition: transform 0.2s, border-color 0.2s;
  border: 1px solid var(--border);
  background: rgba(255,255,255,0.015);
}
.event-row:hover { transform: translateX(4px); border-color: var(--border-md); }

.event-row__date {
  text-align: center;
  flex-shrink: 0;
}
.event-date-day   { font-family: var(--font-display); font-size: var(--text-h3); font-weight: 700; color: var(--text); line-height: 1; }
.event-date-month { font-size: var(--text-label); font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-3); margin-top: 2px; }

.event-row__content { min-width: 0; }
.event-row__type {
  display: inline-block;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: var(--space-1);
}
.event-row__title {
  font-family: var(--font-display);
  font-size: var(--text-h4);
  font-weight: 600;
  color: var(--text);
  line-height: 1.3;
  margin-bottom: var(--space-1);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.event-row__meta {
  font-size: var(--text-xs);
  color: var(--text-3);
  display: flex;
  gap: var(--space-3);
}
.event-row__action {
  flex-shrink: 0;
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--amber);
  white-space: nowrap;
}

/* Skeleton */
.event-row-skel {
  display: grid;
  grid-template-columns: 80px 1fr;
  gap: var(--space-6);
  padding: var(--space-5) var(--space-6);
  border-radius: var(--radius-lg);
  min-height: 88px;
  align-items: center;
}
.skel-date {
  width: 50px; height: 60px;
  background: var(--surface-2);
  border-radius: var(--radius);
  animation: shimmer 1.6s ease-in-out infinite;
  margin: 0 auto;
}
.skel-content { display: flex; flex-direction: column; gap: 4px; }
.skel-line {
  height: 10px; width: 100%;
  background: var(--surface-2); border-radius: 4px;
  animation: shimmer 1.6s ease-in-out infinite;
}
.skel-line--short { width: 30%; }
@keyframes shimmer { 0%,100% { opacity:.4; } 50% { opacity:.7; } }

/* ── Empty ── */
.events-empty {
  display: flex; flex-direction: column; align-items: center; gap: var(--space-6);
  padding: var(--space-20) 0; text-align: center; color: var(--text-3);
}
.events-empty p { font-size: var(--text-base); color: var(--text-2); }

/* ── Load more ── */
.load-more-wrap { display: flex; justify-content: center; margin-top: var(--space-8); }

/* ── Responsive ── */
@media (max-width: 768px) {
  .event-row { grid-template-columns: 60px 1fr; }
  .event-row__action { display: none; }
  .event-date-day { font-size: var(--text-h4); }
}
@media (max-width: 480px) {
  .event-row { grid-template-columns: 1fr; }
  .event-row__date { text-align: left; display: flex; align-items: baseline; gap: var(--space-2); }
  .event-date-day { font-size: var(--text-h4); }
}
</style>


<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const TYPE_COLORS: Record<string, string> = {
    photowalk:  'var(--cyan)',
    workshop:   'var(--amber)',
    contest:    'var(--iris-magenta)',
    exhibition: 'var(--iris-olive)',
    meetup:     'var(--iris-teal)',
    default:    'var(--text-3)',
  };

  let currentType = 'all';
  let pastCursor: string | null = null;

  function formatDate(dateStr: string) {
    const d = new Date(dateStr);
    return {
      day:   d.getDate().toString().padStart(2, '0'),
      month: d.toLocaleString('en-IN', { month: 'short' }).toUpperCase(),
    };
  }

  function createEventRow(ev: any) {
    const link = document.createElement('a');
    link.href = `/events/${ev.slug ?? ev.id}/`;
    link.className = 'event-row glass-panel';

    const { day, month } = ev.date ? formatDate(ev.date) : { day: '—', month: '—' };
    const typeColor = TYPE_COLORS[ev.type?.toLowerCase()] ?? TYPE_COLORS.default;

    link.innerHTML = `
      <div class="event-row__date">
        <div class="event-date-day">${day}</div>
        <div class="event-date-month">${month}</div>
      </div>
      <div class="event-row__content">
        <div class="event-row__type" style="color:${typeColor}">${ev.type ?? 'Event'}</div>
        <div class="event-row__title">${ev.title ?? 'Upcoming Event'}</div>
        <div class="event-row__meta">
          ${ev.time ? `<span>${ev.time}</span>` : ''}
          ${ev.location ? `<span>${ev.location}</span>` : ''}
          ${typeof ev.registeredCount === 'number' ? `<span>${ev.registeredCount} registered</span>` : ''}
        </div>
      </div>
      <div class="event-row__action">Register →</div>
    `;
    return link;
  }

  async function loadUpcoming() {
    const list = document.getElementById('upcoming-list')!;
    const params = new URLSearchParams({ upcoming: 'true', limit: '10' });
    if (currentType !== 'all') params.set('type', currentType);

    try {
      const res = await fetch(`/api/v1/events?${params}`);
      if (!res.ok) throw new Error();
      const { data } = await res.json();
      const events = Array.isArray(data) ? data : [];

      list.innerHTML = '';

      if (events.length === 0) {
        list.innerHTML = `<p style="color:var(--text-3);font-size:var(--text-sm);padding:var(--space-6) 0;">No upcoming events right now. Check back soon!</p>`;
        return;
      }

      events.forEach((ev: any) => list.appendChild(createEventRow(ev)));

      gsap.from('#upcoming-list .event-row', {
        opacity: 0, x: -16, duration: 0.5, stagger: 0.08, ease: 'power2.out',
      });
    } catch {
      list.innerHTML = '';
    }
  }

  async function loadPast(reset = true) {
    const list    = document.getElementById('past-list')!;
    const loadBtn = document.getElementById('past-load-more')!;
    if (reset) { list.innerHTML = ''; pastCursor = null; }

    const params = new URLSearchParams({ past: 'true', limit: '10' });
    if (currentType !== 'all') params.set('type', currentType);
    if (pastCursor) params.set('cursor', pastCursor);

    try {
      const res = await fetch(`/api/v1/events?${params}`);
      if (!res.ok) throw new Error();
      const { data, meta } = await res.json();
      const events = Array.isArray(data) ? data : [];

      events.forEach((ev: any) => list.appendChild(createEventRow(ev)));
      pastCursor = meta?.next_cursor ?? null;
      if (pastCursor) loadBtn.removeAttribute('hidden');
      else             loadBtn.setAttribute('hidden', '');

      if (!reset) {
        gsap.from(list.querySelectorAll('.event-row:not(.was-visible)'), {
          opacity: 0, y: 16, duration: 0.4, stagger: 0.06, ease: 'power2.out',
        });
        list.querySelectorAll('.event-row').forEach(r => r.classList.add('was-visible'));
      }
    } catch { /* silent */ }
  }

  /* ── Type filters ── */
  document.querySelectorAll<HTMLButtonElement>('.type-chip').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.type-chip').forEach(b => {
        b.classList.remove('active'); b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active'); btn.setAttribute('aria-pressed', 'true');
      currentType = btn.dataset.type ?? 'all';
      loadUpcoming(); loadPast(true);
    });
  });

  document.getElementById('past-load-more-btn')?.addEventListener('click', () => loadPast(false));
  document.getElementById('clear-type-filter')?.addEventListener('click', () => {
    currentType = 'all';
    document.querySelectorAll('.type-chip').forEach(b => {
      b.classList.toggle('active', b.dataset.type === 'all');
      b.setAttribute('aria-pressed', b.dataset.type === 'all' ? 'true' : 'false');
    });
    loadUpcoming(); loadPast(true);
  });

  /* ── Init ── */
  loadUpcoming();
  loadPast(true);

  gsap.from('.page-hero .section-header', { opacity: 0, y: 24, duration: 0.6, ease: 'power3.out', delay: 0.1 });
</script>
