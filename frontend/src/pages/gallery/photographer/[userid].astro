---
/**
 * gallery/photographer/[userid].astro
 * Legacy route wrapper that redirects to /photographers/[username]/
 */
import { BUILD_API_URL } from '../../../lib/api';

export async function getStaticPaths() {
  let photographers: any[] = [];
  try {
    const res = await fetch(`${BUILD_API_URL}/photographers?limit=100`);
    if (res.ok) {
      const json = await res.json();
      photographers = json.data || [];
    }
  } catch {
    // Backend unavailable at build time
  }

  // Pre-seed both legacy hyphenated and V6 canonical username paths
  const paths: { params: { userid: string } }[] = [
    // Canonical V6
    { params: { userid: 'rajnishkhare' } },
    { params: { userid: 'ankittiwari' } },
    { params: { userid: 'rahilkhan' } },
    { params: { userid: 'sauvikacharyya' } },
    { params: { userid: 'kshitijpatle' } },
    { params: { userid: 'anupamkharegupta' } },
    // Legacy Hyphenated
    { params: { userid: 'rajnish-khare' } },
    { params: { userid: 'ankit-tiwari' } },
    { params: { userid: 'rahil-khan' } },
    { params: { userid: 'sauvik-acharyya' } },
    { params: { userid: 'kshitij-patle' } },
    { params: { userid: 'anupam-khare-gupta' } },
  ];

  photographers.forEach((p: any) => {
    if (p.username) {
      // Add V6 canonical username path
      if (!paths.some(path => path.params.userid === p.username)) {
        paths.push({ params: { userid: p.username } });
      }
      // Add legacy hyphenated path equivalent (if not already present)
      const hyphenated = p.username.replace(/([a-z]+)(khare|tiwari|khan|acharyya|patle|gupta|more|zode|jain|shukla|dutta|rashid|murtaza|patidar|jangalwa|bhati)/, '$1-$2');
      if (hyphenated !== p.username && !paths.some(path => path.params.userid === hyphenated)) {
        paths.push({ params: { userid: hyphenated } });
      }
    }
  });

  return paths;
}

const { userid } = Astro.params;
// Strip hyphens to resolve the V6 canonical username
const username = userid ? userid.replace(/-/g, '') : '';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="refresh" content={`0;url=/photographers/${username}/`} />
  <link rel="canonical" href={`/photographers/${username}/`} />
  <title>Redirecting...</title>
  <script is:inline define:vars={{ username }}>
    window.location.replace(`/photographers/${username}/`);
  </script>
</head>
<body>
  <p>Redirecting to <a href={`/photographers/${username}/`}>Photographer Profile</a>...</p>
</body>
</html>
