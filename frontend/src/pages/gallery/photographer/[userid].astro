---
/**
 * gallery/photographer/[userid].astro
 * Dynamic Route: /gallery/photographer/[userid]/
 *
 * Photographer profile detail view. Displays photographer card, membership status/badge,
 * stats overview, bio, and a responsive grid of their uploaded showcase photography.
 *
 * Uses hybrid pre-rendering and client-side hydration for build resilience.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionHeader from '../../../components/ui/SectionHeader.astro';
import MemberBadge from '../../../components/ui/MemberBadge.astro';

export async function getStaticPaths() {
  let photographers = [];
  try {
    const res = await fetch('http://localhost:3001/api/v1/photographers?limit=100');
    if (res.ok) {
      const json = await res.json();
      photographers = json.data || [];
    }
  } catch (e) {
    // Silent warn
  }

  // Pre-defined static paths for offline compilation
  const paths = [
    { params: { userid: 'ankit-tiwari' } },
    { params: { userid: 'rahil-khan' } },
    { params: { userid: 'sauvik-acharyya' } },
    { params: { userid: 'rajnish-khare' } },
    { params: { userid: 'kshitij-patle' } }
  ];

  photographers.forEach((p: any) => {
    if (p.userid && !paths.some(path => path.params.userid === p.userid)) {
      paths.push({ params: { userid: p.userid } });
    }
  });

  return paths;
}

const { userid } = Astro.params;

// Fallback details if database is offline
const fallbackPhotographers: Record<string, any> = {
  'ankit-tiwari': {
    displayName: 'Ankit Tiwari',
    userid: 'ankit-tiwari',
    memberClass: 'student',
    joined: '2020',
    bio: 'Travel and documentary photographer capturing the quiet landscapes and cultural heritage of Central India. Passionate about early morning light.',
    photoCount: 12,
    photos: [
      { id: 'orchha-reflection', title: 'Orchha Reflection', src: '/images/Orchha-Reflection-Ankit-Tiwari-1024x737.jpeg', aspect: 1.38 }
    ]
  },
  'rahil-khan': {
    displayName: 'Rahil Khan',
    userid: 'rahil-khan',
    memberClass: 'individual',
    joined: '2016',
    bio: 'Contemporary street visual artist capturing dynamic urban moments, frames, and high-contrast shadow compositions in old Bhopal markets.',
    photoCount: 24,
    photos: [
      { id: 'street-life', title: 'Street Life in Chowk', src: '/images/StreetLife-Rahil-Khan-1024x768.jpeg', aspect: 1.33 }
    ]
  }
};

const defaultPhotographer = fallbackPhotographers[userid] || {
  displayName: 'Club Photographer',
  userid: userid,
  memberClass: 'basic',
  joined: '2026',
  bio: 'A member photographer of the Bhopal Camera Club sharing their vision and documenting regional narratives.',
  photoCount: 1,
  photos: []
};
---

<BaseLayout
  title={`${defaultPhotographer.displayName} — Profile`}
  description={`Explore photography portfolios and member details for ${defaultPhotographer.displayName} on Bhopal Camera Club.`}
>
  <!-- Profile Header Card (Viewfinder Editorial themed) -->
  <header class="profile-header surface-white">
    <div class="container profile-card-layout">
      <div class="avatar-col">
        <div class="avatar-ring">
          <div id="ph-avatar-circle" class="avatar-circle">
            {(defaultPhotographer.displayName ?? '?').slice(0,2).toUpperCase()}
          </div>
        </div>
      </div>

      <div class="info-col">
        <div class="title-row">
          <h1 id="ph-name" class="photographer-name">{defaultPhotographer.displayName}</h1>
          <div id="ph-badge-wrap">
            <MemberBadge memberClass={defaultPhotographer.memberClass as any} size="md" />
          </div>
        </div>

        <p id="ph-bio" class="photographer-bio">{defaultPhotographer.bio}</p>

        <div class="stats-row">
          <div class="stat-box">
            <span class="stat-lbl">Member Since</span>
            <span id="ph-joined" class="stat-val">{defaultPhotographer.joined}</span>
          </div>
          <div class="stat-box">
            <span class="stat-lbl">Showcase Photos</span>
            <span id="ph-photos-count" class="stat-val">{defaultPhotographer.photoCount}</span>
          </div>
        </div>
      </div>
    </div>
    <div class="hairline"></div>
  </header>

  <!-- Photographer Photos Grid -->
  <section class="section portfolio-section" aria-label="Photographer portfolio">
    <div class="container">
      <SectionHeader
        eyebrow="Portfolio"
        title="Showcase Contributions"
        align="left"
      />

      <div id="portfolio-grid" class="portfolio-grid" data-gsap="stagger">
        {defaultPhotographer.photos.length > 0 ? (
          defaultPhotographer.photos.map((photo: any) => (
            <a href={`/showcase/${photo.id}/`} class="portfolio-card vf-card">
              <img src={photo.src} alt={photo.title} class="portfolio-img" loading="lazy" />
              <div class="card-overlay">
                <span class="card-title">{photo.title}</span>
              </div>
              <span class="vf-br" aria-hidden="true"></span>
              <span class="vf-bl" aria-hidden="true"></span>
            </a>
          ))
        ) : (
          <p id="no-photos-msg" class="empty-msg">No photographs uploaded to the showcase yet.</p>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.profile-header {
  padding-top: calc(var(--nav-h) + var(--s-8));
  padding-bottom: var(--s-8);
}
.profile-card-layout {
  display: grid;
  grid-template-columns: 140px 1fr;
  gap: var(--s-6);
  align-items: flex-start;
}
.avatar-col {
  display: flex;
  justify-content: center;
}
.avatar-ring {
  padding: 4px;
  border: 1px solid var(--hairline-strong);
  border-radius: var(--r-full);
}
.avatar-circle {
  width: 110px;
  height: 110px;
  border-radius: var(--r-full);
  background: var(--forest-gradient);
  color: var(--surface-0);
  font-family: var(--font-display);
  font-size: 32px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3px solid var(--surface-0);
  box-shadow: var(--e-1);
}
.avatar-circle img {
  width: 100%;
  height: 100%;
  border-radius: var(--r-full);
  object-fit: cover;
}

.info-col {
  display: flex;
  flex-direction: column;
  gap: var(--s-3);
}
.title-row {
  display: flex;
  align-items: center;
  gap: var(--s-3);
  flex-wrap: wrap;
}
.photographer-name {
  font-family: var(--font-display);
  font-size: var(--text-h2);
  font-weight: 700;
  color: var(--ink-900);
  letter-spacing: -0.015em;
}
.photographer-bio {
  font-family: var(--font-body);
  font-size: 14px;
  line-height: 1.65;
  color: var(--ink-600);
  max-width: 720px;
}
.stats-row {
  display: flex;
  gap: var(--s-6);
  margin-top: var(--s-2);
}
.stat-box {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.stat-lbl {
  font-family: var(--font-body);
  font-size: 10px;
  font-weight: 600;
  color: var(--ink-400);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.stat-val {
  font-family: var(--font-mono);
  font-size: 16px;
  font-weight: 700;
  color: var(--ink-900);
}

/* Portfolio grid */
.portfolio-section {
  background: var(--surface-1);
}
.portfolio-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--s-4);
  margin-top: var(--s-6);
}
.portfolio-card {
  position: relative;
  aspect-ratio: 3/2;
  overflow: hidden;
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  display: block;
}
.portfolio-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--m-fast) ease-in-out;
}
.portfolio-card:hover .portfolio-img {
  transform: scale(1.03);
}
.card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, transparent 60%);
  display: flex;
  align-items: flex-end;
  padding: var(--s-3);
  opacity: 0;
  transition: opacity var(--m-fast) ease-in-out;
  z-index: 5;
}
.portfolio-card:hover .card-overlay {
  opacity: 1;
}
.card-title {
  color: #fff;
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 600;
}
.empty-msg {
  grid-column: 1 / -1;
  text-align: center;
  padding: var(--s-12) 0;
  font-family: var(--font-body);
  font-size: 14px;
  color: var(--ink-400);
  background: var(--surface-0);
  border: 1px solid var(--hairline-soft);
}

@media (max-width: 768px) {
  .profile-card-layout {
    grid-template-columns: 1fr;
    gap: var(--s-4);
  }
  .portfolio-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media (max-width: 480px) {
  .portfolio-grid {
    grid-template-columns: 1fr;
  }
}
</style>

<script>
  const userId = window.location.pathname.split('/').filter(Boolean).pop();

  async function loadPhotographerProfile() {
    if (!userId) return;
    try {
      // 1. Fetch Profile Info
      const profileRes = await fetch(`/api/v1/photographers/${userId}`);
      if (!profileRes.ok) throw new Error('API Error');
      const { data: profile } = await profileRes.json();
      if (profile) {
        document.getElementById('ph-name')!.textContent = profile.displayName;
        document.getElementById('ph-bio')!.textContent = profile.bio || 'No bio provided yet.';
        document.getElementById('ph-joined')!.textContent = profile.joined || '2026';
        document.getElementById('ph-photos-count')!.textContent = String(profile.photoCount ?? 0);

        const initials = (profile.displayName ?? '?').slice(0,2).toUpperCase();
        const avatarCircle = document.getElementById('ph-avatar-circle')!;
        if (profile.avatarUrl) {
          avatarCircle.innerHTML = `<img src="${profile.avatarUrl}" alt="${profile.displayName}" width="110" height="110" />`;
        } else {
          avatarCircle.textContent = initials;
        }

        // Dynamically recreate the membership badge using classes mapping
        const badgeWrap = document.getElementById('ph-badge-wrap')!;
        badgeWrap.innerHTML = '';
        const memberClass = profile.memberClass || 'basic';
        const badgeSpan = document.createElement('span');
        badgeSpan.className = `tag tag-${memberClass}`;
        badgeSpan.style.textTransform = 'uppercase';
        badgeSpan.style.fontSize = '9px';
        badgeSpan.style.fontWeight = '700';
        badgeSpan.textContent = memberClass;
        badgeWrap.appendChild(badgeSpan);
      }

      // 2. Fetch Photos Portfolio via gallery endpoint (requires numeric userId from profile)
      const numericId = profile?.id;
      if (numericId) {
        const photosRes = await fetch(`/api/v1/gallery/photographer/${numericId}?limit=100`);
        if (photosRes.ok) {
          const { photos } = await photosRes.json();
          const grid = document.getElementById('portfolio-grid')!;
          if (Array.isArray(photos) && photos.length > 0) {
            grid.innerHTML = '';
            photos.forEach((photo: any) => {
              const imgSrc = photo.urls?.medium ?? photo.urls?.original ?? '';
              const card = document.createElement('a');
              card.href = `/showcase/${photo.uuid}/`;
              card.className = 'portfolio-card vf-card';
              card.innerHTML = `
                <img src="${imgSrc}" alt="${photo.title ?? ''}" class="portfolio-img" loading="lazy" />
                <div class="card-overlay">
                  <span class="card-title">${photo.title ?? ''}</span>
                </div>
                <span class="vf-br" aria-hidden="true"></span>
                <span class="vf-bl" aria-hidden="true"></span>
              `;
              grid.appendChild(card);
            });
          }
        }
      }
    } catch {
      // Keep static fallbacks
    }
  }

  loadPhotographerProfile();
</script>
