---
/**
 * /hub/account-settings — V6 20 Account Settings
 * Design authority: ProjectDocs/Wireframes/V6/20 Accounts Settings/
 *
 * Shell: BaseLayout (SiteHeader + SiteFooter) — NO HubLayout, NO HubSidebar.
 * Auth guard: redirect to /auth/signin if not authenticated.
 * Accessible to ALL authenticated roles.
 *
 * Sections:
 *   1. Name & Title (editable — PUT /api/v1/hub/account-settings/name)
 *   2. Email Address (change flow — POST /api/v1/hub/account-settings/email/initiate)
 *   3. Password (update — PUT /api/v1/hub/account-settings/password)
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Account Settings" description="Manage your name, email, and password.">
  <main class="as-shell" id="as-main">

    <!-- Auth loading -->
    <div id="as-loading" class="as-loading" aria-live="polite">
      <span class="as-loading__dot"></span>
      <span class="as-loading__dot"></span>
      <span class="as-loading__dot"></span>
    </div>

    <!-- Content (hidden until auth resolves) -->
    <div id="as-content" class="as-content" hidden>

      <div class="as-header">
        <div class="as-breadcrumb">
          <a href="/hub/" class="as-breadcrumb__link">Member Hub</a>
          <span class="as-breadcrumb__sep">›</span>
          <span class="as-breadcrumb__current">Account Settings</span>
        </div>
        <h1 class="as-title">Account Settings</h1>
        <p class="as-subtitle">Manage your name, email address, and password.</p>
      </div>

      <!-- ─────────────────────────────────────
           SECTION 1 — NAME & TITLE
           ───────────────────────────────────── -->
      <section class="as-section" id="as-section-name">
        <div class="as-section__head">
          <h2 class="as-section__title">Name &amp; Title</h2>
        </div>

        <form class="as-form" id="form-name" novalidate>

          <!-- Row 1: Title + First Name -->
          <div class="as-name-row as-name-row--top">
            <div class="as-field">
              <label class="as-label" for="name-title">Title</label>
              <div class="as-select-wrapper">
                <select class="as-select" id="name-title" name="nameTitle">
                  <option value="">—</option>
                  <option value="Mr.">Mr.</option>
                  <option value="Ms.">Ms.</option>
                  <option value="Mrs.">Mrs.</option>
                  <option value="Dr.">Dr.</option>
                  <option value="Prof.">Prof.</option>
                  <option value="Er.">Er.</option>
                  <option value="CA">CA</option>
                  <option value="Adv.">Adv.</option>
                </select>
                <span class="as-select-caret">▾</span>
              </div>
            </div>
            <div class="as-field as-field--grow">
              <label class="as-label" for="first-name">First Name <span class="as-required">*</span></label>
              <input class="as-input" type="text" id="first-name" name="firstName" autocomplete="given-name" required />
            </div>
          </div>

          <!-- Row 2: Middle Name + Last Name -->
          <div class="as-name-row as-name-row--bottom">
            <div class="as-field">
              <label class="as-label" for="middle-name">Middle Name</label>
              <input class="as-input" type="text" id="middle-name" name="middleName" placeholder="optional" autocomplete="additional-name" />
            </div>
            <div class="as-field">
              <label class="as-label" for="last-name">Last Name <span class="as-required">*</span></label>
              <input class="as-input" type="text" id="last-name" name="lastName" autocomplete="family-name" required />
            </div>
          </div>

          <!-- Display Name Preview -->
          <div class="as-preview-band">
            <span class="as-preview-name" id="preview-name">—</span>
            <span class="as-preview-hint">auto-updates as you type</span>
          </div>

          <!-- Username (read-only) -->
          <div class="as-field as-field--readonly">
            <div class="as-label-row">
              <label class="as-label" for="username-display">Username</label>
              <span class="as-badge">PERMANENT · MEM-007</span>
            </div>
            <input class="as-input as-input--readonly" type="text" id="username-display" readonly tabindex="-1" />
            <p class="as-hint">Username is permanent and cannot be changed.</p>
          </div>

          <div class="as-form-footer">
            <button type="submit" class="as-btn-gold" id="btn-save-name">Save Name</button>
            <span class="as-feedback" id="name-feedback" hidden></span>
          </div>

        </form>
      </section>

      <!-- ─────────────────────────────────────
           SECTION 2 — EMAIL ADDRESS
           ───────────────────────────────────── -->
      <section class="as-section" id="as-section-email">
        <div class="as-section__head">
          <h2 class="as-section__title">Email Address</h2>
        </div>

        <div class="as-field as-field--readonly">
          <div class="as-label-row">
            <label class="as-label">Current Email</label>
            <span class="as-badge">READ ONLY</span>
          </div>
          <input class="as-input as-input--readonly" type="email" id="current-email-display" readonly tabindex="-1" />
        </div>

        <!-- Expand trigger -->
        <button type="button" class="as-expand-link" id="email-change-toggle">
          Change email address ↓
        </button>

        <!-- Expanded email change form -->
        <div id="email-change-panel" class="as-email-panel" hidden>
          <div class="as-email-panel__label">CHANGE EMAIL ADDRESS</div>

          <form class="as-form" id="form-email" novalidate>
            <div class="as-field">
              <label class="as-label" for="new-email">New Email Address</label>
              <input class="as-input as-input--gold-focus" type="email" id="new-email" name="newEmail" autocomplete="email" />
            </div>
            <div class="as-form-footer">
              <button type="submit" class="as-btn-secondary" id="btn-send-verify">Send Verification Link</button>
            </div>
          </form>

          <!-- Sent state (hidden until email dispatched) -->
          <div id="email-sent-panel" class="as-sent-panel" hidden>
            <p class="as-sent-text" id="email-sent-text">
              Verification email sent. Click the link to confirm. Your current email stays active until verified.
            </p>
            <div class="as-sent-actions">
              <span id="resend-countdown" class="as-resend-countdown"></span>
              <button type="button" class="as-link-btn" id="btn-resend" hidden>Resend</button>
              <button type="button" class="as-link-btn as-link-btn--muted" id="btn-cancel-email">Cancel</button>
            </div>
          </div>

        </div>
      </section>

      <!-- ─────────────────────────────────────
           SECTION 3 — PASSWORD
           ───────────────────────────────────── -->
      <section class="as-section" id="as-section-password">
        <div class="as-section__head">
          <h2 class="as-section__title">Password</h2>
        </div>

        <form class="as-form" id="form-password" novalidate>

          <div class="as-field">
            <label class="as-label" for="current-password">Current Password</label>
            <div class="as-password-wrap">
              <input class="as-input" type="password" id="current-password" name="currentPassword" autocomplete="current-password" />
              <button type="button" class="as-eye-btn" data-target="current-password" aria-label="Show / hide password">
                <svg class="as-eye-icon as-eye-open" width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M1 9s2.8-5 8-5 8 5 8 5-2.8 5-8 5-8-5-8-5Z" stroke="currentColor" stroke-width="1.4"/><circle cx="9" cy="9" r="2.5" stroke="currentColor" stroke-width="1.4"/></svg>
                <svg class="as-eye-icon as-eye-closed" width="18" height="18" viewBox="0 0 18 18" fill="none" hidden><path d="M2 2l14 14M7.6 7.65A2.5 2.5 0 0 0 11.35 11.4M5 5.25C3.15 6.4 2 9 2 9s2.8 5 7 5c1.38 0 2.6-.41 3.62-1.07M13.62 12.92C15.3 11.6 16 9 16 9s-2.8-5-7-5c-.38 0-.75.03-1.12.08" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
              </button>
            </div>
          </div>

          <div class="as-field">
            <label class="as-label" for="new-password">New Password <span class="as-required">*</span></label>
            <div class="as-password-wrap">
              <input class="as-input" type="password" id="new-password" name="newPassword" autocomplete="new-password" />
              <button type="button" class="as-eye-btn" data-target="new-password" aria-label="Show / hide password">
                <svg class="as-eye-icon as-eye-open" width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M1 9s2.8-5 8-5 8 5 8 5-2.8 5-8 5-8-5-8-5Z" stroke="currentColor" stroke-width="1.4"/><circle cx="9" cy="9" r="2.5" stroke="currentColor" stroke-width="1.4"/></svg>
                <svg class="as-eye-icon as-eye-closed" width="18" height="18" viewBox="0 0 18 18" fill="none" hidden><path d="M2 2l14 14M7.6 7.65A2.5 2.5 0 0 0 11.35 11.4M5 5.25C3.15 6.4 2 9 2 9s2.8 5 7 5c1.38 0 2.6-.41 3.62-1.07M13.62 12.92C15.3 11.6 16 9 16 9s-2.8-5-7-5c-.38 0-.75.03-1.12.08" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
              </button>
            </div>
            <!-- Strength bar -->
            <div class="as-strength-wrap" id="pw-strength-wrap">
              <div class="as-strength-bar">
                <div class="as-strength-fill" id="pw-strength-fill"></div>
              </div>
              <span class="as-strength-label" id="pw-strength-label"></span>
            </div>
          </div>

          <div class="as-field">
            <label class="as-label" for="confirm-password">Confirm New Password <span class="as-required">*</span></label>
            <div class="as-password-wrap">
              <input class="as-input" type="password" id="confirm-password" name="confirmPassword" autocomplete="new-password" />
              <button type="button" class="as-eye-btn" data-target="confirm-password" aria-label="Show / hide password">
                <svg class="as-eye-icon as-eye-open" width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M1 9s2.8-5 8-5 8 5 8 5-2.8 5-8 5-8-5-8-5Z" stroke="currentColor" stroke-width="1.4"/><circle cx="9" cy="9" r="2.5" stroke="currentColor" stroke-width="1.4"/></svg>
                <svg class="as-eye-icon as-eye-closed" width="18" height="18" viewBox="0 0 18 18" fill="none" hidden><path d="M2 2l14 14M7.6 7.65A2.5 2.5 0 0 0 11.35 11.4M5 5.25C3.15 6.4 2 9 2 9s2.8 5 7 5c1.38 0 2.6-.41 3.62-1.07M13.62 12.92C15.3 11.6 16 9 16 9s-2.8-5-7-5c-.38 0-.75.03-1.12.08" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
              </button>
            </div>
            <span class="as-match-indicator" id="pw-match-indicator" hidden></span>
          </div>

          <div class="as-form-footer">
            <button type="submit" class="as-btn-gold" id="btn-update-password">Update Password</button>
            <span class="as-feedback" id="password-feedback" hidden></span>
          </div>

        </form>
      </section>

    </div><!-- /as-content -->
  </main>
</BaseLayout>

<style>
/* Shell */
.as-shell {
  min-height: 100vh;
  padding-top: 96px;
  padding-bottom: 80px;
  background: var(--surface-0, #FAF8F4);
}

.as-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  min-height: 40vh;
}
.as-loading__dot {
  width: 8px; height: 8px;
  background: #D8D2C6;
  border-radius: 999px;
  animation: as-pulse 1.2s ease-in-out infinite both;
}
.as-loading__dot:nth-child(2) { animation-delay: .2s; }
.as-loading__dot:nth-child(3) { animation-delay: .4s; }
@keyframes as-pulse {
  0%,80%,100% { transform:scale(.6); opacity:.4; }
  40%          { transform:scale(1);  opacity:1;  }
}

/* Content container */
.as-content {
  max-width: 640px;
  margin: 0 auto;
  padding: 0 20px;
}

/* Page header */
.as-header { margin-bottom: 40px; }
.as-breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 11px;
  color: #8B8378;
  margin-bottom: 12px;
}
.as-breadcrumb__link {
  color: #C9A961;
  text-decoration: none;
}
.as-breadcrumb__link:hover { text-decoration: underline; }
.as-breadcrumb__sep { color: #D8D2C6; }
.as-title {
  font-family: var(--font-heading, 'Outfit', sans-serif);
  font-size: 28px;
  font-weight: 700;
  color: #141210;
  margin: 0 0 6px;
}
.as-subtitle {
  font-size: 14px;
  color: #8B8378;
  margin: 0;
}

/* Section */
.as-section {
  background: #FFFFFF;
  border: 1px solid #E7E1D6;
  padding: 28px 28px 24px;
  margin-bottom: 20px;
}
.as-section__head { margin-bottom: 20px; }
.as-section__title {
  font-family: var(--font-heading, 'Outfit', sans-serif);
  font-size: 16px;
  font-weight: 700;
  color: #141210;
  margin: 0;
}

/* Form layout */
.as-form { display: flex; flex-direction: column; gap: 18px; }
.as-name-row {
  display: grid;
  gap: 12px;
}
.as-name-row--top { grid-template-columns: 116px 1fr; }
.as-name-row--bottom { grid-template-columns: 1fr 1fr; }
.as-field { display: flex; flex-direction: column; gap: 6px; }
.as-field--grow { flex: 1; }
.as-field--readonly { }
.as-label-row {
  display: flex;
  align-items: center;
  gap: 10px;
}
.as-label {
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .06em;
  text-transform: uppercase;
  color: #8B8378;
}
.as-required { color: #C9A961; }

.as-input {
  width: 100%;
  padding: 10px 12px;
  font-size: 14px;
  font-family: var(--font-body, 'Inter', sans-serif);
  color: #141210;
  background: #FFFFFF;
  border: 1px solid #D8D2C6;
  border-radius: 2px;
  outline: none;
  transition: border-color .15s;
  box-sizing: border-box;
}
.as-input:focus { border-color: #C9A961; }
.as-input--readonly {
  background: #F4F0E8;
  color: #8B8378;
  cursor: default;
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 13px;
}
.as-input--gold-focus:focus { border: 2px solid #C9A961; }

.as-select-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}
.as-select {
  width: 100%;
  padding: 10px 28px 10px 12px;
  font-size: 14px;
  color: #141210;
  background: #FFFFFF;
  border: 1px solid #D8D2C6;
  border-radius: 2px;
  outline: none;
  appearance: none;
  transition: border-color .15s;
}
.as-select:focus { border-color: #C9A961; }
.as-select-caret {
  position: absolute;
  right: 10px;
  pointer-events: none;
  font-size: 10px;
  color: #8B8378;
}
.as-badge {
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: #8B8378;
  background: #F4F0E8;
  border: 1px solid #E7E1D6;
  padding: 2px 7px;
  white-space: nowrap;
}
.as-hint {
  font-size: 12px;
  color: #8B8378;
  margin: 0;
}

/* Display name preview */
.as-preview-band {
  background: #F4F0E8;
  border: 1px solid #E7E1D6;
  padding: 16px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}
.as-preview-name {
  font-family: var(--font-heading, 'Outfit', sans-serif);
  font-size: 18px;
  font-weight: 600;
  color: #141210;
}
.as-preview-hint {
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 9px;
  color: #8B8378;
  white-space: nowrap;
}

/* Buttons */
.as-btn-gold {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 11px 28px;
  background: linear-gradient(135deg, #C9A961, #A8843C);
  color: #FFFFFF;
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: .03em;
  border: none;
  border-radius: 2px;
  cursor: pointer;
  transition: opacity .15s;
}
.as-btn-gold:hover { opacity: .9; }
.as-btn-gold:disabled { opacity: .5; cursor: default; }

.as-btn-secondary {
  display: inline-flex;
  align-items: center;
  padding: 11px 24px;
  background: transparent;
  border: 1px solid #D8D2C6;
  color: #141210;
  font-size: 13px;
  font-weight: 600;
  border-radius: 2px;
  cursor: pointer;
  transition: border-color .15s, color .15s;
}
.as-btn-secondary:hover { border-color: #C9A961; color: #A8843C; }

.as-link-btn {
  background: none;
  border: none;
  font-size: 13px;
  color: #C9A961;
  cursor: pointer;
  text-decoration: underline;
  padding: 0;
  font-family: var(--font-body, 'Inter', sans-serif);
}
.as-link-btn--muted { color: #8B8378; }

.as-form-footer {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
  margin-top: 4px;
}
.as-feedback {
  font-size: 13px;
  font-weight: 600;
}
.as-feedback--success { color: #2E6B45; }
.as-feedback--error   { color: #C0392B; }

/* Email change expand */
.as-expand-link {
  background: none;
  border: none;
  cursor: pointer;
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: 13px;
  color: #C9A961;
  text-decoration: underline;
  text-decoration-color: #C9A961;
  padding: 0;
  margin-top: 12px;
  display: inline-block;
}
.as-email-panel {
  margin-top: 20px;
  border-top: 1px solid #F0EBE0;
  padding-top: 20px;
}
.as-email-panel__label {
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .08em;
  color: #C9A961;
  margin-bottom: 16px;
}

/* Sent panel */
.as-sent-panel {
  background: #FFFFFF;
  border: 1px solid #D8D2C6;
  border-left: 3px solid #C9A961;
  padding: 16px 18px;
  margin-top: 16px;
}
.as-sent-text {
  font-size: 13px;
  color: #141210;
  margin: 0 0 12px;
  line-height: 1.55;
}
.as-sent-actions {
  display: flex;
  align-items: center;
  gap: 16px;
}
.as-resend-countdown {
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 11px;
  color: #8B8378;
}

/* Password */
.as-password-wrap {
  position: relative;
  display: flex;
  align-items: center;
}
.as-password-wrap .as-input { padding-right: 40px; }
.as-eye-btn {
  position: absolute;
  right: 10px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  color: #8B8378;
  display: flex;
  align-items: center;
}
.as-eye-btn:hover { color: #141210; }
.as-eye-icon[hidden] { display: none !important; }

/* Strength bar */
.as-strength-wrap { margin-top: 6px; }
.as-strength-bar {
  height: 4px;
  background: #E7E1D6;
  border-radius: 2px;
  overflow: hidden;
}
.as-strength-fill {
  height: 100%;
  width: 0;
  border-radius: 2px;
  transition: width .25s, background .25s;
}
.as-strength-fill--weak   { background: #C0392B; width: 33%; }
.as-strength-fill--fair   { background: #E67E22; width: 66%; }
.as-strength-fill--strong { background: #2E6B45; width: 100%; }
.as-strength-label {
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 10px;
  color: #8B8378;
  display: block;
  margin-top: 4px;
}

/* Match indicator */
.as-match-indicator {
  font-size: 12px;
  font-weight: 600;
}
.as-match-indicator--ok  { color: #2E6B45; }
.as-match-indicator--err { color: #C0392B; }

@media (max-width: 600px) {
  .as-name-row--top    { grid-template-columns: 1fr; }
  .as-name-row--bottom { grid-template-columns: 1fr; }
  .as-section { padding: 20px 16px 18px; }
  .as-preview-band { flex-direction: column; align-items: flex-start; gap: 4px; }
}
</style>

<script>
  const API = '/api/v1';

  /* ─── Auth helpers ───────────────────────────────────────────────── */
  async function getToken(): Promise<string | null> {
    const token = localStorage.getItem('bcc_token');
    if (!token) return null;
    try {
      const parts = token.split('.');
      if (parts.length !== 3) return null;
      const payload = JSON.parse(atob(parts[1].replace(/-/g, '+').replace(/_/g, '/')));
      if (Date.now() < (payload.exp as number) * 1000 - 60_000) return token;

      const refresh = localStorage.getItem('bcc_refresh');
      if (!refresh) { clearAuth(); return null; }
      const res = await fetch(`${API}/auth/refresh`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ refreshToken: refresh }),
      });
      if (!res.ok) { clearAuth(); return null; }
      const data = await res.json() as { accessToken: string; refreshToken: string };
      localStorage.setItem('bcc_token', data.accessToken);
      localStorage.setItem('bcc_refresh', data.refreshToken);
      return data.accessToken;
    } catch { return null; }
  }
  function clearAuth() {
    localStorage.removeItem('bcc_token');
    localStorage.removeItem('bcc_refresh');
    localStorage.removeItem('bcc_user');
  }

  /* ─── Helpers ───────────────────────────────────────────────────── */
  function showFeedback(el: HTMLElement, msg: string, type: 'success' | 'error') {
    el.textContent = msg;
    el.className = `as-feedback as-feedback--${type}`;
    el.removeAttribute('hidden');
    if (type === 'success') {
      setTimeout(() => { el.setAttribute('hidden', ''); }, 4000);
    }
  }

  /* ─── Boot ───────────────────────────────────────────────────────── */
  async function init() {
    const token = await getToken();
    if (!token) {
      const next = encodeURIComponent(window.location.pathname + window.location.search);
      window.location.replace(`/auth/signin/?next=${next}`);
      return;
    }

    const res = await fetch(`${API}/hub/account-settings`, {
      headers: { Authorization: `Bearer ${token}` },
    });
    if (!res.ok) {
      window.location.replace('/auth/signin/');
      return;
    }
    const data = await res.json() as {
      nameTitle: string | null;
      firstName: string | null;
      middleName: string | null;
      lastName: string | null;
      fullName: string;
      username: string | null;
      email: string | null;
    };

    // Populate Name section
    (document.getElementById('name-title') as HTMLSelectElement).value    = data.nameTitle  ?? '';
    (document.getElementById('first-name') as HTMLInputElement).value     = data.firstName  ?? '';
    (document.getElementById('middle-name') as HTMLInputElement).value    = data.middleName ?? '';
    (document.getElementById('last-name') as HTMLInputElement).value      = data.lastName   ?? '';
    (document.getElementById('username-display') as HTMLInputElement).value = data.username ?? '';
    updatePreview();

    // Populate Email section
    (document.getElementById('current-email-display') as HTMLInputElement).value = data.email ?? '';

    // Show content
    document.getElementById('as-loading')!.setAttribute('hidden', '');
    document.getElementById('as-content')!.removeAttribute('hidden');
  }

  /* ─── Live preview ───────────────────────────────────────────────── */
  function updatePreview() {
    const title  = (document.getElementById('name-title') as HTMLSelectElement).value;
    const first  = (document.getElementById('first-name') as HTMLInputElement).value.trim();
    const middle = (document.getElementById('middle-name') as HTMLInputElement).value.trim();
    const last   = (document.getElementById('last-name') as HTMLInputElement).value.trim();
    const parts  = [title, first, middle, last].filter(Boolean).join(' ');
    (document.getElementById('preview-name') as HTMLElement).textContent = parts || '—';
  }

  ['name-title', 'first-name', 'middle-name', 'last-name'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', updatePreview);
    document.getElementById(id)?.addEventListener('change', updatePreview);
  });

  /* ─── Section 1: Save Name ───────────────────────────────────────── */
  document.getElementById('form-name')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const feedback = document.getElementById('name-feedback') as HTMLElement;
    const btn      = document.getElementById('btn-save-name') as HTMLButtonElement;
    const token    = await getToken();
    if (!token) { window.location.replace('/auth/signin/'); return; }

    btn.disabled = true;
    try {
      const body = {
        nameTitle:  (document.getElementById('name-title') as HTMLSelectElement).value || undefined,
        firstName:  (document.getElementById('first-name') as HTMLInputElement).value.trim(),
        middleName: (document.getElementById('middle-name') as HTMLInputElement).value.trim() || undefined,
        lastName:   (document.getElementById('last-name') as HTMLInputElement).value.trim(),
      };
      const res = await fetch(`${API}/hub/account-settings/name`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
        body: JSON.stringify(body),
      });
      if (res.ok) {
        const d = await res.json() as { fullName: string };
        showFeedback(feedback, '✓ Name updated.', 'success');

        // Update localStorage
        try {
          const stored = JSON.parse(localStorage.getItem('bcc_user') ?? '{}') as Record<string, unknown>;
          const initials = d.fullName.trim().split(/\s+/).map((w: string) => w[0]).join('').slice(0, 2).toUpperCase();
          stored.displayName = d.fullName;
          stored.initials    = initials;
          localStorage.setItem('bcc_user', JSON.stringify(stored));
          // Update visible nav initials
          document.querySelectorAll('#nav-initials, #nav-initials-menu, #nav-mobile-initials, #drawer-initials').forEach(el => {
            el.textContent = initials;
          });
          document.querySelectorAll('#nav-name, #nav-name-menu, #drawer-name').forEach(el => {
            el.textContent = d.fullName;
          });
        } catch { /* non-critical */ }
      } else {
        const err = await res.json().catch(() => ({})) as { message?: string };
        showFeedback(feedback, err.message ?? 'Failed to save name.', 'error');
      }
    } catch {
      showFeedback(feedback, 'Network error. Please try again.', 'error');
    } finally {
      btn.disabled = false;
    }
  });

  /* ─── Section 2: Email change ────────────────────────────────────── */
  document.getElementById('email-change-toggle')?.addEventListener('click', () => {
    const panel = document.getElementById('email-change-panel');
    if (!panel) return;
    if (panel.hasAttribute('hidden')) {
      panel.removeAttribute('hidden');
    } else {
      panel.setAttribute('hidden', '');
    }
  });

  document.getElementById('btn-cancel-email')?.addEventListener('click', () => {
    document.getElementById('email-change-panel')?.setAttribute('hidden', '');
    document.getElementById('email-sent-panel')?.setAttribute('hidden', '');
    (document.getElementById('new-email') as HTMLInputElement).value = '';
  });

  let resendCountdownTimer: ReturnType<typeof setInterval> | null = null;

  function startResendCountdown() {
    const countdownEl = document.getElementById('resend-countdown') as HTMLElement;
    const resendBtn   = document.getElementById('btn-resend') as HTMLButtonElement;
    resendBtn.setAttribute('hidden', '');
    let secs = 60;
    countdownEl.textContent = `Resend in ${secs}s`;
    resendCountdownTimer && clearInterval(resendCountdownTimer);
    resendCountdownTimer = setInterval(() => {
      secs--;
      if (secs <= 0) {
        clearInterval(resendCountdownTimer!);
        countdownEl.textContent = '';
        resendBtn.removeAttribute('hidden');
      } else {
        countdownEl.textContent = `Resend in ${secs}s`;
      }
    }, 1000);
  }

  async function sendEmailChangeRequest() {
    const token = await getToken();
    if (!token) { window.location.replace('/auth/signin/'); return; }
    const newEmail = (document.getElementById('new-email') as HTMLInputElement).value.trim();
    if (!newEmail) return;

    const btn = document.getElementById('btn-send-verify') as HTMLButtonElement;
    btn.disabled = true;
    try {
      const res = await fetch(`${API}/hub/account-settings/email/initiate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
        body: JSON.stringify({ newEmail }),
      });
      if (res.ok) {
        const sentPanel = document.getElementById('email-sent-panel') as HTMLElement;
        const sentText  = document.getElementById('email-sent-text') as HTMLElement;
        sentText.textContent = `Verification email sent to ${newEmail}. Click the link to confirm. Your current email stays active until verified.`;
        document.getElementById('form-email')?.setAttribute('hidden', '');
        sentPanel.removeAttribute('hidden');
        startResendCountdown();
      } else {
        const err = await res.json().catch(() => ({})) as { message?: string };
        alert(err.message ?? 'Failed to send verification email.');
      }
    } catch {
      alert('Network error. Please try again.');
    } finally {
      btn.disabled = false;
    }
  }

  document.getElementById('form-email')?.addEventListener('submit', (e) => {
    e.preventDefault();
    sendEmailChangeRequest();
  });

  document.getElementById('btn-resend')?.addEventListener('click', () => {
    document.getElementById('form-email')?.removeAttribute('hidden');
    sendEmailChangeRequest();
  });

  /* ─── Section 3: Password strength + match ─────────────────────── */
  document.getElementById('new-password')?.addEventListener('input', () => {
    const val  = (document.getElementById('new-password') as HTMLInputElement).value;
    const fill = document.getElementById('pw-strength-fill') as HTMLElement;
    const lbl  = document.getElementById('pw-strength-label') as HTMLElement;

    fill.className = 'as-strength-fill';
    if (val.length === 0) {
      fill.style.width = '0'; lbl.textContent = '';
    } else if (val.length < 8) {
      fill.classList.add('as-strength-fill--weak');
      lbl.textContent = 'Too short (min 8 characters)';
    } else if (/[A-Z]/.test(val) && /[0-9]/.test(val) && /[^A-Za-z0-9]/.test(val)) {
      fill.classList.add('as-strength-fill--strong');
      lbl.textContent = 'Strong';
    } else {
      fill.classList.add('as-strength-fill--fair');
      lbl.textContent = 'Fair — add uppercase, numbers, symbols';
    }
    checkMatch();
  });

  function checkMatch() {
    const np  = (document.getElementById('new-password') as HTMLInputElement).value;
    const cp  = (document.getElementById('confirm-password') as HTMLInputElement).value;
    const ind = document.getElementById('pw-match-indicator') as HTMLElement;
    if (!np || !cp) { ind.setAttribute('hidden', ''); return; }
    ind.removeAttribute('hidden');
    if (np === cp) {
      ind.textContent = 'Passwords match ✓';
      ind.className = 'as-match-indicator as-match-indicator--ok';
    } else {
      ind.textContent = 'Passwords don\'t match';
      ind.className = 'as-match-indicator as-match-indicator--err';
    }
  }
  document.getElementById('confirm-password')?.addEventListener('input', checkMatch);

  /* ─── Eye toggle ─────────────────────────────────────────────────── */
  document.querySelectorAll('.as-eye-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = (btn as HTMLElement).dataset.target!;
      const input    = document.getElementById(targetId) as HTMLInputElement;
      const openIcon = btn.querySelector('.as-eye-open') as HTMLElement;
      const closedIcon = btn.querySelector('.as-eye-closed') as HTMLElement;
      const isHidden = input.type === 'password';
      input.type = isHidden ? 'text' : 'password';
      openIcon.hidden = isHidden;
      closedIcon.hidden = !isHidden;
    });
  });

  /* ─── Section 3: Update Password ────────────────────────────────── */
  document.getElementById('form-password')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const feedback = document.getElementById('password-feedback') as HTMLElement;
    const btn      = document.getElementById('btn-update-password') as HTMLButtonElement;
    const np  = (document.getElementById('new-password') as HTMLInputElement).value;
    const cp  = (document.getElementById('confirm-password') as HTMLInputElement).value;

    if (np !== cp) {
      showFeedback(feedback, 'Passwords don\'t match.', 'error');
      return;
    }
    if (np.length < 8) {
      showFeedback(feedback, 'New password must be at least 8 characters.', 'error');
      return;
    }

    const token = await getToken();
    if (!token) { window.location.replace('/auth/signin/'); return; }

    btn.disabled = true;
    try {
      const res = await fetch(`${API}/hub/account-settings/password`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
        body: JSON.stringify({
          currentPassword: (document.getElementById('current-password') as HTMLInputElement).value,
          newPassword: np,
        }),
      });
      if (res.ok) {
        showFeedback(feedback, 'Password updated.', 'success');
        (document.getElementById('form-password') as HTMLFormElement).reset();
        (document.getElementById('pw-strength-fill') as HTMLElement).className = 'as-strength-fill';
        (document.getElementById('pw-strength-label') as HTMLElement).textContent = '';
        document.getElementById('pw-match-indicator')?.setAttribute('hidden', '');
      } else if (res.status === 401) {
        showFeedback(feedback, 'Current password is incorrect.', 'error');
      } else {
        const err = await res.json().catch(() => ({})) as { message?: string };
        showFeedback(feedback, err.message ?? 'Failed to update password.', 'error');
      }
    } catch {
      showFeedback(feedback, 'Network error. Please try again.', 'error');
    } finally {
      btn.disabled = false;
    }
  });

  init();
</script>
