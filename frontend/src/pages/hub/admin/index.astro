}
.btn-set-spotlight:hover:not(:disabled) { opacity: 0.8; }
.btn-set-spotlight:disabled { opacity: 0.5; cursor: not-allowed; }
</style>

<script>
  const API = '/api/v1';

  /* ── Auth helper ───────────────────────────────────────────── */
  function getToken(): string | null {
    return localStorage.getItem('bcc_token');
  }

  function authHeaders(): Record<string, string> {
    const t = getToken();
    return t ? { Authorization: `Bearer ${t}`, 'Content-Type': 'application/json' } : {};
  }

  /* ── Helpers ────────────────────────────────────────────────── */
  function show(el: HTMLElement | null) { if (el) el.hidden = false; }
  function hide(el: HTMLElement | null) { if (el) el.hidden = true; }

  function fmtDate(val: string | null | undefined): string {
    if (!val) return '—';
    try { return new Date(val).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }); }
    catch { return val; }
  }

  /* ════════════════════════════════════════════════════════════
     SECTION 1 — PENDING APPLICATIONS
  ════════════════════════════════════════════════════════════ */
  interface PendingRow {
    id: number;
    user_id: number;
    username: string | null;
    full_name: string | null;
    email: string | null;
    class_name: string | null;
    class_code: string | null;
    applied_at: string | null;
    owner_type: string;
  }

  async function loadPending() {
    const loading = document.getElementById('pending-loading');
    const empty   = document.getElementById('pending-empty');
    const errorEl = document.getElementById('pending-error');
    const list    = document.getElementById('pending-list');
    if (!loading || !empty || !errorEl || !list) return;

    try {
      const res = await fetch(`${API}/membership/admin/pending`, { headers: authHeaders() });
      hide(loading);
      if (!res.ok) {
        errorEl.textContent = `Error ${res.status}: unable to load pending applications.`;
        show(errorEl);
        return;
      }
      const rows: PendingRow[] = await res.json() as PendingRow[];
      if (!rows.length) { show(empty); return; }

      list.innerHTML = rows.map(r => `
        <div class="pending-card" data-id="${r.id}">
          <div class="pending-card__info">
            <div class="pending-card__name">${r.full_name ?? r.username ?? 'Unknown'}</div>
            <div class="pending-card__meta">
              ${r.username ? `@${r.username} · ` : ''}${r.email ?? '—'}
              ${r.applied_at ? ` · Applied ${fmtDate(r.applied_at)}` : ''}
            </div>
          </div>
          ${r.class_name ? `<span class="pending-card__class">${r.class_name}</span>` : ''}
          <div class="pending-card__actions">
            <button class="btn-approve" data-action="approve" data-id="${r.id}">Approve</button>
            <button class="btn-reject"  data-action="reject"  data-id="${r.id}">Reject</button>
          </div>
          <span class="pending-card__status" id="status-${r.id}" hidden></span>
        </div>
      `).join('');

      show(list);

      list.addEventListener('click', async (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-action]');
        if (!btn) return;
        const action = btn.dataset.action as 'approve' | 'reject';
        const id = btn.dataset.id!;
        const card = list.querySelector<HTMLElement>(`.pending-card[data-id="${id}"]`);
        const statusEl = document.getElementById(`status-${id}`);
        const approveBtn = card?.querySelector<HTMLButtonElement>('[data-action="approve"]');
        const rejectBtn  = card?.querySelector<HTMLButtonElement>('[data-action="reject"]');

        if (approveBtn) approveBtn.disabled = true;
        if (rejectBtn)  rejectBtn.disabled  = true;

        let note = '';
        if (action === 'reject') {
          note = prompt('Reason for rejection (optional):') ?? '';
        }

        try {
          const body = action === 'reject' ? JSON.stringify({ reason: note }) : '{}';
          const res = await fetch(`${API}/membership/${id}/${action}`, {
            method: 'POST',
            headers: authHeaders(),
            body,
          });
          if (res.ok) {
            if (statusEl) { statusEl.textContent = action === 'approve' ? '✓ Approved' : '✗ Rejected'; show(statusEl); }
            if (card) card.style.opacity = '0.5';
          } else {
            const err = await res.json().catch(() => ({})) as { message?: string };
            if (statusEl) {
              statusEl.textContent = `Error: ${err.message ?? res.status}`;
              show(statusEl);
            }
            if (approveBtn) approveBtn.disabled = false;
            if (rejectBtn)  rejectBtn.disabled  = false;
          }
        } catch {
          if (statusEl) { statusEl.textContent = 'Network error'; show(statusEl); }
          if (approveBtn) approveBtn.disabled = false;
          if (rejectBtn)  rejectBtn.disabled  = false;
        }
      });
    } catch {
      hide(loading);
      if (errorEl) { errorEl.textContent = 'Failed to load pending applications.'; show(errorEl); }
    }
  }

  /* ════════════════════════════════════════════════════════════
     SECTION 2 — MEMBER SEARCH + PASSWORD RESET
  ════════════════════════════════════════════════════════════ */
  interface MemberRow {
    id: number;
    username: string | null;
    full_name: string | null;
    email: string | null;
    identity_status: 'IDENTITY_PENDING' | 'IDENTITY_COMPLETE' | null;
    identity_completed_at: string | null;
  }

  const searchForm    = document.getElementById('search-form')    as HTMLFormElement | null;
  const searchInput   = document.getElementById('search-input')   as HTMLInputElement | null;
  const searchLoading = document.getElementById('search-loading');
  const searchEmpty   = document.getElementById('search-empty');
  const searchError   = document.getElementById('search-error');
  const searchResults = document.getElementById('search-results');
  const resetPanel    = document.getElementById('reset-panel');
  const resetTargetName = document.getElementById('reset-target-name');
  const resetUserId   = document.getElementById('reset-user-id') as HTMLInputElement | null;
  const resetForm     = document.getElementById('reset-form')    as HTMLFormElement | null;
  const resetPassword = document.getElementById('reset-password') as HTMLInputElement | null;
  const resetFeedback = document.getElementById('reset-feedback');

  function clearSearchState() {
    hide(searchLoading); hide(searchEmpty); hide(searchError); hide(searchResults); hide(resetPanel);
    if (searchResults) searchResults.innerHTML = '';
    if (searchError) searchError.textContent = '';
  }

  searchForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const q = searchInput?.value.trim() ?? '';
    if (q.length < 2) return;

    clearSearchState();
    show(searchLoading);

    try {
      const res = await fetch(`${API}/users/admin/search?q=${encodeURIComponent(q)}`, { headers: authHeaders() });
      hide(searchLoading);

      if (!res.ok) {
        if (searchError) { searchError.textContent = `Search failed (${res.status}).`; show(searchError); }
        return;
      }
      const members: MemberRow[] = await res.json() as MemberRow[];
      if (!members.length) { show(searchEmpty); return; }

      if (searchResults) {
        searchResults.innerHTML = members.map(m => {
          const isPending = m.identity_status === 'IDENTITY_PENDING' || m.identity_status === null;
          const badgeCls  = isPending ? 'result-row__identity--pending' : 'result-row__identity--complete';
          const badgeTxt  = isPending ? 'PENDING' : 'COMPLETE';
          return `
            <div class="result-row"
              data-uid="${m.id}"
              data-name="${(m.full_name ?? m.username ?? 'Member').replace(/"/g, '&quot;')}"
              data-identity="${m.identity_status ?? 'IDENTITY_PENDING'}"
              data-identity-at="${m.identity_completed_at ?? ''}"
              data-username="${(m.username ?? '').replace(/"/g, '&quot;')}">
              <div class="result-row__name">${m.full_name ?? m.username ?? 'Unknown'}</div>
              <div class="result-row__meta">${m.username ? `@${m.username}` : '<em>no username</em>'} · ${m.email ?? ''}</div>
              <span class="result-row__identity ${badgeCls}">${badgeTxt}</span>
            </div>
          `;
        }).join('');
        show(searchResults);

        searchResults.addEventListener('click', (ev) => {
          const row = (ev.target as HTMLElement).closest<HTMLElement>('[data-uid]');
          if (!row) return;
          const uid        = row.dataset.uid!;
          const name       = row.dataset.name!;
          const identityStatus = row.dataset.identity!;
          const identityAt     = row.dataset.identityAt ?? '';
          const username       = row.dataset.username ?? '';

          // Password reset panel
          if (resetUserId) resetUserId.value = uid;
          if (resetTargetName) resetTargetName.textContent = `Reset password for: ${name}`;
          if (resetFeedback) { resetFeedback.textContent = ''; resetFeedback.className = 'reset-feedback'; hide(resetFeedback); }
          if (resetPassword) resetPassword.value = '';
          show(resetPanel);
          resetPassword?.focus();

          // Identity panel
          const identityPanel   = document.getElementById('identity-panel');
          const statusBadge     = document.getElementById('identity-status-badge');
          const identityDetail  = document.getElementById('identity-detail');
          const identityActions = document.getElementById('identity-actions');
          const identityFeedback= document.getElementById('identity-feedback');

          const isPending = identityStatus === 'IDENTITY_PENDING';
          if (statusBadge) {
            statusBadge.textContent = isPending ? 'IDENTITY PENDING' : 'IDENTITY COMPLETE';
            statusBadge.className = `identity-badge ${isPending ? 'identity-badge--pending' : 'identity-badge--complete'}`;
          }
          if (identityDetail) {
            if (isPending) {
              identityDetail.innerHTML = `<strong>${name}</strong> has not yet chosen a username.`;
            } else {
              identityDetail.innerHTML = `<strong>@${username}</strong> · Completed ${fmtDate(identityAt)}`;
            }
          }
          // Show action buttons only for PENDING users
          if (identityActions) {
            identityActions.hidden = !isPending;
            // Wire identity action buttons to this user (replace prior listeners by setting data attrs)
            identityActions.dataset.uid  = uid;
            identityActions.dataset.name = name;
          }
          if (identityFeedback) { identityFeedback.textContent = ''; identityFeedback.className = 'reset-feedback'; hide(identityFeedback); }
          if (identityPanel) show(identityPanel);
        }, { once: true });
      }
    } catch {
      hide(searchLoading);
      if (searchError) { searchError.textContent = 'Network error during search.'; show(searchError); }
    }
  });

  resetForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const uid = resetUserId?.value;
    const pwd = resetPassword?.value ?? '';
    if (!uid || pwd.length < 8) return;

    const submitBtn = resetForm.querySelector<HTMLButtonElement>('[type="submit"]');
    if (submitBtn) submitBtn.disabled = true;
    if (resetFeedback) { resetFeedback.hidden = true; }

    try {
      const res = await fetch(`${API}/membership/admin/users/${uid}/reset-password`, {
        method: 'POST',
        headers: authHeaders(),
        body: JSON.stringify({ newPassword: pwd }),
      });
      if (resetFeedback) {
        if (res.ok) {
          resetFeedback.textContent = 'Password reset. Member will be prompted to set a new one on next login.';
          resetFeedback.className = 'reset-feedback ok';
        } else {
          const err = await res.json().catch(() => ({})) as { message?: string };
          resetFeedback.textContent = `Error: ${err.message ?? res.status}`;
          resetFeedback.className = 'reset-feedback error';
        }
        show(resetFeedback);
      }
    } catch {
      if (resetFeedback) {
        resetFeedback.textContent = 'Network error. Please try again.';
        resetFeedback.className = 'reset-feedback error';
        show(resetFeedback);
      }
    } finally {
      if (submitBtn) submitBtn.disabled = false;
      if (resetPassword) resetPassword.value = '';
    }
  });

  /* ════════════════════════════════════════════════════════════
     SECTION 3 — EDITORIAL HERO MANAGER
  ════════════════════════════════════════════════════════════ */

  let eligiblePhotos = [];
  let destinations = [];
  let selectedPhotoUuid = '';
  let pendingSaveDestinations = [];
  let pendingReplacements = [];
  let currentReplacementIndex = 0;

  async function loadHeroManagerData() {
    const loadingEl = document.getElementById('hero-manager-loading');
    const emptyEl   = document.getElementById('hero-manager-empty');
    const errorEl   = document.getElementById('hero-manager-error');
    const listEl    = document.getElementById('hero-photo-list');

    show(loadingEl); hide(emptyEl); hide(errorEl); hide(listEl);

    try {
      if (destinations.length === 0) {
        const destRes = await fetch(`${API}/gallery/hero/destinations`);
        if (destRes.ok) {
          destinations = await destRes.json();
        }
      }

      const res = await fetch(`${API}/gallery/hero/eligible`, { headers: authHeaders() });
      hide(loadingEl);
      if (!res.ok) {
        if (errorEl) {
          errorEl.textContent = `Error loading eligible photos: ${res.status}`;
          show(errorEl);
        }
        return;
      }
      eligiblePhotos = await res.json();
      
      renderEligiblePhotos();
      populateFilters();
    } catch (e) {
      hide(loadingEl);
      if (errorEl) {
        errorEl.textContent = 'Network error loading eligible photos.';
        show(errorEl);
      }
      console.error(e);
    }
  }

  function populateFilters() {
    const projectSelect = document.getElementById('hero-filter-project') as HTMLSelectElement | null;
    const tagSelect     = document.getElementById('hero-filter-tag') as HTMLSelectElement | null;

    if (!projectSelect || !tagSelect) return;

    projectSelect.innerHTML = '<option value="">All Projects</option>';
    tagSelect.innerHTML     = '<option value="">All Tags</option>';

    const projects = new Set<string>();
    const tags = new Set<string>();

    eligiblePhotos.forEach(p => {
      (p.tags || []).forEach((t: any) => {
        if (t.category === 'PROJECT') {
          projects.add(JSON.stringify({ key: t.tag_key, name: t.display_name }));
        } else {
          tags.add(JSON.stringify({ key: t.tag_key, name: t.display_name }));
        }
      });
    });

    Array.from(projects).map(item => JSON.parse(item)).sort((a,b) => a.name.localeCompare(b.name)).forEach(proj => {
      const opt = document.createElement('option');
      opt.value = proj.key;
      opt.textContent = proj.name;
      projectSelect.appendChild(opt);
    });

    Array.from(tags).map(item => JSON.parse(item)).sort((a,b) => a.name.localeCompare(b.name)).forEach(tag => {
      const opt = document.createElement('option');
      opt.value = tag.key;
      opt.textContent = tag.name;
      tagSelect.appendChild(opt);
    });
  }

  function renderEligiblePhotos() {
    const listEl = document.getElementById('hero-photo-list');
    const emptyEl = document.getElementById('hero-manager-empty');
    if (!listEl) return;

    const qPhotographer = (document.getElementById('hero-search-photographer') as HTMLInputElement | null)?.value.trim().toLowerCase() ?? '';
    const qTitle = (document.getElementById('hero-search-title') as HTMLInputElement | null)?.value.trim().toLowerCase() ?? '';
    const fProject = (document.getElementById('hero-filter-project') as HTMLSelectElement | null)?.value ?? '';
    const fTag = (document.getElementById('hero-filter-tag') as HTMLSelectElement | null)?.value ?? '';
    const fUsage = (document.getElementById('hero-filter-usage') as HTMLSelectElement | null)?.value ?? '';
    const sortVal = (document.getElementById('hero-sort') as HTMLSelectElement | null)?.value ?? 'newest';

    let filtered = [...eligiblePhotos];

    if (qPhotographer) {
      filtered = filtered.filter(p => (p.photographer?.name ?? '').toLowerCase().includes(qPhotographer));
    }
    if (qTitle) {
      filtered = filtered.filter(p => (p.title ?? '').toLowerCase().includes(qTitle));
    }
    if (fProject) {
      filtered = filtered.filter(p => (p.tags || []).some((t: any) => t.tag_key === fProject));
    }
    if (fTag) {
      filtered = filtered.filter(p => (p.tags || []).some((t: any) => t.tag_key === fTag));
    }
    if (fUsage === 'unused') {
      filtered = filtered.filter(p => (p.assignments || []).length === 0);
    } else if (fUsage === 'assigned') {
      filtered = filtered.filter(p => (p.assignments || []).length > 0);
    } else if (fUsage === 'fixed') {
      filtered = filtered.filter(p => (p.assignments || []).some((a: any) => a.mode === 'FIXED'));
    } else if (fUsage === 'pool') {
      filtered = filtered.filter(p => (p.assignments || []).some((a: any) => a.mode === 'POOL'));
    }

    if (sortVal === 'newest') {
      filtered.sort((a,b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
    } else {
      filtered.sort((a,b) => new Date(a.created_at).getTime() - new Date(b.created_at).getTime());
    }

    listEl.innerHTML = '';
    if (filtered.length === 0) {
      show(emptyEl);
      hide(listEl);
      return;
    }

    hide(emptyEl);
    show(listEl);

    filtered.forEach(p => {
      const ratio = p.width_px && p.height_px ? (p.width_px / p.height_px).toFixed(2) : '—';
      const dateStr = new Date(p.created_at).toLocaleDateString('en-IN', {
        year: 'numeric', month: 'long', day: 'numeric'
      });

      let usageHtml = '<span class="usage-none-text">Not used currently</span>';
      if (p.assignments && p.assignments.length > 0) {
        usageHtml = p.assignments.map((a: any) => {
          const dest = destinations.find(d => d.key === a.location);
          const label = dest ? dest.label : a.location;
          const modeLabel = a.mode === 'FIXED' ? 'Fixed' : 'Pool';
          const badgeClass = a.mode === 'FIXED' ? 'usage-badge--fixed' : 'usage-badge--pool';
          return `<span class="usage-badge ${badgeClass}">✓ ${label} (${modeLabel})</span>`;
        }).join(' ');
      }

      const card = document.createElement('div');
      card.className = 'hero-photo-card';
      card.innerHTML = `
        <div class="hero-photo-card__preview">
          <img src="${p.urls?.medium ?? p.urls?.original ?? ''}" alt="${p.title ?? 'Hero Candidate'}" loading="lazy" />
        </div>
        <div class="hero-photo-card__details">
          <h3 class="hero-photo-card__title">${p.title ?? 'Untitled'}</h3>
          <div class="hero-photo-card__photographer">${p.photographer ? p.photographer.name : 'Unknown Photographer'}</div>
          <div class="hero-photo-card__meta">
            <span>Dimensions: ${p.width_px ?? '—'} &times; ${p.height_px ?? '—'}</span>
            <span class="meta-dot">&middot;</span>
            <span>Aspect Ratio: ${ratio}</span>
            <span class="meta-dot">&middot;</span>
            <span>Uploaded: ${dateStr}</span>
          </div>
          <div class="hero-photo-card__usage">
            <strong style="font-size:11px; text-transform:uppercase; letter-spacing:0.04em; color:var(--ink-400);">Used By:</strong>
            <div class="usage-list" style="display:inline-flex; flex-wrap:wrap; gap:6px; margin-left:8px; align-items:center;">
              ${usageHtml}
            </div>
          </div>
          <button type="button" class="btn-assign-hero" data-uuid="${p.uuid}">Assign Hero</button>
        </div>
      `;
      listEl.appendChild(card);
    });
  }

  function openAssignModal(uuid: string) {
    selectedPhotoUuid = uuid;
    const p = eligiblePhotos.find(photo => photo.uuid === uuid);
    if (!p) return;

    const img = document.getElementById('hero-modal-photo-img') as HTMLImageElement | null;
    const title = document.getElementById('hero-modal-photo-title');
    const credit = document.getElementById('hero-modal-photo-credit');
    const dims = document.getElementById('hero-modal-photo-dims');
    const container = document.getElementById('hero-destinations-container');

    if (img) img.src = p.urls?.medium ?? p.urls?.original ?? '';
    if (title) title.textContent = p.title ?? 'Untitled';
    if (credit) credit.textContent = p.photographer ? p.photographer.name : 'Unknown';
    if (dims) {
      const ratio = p.width_px && p.height_px ? (p.width_px / p.height_px).toFixed(2) : '—';
      dims.textContent = `${p.width_px ?? '—'} x ${p.height_px ?? '—'} (Ratio: ${ratio})`;
    }

    if (container) {
      container.innerHTML = destinations.map(dest => {
        const existing = (p.assignments || []).find((a: any) => a.location === dest.key);
        const isChecked = existing ? 'checked' : '';
        const isFixed = !existing || existing.mode === 'FIXED' ? 'checked' : '';
        const isPool = existing && existing.mode === 'POOL' ? 'checked' : '';
        const modesStyle = existing ? '' : 'style="display:none;"';

        return `
          <div class="hero-dest-item" data-key="${dest.key}">
            <div class="hero-dest-row">
              <input type="checkbox" id="chk-${dest.key}" class="dest-checkbox" data-key="${dest.key}" ${isChecked} />
              <div class="hero-dest-label-group">
                <label for="chk-${dest.key}" class="hero-dest-label">${dest.label}</label>
                <span class="hero-dest-desc">${dest.description}</span>
              </div>
            </div>
            <div class="hero-dest-modes" id="modes-${dest.key}" ${modesStyle}>
              ${dest.supportsFixed ? `
                <label>
                  <input type="radio" name="mode-${dest.key}" value="FIXED" ${isFixed} />
                  Fixed Hero
                </label>
              ` : ''}
              ${dest.supportsRotation ? `
                <label>
                  <input type="radio" name="mode-${dest.key}" value="POOL" ${isPool} />
                  Daily Rotation Pool
                </label>
              ` : ''}
            </div>
          </div>
        `;
      }).join('');

      container.querySelectorAll('.dest-checkbox').forEach(chk => {
        chk.addEventListener('change', (e) => {
          const key = (e.target as HTMLInputElement).dataset.key!;
          const checked = (e.target as HTMLInputElement).checked;
          const modesDiv = document.getElementById(`modes-${key}`);
          if (modesDiv) {
            modesDiv.style.display = checked ? 'flex' : 'none';
          }
        });
      });
    }

    show(document.getElementById('hero-assign-modal'));
  }

  async function saveAssignmentsFlow() {
    pendingSaveDestinations = [];
    pendingReplacements = [];
    currentReplacementIndex = 0;

    destinations.forEach(dest => {
      const chk = document.getElementById(`chk-${dest.key}`) as HTMLInputElement | null;
      if (chk && chk.checked) {
        const modeRadio = document.querySelector(`input[name="mode-${dest.key}"]:checked`) as HTMLInputElement | null;
        const mode = modeRadio ? modeRadio.value : 'FIXED';
        
        pendingSaveDestinations.push({ location: dest.key, mode });

        if (mode === 'FIXED') {
          const conflictPhoto = eligiblePhotos.find(other => 
            other.uuid !== selectedPhotoUuid && 
            (other.assignments || []).some((a: any) => a.location === dest.key && a.mode === 'FIXED')
          );
          if (conflictPhoto) {
            pendingReplacements.push({
              destination: dest,
              currentPhoto: conflictPhoto
            });
          }
        }
      }
    });

    if (pendingReplacements.length > 0) {
      hide(document.getElementById('hero-assign-modal'));
      showReplacementConfirmation();
    } else {
      await commitAssignments();
    }
  }

  function showReplacementConfirmation() {
    if (currentReplacementIndex >= pendingReplacements.length) {
      commitAssignments();
      return;
    }

    const rep = pendingReplacements[currentReplacementIndex];
    const destLabel = document.getElementById('replace-destination-label');
    const currentImg = document.getElementById('replace-current-img') as HTMLImageElement | null;
    const currentTitle = document.getElementById('replace-current-title');
    const currentCredit = document.getElementById('replace-current-credit');

    const newImg = document.getElementById('replace-new-img') as HTMLImageElement | null;
    const newTitle = document.getElementById('replace-new-title');
    const newCredit = document.getElementById('replace-new-credit');

    const newPhoto = eligiblePhotos.find(p => p.uuid === selectedPhotoUuid)!;

    if (destLabel) destLabel.textContent = rep.destination.label;
    
    if (currentImg) currentImg.src = rep.currentPhoto.urls?.medium ?? rep.currentPhoto.urls?.original ?? '';
    if (currentTitle) currentTitle.textContent = rep.currentPhoto.title ?? 'Untitled';
    if (currentCredit) currentCredit.textContent = rep.currentPhoto.photographer ? `by ${rep.currentPhoto.photographer.name}` : 'Unknown';

    if (newImg) newImg.src = newPhoto.urls?.medium ?? newPhoto.urls?.original ?? '';
    if (newTitle) newTitle.textContent = newPhoto.title ?? 'Untitled';
    if (newCredit) newCredit.textContent = newPhoto.photographer ? `by ${newPhoto.photographer.name}` : 'Unknown';

    show(document.getElementById('hero-replace-modal'));
  }

  async function commitAssignments() {
    hide(document.getElementById('hero-assign-modal'));
    hide(document.getElementById('hero-replace-modal'));

    const p = eligiblePhotos.find(photo => photo.uuid === selectedPhotoUuid);
    if (!p) return;

    const currentAssignments = p.assignments || [];
    const newAssignments = [...pendingSaveDestinations];

    const toUnassign = currentAssignments.filter((curr: any) => 
      !newAssignments.some(nxt => nxt.location === curr.location)
    );
    const toAssign = [...newAssignments];

    const saveBtn = document.getElementById('hero-assign-save') as HTMLButtonElement | null;
    if (saveBtn) {
      saveBtn.disabled = true;
      saveBtn.textContent = 'Saving…';
    }

    try {
      const promises = [];

      toUnassign.forEach(u => {
        promises.push(
          fetch(`${API}/gallery/hero/unassign`, {
            method: 'POST',
            headers: authHeaders(),
            body: JSON.stringify({ photo_uuid: selectedPhotoUuid, location: u.location })
          })
        );
      });

      toAssign.forEach(a => {
        promises.push(
          fetch(`${API}/gallery/hero/assign`, {
            method: 'POST',
            headers: authHeaders(),
            body: JSON.stringify({ photo_uuid: selectedPhotoUuid, location: a.location, mode: a.mode })
          })
        );
      });

      await Promise.all(promises);
      await loadHeroManagerData();
    } catch (e) {
      console.error('Failed to save assignments', e);
      alert('An error occurred while saving assignments.');
    } finally {
      if (saveBtn) {
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save Assignments';
      }
    }
  }

  // Register filter event listeners
  document.getElementById('hero-search-photographer')?.addEventListener('input', () => renderEligiblePhotos());
  document.getElementById('hero-search-title')?.addEventListener('input', () => renderEligiblePhotos());
  document.getElementById('hero-filter-project')?.addEventListener('change', () => renderEligiblePhotos());
  document.getElementById('hero-filter-tag')?.addEventListener('change', () => renderEligiblePhotos());
  document.getElementById('hero-filter-usage')?.addEventListener('change', () => renderEligiblePhotos());
  document.getElementById('hero-sort')?.addEventListener('change', () => renderEligiblePhotos());

  // Close modals listeners
  document.getElementById('hero-assign-modal-close')?.addEventListener('click', () => {
    hide(document.getElementById('hero-assign-modal'));
  });
  document.getElementById('hero-assign-cancel')?.addEventListener('click', () => {
    hide(document.getElementById('hero-assign-modal'));
  });
  document.getElementById('hero-assign-save')?.addEventListener('click', () => {
    saveAssignmentsFlow();
  });

  document.getElementById('hero-replace-cancel')?.addEventListener('click', () => {
    hide(document.getElementById('hero-replace-modal'));
    show(document.getElementById('hero-assign-modal'));
  });

  document.getElementById('hero-replace-confirm')?.addEventListener('click', () => {
    hide(document.getElementById('hero-replace-modal'));
    currentReplacementIndex++;
    if (currentReplacementIndex >= pendingReplacements.length) {
      commitAssignments();
    } else {
      showReplacementConfirmation();
    }
  });

  // Assign button click listener delegation
  document.getElementById('hero-photo-list')?.addEventListener('click', (ev) => {
    const btn = (ev.target as HTMLElement).closest<HTMLButtonElement>('.btn-assign-hero');
    if (!btn) return;
    const uuid = btn.dataset.uuid!;
    openAssignModal(uuid);
  });

  /* ════════════════════════════════════════════════════════════
     IDENTITY ACTIONS
  ════════════════════════════════════════════════════════════ */
  function identityFeedbackMsg(msg: string, kind: 'ok' | 'error'): void {
    const el = document.getElementById('identity-feedback');
    if (!el) return;
    el.textContent = msg;
    el.className = `reset-feedback ${kind}`;
    show(el);
  }

  async function identityAction(endpoint: string, uid: string, successMsg: string = 'Email dispatched.'): Promise<void> {
    const res = await fetch(`${API}/identity/${endpoint}/${uid}`, {
      method: 'POST',
      headers: authHeaders(),
      body: '{}',
    });
    if (res.ok) {
      identityFeedbackMsg(successMsg, 'ok');
    } else {
      const err = await res.json().catch(() => ({})) as { message?: string };
      identityFeedbackMsg(`Error: ${err.message ?? res.status}`, 'error');
    }
  }

  function getIdentityUid(): string | null {
    return (document.getElementById('identity-actions') as HTMLElement | null)?.dataset.uid ?? null;
  }

  document.getElementById('btn-send-link')?.addEventListener('click', async () => {
    const uid = getIdentityUid(); if (!uid) return;
    const btn = document.getElementById('btn-send-link') as HTMLButtonElement;
    btn.disabled = true;
    try { await identityAction('admin/send-completion-link', uid); }
    catch { identityFeedbackMsg('Network error. Please try again.', 'error'); }
    finally { btn.disabled = false; }
  });

  document.getElementById('btn-send-priority')?.addEventListener('click', async () => {
    const uid = getIdentityUid(); if (!uid) return;
    const btn = document.getElementById('btn-send-priority') as HTMLButtonElement;
    btn.disabled = true;
    try { await identityAction('admin/send-priority-completion-link', uid); }
    catch { identityFeedbackMsg('Network error. Please try again.', 'error'); }
    finally { btn.disabled = false; }
  });

  document.getElementById('btn-resend-welcome')?.addEventListener('click', async () => {
    const uid = getIdentityUid(); if (!uid) return;
    const btn = document.getElementById('btn-resend-welcome') as HTMLButtonElement;
    btn.disabled = true;
    try { await identityAction('admin/resend-welcome', uid); }
    catch { identityFeedbackMsg('Network error. Please try again.', 'error'); }
    finally { btn.disabled = false; }
  });

  document.getElementById('btn-send-invitation')?.addEventListener('click', async () => {
    const uid = getIdentityUid(); if (!uid) return;
    const btn = document.getElementById('btn-send-invitation') as HTMLButtonElement;
    btn.disabled = true;
    try { await identityAction('admin/send-membership-invitation', uid, 'Membership invitation email sent successfully.'); }
    catch { identityFeedbackMsg('Network error. Please try again.', 'error'); }
    finally { btn.disabled = false; }
  });

  /* ── Init ────────────────────────────────────────────────── */
  loadPending();
  loadHeroManagerData();
</script>
