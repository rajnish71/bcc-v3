---
/**
 * hub/admin/index.astro — Admin Console
 * Route: /hub/admin/
 *
 * Requires admin role (enforced client-side; backend guards enforce server-side).
 * Sections:
 *   1. Pending membership applications — approve / reject
 *   2. Member search + password reset
 */
import HubLayout from '../../../layouts/HubLayout.astro';
---

<HubLayout title="Admin Console" description="Bhopal Camera Club admin console.">

  <div class="admin-console">

    <!-- ① PENDING APPLICATIONS ──────────────────────────────────────────── -->
    <section class="admin-section" id="section-pending">
      <div class="section-kicker"><span class="kicker-rule"></span>Membership Applications</div>
      <h2 class="section-title">Pending Approvals</h2>

      <div id="pending-loading" class="state-loading">Loading applications…</div>
      <div id="pending-empty"   class="state-empty"   hidden>No pending applications.</div>
      <div id="pending-error"   class="state-error"   hidden></div>

      <div id="pending-list" class="pending-list" hidden></div>
    </section>

    <!-- ② MEMBER SEARCH + PASSWORD RESET ──────────────────────────────── -->
    <section class="admin-section" id="section-members">
      <div class="section-kicker"><span class="kicker-rule"></span>Member Management</div>
      <h2 class="section-title">Password Reset</h2>

      <form class="search-form" id="search-form" autocomplete="off">
        <input
          type="text"
          id="search-input"
          class="search-input"
          placeholder="Search by username, name or email…"
          minlength="2"
          required
        />
        <button type="submit" class="btn-search">Search</button>
      </form>

      <div id="search-loading" class="state-loading" hidden>Searching…</div>
      <div id="search-empty"   class="state-empty"   hidden>No members found.</div>
      <div id="search-error"   class="state-error"   hidden></div>
      <div id="search-results" class="search-results" hidden></div>

      <!-- Inline reset form (revealed when a member is selected) -->
      <div id="reset-panel" class="reset-panel" hidden>
        <h3 class="reset-title" id="reset-target-name"></h3>
        <p class="reset-hint">Set a temporary password. The member will be forced to change it on next login.</p>
        <form id="reset-form" class="reset-form">
          <input type="hidden" id="reset-user-id" />
          <div class="field-row">
            <input
              type="password"
              id="reset-password"
              class="field-input"
              placeholder="New temporary password (min 8 chars)"
              minlength="8"
              required
            />
            <button type="submit" class="btn-reset">Set Password</button>
          </div>
          <div id="reset-feedback" class="reset-feedback" hidden></div>
        </form>
      </div>

      <!-- Identity actions panel (revealed alongside reset-panel when a member is selected) -->
      <div id="identity-panel" class="identity-panel" hidden>
        <div class="identity-panel__header">
          <span class="identity-panel__label">Identity Status</span>
          <span id="identity-status-badge" class="identity-badge"></span>
        </div>
        <div id="identity-detail" class="identity-detail"></div>
        <div class="identity-actions" id="identity-actions" hidden>
          <button id="btn-send-link"     type="button" class="btn-identity-action">Send Completion Link</button>
          <button id="btn-send-priority" type="button" class="btn-identity-action btn-identity-action--priority">Send Priority Link</button>
          <button id="btn-resend-welcome" type="button" class="btn-identity-action btn-identity-action--secondary">Resend Welcome Email</button>
        </div>
        <div id="identity-feedback" class="reset-feedback" hidden></div>
      </div>
    </section>

    <!-- ③ SPOTLIGHT MANAGEMENT ─────────────────────────────────────────── -->
    <section class="admin-section" id="section-spotlight">
      <div class="section-kicker"><span class="kicker-rule"></span>Homepage</div>
      <h2 class="section-title">Spotlight Photo</h2>

      <!-- Current spotlight preview -->
      <div id="spotlight-current" class="spotlight-current" hidden>
        <div class="spotlight-label">Current spotlight</div>
        <div class="spotlight-preview-row">
          <img id="spotlight-preview-img" class="spotlight-preview-img" src="" alt="" />
          <div class="spotlight-preview-info">
            <div class="spotlight-preview-title" id="spotlight-preview-title"></div>
            <div class="spotlight-preview-credit" id="spotlight-preview-credit"></div>
          </div>
        </div>
      </div>
      <div id="spotlight-none" class="state-empty" hidden>No spotlight set — homepage falls back to latest gallery photo.</div>

      <!-- Photo search -->
      <form class="search-form" id="spotlight-search-form" autocomplete="off">
        <input
          type="text"
          id="spotlight-search-input"
          class="search-input"
          placeholder="Search public photos by title or photographer…"
          minlength="2"
          required
        />
        <button type="submit" class="btn-search">Search</button>
      </form>

      <div id="spotlight-search-loading" class="state-loading" hidden>Searching…</div>
      <div id="spotlight-search-empty"   class="state-empty"   hidden>No photos found.</div>
      <div id="spotlight-search-error"   class="state-error"   hidden></div>

      <!-- Photo results grid -->
      <div id="spotlight-results" class="spotlight-results" hidden></div>

      <!-- Set confirmation -->
      <div id="spotlight-set-feedback" class="reset-feedback" hidden></div>
    </section>

  </div>

</HubLayout>

<style>
/* ─── Layout ─────────────────────────────────────────────────── */
.admin-console {
  padding: 32px 0 64px;
  display: flex;
  flex-direction: column;
  gap: 56px;
}

/* ─── Section ────────────────────────────────────────────────── */
.admin-section {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.section-kicker {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #A8843C;
}
.kicker-rule {
  display: inline-block;
  width: 24px;
  height: 1px;
  background: #A8843C;
}
.section-title {
  font-family: 'Outfit', sans-serif;
  font-size: 22px;
  font-weight: 600;
  color: #141210;
  margin: 0;
  line-height: 1.3;
}

/* ─── State messages ──────────────────────────────────────────── */
.state-loading,
.state-empty {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  color: #7A7469;
  padding: 12px 0;
}
.state-error {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  color: #C0392B;
  padding: 12px 0;
}

/* ─── Pending list ────────────────────────────────────────────── */
.pending-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.pending-card {
  background: #fff;
  border: 1px solid #E7E1D6;
  padding: 16px 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}
.pending-card__info {
  flex: 1 1 auto;
  min-width: 160px;
}
.pending-card__name {
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 600;
  color: #141210;
}
.pending-card__meta {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  color: #7A7469;
  margin-top: 3px;
}
.pending-card__class {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  background: #F5F0E8;
  color: #5A4E38;
  padding: 2px 8px;
  border: 1px solid #E7E1D6;
  align-self: center;
  white-space: nowrap;
}
.pending-card__actions {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}
.btn-approve,
.btn-reject {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  font-weight: 600;
  padding: 6px 16px;
  border: none;
  cursor: pointer;
  transition: opacity 0.15s;
}
.btn-approve {
  background: #1A7A40;
  color: #fff;
}
.btn-reject {
  background: transparent;
  border: 1px solid #C0392B;
  color: #C0392B;
}
.btn-approve:disabled,
.btn-reject:disabled { opacity: 0.5; cursor: not-allowed; }
.btn-approve:hover:not(:disabled) { opacity: 0.85; }
.btn-reject:hover:not(:disabled)  { opacity: 0.75; }

.pending-card__status {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  font-style: italic;
  color: #7A7469;
}

/* ─── Search form ─────────────────────────────────────────────── */
.search-form {
  display: flex;
  gap: 8px;
  max-width: 520px;
}
.search-input {
  flex: 1;
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  padding: 9px 14px;
  border: 1px solid #D8D2C6;
  color: #141210;
  background: #fff;
  outline: none;
  transition: border-color 0.15s;
}
.search-input:focus { border-color: #A8843C; }
.btn-search {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  font-weight: 600;
  padding: 9px 20px;
  background: #141210;
  color: #fff;
  border: none;
  cursor: pointer;
  transition: opacity 0.15s;
}
.btn-search:hover { opacity: 0.8; }

/* ─── Search results ──────────────────────────────────────────── */
.search-results {
  display: flex;
  flex-direction: column;
  gap: 6px;
  max-width: 520px;
}
.result-row {
  background: #fff;
  border: 1px solid #E7E1D6;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  transition: background 0.12s;
}
.result-row:hover { background: #FAF8F4; }
.result-row__name {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 600;
  color: #141210;
  flex: 1;
}
.result-row__meta {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  color: #7A7469;
}

/* ─── Reset panel ─────────────────────────────────────────────── */
.reset-panel {
  max-width: 520px;
  background: #FAF8F4;
  border: 1px solid #E7E1D6;
  padding: 20px 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.reset-title {
  font-family: 'Outfit', sans-serif;
  font-size: 16px;
  font-weight: 600;
  color: #141210;
  margin: 0;
}
.reset-hint {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  color: #7A7469;
  margin: 0;
}
.reset-form { display: flex; flex-direction: column; gap: 10px; }
.field-row {
  display: flex;
  gap: 8px;
}
.field-input {
  flex: 1;
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  padding: 9px 14px;
  border: 1px solid #D8D2C6;
  background: #fff;
  color: #141210;
  outline: none;
  transition: border-color 0.15s;
}
.field-input:focus { border-color: #A8843C; }
.btn-reset {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  font-weight: 600;
  padding: 9px 20px;
  background: #C9A961;
  color: #141210;
  border: none;
  cursor: pointer;
  transition: opacity 0.15s;
  white-space: nowrap;
}
.btn-reset:hover:not(:disabled) { opacity: 0.85; }
.btn-reset:disabled { opacity: 0.5; cursor: not-allowed; }
.reset-feedback {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  padding: 8px 12px;
}
.reset-feedback.ok    { background: #E8F5E9; color: #1A7A40; }
.reset-feedback.error { background: #FDECEA; color: #C0392B; }

/* ─── Identity badge ──────────────────────────────────────── */
.identity-badge {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  font-weight: 700;
  padding: 2px 8px;
  border: 1px solid;
  white-space: nowrap;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.identity-badge--pending {
  background: #FEF3C7;
  border-color: #FCD34D;
  color: #92400E;
}
.identity-badge--complete {
  background: #D1FAE5;
  border-color: #6EE7B7;
  color: #065F46;
}

/* Identity status in search result rows */
.result-row__identity {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  padding: 1px 6px;
  border: 1px solid;
}
.result-row__identity--pending  { background: #FEF3C7; border-color: #FCD34D; color: #92400E; }
.result-row__identity--complete { background: #D1FAE5; border-color: #6EE7B7; color: #065F46; }

/* ─── Identity panel ──────────────────────────────────────── */
.identity-panel {
  max-width: 520px;
  background: #F8F6F2;
  border: 1px solid #E7E1D6;
  padding: 16px 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 4px;
}
.identity-panel__header {
  display: flex;
  align-items: center;
  gap: 10px;
}
.identity-panel__label {
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #7A7469;
}
.identity-detail {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  color: #5A5048;
  line-height: 1.6;
}
.identity-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.btn-identity-action {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  font-weight: 600;
  padding: 7px 14px;
  border: none;
  cursor: pointer;
  transition: opacity 0.15s;
  background: #141210;
  color: #fff;
  white-space: nowrap;
}
.btn-identity-action--priority {
  background: #C0392B;
}
.btn-identity-action--secondary {
  background: transparent;
  border: 1px solid #7A7469;
  color: #5A5048;
}
.btn-identity-action:disabled { opacity: 0.5; cursor: not-allowed; }
.btn-identity-action:hover:not(:disabled) { opacity: 0.8; }

/* ─── Spotlight management ─────────────────────────────────── */
.spotlight-current {
  background: #FAF8F4;
  border: 1px solid #E7E1D6;
  padding: 14px 16px;
  max-width: 560px;
}
.spotlight-label {
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #A8843C;
  margin-bottom: 10px;
}
.spotlight-preview-row {
  display: flex;
  align-items: flex-start;
  gap: 14px;
}
.spotlight-preview-img {
  width: 96px;
  height: 64px;
  object-fit: cover;
  flex-shrink: 0;
  border: 1px solid #E7E1D6;
}
.spotlight-preview-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.spotlight-preview-title {
  font-family: 'Outfit', sans-serif;
  font-size: 14px;
  font-weight: 600;
  color: #141210;
}
.spotlight-preview-credit {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  color: #7A7469;
}
.spotlight-results {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 10px;
  max-width: 640px;
}
.spotlight-photo-card {
  position: relative;
  cursor: pointer;
  border: 2px solid transparent;
  transition: border-color 0.15s;
}
.spotlight-photo-card:hover { border-color: #C9A961; }
.spotlight-photo-card img {
  display: block;
  width: 100%;
  height: 108px;
  object-fit: cover;
}
.spotlight-photo-card__title {
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  color: #141210;
  padding: 4px 6px 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  background: #fff;
  border: 1px solid #E7E1D6;
  border-top: none;
}
.spotlight-photo-card__credit {
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  color: #7A7469;
  padding: 0 6px 4px;
  background: #fff;
  border: 1px solid #E7E1D6;
  border-top: none;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.btn-set-spotlight {
  display: block;
  width: 100%;
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 600;
  padding: 5px 0;
  background: #C9A961;
  color: #141210;
  border: none;
  cursor: pointer;
  transition: opacity 0.15s;
}
.btn-set-spotlight:hover:not(:disabled) { opacity: 0.8; }
.btn-set-spotlight:disabled { opacity: 0.5; cursor: not-allowed; }
</style>

<script>
  const API = '/api/v1';

  /* ── Auth helper ───────────────────────────────────────────── */
  function getToken(): string | null {
    return localStorage.getItem('bcc_token');
  }

  function authHeaders(): Record<string, string> {
    const t = getToken();
    return t ? { Authorization: `Bearer ${t}`, 'Content-Type': 'application/json' } : {};
  }

  /* ── Helpers ────────────────────────────────────────────────── */
  function show(el: HTMLElement | null) { if (el) el.hidden = false; }
  function hide(el: HTMLElement | null) { if (el) el.hidden = true; }

  function fmtDate(val: string | null | undefined): string {
    if (!val) return '—';
    try { return new Date(val).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }); }
    catch { return val; }
  }

  /* ════════════════════════════════════════════════════════════
     SECTION 1 — PENDING APPLICATIONS
  ════════════════════════════════════════════════════════════ */
  interface PendingRow {
    id: number;
    user_id: number;
    username: string | null;
    full_name: string | null;
    email: string | null;
    class_name: string | null;
    class_code: string | null;
    applied_at: string | null;
    owner_type: string;
  }

  async function loadPending() {
    const loading = document.getElementById('pending-loading');
    const empty   = document.getElementById('pending-empty');
    const errorEl = document.getElementById('pending-error');
    const list    = document.getElementById('pending-list');
    if (!loading || !empty || !errorEl || !list) return;

    try {
      const res = await fetch(`${API}/membership/admin/pending`, { headers: authHeaders() });
      hide(loading);
      if (!res.ok) {
        errorEl.textContent = `Error ${res.status}: unable to load pending applications.`;
        show(errorEl);
        return;
      }
      const rows: PendingRow[] = await res.json() as PendingRow[];
      if (!rows.length) { show(empty); return; }

      list.innerHTML = rows.map(r => `
        <div class="pending-card" data-id="${r.id}">
          <div class="pending-card__info">
            <div class="pending-card__name">${r.full_name ?? r.username ?? 'Unknown'}</div>
            <div class="pending-card__meta">
              ${r.username ? `@${r.username} · ` : ''}${r.email ?? '—'}
              ${r.applied_at ? ` · Applied ${fmtDate(r.applied_at)}` : ''}
            </div>
          </div>
          ${r.class_name ? `<span class="pending-card__class">${r.class_name}</span>` : ''}
          <div class="pending-card__actions">
            <button class="btn-approve" data-action="approve" data-id="${r.id}">Approve</button>
            <button class="btn-reject"  data-action="reject"  data-id="${r.id}">Reject</button>
          </div>
          <span class="pending-card__status" id="status-${r.id}" hidden></span>
        </div>
      `).join('');

      show(list);

      list.addEventListener('click', async (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-action]');
        if (!btn) return;
        const action = btn.dataset.action as 'approve' | 'reject';
        const id = btn.dataset.id!;
        const card = list.querySelector<HTMLElement>(`.pending-card[data-id="${id}"]`);
        const statusEl = document.getElementById(`status-${id}`);
        const approveBtn = card?.querySelector<HTMLButtonElement>('[data-action="approve"]');
        const rejectBtn  = card?.querySelector<HTMLButtonElement>('[data-action="reject"]');

        if (approveBtn) approveBtn.disabled = true;
        if (rejectBtn)  rejectBtn.disabled  = true;

        let note = '';
        if (action === 'reject') {
          note = prompt('Reason for rejection (optional):') ?? '';
        }

        try {
          const body = action === 'reject' ? JSON.stringify({ reason: note }) : '{}';
          const res = await fetch(`${API}/membership/${id}/${action}`, {
            method: 'POST',
            headers: authHeaders(),
            body,
          });
          if (res.ok) {
            if (statusEl) { statusEl.textContent = action === 'approve' ? '✓ Approved' : '✗ Rejected'; show(statusEl); }
            if (card) card.style.opacity = '0.5';
          } else {
            const err = await res.json().catch(() => ({})) as { message?: string };
            if (statusEl) {
              statusEl.textContent = `Error: ${err.message ?? res.status}`;
              show(statusEl);
            }
            if (approveBtn) approveBtn.disabled = false;
            if (rejectBtn)  rejectBtn.disabled  = false;
          }
        } catch {
          if (statusEl) { statusEl.textContent = 'Network error'; show(statusEl); }
          if (approveBtn) approveBtn.disabled = false;
          if (rejectBtn)  rejectBtn.disabled  = false;
        }
      });
    } catch {
      hide(loading);
      if (errorEl) { errorEl.textContent = 'Failed to load pending applications.'; show(errorEl); }
    }
  }

  /* ════════════════════════════════════════════════════════════
     SECTION 2 — MEMBER SEARCH + PASSWORD RESET
  ════════════════════════════════════════════════════════════ */
  interface MemberRow {
    id: number;
    username: string | null;
    full_name: string | null;
    email: string | null;
    identity_status: 'IDENTITY_PENDING' | 'IDENTITY_COMPLETE' | null;
    identity_completed_at: string | null;
  }

  const searchForm    = document.getElementById('search-form')    as HTMLFormElement | null;
  const searchInput   = document.getElementById('search-input')   as HTMLInputElement | null;
  const searchLoading = document.getElementById('search-loading');
  const searchEmpty   = document.getElementById('search-empty');
  const searchError   = document.getElementById('search-error');
  const searchResults = document.getElementById('search-results');
  const resetPanel    = document.getElementById('reset-panel');
  const resetTargetName = document.getElementById('reset-target-name');
  const resetUserId   = document.getElementById('reset-user-id') as HTMLInputElement | null;
  const resetForm     = document.getElementById('reset-form')    as HTMLFormElement | null;
  const resetPassword = document.getElementById('reset-password') as HTMLInputElement | null;
  const resetFeedback = document.getElementById('reset-feedback');

  function clearSearchState() {
    hide(searchLoading); hide(searchEmpty); hide(searchError); hide(searchResults); hide(resetPanel);
    if (searchResults) searchResults.innerHTML = '';
    if (searchError) searchError.textContent = '';
  }

  searchForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const q = searchInput?.value.trim() ?? '';
    if (q.length < 2) return;

    clearSearchState();
    show(searchLoading);

    try {
      const res = await fetch(`${API}/users/admin/search?q=${encodeURIComponent(q)}`, { headers: authHeaders() });
      hide(searchLoading);

      if (!res.ok) {
        if (searchError) { searchError.textContent = `Search failed (${res.status}).`; show(searchError); }
        return;
      }
      const members: MemberRow[] = await res.json() as MemberRow[];
      if (!members.length) { show(searchEmpty); return; }

      if (searchResults) {
        searchResults.innerHTML = members.map(m => {
          const isPending = m.identity_status === 'IDENTITY_PENDING' || m.identity_status === null;
          const badgeCls  = isPending ? 'result-row__identity--pending' : 'result-row__identity--complete';
          const badgeTxt  = isPending ? 'PENDING' : 'COMPLETE';
          return `
            <div class="result-row"
              data-uid="${m.id}"
              data-name="${(m.full_name ?? m.username ?? 'Member').replace(/"/g, '&quot;')}"
              data-identity="${m.identity_status ?? 'IDENTITY_PENDING'}"
              data-identity-at="${m.identity_completed_at ?? ''}"
              data-username="${(m.username ?? '').replace(/"/g, '&quot;')}">
              <div class="result-row__name">${m.full_name ?? m.username ?? 'Unknown'}</div>
              <div class="result-row__meta">${m.username ? `@${m.username}` : '<em>no username</em>'} · ${m.email ?? ''}</div>
              <span class="result-row__identity ${badgeCls}">${badgeTxt}</span>
            </div>
          `;
        }).join('');
        show(searchResults);

        searchResults.addEventListener('click', (ev) => {
          const row = (ev.target as HTMLElement).closest<HTMLElement>('[data-uid]');
          if (!row) return;
          const uid        = row.dataset.uid!;
          const name       = row.dataset.name!;
          const identityStatus = row.dataset.identity!;
          const identityAt     = row.dataset.identityAt ?? '';
          const username       = row.dataset.username ?? '';

          // Password reset panel
          if (resetUserId) resetUserId.value = uid;
          if (resetTargetName) resetTargetName.textContent = `Reset password for: ${name}`;
          if (resetFeedback) { resetFeedback.textContent = ''; resetFeedback.className = 'reset-feedback'; hide(resetFeedback); }
          if (resetPassword) resetPassword.value = '';
          show(resetPanel);
          resetPassword?.focus();

          // Identity panel
          const identityPanel   = document.getElementById('identity-panel');
          const statusBadge     = document.getElementById('identity-status-badge');
          const identityDetail  = document.getElementById('identity-detail');
          const identityActions = document.getElementById('identity-actions');
          const identityFeedback= document.getElementById('identity-feedback');

          const isPending = identityStatus === 'IDENTITY_PENDING';
          if (statusBadge) {
            statusBadge.textContent = isPending ? 'IDENTITY PENDING' : 'IDENTITY COMPLETE';
            statusBadge.className = `identity-badge ${isPending ? 'identity-badge--pending' : 'identity-badge--complete'}`;
          }
          if (identityDetail) {
            if (isPending) {
              identityDetail.innerHTML = `<strong>${name}</strong> has not yet chosen a username.`;
            } else {
              identityDetail.innerHTML = `<strong>@${username}</strong> · Completed ${fmtDate(identityAt)}`;
            }
          }
          // Show action buttons only for PENDING users
          if (identityActions) {
            identityActions.hidden = !isPending;
            // Wire identity action buttons to this user (replace prior listeners by setting data attrs)
            identityActions.dataset.uid  = uid;
            identityActions.dataset.name = name;
          }
          if (identityFeedback) { identityFeedback.textContent = ''; identityFeedback.className = 'reset-feedback'; hide(identityFeedback); }
          if (identityPanel) show(identityPanel);
        }, { once: true });
      }
    } catch {
      hide(searchLoading);
      if (searchError) { searchError.textContent = 'Network error during search.'; show(searchError); }
    }
  });

  resetForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const uid = resetUserId?.value;
    const pwd = resetPassword?.value ?? '';
    if (!uid || pwd.length < 8) return;

    const submitBtn = resetForm.querySelector<HTMLButtonElement>('[type="submit"]');
    if (submitBtn) submitBtn.disabled = true;
    if (resetFeedback) { resetFeedback.hidden = true; }

    try {
      const res = await fetch(`${API}/membership/admin/users/${uid}/reset-password`, {
        method: 'POST',
        headers: authHeaders(),
        body: JSON.stringify({ newPassword: pwd }),
      });
      if (resetFeedback) {
        if (res.ok) {
          resetFeedback.textContent = 'Password reset. Member will be prompted to set a new one on next login.';
          resetFeedback.className = 'reset-feedback ok';
        } else {
          const err = await res.json().catch(() => ({})) as { message?: string };
          resetFeedback.textContent = `Error: ${err.message ?? res.status}`;
          resetFeedback.className = 'reset-feedback error';
        }
        show(resetFeedback);
      }
    } catch {
      if (resetFeedback) {
        resetFeedback.textContent = 'Network error. Please try again.';
        resetFeedback.className = 'reset-feedback error';
        show(resetFeedback);
      }
    } finally {
      if (submitBtn) submitBtn.disabled = false;
      if (resetPassword) resetPassword.value = '';
    }
  });

  /* ════════════════════════════════════════════════════════════
     SECTION 3 — SPOTLIGHT MANAGEMENT
  ════════════════════════════════════════════════════════════ */

  async function loadCurrentSpotlight() {
    const currentEl = document.getElementById('spotlight-current');
    const noneEl    = document.getElementById('spotlight-none');
    try {
      const res = await fetch(`${API}/gallery/spotlight`);
      if (res.ok) {
        const p = await res.json() as any;
        const img   = document.getElementById('spotlight-preview-img')  as HTMLImageElement | null;
        const title = document.getElementById('spotlight-preview-title') as HTMLElement | null;
        const credit= document.getElementById('spotlight-preview-credit')as HTMLElement | null;
        if (img)    img.src         = p.urls?.medium ?? p.urls?.thumbnail ?? '';
        if (img)    img.alt         = p.title ?? 'Spotlight';
        if (title)  title.textContent  = p.title_override ?? p.title ?? '—';
        if (credit) credit.textContent = p.credit_override ?? (p.photographer ? `Photo by ${p.photographer.name}` : '—');
        show(currentEl);
      } else {
        show(noneEl);
      }
    } catch {
      show(noneEl);
    }
  }

  const spotlightSearchForm    = document.getElementById('spotlight-search-form')    as HTMLFormElement | null;
  const spotlightSearchInput   = document.getElementById('spotlight-search-input')   as HTMLInputElement | null;
  const spotlightSearchLoading = document.getElementById('spotlight-search-loading');
  const spotlightSearchEmpty   = document.getElementById('spotlight-search-empty');
  const spotlightSearchError   = document.getElementById('spotlight-search-error');
  const spotlightResults       = document.getElementById('spotlight-results');
  const spotlightFeedback      = document.getElementById('spotlight-set-feedback');

  spotlightSearchForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const q = spotlightSearchInput?.value.trim() ?? '';
    if (q.length < 2) return;

    hide(spotlightSearchEmpty); hide(spotlightSearchError); hide(spotlightResults);
    if (spotlightResults) spotlightResults.innerHTML = '';
    show(spotlightSearchLoading);

    try {
      // Search public feed with the query as a tag/title hint
      const res = await fetch(`${API}/gallery/feed?limit=20&shuffle=false`, { headers: authHeaders() });
      hide(spotlightSearchLoading);
      if (!res.ok) {
        if (spotlightSearchError) { spotlightSearchError.textContent = `Error ${res.status}`; show(spotlightSearchError); }
        return;
      }
      const { photos } = await res.json() as { photos: any[] };
      // Client-side filter by title or photographer name
      const ql = q.toLowerCase();
      const filtered = photos.filter(p =>
        (p.title ?? '').toLowerCase().includes(ql) ||
        (p.photographer?.name ?? '').toLowerCase().includes(ql) ||
        (p.caption ?? '').toLowerCase().includes(ql)
      );
      if (!filtered.length) { show(spotlightSearchEmpty); return; }

      if (spotlightResults) {
        spotlightResults.innerHTML = filtered.map(p => {
          const thumb = p.urls?.thumbnail ?? p.urls?.medium ?? '';
          const title = p.title ?? 'Untitled';
          const credit = p.photographer ? `by ${p.photographer.name}` : '';
          return `
            <div class="spotlight-photo-card" data-uuid="${p.uuid}">
              <img src="${thumb}" alt="${title.replace(/"/g, '&quot;')}" loading="lazy" />
              <div class="spotlight-photo-card__title">${title}</div>
              <div class="spotlight-photo-card__credit">${credit}</div>
              <button class="btn-set-spotlight" data-uuid="${p.uuid}">Set as Spotlight</button>
            </div>
          `;
        }).join('');
        show(spotlightResults);

        spotlightResults.addEventListener('click', async (ev) => {
          const btn = (ev.target as HTMLElement).closest<HTMLButtonElement>('.btn-set-spotlight');
          if (!btn) return;
          const uuid = btn.dataset.uuid!;
          btn.disabled = true;
          btn.textContent = 'Setting…';
          if (spotlightFeedback) { hide(spotlightFeedback); spotlightFeedback.className = 'reset-feedback'; }

          try {
            const setRes = await fetch(`${API}/gallery/spotlight`, {
              method: 'PUT',
              headers: authHeaders(),
              body: JSON.stringify({ photo_uuid: uuid }),
            });
            if (setRes.ok) {
              if (spotlightFeedback) {
                spotlightFeedback.textContent = 'Spotlight updated. Homepage will show this photo.';
                spotlightFeedback.className = 'reset-feedback ok';
                show(spotlightFeedback);
              }
              // Refresh current spotlight preview
              hide(document.getElementById('spotlight-current'));
              hide(document.getElementById('spotlight-none'));
              loadCurrentSpotlight();
            } else {
              const err = await setRes.json().catch(() => ({})) as { message?: string };
              if (spotlightFeedback) {
                spotlightFeedback.textContent = `Error: ${err.message ?? setRes.status}`;
                spotlightFeedback.className = 'reset-feedback error';
                show(spotlightFeedback);
              }
              btn.disabled = false;
              btn.textContent = 'Set as Spotlight';
            }
          } catch {
            if (spotlightFeedback) {
              spotlightFeedback.textContent = 'Network error. Please try again.';
              spotlightFeedback.className = 'reset-feedback error';
              show(spotlightFeedback);
            }
            btn.disabled = false;
            btn.textContent = 'Set as Spotlight';
          }
        });
      }
    } catch {
      hide(spotlightSearchLoading);
      if (spotlightSearchError) { spotlightSearchError.textContent = 'Failed to search photos.'; show(spotlightSearchError); }
    }
  });

  /* ════════════════════════════════════════════════════════════
     IDENTITY ACTIONS
  ════════════════════════════════════════════════════════════ */
  function identityFeedbackMsg(msg: string, kind: 'ok' | 'error'): void {
    const el = document.getElementById('identity-feedback');
    if (!el) return;
    el.textContent = msg;
    el.className = `reset-feedback ${kind}`;
    show(el);
  }

  async function identityAction(endpoint: string, uid: string): Promise<void> {
    const res = await fetch(`${API}/identity/${endpoint}/${uid}`, {
      method: 'POST',
      headers: authHeaders(),
      body: '{}',
    });
    if (res.ok) {
      identityFeedbackMsg('Email dispatched.', 'ok');
    } else {
      const err = await res.json().catch(() => ({})) as { message?: string };
      identityFeedbackMsg(`Error: ${err.message ?? res.status}`, 'error');
    }
  }

  function getIdentityUid(): string | null {
    return (document.getElementById('identity-actions') as HTMLElement | null)?.dataset.uid ?? null;
  }

  document.getElementById('btn-send-link')?.addEventListener('click', async () => {
    const uid = getIdentityUid(); if (!uid) return;
    const btn = document.getElementById('btn-send-link') as HTMLButtonElement;
    btn.disabled = true;
    try { await identityAction('admin/send-completion-link', uid); }
    catch { identityFeedbackMsg('Network error. Please try again.', 'error'); }
    finally { btn.disabled = false; }
  });

  document.getElementById('btn-send-priority')?.addEventListener('click', async () => {
    const uid = getIdentityUid(); if (!uid) return;
    const btn = document.getElementById('btn-send-priority') as HTMLButtonElement;
    btn.disabled = true;
    try { await identityAction('admin/send-priority-completion-link', uid); }
    catch { identityFeedbackMsg('Network error. Please try again.', 'error'); }
    finally { btn.disabled = false; }
  });

  document.getElementById('btn-resend-welcome')?.addEventListener('click', async () => {
    const uid = getIdentityUid(); if (!uid) return;
    const btn = document.getElementById('btn-resend-welcome') as HTMLButtonElement;
    btn.disabled = true;
    try { await identityAction('admin/resend-welcome', uid); }
    catch { identityFeedbackMsg('Network error. Please try again.', 'error'); }
    finally { btn.disabled = false; }
  });

  /* ── Init ────────────────────────────────────────────────── */
  loadPending();
  loadCurrentSpotlight();
</script>
