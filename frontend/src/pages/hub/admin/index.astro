---
/**
 * hub/admin/index.astro — Admin Console
 * Route: /hub/admin/
 *
 * Requires admin role (enforced client-side; backend guards enforce server-side).
 * Sections:
 *   1. Pending membership applications — approve / reject
 *   2. Member search + password reset
 */
import HubLayout from '../../../layouts/HubLayout.astro';
---

<HubLayout title="Admin Console" description="Bhopal Camera Club admin console.">

  <div class="admin-console">

    <!-- ① PENDING APPLICATIONS ──────────────────────────────────────────── -->
    <section class="admin-section" id="section-pending">
      <div class="section-kicker"><span class="kicker-rule"></span>Membership Applications</div>
      <h2 class="section-title">Pending Approvals</h2>

      <div id="pending-loading" class="state-loading">Loading applications…</div>
      <div id="pending-empty"   class="state-empty"   hidden>No pending applications.</div>
      <div id="pending-error"   class="state-error"   hidden></div>

      <div id="pending-list" class="pending-list" hidden></div>
    </section>

    <!-- ② EDITORIAL HERO MANAGER ─────────────────────────────────────────── -->
    <section class="admin-section" id="section-hero-manager">
      <div class="section-kicker"><span class="kicker-rule"></span>Homepage & Pages</div>
      <h2 class="section-title">Editorial Hero Manager</h2>

      <!-- Filters Bar -->
      <div class="hero-filters-bar">
        <div class="filter-row-top">
          <input type="text" id="hero-search-photographer" class="search-input" placeholder="Search photographer..." style="flex:1;" />
          <input type="text" id="hero-search-title" class="search-input" placeholder="Search photo title..." style="flex:1;" />
          <select id="hero-filter-project" class="search-input select-filter" style="flex:1;">
            <option value="">All Projects</option>
          </select>
          <select id="hero-filter-tag" class="search-input select-filter" style="flex:1;">
            <option value="">All Tags</option>
          </select>
        </div>
        <div class="filter-row-bottom">
          <select id="hero-filter-usage" class="search-input select-filter" style="flex:1;">
            <option value="">All Usage Status</option>
            <option value="unused">Unused Hero Images</option>
            <option value="assigned">Already Assigned</option>
            <option value="fixed">Fixed Heroes</option>
            <option value="pool">Rotation Pool</option>
          </select>
          <select id="hero-sort" class="search-input select-filter" style="flex:1;">
            <option value="newest">Newest Upload</option>
            <option value="oldest">Oldest Upload</option>
          </select>
        </div>
      </div>

      <div id="hero-manager-loading" class="state-loading">Loading eligible photos…</div>
      <div id="hero-manager-empty" class="state-empty" hidden>No eligible 16:5 photographs found.</div>
      <div id="hero-manager-error" class="state-error" hidden></div>

      <!-- Single-Column Editorial Photo Browser -->
      <div id="hero-photo-list" class="hero-photo-list" hidden></div>
    </section>

    <!-- ③ USER IDENTITY & MEMBERSHIP ──────────────────────────────── -->
    <section class="admin-section" id="section-members">
      <div class="section-kicker"><span class="kicker-rule"></span>User Identity & Membership</div>
      <h2 class="section-title">Identity Status / Password Reset</h2>

      <form class="search-form" id="search-form" autocomplete="off">
        <input
          type="text"
          id="search-input"
          class="search-input"
          placeholder="Search by username, name or email…"
          minlength="2"
          required
        />
        <button type="submit" class="btn-search">Search</button>
      </form>

      <div id="search-loading" class="state-loading" hidden>Searching…</div>
      <div id="search-empty"   class="state-empty"   hidden>No members found.</div>
      <div id="search-error"   class="state-error"   hidden></div>
      <div id="search-results" class="search-results" hidden></div>

      <!-- Inline reset form (revealed when a member is selected) -->
      <div id="reset-panel" class="reset-panel" hidden>
        <h3 class="reset-title" id="reset-target-name"></h3>
        <p class="reset-hint">Set a temporary password. The member will be forced to change it on next login.</p>
        <form id="reset-form" class="reset-form">
          <input type="hidden" id="reset-user-id" />
          <div class="field-row">
            <input
              type="password"
              id="reset-password"
              class="field-input"
              placeholder="New temporary password (min 8 chars)"
              minlength="8"
              required
            />
            <button type="submit" class="btn-reset">Set Password</button>
          </div>
          <div id="reset-feedback" class="reset-feedback" hidden></div>
        </form>
      </div>

      <!-- Identity actions panel (revealed alongside reset-panel when a member is selected) -->
      <div id="identity-panel" class="identity-panel" hidden>
        <div class="identity-panel__header">
          <span class="identity-panel__label">Identity Status</span>
          <span id="identity-status-badge" class="identity-badge"></span>
        </div>
        <div id="identity-detail" class="identity-detail"></div>
        <div class="identity-actions" id="identity-actions" hidden>
          <button id="btn-send-link"     type="button" class="btn-identity-action">Send Completion Link</button>
          <button id="btn-send-priority" type="button" class="btn-identity-action btn-identity-action--priority">Send Priority Link</button>
          <button id="btn-resend-welcome" type="button" class="btn-identity-action btn-identity-action--secondary">Resend Welcome Email</button>
          <button id="btn-send-invitation" type="button" class="btn-identity-action">Send Membership Invitation</button>
        </div>
        <div id="identity-feedback" class="reset-feedback" hidden></div>
      </div>
    </section>

    <!-- Assign Hero Modal -->
    <div id="hero-assign-modal" class="admin-modal" hidden>
      <div class="admin-modal__overlay" id="hero-assign-modal-overlay"></div>
      <div class="admin-modal__content">
        <div class="admin-modal__header">
          <h3 class="admin-modal__title">Assign Hero Image</h3>
          <button type="button" class="admin-modal__close" id="hero-assign-modal-close">&times;</button>
        </div>
        <div class="admin-modal__body">
          <div class="hero-modal-photo-preview-wrap">
            <img id="hero-modal-photo-img" class="hero-modal-photo-img" src="" alt="" />
            <div class="hero-modal-photo-meta">
              <div class="hero-modal-photo-title" id="hero-modal-photo-title"></div>
              <div class="hero-modal-photo-credit" id="hero-modal-photo-credit"></div>
              <div class="hero-modal-photo-dims" id="hero-modal-photo-dims"></div>
            </div>
          </div>

          <div class="hero-destinations-list-header">Select Hero Destinations</div>
          <div id="hero-destinations-container" class="hero-destinations-container">
            <!-- Dynamically populated -->
          </div>
        </div>
        <div class="admin-modal__footer">
          <button type="button" class="btn btn-outline" id="hero-assign-cancel">Cancel</button>
          <button type="button" class="btn btn-dark" id="hero-assign-save" style="margin-left: 10px;">Save Assignments</button>
        </div>
      </div>
    </div>

    <!-- Confirm Replace Modal -->
    <div id="hero-replace-modal" class="admin-modal admin-modal--confirm" hidden>
      <div class="admin-modal__overlay" id="hero-replace-modal-overlay"></div>
      <div class="admin-modal__content admin-modal__content--confirm">
        <div class="admin-modal__header">
          <h3 class="admin-modal__title">Replace Fixed Hero?</h3>
        </div>
        <div class="admin-modal__body">
          <p class="replace-warning-text"><strong id="replace-destination-label">About</strong> already has a Fixed Hero. Overwrite assignment?</p>
          
          <div class="hero-replace-preview-grid">
            <div class="replace-preview-column">
              <div class="replace-preview-header">Current Hero</div>
              <div class="replace-preview-card">
                <img id="replace-current-img" class="replace-preview-img" src="" alt="Current Hero" />
                <div class="replace-preview-title" id="replace-current-title"></div>
                <div class="replace-preview-credit" id="replace-current-credit"></div>
              </div>
            </div>
            
            <div class="replace-preview-divider" aria-hidden="true">&rarr;</div>
            
            <div class="replace-preview-column">
              <div class="replace-preview-header">New Hero</div>
              <div class="replace-preview-card">
                <img id="replace-new-img" class="replace-preview-img" src="" alt="New Hero" />
                <div class="replace-preview-title" id="replace-new-title"></div>
                <div class="replace-preview-credit" id="replace-new-credit"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="admin-modal__footer">
          <button type="button" class="btn btn-outline" id="hero-replace-cancel">Cancel</button>
          <button type="button" class="btn btn-dark" id="hero-replace-confirm" style="margin-left: 10px;">Replace</button>
        </div>
      </div>
    </div>

  </div>

</HubLayout>

<style>
/* ─── Layout ─────────────────────────────────────────────────── */
.admin-console {
  padding: 32px 0 64px;
  display: flex;
  flex-direction: column;
  gap: 56px;
}

/* ─── Section ────────────────────────────────────────────────── */
.admin-section {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.section-kicker {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-body);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold-600);
}
.kicker-rule {
  display: inline-block;
  width: 24px;
  height: 1px;
  background: var(--gold-600);
}
.section-title {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 600;
  color: var(--ink-900);
  margin: 0;
  line-height: 1.3;
}

/* ─── State messages ──────────────────────────────────────────── */
.state-loading,
.state-empty {
  font-family: var(--font-body);
  font-size: 13px;
  color: var(--ink-400);
  padding: 12px 0;
}
.state-error {
  font-family: var(--font-body);
  font-size: 13px;
  color: var(--input-error);
  padding: 12px 0;
}

/* ─── Pending list ────────────────────────────────────────────── */
.pending-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.pending-card {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  padding: 16px 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}
.pending-card__info {
  flex: 1 1 auto;
  min-width: 160px;
}
.pending-card__name {
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 600;
  color: var(--ink-900);
}
.pending-card__meta {
  font-family: var(--font-body);
  font-size: 12px;
  color: var(--ink-400);
  margin-top: 3px;
}
.pending-card__class {
  font-family: var(--font-mono);
  font-size: 11px;
  background: var(--surface-2);
  color: var(--ink-600);
  padding: 2px 8px;
  border: 1px solid var(--hairline);
  align-self: center;
  white-space: nowrap;
}
.pending-card__actions {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}
.btn-approve,
.btn-reject {
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 600;
  padding: 6px 16px;
  border: none;
  cursor: pointer;
  transition: opacity var(--m-fast);
}
.btn-approve {
  background: #1A7A40;
  color: var(--surface-0);
}
.btn-reject {
  background: transparent;
  border: 1px solid var(--input-error);
  color: var(--input-error);
}
.btn-approve:disabled,
.btn-reject:disabled { opacity: 0.5; cursor: not-allowed; }
.btn-approve:hover:not(:disabled) { opacity: 0.85; }
.btn-reject:hover:not(:disabled)  { opacity: 0.75; }

.pending-card__status {
  font-family: var(--font-body);
  font-size: 12px;
  font-style: italic;
  color: var(--ink-400);
}

/* ─── Search form ─────────────────────────────────────────────── */
.search-form {
  display: flex;
  gap: 8px;
  max-width: 520px;
}
.search-input {
  flex: 1;
  font-family: var(--font-body);
  font-size: 13px;
  padding: 9px 14px;
  border: 1px solid var(--hairline-strong);
  color: var(--ink-900);
  background: var(--surface-0);
  outline: none;
  transition: border-color var(--m-fast);
}
.search-input:focus { border-color: var(--gold-600); }
.btn-search {
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 600;
  padding: 9px 20px;
  background: var(--ink-900);
  color: var(--surface-0);
  border: none;
  cursor: pointer;
  transition: opacity var(--m-fast);
}
.btn-search:hover { opacity: 0.8; }

/* ─── Search results ──────────────────────────────────────────── */
.search-results {
  display: flex;
  flex-direction: column;
  gap: 6px;
  max-width: 520px;
}
.result-row {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  transition: background var(--m-fast);
}
.result-row:hover { background: var(--surface-1); }
.result-row__name {
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 600;
  color: var(--ink-900);
  flex: 1;
}
.result-row__meta {
  font-family: var(--font-body);
  font-size: 12px;
  color: var(--ink-400);
}

/* ─── Reset panel ─────────────────────────────────────────────── */
.reset-panel {
  max-width: 520px;
  background: var(--surface-1);
  border: 1px solid var(--hairline);
  padding: 20px 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.reset-title {
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 600;
  color: var(--ink-900);
  margin: 0;
}
.reset-hint {
  font-family: var(--font-body);
  font-size: 12px;
  color: var(--ink-400);
  margin: 0;
}
.reset-form { display: flex; flex-direction: column; gap: 10px; }
.field-row {
  display: flex;
  gap: 8px;
}
.field-input {
  flex: 1;
  font-family: var(--font-body);
  font-size: 13px;
  padding: 9px 14px;
  border: 1px solid var(--hairline-strong);
  background: var(--surface-0);
  color: var(--ink-900);
  outline: none;
  transition: border-color var(--m-fast);
}
.field-input:focus { border-color: var(--gold-600); }
.btn-reset {
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 600;
  padding: 9px 20px;
  background: var(--gold-500);
  color: var(--ink-900);
  border: none;
  cursor: pointer;
  transition: opacity var(--m-fast);
  white-space: nowrap;
}
.btn-reset:hover:not(:disabled) { opacity: 0.85; }
.btn-reset:disabled { opacity: 0.5; cursor: not-allowed; }
.reset-feedback {
  font-family: var(--font-body);
  font-size: 12px;
  padding: 8px 12px;
}
.reset-feedback.ok    { background: #E8F5E9; color: #1A7A40; }
.reset-feedback.error { background: #FDECEA; color: var(--input-error); }

/* ─── Identity badge ──────────────────────────────────────── */
.identity-badge {
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 700;
  padding: 2px 8px;
  border: 1px solid;
  white-space: nowrap;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.identity-badge--pending {
  background: #FEF3C7;
  border-color: #FCD34D;
  color: #92400E;
}
.identity-badge--complete {
  background: #D1FAE5;
  border-color: #6EE7B7;
  color: #065F46;
}

/* Identity status in search result rows */
.result-row__identity {
  font-family: var(--font-mono);
  font-size: 10px;
  padding: 1px 6px;
  border: 1px solid;
}
.result-row__identity--pending  { background: #FEF3C7; border-color: #FCD34D; color: #92400E; }
.result-row__identity--complete { background: #D1FAE5; border-color: #6EE7B7; color: #065F46; }

/* ─── Identity panel ──────────────────────────────────────── */
.identity-panel {
  max-width: 520px;
  background: var(--surface-2);
  border: 1px solid var(--hairline);
  padding: 16px 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 4px;
}
.identity-panel__header {
  display: flex;
  align-items: center;
  gap: 10px;
}
.identity-panel__label {
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--ink-400);
}
.identity-detail {
  font-family: var(--font-body);
  font-size: 12px;
  color: var(--ink-600);
  line-height: 1.6;
}
.identity-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.btn-identity-action {
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 600;
  padding: 7px 14px;
  border: none;
  cursor: pointer;
  transition: opacity var(--m-fast);
  background: var(--ink-900);
  color: var(--surface-0);
  white-space: nowrap;
}
.btn-identity-action--priority {
  background: var(--input-error);
}
.btn-identity-action--secondary {
  background: transparent;
  border: 1px solid var(--ink-400);
  color: var(--ink-600);
}
.btn-identity-action:disabled { opacity: 0.5; cursor: not-allowed; }
.btn-identity-action:hover:not(:disabled) { opacity: 0.8; }

/* ─── Editorial Hero Manager ────────────────────────────────── */
.hero-filters-bar {
  background: var(--surface-1);
  border: 1px solid var(--hairline);
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 20px;
}
.filter-row-top,
.filter-row-bottom {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}
.select-filter {
  height: 38px;
  border: 1px solid var(--hairline-strong);
  background: var(--surface-0);
  color: var(--ink-900);
  font-family: var(--font-body);
  font-size: 13px;
  padding: 0 8px;
  outline: none;
  cursor: pointer;
}
.hero-photo-list {
  display: flex;
  flex-direction: column;
  gap: 32px;
}
.hero-photo-card {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.hero-photo-card__preview {
  width: 100%;
  border: 1px solid var(--hairline-soft);
  overflow: hidden;
  position: relative;
  aspect-ratio: 16/5;
  background: var(--surface-2);
}
.hero-photo-card__preview img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.hero-photo-card__details {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.hero-photo-card__title {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 700;
  color: var(--ink-900);
  margin: 0;
}
.hero-photo-card__photographer {
  font-family: var(--font-body);
  font-size: 14px;
  color: var(--ink-600);
  font-weight: 500;
}
.hero-photo-card__meta {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-400);
  letter-spacing: var(--ls-mono);
}
.meta-dot {
  margin: 0 4px;
}
.hero-photo-card__usage {
  display: flex;
  align-items: center;
  margin-top: 4px;
}
.usage-none-text {
  font-size: 12px;
  color: var(--ink-400);
  font-style: italic;
}
.usage-badge {
  font-family: var(--font-mono);
  font-size: 9px;
  padding: 3px 8px;
  border-radius: var(--r-0);
  font-weight: 600;
  letter-spacing: var(--ls-mono);
}
.usage-badge--fixed {
  background: rgba(201, 169, 97, 0.12);
  color: var(--gold-600);
  border: 1px solid rgba(201, 169, 97, 0.3);
}
.usage-badge--pool {
  background: rgba(20, 18, 16, 0.05);
  color: var(--ink-600);
  border: 1px solid var(--hairline);
}
.btn-assign-hero {
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 600;
  padding: 8px 16px;
  border: 1px solid var(--ink-900);
  background: var(--surface-0);
  color: var(--ink-900);
  cursor: pointer;
  transition: background var(--m-fast), color var(--m-fast);
  width: fit-content;
}
.btn-assign-hero:hover {
  background: var(--ink-900);
  color: var(--surface-0);
}

/* Modals */
.admin-modal {
  position: fixed;
  inset: 0;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
}
.admin-modal__overlay {
  position: absolute;
  inset: 0;
  background: rgba(20, 18, 16, 0.6);
  backdrop-filter: blur(4px);
}
.admin-modal__content {
  position: relative;
  z-index: 1;
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  width: 100%;
  max-width: 580px;
  box-shadow: var(--e-4);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  max-height: 90vh;
}
.admin-modal__header {
  padding: 16px 20px;
  border-bottom: 1px solid var(--hairline);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.admin-modal__title {
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 700;
  color: var(--ink-900);
  margin: 0;
}
.admin-modal__close {
  background: none;
  border: none;
  font-size: 24px;
  color: var(--ink-400);
  cursor: pointer;
  transition: color var(--m-fast);
  line-height: 1;
}
.admin-modal__close:hover {
  color: var(--ink-900);
}
.admin-modal__body {
  padding: 20px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.admin-modal__footer {
  padding: 16px 20px;
  border-top: 1px solid var(--hairline);
  display: flex;
  justify-content: flex-end;
  background: var(--surface-1);
}
.hero-modal-photo-preview-wrap {
  display: flex;
  gap: 16px;
  padding: 12px;
  background: var(--surface-1);
  border: 1px solid var(--hairline);
}
.hero-modal-photo-img {
  width: 120px;
  aspect-ratio: 16/5;
  object-fit: cover;
  border: 1px solid var(--hairline-soft);
  background: var(--surface-2);
}
.hero-modal-photo-meta {
  display: flex;
  flex-direction: column;
