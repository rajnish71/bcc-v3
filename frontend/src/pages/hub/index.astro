---
/**
 * hub/index.astro — Member Hub Main Home (V6 09)
 * Route: /hub/
 *
 * Auth-gated via HubLayout. All data fetched client-side after auth check.
 *
 * Five content sections (populated state):
 *   1. Welcome Band       — greeting + one gold CTA (Upload)
 *   2. Attention Row      — ≤3 computed items; hidden when empty
 *   3. Recent Work        — 5 photo mats + upload tile (or empty-state frame)
 *   4. Happening at Club  — announcement + upcoming events
 *   5. Journey Numbers    — stats strip; hidden when all zero
 *
 * Three-column shell: 240px left rail | fluid main | 280px personal rail
 * Responsive: ≥1200 three-col · 641–1199 HubTabs + stacked · ≤640 HubMobileBar
 *
 * MEM-006: Constitutional class names ARE shown inside the hub (not a public surface).
 * One gold CTA per view max.
 */
import HubLayout from '../../layouts/HubLayout.astro';
---

<HubLayout title="Member Hub" description="Your Bhopal Camera Club member dashboard.">

<!-- ═══════════════════════════════════════════════════════════════════════
     HUB SHELL  — three-column grid
════════════════════════════════════════════════════════════════════════ -->
<div class="hub-shell-wrap">

  <!-- ── LEFT RAIL (≥1200px) ─────────────────────────────────────────── -->
  <nav class="hub-rail" aria-label="Hub navigation">
    <div class="rail-section">
      <div class="rail-label">Studio</div>
      <a href="/hub/" class="rail-item rail-item--active" aria-current="page">
        <span class="rail-dot"></span>Home
      </a>
      <a href="/hub/portfolio/" class="rail-item">Portfolio</a>
      <a href="/hub/upload/" class="rail-item">Upload</a>
      <a href="/hub/upload/batch/" class="rail-item">Batch Upload</a>
    </div>
    <div class="rail-section">
      <div class="rail-label">Grow</div>
      <span class="rail-item rail-item--soon">Academy <span class="rail-soon">SOON</span></span>
      <span class="rail-item rail-item--soon">Contests <span class="rail-soon">SOON</span></span>
    </div>
    <div class="rail-section">
      <div class="rail-label">Club Activities</div>
      <a href="/activities/?type=tour" class="rail-item">Tours</a>
      <a href="/activities/?type=workshop" class="rail-item">Workshops</a>
      <a href="/activities/?type=photo_walk" class="rail-item">Photo Walks</a>
      <a href="/activities/?type=meetup" class="rail-item">Meetups</a>
    </div>
    <div class="rail-section">
      <div class="rail-label">Account</div>
      <a href="/hub/profile/" class="rail-item">My Profile</a>
      <a href="/hub/membership/" class="rail-item">Membership &amp; Billing</a>
    </div>
    <div class="rail-footer">
      <button id="rail-signout" type="button" class="rail-signout">Sign Out</button>
    </div>
  </nav>

  <!-- ── HUBTABS (641–1199px) ────────────────────────────────────────── -->
  <div class="hub-tabs-bar" role="tablist" aria-label="Hub sections">
    <a href="/hub/"            class="hub-tab hub-tab--active" role="tab" aria-selected="true">Home</a>
    <a href="/hub/portfolio/"  class="hub-tab" role="tab">Portfolio</a>
    <a href="/hub/upload/"     class="hub-tab" role="tab">Upload</a>
    <a href="/activities/?type=photo_walk" class="hub-tab" role="tab">Photo Walks</a>
    <a href="/activities/?type=workshop"   class="hub-tab" role="tab">Workshops</a>
    <a href="/hub/profile/"    class="hub-tab" role="tab">Account</a>
  </div>

  <!-- ── MAIN CONTENT ────────────────────────────────────────────────── -->
  <main class="hub-main" id="hub-main">

    <!-- 1. WELCOME BAND -->
    <div class="welcome-band">
      <div class="welcome-copy">
        <div class="section-kicker"><span class="kicker-rule"></span>Member Hub — Studio</div>
        <h1 class="welcome-greeting" id="hub-greeting">Welcome back</h1>
        <div class="welcome-meta" id="hub-meta">
          <span id="hub-class-label"></span>
          <span id="hub-since-text"></span>
          <a href="/gallery/photographer/" id="hub-portfolio-link" class="welcome-portfolio-link" hidden>
            View public portfolio ↗
          </a>
        </div>
      </div>
      <!-- Populated state: gold Upload CTA in welcome band -->
      <a href="/hub/upload/" class="btn-gold-cta" id="hub-upload-cta" aria-label="Upload a Photograph" hidden>
        &#8593; Upload a Photograph
      </a>
    </div>

    <!-- 2. ATTENTION ROW (hidden until populated) -->
    <div class="attention-row" id="attention-row" hidden>
      <!-- items injected by JS -->
    </div>

    <!-- 3a. RECENT WORK (populated) -->
    <div class="section-block recent-work" id="recent-work" hidden>
      <div class="section-head">
        <div class="section-kicker"><span class="kicker-rule"></span>Your Latest Work</div>
        <a href="/hub/portfolio/" class="section-link">Portfolio &#8594;</a>
      </div>
      <div class="photo-grid" id="photo-grid">
        <!-- 5 mats + upload tile injected by JS -->
      </div>
    </div>

    <!-- 3b. EMPTY STATE (day one) -->
    <div class="empty-state-frame" id="empty-state" hidden>
      <h2 class="empty-title">Your portfolio begins here.</h2>
      <p class="empty-desc">Photographs you upload appear on your public portfolio page — and could hang on the club's wall.</p>
      <a href="/hub/upload/" class="btn-gold-cta">&#8593; Upload your first photograph</a>
    </div>

    <!-- 4. HAPPENING AT THE CLUB -->
    <div class="section-block" id="club-section" hidden>
      <div class="section-kicker"><span class="kicker-rule"></span>Happening at the Club</div>
      <div id="club-announcement" hidden></div>
      <div id="events-list"></div>
      <div id="events-loading" class="events-loading" aria-live="polite">
        <span class="hub-loading-dot"></span>
        <span class="hub-loading-dot"></span>
        <span class="hub-loading-dot"></span>
      </div>
    </div>

    <!-- 5. JOURNEY NUMBERS (hidden until member has activity) -->
    <div class="journey-numbers" id="journey-numbers" hidden>
      <div class="journey-stat">
        <div class="journey-num" id="jn-photos">—</div>
        <div class="journey-label">Photographs</div>
      </div>
      <div class="journey-stat">
        <div class="journey-num" id="jn-events">—</div>
        <div class="journey-label">Walks &amp; Tours</div>
      </div>
      <div class="journey-stat">
        <div class="journey-num" id="jn-courses">—</div>
        <div class="journey-label">Courses</div>
      </div>
      <div class="journey-stat">
        <div class="journey-num" id="jn-years">—</div>
        <div class="journey-label">Years</div>
      </div>
    </div>

  </main><!-- /hub-main -->

  <!-- ── PERSONAL RAIL ───────────────────────────────────────────────── -->
  <aside class="personal-rail" id="personal-rail">

    <!-- Academy card (populated: continue learning; empty: browse) -->
    <div class="personal-card academy-card" id="academy-card" hidden>
      <div class="personal-card__label" id="academy-card-label">Continue Learning</div>
      <div id="academy-card-body">
        <!-- injected by JS -->
      </div>
    </div>

    <!-- Membership card (dark) -->
    <div class="membership-dark-card" id="membership-dark-card" hidden>
      <img src="/images/BCC White Logo.png" alt="BCC" class="mcard-logo" />
      <div class="mcard-name" id="mcard-name">—</div>
      <div class="mcard-class" id="mcard-class">Member</div>
      <div class="mcard-footer">
        <div>
          <div class="mcard-field-label">Membership No.</div>
          <div class="mcard-field-value" id="mcard-number">—</div>
        </div>
        <div class="mcard-expiry-col">
          <div class="mcard-field-label" id="mcard-expiry-label">Valid Thru</div>
          <div class="mcard-field-value mcard-field-value--gold" id="mcard-expiry">—</div>
        </div>
      </div>
      <div class="mcard-bottom">
        <a href="/hub/membership/" class="mcard-link">Membership &amp; Billing &#8594;</a>
        <span class="mcard-renews" id="mcard-renews" hidden></span>
      </div>
    </div>

    <!-- Journey Strip (populated only) -->
    <div class="personal-card journey-card" id="journey-card" hidden>
      <div class="personal-card__label">Your Journey</div>
      <div id="journey-milestones">
        <!-- injected by JS -->
      </div>
      <a href="/hub/journey/" class="personal-card__link">Full journey &#8594;</a>
    </div>

  </aside>

</div><!-- /hub-shell-wrap -->

<!-- ── HUB MOBILE BAR (≤640px) ─────────────────────────────────────── -->
<nav class="hub-mobile-bar" aria-label="Hub quick navigation">
  <a href="/hub/"           class="mobile-bar-item mobile-bar-item--active" aria-current="page">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M3 8.5L10 2l7 6.5V17a1 1 0 01-1 1H4a1 1 0 01-1-1V8.5z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span>Home</span>
  </a>
  <a href="/hub/portfolio/"  class="mobile-bar-item">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <rect x="2" y="2" width="16" height="16" stroke="currentColor" stroke-width="1.4"/>
      <circle cx="7" cy="7" r="1.5" stroke="currentColor" stroke-width="1"/>
      <polyline points="18 13 13 8 5 18" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span>Portfolio</span>
  </a>
  <a href="/hub/upload/"     class="mobile-bar-item mobile-bar-item--upload">
    <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
      <circle cx="11" cy="11" r="10" stroke="currentColor" stroke-width="1.4"/>
      <line x1="11" y1="7" x2="11" y2="15" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <polyline points="7 11 11 7 15 11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span>Upload</span>
  </a>
  <a href="/activities/"     class="mobile-bar-item">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <rect x="2" y="3" width="16" height="16" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
      <line x1="14" y1="1" x2="14" y2="5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="6"  y1="1" x2="6"  y2="5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="2"  y1="9" x2="18" y2="9" stroke="currentColor" stroke-width="1.4"/>
    </svg>
    <span>Events</span>
  </a>
  <a href="/hub/profile/"    class="mobile-bar-item">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <circle cx="10" cy="7" r="3.5" stroke="currentColor" stroke-width="1.4"/>
      <path d="M2 18c0-4 3.6-7 8-7s8 3 8 7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </svg>
    <span>Account</span>
  </a>
</nav>

</HubLayout>

<style>
/* ═══════════════════════════════════════════════════════════════
   TOKENS (local aliases)
═══════════════════════════════════════════════════════════════ */
:root {
  --hub-rail-w: 240px;
  --hub-personal-w: 280px;
  --hub-gap: 40px;
  --hub-pad: 48px;
}

/* ═══════════════════════════════════════════════════════════════
   SHELL GRID
═══════════════════════════════════════════════════════════════ */
.hub-shell-wrap {
  max-width: 1360px;
  margin: 0 auto;
  padding: 0 var(--hub-pad);
  display: grid;
  grid-template-columns: var(--hub-rail-w) 1fr var(--hub-personal-w);
  grid-template-rows: auto 1fr;
  gap: 0 var(--hub-gap);
  align-items: start;
}

/* HubTabs spans full grid on tablet */
.hub-tabs-bar {
  display: none;
  grid-column: 1 / -1;
  gap: 8px;
  padding: 20px 0 0;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.hub-tabs-bar::-webkit-scrollbar { display: none; }

@media (min-width: 1200px) {
  .hub-rail      { display: flex; }
  .hub-tabs-bar  { display: none; }
  .hub-shell-wrap {
    grid-template-columns: var(--hub-rail-w) 1fr var(--hub-personal-w);
  }
}

@media (min-width: 641px) and (max-width: 1199px) {
  .hub-tabs-bar { display: flex; }
  .hub-rail     { display: none !important; }
  .hub-shell-wrap {
    grid-template-columns: 1fr;
    padding: 0 24px;
  }
  .hub-main      { grid-column: 1; }
  .personal-rail { grid-column: 1; border-left: none; padding-left: 0; margin-top: 32px; display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
}

@media (max-width: 640px) {
  .hub-tabs-bar  { display: none; }
  .hub-rail      { display: none !important; }
  .hub-shell-wrap {
    grid-template-columns: 1fr;
    padding: 0 16px;
  }
  .hub-main      { grid-column: 1; }
  .personal-rail { grid-column: 1; border-left: none; padding-left: 0; margin-top: 24px; display: flex; flex-direction: column; gap: 16px; }
  /* Extra bottom padding for mobile bar */
  .hub-shell-wrap { padding-bottom: 80px; }
}

/* ═══════════════════════════════════════════════════════════════
   LEFT RAIL
═══════════════════════════════════════════════════════════════ */
.hub-rail {
  grid-column: 1;
  border-right: 1px solid #E7E1D6;
  padding: 40px 24px 32px 0;
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 96px);
  position: sticky;
  top: 96px;
}

.rail-section { margin-bottom: 8px; }

.rail-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #8B8378;
  margin: 20px 0 4px;
  font-family: var(--font-body);
}
.rail-section:first-child .rail-label { margin-top: 0; }

.rail-item {
  display: flex;
  align-items: center;
  height: 44px;
  font-size: 15px;
  font-weight: 500;
  color: #57514B;
  padding-left: 16px;
  text-decoration: none;
  transition: color 0.15s;
  border-radius: 2px;
}
.rail-item:hover { color: #141210; }
.rail-item--active {
  color: #141210;
  padding-left: 0;
  gap: 10px;
}
.rail-item--soon { color: #8B8378; cursor: default; justify-content: space-between; padding-right: 0; }

.rail-dot {
  width: 6px; height: 6px;
  border-radius: 999px;
  background: linear-gradient(135deg, #C9A961, #A8843C);
  flex-shrink: 0;
}

.rail-soon {
  font-family: var(--font-mono);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: #8B8378;
  background: #F0EBE0;
  padding: 2px 6px;
  margin-left: auto;
}

.rail-footer {
  margin-top: auto;
  border-top: 1px solid #E7E1D6;
  padding-top: 20px;
}

.rail-signout {
  font-size: 14px;
  color: #8B8378;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  font-family: var(--font-body);
  transition: color 0.15s;
}
.rail-signout:hover { color: #141210; }

/* ═══════════════════════════════════════════════════════════════
   HUB TABS (641–1199px)
═══════════════════════════════════════════════════════════════ */
.hub-tab {
  flex-shrink: 0;
  font-size: 13px;
  font-weight: 500;
  padding: 8px 16px;
  border-radius: 999px;
  border: 1px solid #D8D2C6;
  background: #FAF8F4;
  color: #57514B;
  text-decoration: none;
  white-space: nowrap;
  transition: background 0.15s, color 0.15s, border-color 0.15s;
}
.hub-tab:hover { border-color: #C9A961; color: #141210; }
.hub-tab--active { background: #141210; border-color: #141210; color: #FAF8F4; }

/* ═══════════════════════════════════════════════════════════════
   MAIN CONTENT
═══════════════════════════════════════════════════════════════ */
.hub-main {
  grid-column: 2;
  padding-top: 40px;
  display: flex;
  flex-direction: column;
  gap: 0;
  min-width: 0;
}

/* 1. WELCOME BAND */
.welcome-band {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 32px;
  padding-bottom: 24px;
  border-bottom: 1px solid #E7E1D6;
  flex-wrap: wrap;
}

.welcome-copy { flex: 1; min-width: 0; }

.section-kicker {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #A8843C;
  margin-bottom: 14px;
  font-family: var(--font-body);
}

.kicker-rule {
  display: inline-block;
  width: 28px;
  height: 1px;
  background: #C9A961;
  flex-shrink: 0;
}

.welcome-greeting {
  font-family: var(--font-display);
  font-size: clamp(32px, 4vw, 44px);
  font-weight: 700;
  letter-spacing: -0.025em;
  line-height: 1.05;
  color: #141210;
  margin: 0 0 10px;
}

.welcome-meta {
  font-size: 14px;
  color: #8B8378;
  display: flex;
  flex-wrap: wrap;
  gap: 0 6px;
  align-items: center;
  font-family: var(--font-body);
}

.welcome-portfolio-link {
  color: #A8843C;
  border-bottom: 1px solid rgba(168,132,60,0.4);
  text-decoration: none;
  transition: border-color 0.15s;
}
.welcome-portfolio-link:hover { border-color: #A8843C; }

/* Gold CTA */
.btn-gold-cta {
  display: inline-block;
  font-size: 15px;
  font-weight: 600;
  color: #FFFFFF;
  background: linear-gradient(135deg, #C9A961, #A8843C);
  padding: 13px 26px;
  border-radius: 2px;
  box-shadow: 0 2px 10px rgba(168,132,60,0.3), inset 0 1px 0 rgba(255,255,255,0.25);
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
  transition: box-shadow 0.2s, transform 0.15s;
  font-family: var(--font-body);
}
.btn-gold-cta:hover {
  box-shadow: 0 4px 16px rgba(168,132,60,0.4), inset 0 1px 0 rgba(255,255,255,0.25);
  transform: translateY(-1px);
}

/* 2. ATTENTION ROW */
.attention-row {
  display: flex;
  flex-wrap: wrap;
  border-bottom: 1px solid #E7E1D6;
  margin-bottom: 36px;
}
.attention-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 16px 24px 16px 0;
  font-size: 13px;
  font-weight: 500;
  color: #141210;
  white-space: nowrap;
  text-decoration: none;
  border-right: 1px solid #F0EBE0;
  margin-right: 24px;
  font-family: var(--font-body);
}
.attention-item:last-child { border-right: none; margin-right: 0; }
.attention-dot {
  width: 7px; height: 7px;
  border-radius: 999px;
  background: linear-gradient(135deg, #C9A961, #A8843C);
  flex-shrink: 0;
}

/* 3. SECTION BLOCK */
.section-block { margin-bottom: 40px; }

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18px;
}

.section-link {
  font-size: 13px;
  font-weight: 500;
  color: #A8843C;
  border-bottom: 1px solid rgba(168,132,60,0.4);
  text-decoration: none;
  font-family: var(--font-body);
}

/* PHOTO GRID */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 14px;
}

@media (max-width: 1199px) { .photo-grid { grid-template-columns: repeat(4, 1fr); } }
@media (max-width: 640px)  { .photo-grid { grid-template-columns: repeat(3, 1fr); } }

.photo-mat {
  background: #FFFFFF;
  border: 1px solid #E7E1D6;
  box-shadow: 0 1px 2px rgba(20,18,16,0.04);
  padding: 8px;
  text-decoration: none;
  color: inherit;
  display: block;
  transition: box-shadow 0.15s;
}
.photo-mat:hover { box-shadow: 0 4px 12px rgba(20,18,16,0.1); }

.photo-thumb {
  aspect-ratio: 4 / 5;
  background: #1A1816;
  overflow: hidden;
  position: relative;
}
.photo-thumb img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}

.photo-thumb-empty {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
}

.photo-mat-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 4px;
  margin-top: 8px;
}
.photo-mat-title {
  font-size: 11px;
  font-weight: 600;
  color: #141210;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-family: var(--font-body);
}
.photo-vis-badge {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.08em;
  padding: 2px 5px;
  flex-shrink: 0;
  font-family: var(--font-body);
}
.photo-vis-badge--public  { background: #E8EFE9; color: #3E5A48; }
.photo-vis-badge--pending { background: #FBF0E8; color: #8C6830; }
.photo-vis-badge--private { background: #F4F0E8; color: #57514B; border: 1px solid #D8D2C6; }

.upload-tile {
  padding: 8px;
  border: 1px dashed #C9A961;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  text-decoration: none;
  color: #A8843C;
  transition: background 0.15s;
  aspect-ratio: unset;
  min-height: 80px;
}
.upload-tile:hover { background: rgba(201,169,97,0.06); }
.upload-tile-plus { font-size: 20px; line-height: 1; }
.upload-tile-label { font-size: 11px; font-weight: 500; color: #8B8378; text-align: center; line-height: 1.3; font-family: var(--font-body); }

/* 3b. EMPTY STATE */
.empty-state-frame {
  border: 1px dashed #C9A961;
  padding: 56px 48px;
  text-align: center;
  margin-bottom: 36px;
}
.empty-title {
