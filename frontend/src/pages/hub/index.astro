<script>
import { logout } from '../../lib/auth';

const API = '/api/v1';

/* ── Utilities ──────────────────────────────────────────────── */
function tok(): string { return localStorage.getItem('bcc_token') ?? ''; }

async function apiFetch(path: string): Promise<Response> {
  return fetch(path, { headers: { Authorization: `Bearer ${tok()}` } });
}

function show(id: string) {
  const el = document.getElementById(id);
  if (el) el.hidden = false;
}
function hide(id: string) {
  const el = document.getElementById(id);
  if (el) el.hidden = true;
}
function setText(id: string, text: string) {
  const el = document.getElementById(id);
  if (el) el.textContent = text;
}

/* Time-of-day greeting */
function greeting(firstName: string): string {
  const h = new Date().getHours();
  if (h < 12) return `Good morning, ${firstName}.`;
  if (h < 17) return `Good afternoon, ${firstName}.`;
  return `Good evening, ${firstName}.`;
}

/* Map class_id → display label (MEM-006: shown inside hub, not public surface) */
const CLASS_LABELS: Record<number, string> = {
  1: 'Founding Member',
  2: 'Patron Member',
  3: 'Life Member',
  4: 'Full Member',
  5: 'Basic Member',
  6: 'Student Member',
  7: 'Individual Member',
};

/* Photo visibility badge */
function visBadge(vis: string): string {
  if (vis === 'PUBLIC')       return '<span class="photo-vis-badge photo-vis-badge--public">PUBLIC</span>';
  if (vis === 'MEMBERS_ONLY') return '<span class="photo-vis-badge photo-vis-badge--pending">MEMBERS</span>';
  return '<span class="photo-vis-badge photo-vis-badge--private">PRIVATE</span>';
}

/* HTML-escape helper for values interpolated into innerHTML */
function escHtml(s: string): string {
  return String(s ?? '')
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}

/* Branded fallback thumbnail for stories/collections with no cover/photos yet */
const SC_FALLBACK = `
  <div class="sc-thumb-fallback">
    <svg width="26" height="26" viewBox="0 0 28 28" fill="none" aria-hidden="true" stroke="currentColor">
      <rect x="2" y="2" width="24" height="24" stroke-width="1"/>
      <circle cx="9" cy="8" r="2.5" stroke-width="0.75"/>
      <path d="M2 20l7-6 5 4 4-3 8 6" stroke-width="0.75"/>
    </svg>
    <span class="sc-fallback-mark">BCC</span>
  </div>`;

/* Placeholder SVG for photos without thumbnails */
const PHOTO_PH = `
  <div class="photo-thumb-empty">
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" class="ph-svg">
      <rect x="2" y="2" width="24" height="24" stroke-width="1"/>
      <line x1="2" y1="26" x2="26" y2="2" stroke-width="0.5"/>
      <circle cx="9" cy="8" r="2.5" stroke-width="0.75"/>
    </svg>
  </div>`;

/* Event type → tag CSS class + label */
function eventTypeTag(type: string): string {
  const map: Record<string, [string, string]> = {
    'PHOTO_WALK': ['walk',     'Photo Walk'],
    'WORKSHOP':   ['workshop', 'Workshop'],
    'TOUR':       ['tour',     'Tour'],
    'MEETUP':     ['meetup',   'Meetup'],
  };
  const [cls, label] = map[type?.toUpperCase()] ?? ['meetup', type ?? 'Event'];
  return `<span class="event-type-tag event-type-tag--${cls}">${label}</span>`;
}

/* ── LOAD USER ──────────────────────────────────────────────── */
async function loadUser(): Promise<{ firstName: string; createdAt: string; userId: number; username: string } | null> {
  const res = await apiFetch(`${API}/users/me`);
  if (!res.ok) return null;
  const u = await res.json() as { fullName?: string; createdAt?: string; id?: number; username?: string };

  const firstName = (u.fullName ?? 'there').trim().split(/\s+/)[0];
  const createdAt = u.createdAt ?? '';
  const userId    = u.id ?? 0;
  const username  = u.username ?? '';

  setText('hub-greeting', greeting(firstName));

  const sinceYear = createdAt ? new Date(createdAt).getFullYear() : null;
  const sinceEl = document.getElementById('hub-since-text');
  if (sinceEl) sinceEl.textContent = sinceYear ? `member since ${sinceYear}` : '';

  const portfolioLink = document.getElementById('hub-portfolio-link') as HTMLAnchorElement | null;
  if (portfolioLink && username) {
    portfolioLink.href   = `/photographers/${username}/`;
    portfolioLink.hidden = false;
  }

  return { firstName, createdAt, userId, username };
}

/* ── LOAD MEMBERSHIP ────────────────────────────────────────── */
async function loadMembership(): Promise<void> {
  const res = await apiFetch(`${API}/membership/mine`);
  if (!res.ok) {
    show('membership-dark-card');
    setText('mcard-name', '—');
    return;
  }

  const memberships = await res.json() as Array<{
    id?: number;
    lifecycle_state?: string;
    membership_number?: string | null;
    membership_class_id?: number | null;
    expires_at?: string | null;
    activated_at?: string | null;
  }>;

  const active = memberships.find(m => m.lifecycle_state === 'ACTIVE')
    || memberships.find(m => m.lifecycle_state === 'APPROVED')
    || memberships.find(m => m.lifecycle_state === 'PENDING')
    || memberships[0];

  // item 72: keep the membership application visible & resumable in the hub
  // shell. Anyone who is not yet an ACTIVE/APPROVED member gets a clear prompt —
  // "under review" if they've submitted (PENDING), otherwise "complete it".
  const isRealMember = !!active && (active.lifecycle_state === 'ACTIVE' || active.lifecycle_state === 'APPROVED');
  const hasPending   = memberships.some(m => m.lifecycle_state === 'PENDING');
  if (!isRealMember) {
    addAttentionItem(
      hasPending
        ? 'Your <strong>membership application</strong> is under review — view status'
        : 'Complete your <strong>membership application</strong> to unlock member benefits',
      '/hub/membership/apply/',
    );
  }

  if (!active) return;

  const classLabel = active.membership_class_id
    ? (CLASS_LABELS[active.membership_class_id] ?? 'Member')
    : 'Member';

  // Welcome meta class label
  const classEl = document.getElementById('hub-class-label');
  if (classEl) classEl.textContent = classLabel + ' ·';

  // Dark membership card
  show('membership-dark-card');
  setText('mcard-class', classLabel.toUpperCase());

  // MEM-007 §6 temporary identifier (item 46): show BCCTempXXXXX until a
  // permanent number is allocated. Display-only, derived from membership id.
  const tempNumber = active.id != null ? `BCCTemp${String(active.id).padStart(5, '0')}` : 'Pending';
  const numEl = document.getElementById('mcard-number');
  if (numEl) numEl.textContent = active.membership_number ?? tempNumber;

  // Expiry / renewal
  const expiryEl      = document.getElementById('mcard-expiry');
  const expiryLabelEl = document.getElementById('mcard-expiry-label');
  if (active.expires_at) {
    const d = new Date(active.expires_at);
    if (expiryEl) expiryEl.textContent = d.toLocaleDateString('en-IN', { month: 'short', year: 'numeric' }).toUpperCase();
    if (expiryLabelEl) expiryLabelEl.textContent = 'Valid Thru';

    const daysLeft = Math.ceil((d.getTime() - Date.now()) / 86400000);
    if (daysLeft <= 60 && daysLeft > 0) {
      const renewEl = document.getElementById('mcard-renews');
      if (renewEl) { renewEl.textContent = `RENEWS ${daysLeft}D`; renewEl.hidden = false; }
      addAttentionItem(
        `Membership renews <span style="font-family:var(--font-mono);margin-left:4px">${d.toLocaleDateString('en-IN',{day:'numeric',month:'short'})}</span>`,
        '/hub/membership/'
      );
    }
  } else if (active.lifecycle_state === 'ACTIVE') {
    // ACTIVE with null expiry → genuinely lifetime membership class
    if (expiryEl) expiryEl.textContent = 'Lifetime';
    if (expiryLabelEl) expiryLabelEl.textContent = 'Status';
  } else {
    // Not yet active (PENDING awaiting review, APPROVED awaiting activation) —
    // null expiry here does NOT mean lifetime; show the actual state instead.
    const stateText = active.lifecycle_state === 'PENDING'   ? 'Pending'
                    : active.lifecycle_state === 'APPROVED'  ? 'Processing'
                    : '–';
    if (expiryEl) expiryEl.textContent = stateText;
    if (expiryLabelEl) expiryLabelEl.textContent = 'Status';
  }

  // Populate member name from localStorage (fast path)
  const raw = localStorage.getItem('bcc_user');
  if (raw) {
    try {
      const u = JSON.parse(raw) as { displayName?: string };
      if (u.displayName) setText('mcard-name', u.displayName);
    } catch { /* ignore */ }
  }
}

/* ── ATTENTION ROW helpers ──────────────────────────────────── */
const attentionItems: Array<{ html: string; href: string }> = [];

function addAttentionItem(html: string, href: string) {
  attentionItems.push({ html, href });
}

function renderAttentionRow() {
  if (!attentionItems.length) return;
  const row = document.getElementById('attention-row');
  if (!row) return;
  row.innerHTML = attentionItems.slice(0, 3).map(item =>
    `<a href="${item.href}" class="attention-item">
       <span class="attention-dot"></span>${item.html} &rarr;
     </a>`
  ).join('');
  row.hidden = false;
}

/* ── LOAD PHOTOS ────────────────────────────────────────────── */
async function loadPhotos(): Promise<number> {
  const res = await apiFetch(`${API}/gallery/photos?limit=6`);
  if (!res.ok) {
    // On error: hide shimmer, show empty state
    hide('photo-grid-loading');
    show('empty-state');
    return 0;
  }

  const data = await res.json() as {
    photos: Array<{
      id: number;
      uuid: string;
      title?: string | null;
      visibility?: string;
      urls?: { thumbnail?: string; medium?: string };
    }>;
    total: number;
  };

  const photos = data.photos ?? [];
  const total  = data.total ?? photos.length;

  if (photos.length === 0) {
    // Day one: hide shimmer section, show empty-state with gold CTA
    hide('recent-work');
    show('empty-state');
    return 0;
  }

  // Populated: replace shimmer with real mats
  hide('photo-grid-loading');
  show('hub-upload-cta');
  show('recent-work');

  const grid = document.getElementById('photo-grid');
  if (!grid) return total;

  const recentPhotos = photos.slice(0, 5);
  const mats = recentPhotos.map(p => {
    const thumbUrl   = p.urls?.thumbnail ?? p.urls?.medium ?? '';
    const thumbInner = thumbUrl
      ? `<img src="${thumbUrl}" alt="${p.title ?? 'Photograph'}" loading="lazy" />`
      : PHOTO_PH;
    const title = p.title ?? 'Untitled';
    const vis   = visBadge(p.visibility ?? 'PRIVATE');
    return `
      <a href="/showcase/${p.id}/" class="photo-mat" data-photoid="${p.id}" title="${title}">
        <div class="photo-thumb">${thumbInner}</div>
        <div class="photo-mat-meta">
          <div class="photo-mat-title">${title}</div>
          ${vis}
        </div>
      </a>`;
  }).join('');

  const uploadTile = `
    <a href="/hub/upload/" class="upload-tile" aria-label="Upload a photograph">
      <span class="upload-tile-plus">+</span>
      <span class="upload-tile-label">Add a photograph</span>
    </a>`;

  grid.innerHTML = mats + uploadTile;
  grid.hidden = false;

  // Store viewing context in sessionStorage before navigating so showcase
  // page can show prev/next among the recent photo set without a polluted URL.
  const recentIds = recentPhotos.map(p => p.id);
  grid.addEventListener('click', (e: MouseEvent) => {
    const anchor = (e.target as HTMLElement).closest('a[data-photoid]') as HTMLAnchorElement | null;
    if (!anchor) return;
    e.preventDefault();
    sessionStorage.setItem('bcc_photo_ctx', JSON.stringify({
      type: 'portfolio', ctxId: 'me', ctxLabel: 'My Photos', ids: recentIds,
    }));
    window.location.href = anchor.href;
  });

  setText('jn-photos', String(total));

  return total;
}

/* ── LOAD STORIES & COLLECTIONS (item 68) ───────────────────────
   Source: GET /api/v1/gallery/albums (own albums). Each card shows the
   container cover (or a branded fallback) with its name beneath. */
async function loadStoriesCollections(): Promise<void> {
  const res = await apiFetch(`${API}/gallery/albums`);
  if (!res.ok) return;

  const albums = await res.json() as Array<{
    uuid: string;
    title: string;
    kind?: string;
    photo_count?: number;
    cover_image_url?: string | null;
  }>;
  if (!Array.isArray(albums) || albums.length === 0) return;  // stays hidden

  const grid = document.getElementById('sc-grid');
  if (!grid) return;

  grid.innerHTML = albums.map(a => {
    const kindLabel = a.kind === 'STORY' ? 'Story' : 'Collection';
    const count = a.photo_count ?? 0;
    const countLabel = `${count} ${count === 1 ? 'photo' : 'photos'}`;
    const thumb = a.cover_image_url
      ? `<img src="${escHtml(a.cover_image_url)}" alt="${escHtml(a.title)}" loading="lazy" />`
      : SC_FALLBACK;
    return `
      <a href="/hub/portfolio/" class="sc-card" title="${escHtml(a.title)}">
        <div class="sc-thumb">${thumb}</div>
        <div class="sc-name">${escHtml(a.title)}</div>
        <div class="sc-meta">${kindLabel} · ${countLabel}</div>
      </a>`;
  }).join('');

  show('stories-collections');
}

/* ── LOAD EVENTS ────────────────────────────────────────────── */
async function loadEvents(isEmpty: boolean): Promise<void> {
  show('club-section');

  const res = await fetch(`${API}/events?upcoming=true&limit=3`);
  hide('events-loading');

  if (!res.ok) return;

  const events = await res.json() as Array<{
    id: number;
    title?: string;
    event_type?: string;
    starts_at?: string;
    location_name?: string | null;
    location_address?: string | null;
  }>;

  const listEl = document.getElementById('events-list');
  if (!listEl || !events.length) return;

  // Attention: upcoming event
  if (events[0]) {
    const first = events[0];
    const d = first.starts_at ? new Date(first.starts_at) : null;
    if (d) {
      const tomorrow = new Date(); tomorrow.setDate(tomorrow.getDate() + 1);
      const isToday    = d.toDateString() === new Date().toDateString();
      const isTomorrow = d.toDateString() === tomorrow.toDateString();
      const when = isToday ? 'today' : isTomorrow ? 'tomorrow' : d.toLocaleDateString('en-IN', { day: 'numeric', month: 'short' });
      addAttentionItem(
        `${first.title ?? 'Upcoming event'} registration opens <span style="font-family:var(--font-mono);margin-left:4px">${when}</span>`,
        `/activities/${first.id}/`
      );
    }
  }

  listEl.innerHTML = events.map(ev => {
    const d    = ev.starts_at ? new Date(ev.starts_at) : null;
    const day  = d ? String(d.getDate()).padStart(2, '0') : '--';
    const mon  = d ? d.toLocaleString('en-IN', { month: 'short' }).toUpperCase() : '';
    const time = d ? d.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit', hour12: true }) : '';
    const loc  = [ev.location_name, ev.location_address].filter(Boolean).join(', ');

    if (isEmpty) {
      // Day one: simplified 3-col row (no event thumbnail)
      return `
        <div class="event-row event-row--no-thumb">
          <div class="event-date-col">
            <div class="event-day">${day}</div>
            <div class="event-month">${mon}</div>
          </div>
          <div class="event-info">
            <div class="event-title">${ev.title ?? 'Event'}</div>
            <div class="event-location">${ev.event_type ?? ''} · ${time}${loc ? ' · ' + loc : ''}</div>
          </div>
          <a href="/activities/${ev.id}/" class="event-action-register">Register</a>
        </div>`;
    }

    return `
      <div class="event-row">
        <div class="event-date-col">
          <div class="event-day">${day}</div>
          <div class="event-month">${mon}</div>
        </div>
        <div class="event-thumb">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" class="ph-svg">
            <rect x="1" y="1" width="18" height="18" stroke-width="0.75"/>
            <line x1="1" y1="19" x2="19" y2="1" stroke-width="0.5"/>
          </svg>
        </div>
        <div class="event-info">
          <div class="event-tags">${eventTypeTag(ev.event_type ?? '')}<span class="event-time">${time}</span></div>
          <div class="event-title">${ev.title ?? 'Event'}</div>
          ${loc ? `<div class="event-location">${loc}</div>` : ''}
        </div>
        <a href="/activities/${ev.id}/" class="event-action-register">Register</a>
      </div>`;
  }).join('');
}

/* ── ACADEMY CARD ───────────────────────────────────────────── */
function renderAcademyCard(hasPhotos: boolean) {
  show('academy-card');
  const labelEl = document.getElementById('academy-card-label');
  const bodyEl  = document.getElementById('academy-card-body');
  if (!bodyEl) return;

  if (hasPhotos) {
    if (labelEl) labelEl.textContent = 'Continue Learning';
    bodyEl.innerHTML = `
      <div class="academy-course-title">Foundations of Exposure</div>
      <div class="academy-lesson">Lesson 5 of 12 — Metering modes</div>
      <div class="academy-progress-track">
        <div class="academy-progress-bar"><div class="academy-progress-fill" style="width:42%"></div></div>
        <span class="academy-progress-pct">42%</span>
      </div>
      <a href="/hub/academy/" class="academy-resume-btn">Resume lesson &rarr;</a>`;
  } else {
    if (labelEl) labelEl.textContent = 'BCC Academy';
    bodyEl.innerHTML = `
      <div class="academy-browse-title">Start learning</div>
      <p class="academy-browse-desc">Structured paths from exposure fundamentals to genre mastery.<br>
        <a href="/hub/academy/" class="academy-browse-link">Browse the Academy &rarr;</a>
      </p>`;
  }
}

/* ── JOURNEY STRIP (horizontal 3-col, populated members only) ── */
function renderJourneyStrip() {
  const milestonesEl = document.getElementById('journey-milestones');
  if (!milestonesEl) return;

  const milestones = [
    { gold: true,  title: 'First Award',    sub: 'Monsoon Frames 2024' },
    { gold: false, title: '10th Walk',       sub: 'Chowk Bazaar · Mar 2025' },
    { gold: false, title: '40 Photographs',  sub: 'Gallery milestone · Jan 2025' },
  ];

  milestonesEl.innerHTML = milestones.map(m => `
    <div class="journey-milestone">
      <div class="milestone-icon ${m.gold ? 'milestone-icon--gold' : 'milestone-icon--neutral'}">
        ${m.gold
          ? `<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 1l1.5 3H11L8.5 6.5l1 3L6 8 2.5 9.5l1-3L1 4h3.5z" fill="white"/></svg>`
          : `<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><rect x="1" y="1" width="10" height="10" stroke="#8B8378" stroke-width="1"/><line x1="1" y1="11" x2="11" y2="1" stroke="#8B8378" stroke-width="0.75"/></svg>`
        }
      </div>
      <div>
        <div class="milestone-title">${m.title}</div>
        <div class="milestone-sub">${m.sub}</div>
      </div>
    </div>`).join('');

  show('journey-card');
}

/* ── JOURNEY NUMBERS ────────────────────────────────────────── */
function renderJourneyNumbers(photoCount: number) {
  if (photoCount === 0) return;
  setText('jn-photos', String(photoCount));
  setText('jn-events', '—');
  setText('jn-courses', '—');
  setText('jn-years', '—');
  setText('jn-award', '—');
  show('journey-numbers');
}

/* ── BOOTSTRAP ──────────────────────────────────────────────── */
async function init() {
  // Show recent-work section immediately (shimmer mats visible)
  show('recent-work');

  const [userResult, photoCount] = await Promise.all([
    loadUser().catch(() => null),
    loadPhotos().catch(() => 0),
  ]);

  const hasPhotos = photoCount > 0;

  await Promise.all([
    loadMembership().catch(() => {}),
    loadEvents(!hasPhotos).catch(() => {}),
    loadStoriesCollections().catch(() => {}),
  ]);

  renderAttentionRow();
  renderAcademyCard(hasPhotos);
  if (hasPhotos) {
    renderJourneyStrip();
    renderJourneyNumbers(photoCount);
  }

  // Sync membership card name from localStorage
  if (userResult) {
    const raw = localStorage.getItem('bcc_user');
    if (raw) {
      try {
        const u = JSON.parse(raw) as { displayName?: string };
        if (u.displayName) setText('mcard-name', u.displayName);
      } catch { /* ignore */ }
    }
  }
}

init().catch(() => {});
</script>
