---
/**
 * hub/index.astro — Member Hub Main Home (V6 09)
 * Route: /hub/
 *
 * Auth-gated via HubLayout. All data fetched client-side after auth check.
 *
 * Workspace sections (populated state):
 *   1. WelcomeBand        — time-aware greeting + single gold CTA (Upload)
 *   2. AttentionRow       — ≤3 computed items; hidden when empty
 *   3. RecentWork         — 5 photo mats + upload tile (or empty-state frame)
 *   4. HappeningAtTheClub — announcement card + event rows
 *   5. JourneyNumbers     — stats strip; hidden when all zero (day one)
 *   6. PersonalStack      — AcademyContinue + MembershipCard (2-col grid)
 *                           + JourneyStrip (full-width horizontal, populated only)
 *
 * Shell: 240px HubSidebar rail | fluid workspace (owned by HubLayout/HubSidebar)
 * Responsive: ≥1200 rail · 641–1199 HubTabs · ≤640 HubMobileBar
 *
 * PersonalStack lives INSIDE workspace below JourneyNumbers — not a right rail.
 * One gold CTA per view: Upload in WelcomeBand (populated) or empty-state frame (day one).
 * MEM-006: Constitutional class names ARE shown inside the hub (not a public surface).
 */
import HubLayout from '../../layouts/HubLayout.astro';
---

<HubLayout title="Member Hub" description="Your Bhopal Camera Club member dashboard.">

  <main class="hub-main" id="hub-main">

    <!-- ① WELCOME BAND ─────────────────────────────────────────────────── -->
    <div class="welcome-band">
      <div class="welcome-copy">
        <div class="section-kicker"><span class="kicker-rule"></span>Member Hub — Studio</div>
        <h1 class="welcome-greeting" id="hub-greeting">Welcome back</h1>
        <div class="welcome-meta" id="hub-meta">
          <span id="hub-class-label"></span>
          <span id="hub-since-text"></span>
          <a href="/photographers/" id="hub-portfolio-link" class="welcome-portfolio-link" hidden>
            View public portfolio ↗
          </a>
        </div>
      </div>
      <!-- Gold CTA: only shown when member has photographs (populated state) -->
      <a href="/hub/upload/" class="btn-gold-cta" id="hub-upload-cta" aria-label="Upload a Photograph" hidden>
        &#8593; Upload a Photograph
      </a>
    </div>

    <!-- ①.5 YOUR STORIES & COLLECTIONS (item 68) — top of main content ─────
         Hidden until the member has at least one story/collection. -->
    <div class="section-block stories-collections" id="stories-collections" hidden>
      <div class="section-head">
        <div class="section-kicker"><span class="kicker-rule"></span>Your Stories &amp; Collections</div>
        <a href="/hub/portfolio/" class="section-link">Manage &#8594;</a>
      </div>
      <div class="sc-grid" id="sc-grid"></div>
    </div>

    <!-- ② ATTENTION ROW (hidden when no items) ──────────────────────────── -->
    <div class="attention-row" id="attention-row" hidden>
      <!-- items injected by JS: max 3 -->
    </div>

    <!-- ③a RECENT WORK (populated) ─────────────────────────────────────── -->
    <div class="section-block recent-work" id="recent-work" hidden>
      <div class="section-head">
        <div class="section-kicker"><span class="kicker-rule"></span>Your Latest Work</div>
        <a href="/hub/portfolio/" class="section-link">Portfolio &#8594;</a>
      </div>
      <!-- Loading: shimmer mats shown before API returns -->
      <div class="photo-grid" id="photo-grid-loading" aria-hidden="true">
        <div class="photo-mat photo-mat--shimmer"><div class="photo-thumb"></div><div class="shimmer-title"></div></div>
        <div class="photo-mat photo-mat--shimmer"><div class="photo-thumb"></div><div class="shimmer-title"></div></div>
        <div class="photo-mat photo-mat--shimmer"><div class="photo-thumb"></div><div class="shimmer-title"></div></div>
        <div class="photo-mat photo-mat--shimmer"><div class="photo-thumb"></div><div class="shimmer-title"></div></div>
        <div class="photo-mat photo-mat--shimmer"><div class="photo-thumb"></div><div class="shimmer-title"></div></div>
        <div class="upload-tile">
          <span class="upload-tile-plus">+</span>
          <span class="upload-tile-label">Add a photograph</span>
        </div>
      </div>
      <!-- Populated: real photo mats injected by JS -->
      <div class="photo-grid" id="photo-grid" hidden></div>
    </div>

    <!-- ③b EMPTY STATE — day one (gold CTA moves here) ─────────────────── -->
    <div class="empty-state-frame" id="empty-state" hidden>
      <h2 class="empty-title">Your portfolio begins here.</h2>
      <p class="empty-desc">Photographs you upload appear on your public portfolio page — and could hang on the club's wall.</p>
      <a href="/hub/upload/" class="btn-gold-cta">&#8593; Upload your first photograph</a>
    </div>

    <!-- ── HUB LOWER BAND ──────────────────────────────────────────────────
         Desktop: sections stacked in order (events → journey-numbers → personal)
         Tablet (641–1199px): events + personal side-by-side, journey-numbers below
    ────────────────────────────────────────────────────────────────────── -->
    <div class="hub-lower-band">

      <!-- ④ HAPPENING AT THE CLUB ──────────────────────────────────────── -->
      <div class="section-block hub-events-section" id="club-section" hidden>
        <div class="section-kicker"><span class="kicker-rule"></span>Happening at the Club</div>
        <div id="club-announcement" hidden></div>
        <div id="events-list"></div>
        <div id="events-loading" class="events-loading" aria-live="polite">
          <span class="hub-loading-dot"></span>
          <span class="hub-loading-dot"></span>
          <span class="hub-loading-dot"></span>
        </div>
      </div>

      <!-- ⑤ JOURNEY NUMBERS (hidden on day one — all stats zero) ──────── -->
      <div class="journey-numbers" id="journey-numbers" hidden>
        <div class="journey-stat">
          <div class="journey-num" id="jn-photos">—</div>
          <div class="journey-label">Photographs</div>
        </div>
        <div class="journey-stat">
          <div class="journey-num" id="jn-events">—</div>
          <div class="journey-label">Walks &amp; Tours</div>
        </div>
        <div class="journey-stat">
          <div class="journey-num" id="jn-courses">—</div>
          <div class="journey-label">Courses</div>
        </div>
        <div class="journey-stat">
          <div class="journey-num" id="jn-years">—</div>
          <div class="journey-label">Years</div>
        </div>
        <div class="journey-stat">
          <div class="journey-num" id="jn-award">—</div>
          <div class="journey-label">Award</div>
        </div>
      </div>

      <!-- ⑥ PERSONAL STACK ─────────────────────────────────────────────── -->
      <div class="personal-stack" id="personal-stack">

        <!-- 2-col grid: AcademyContinue | MembershipCard -->
        <div class="personal-stack-grid">

          <!-- AcademyContinue (populated: resume lesson; day one: browse Academy) -->
          <div class="personal-card academy-card" id="academy-card" hidden>
            <div class="personal-card__label" id="academy-card-label">Continue Learning</div>
            <div id="academy-card-body">
              <!-- injected by JS -->
            </div>
          </div>

          <!-- MembershipCard (dark) -->
          <div class="membership-dark-card" id="membership-dark-card" hidden>
            <img src="/brand/BCC White Logo.png" alt="BCC" class="mcard-logo" />
            <div class="mcard-name" id="mcard-name">—</div>
            <div class="mcard-class" id="mcard-class">Member</div>
            <div class="mcard-footer">
              <div>
                <div class="mcard-field-label">Membership No.</div>
                <div class="mcard-field-value" id="mcard-number">—</div>
              </div>
              <div class="mcard-expiry-col">
                <div class="mcard-field-label" id="mcard-expiry-label">Valid Thru</div>
                <div class="mcard-field-value mcard-field-value--gold" id="mcard-expiry">—</div>
              </div>
            </div>
            <div class="mcard-bottom">
              <a href="/hub/membership/" class="mcard-link">Membership &amp; Billing &#8594;</a>
              <span class="mcard-renews" id="mcard-renews" hidden></span>
            </div>
          </div>

        </div><!-- /personal-stack-grid -->

        <!-- JourneyStrip — horizontal 3-col, shown for established members only -->
        <div class="journey-strip" id="journey-card" hidden>
          <div class="personal-card__label">Your Journey</div>
          <div class="journey-milestones-grid" id="journey-milestones">
            <!-- injected by JS -->
          </div>
          <a href="/hub/journey/" class="journey-strip__link">Full journey &#8594;</a>
        </div>

      </div><!-- /personal-stack -->

    </div><!-- /hub-lower-band -->

  </main>

</HubLayout>

<style>
/* ═══════════════════════════════════════════════════════════════
   MAIN CONTENT COLUMN
═══════════════════════════════════════════════════════════════ */
.hub-main {
  padding-top: 40px;
  display: flex;
  flex-direction: column;
  gap: 0;
  min-width: 0;
}

/* ① WELCOME BAND ─────────────────────────────────────────────── */
.welcome-band {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 32px;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--hairline);
  flex-wrap: wrap;
}

.welcome-copy { flex: 1; min-width: 0; }

.welcome-greeting {
  font-family: var(--font-display);
  font-size: clamp(32px, 4vw, 44px);
  font-weight: 700;
  letter-spacing: -0.025em;
  line-height: 1.05;
  color: var(--ink-900);
  margin: 0 0 10px;
}
.welcome-meta {
  font-size: 14px;
  color: var(--ink-400);
  display: flex;
  flex-wrap: wrap;
  gap: 0 6px;
  align-items: center;
  font-family: var(--font-body);
}
.welcome-portfolio-link {
  color: var(--gold-600);
  border-bottom: 1px solid rgba(168,132,60,0.4);
  text-decoration: none;
  transition: border-color 0.15s;
}
.welcome-portfolio-link:hover { border-color: var(--gold-600); }

/* Gold CTA — one per view */
.btn-gold-cta {
  display: inline-block;
  font-size: 15px;
  font-weight: 600;
  color: #FFFFFF;
  background: var(--gold-gradient);
  padding: 13px 26px;
  border-radius: 2px;
  box-shadow: 0 2px 10px rgba(168,132,60,0.3), inset 0 1px 0 rgba(255,255,255,0.25);
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
  transition: box-shadow 0.2s, transform 0.15s;
  font-family: var(--font-body);
}
.btn-gold-cta:hover {
  box-shadow: 0 4px 16px rgba(168,132,60,0.4), inset 0 1px 0 rgba(255,255,255,0.25);
  transform: translateY(-1px);
}

/* ② ATTENTION ROW ────────────────────────────────────────────── */
.attention-row {
  display: flex;
  flex-wrap: wrap;
  border-bottom: 1px solid var(--hairline);
  margin-bottom: 36px;
}
.attention-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 16px 24px 16px 0;
  font-size: 13px;
  font-weight: 500;
  color: var(--ink-900);
  white-space: nowrap;
  text-decoration: none;
  border-right: 1px solid var(--hairline-soft);
  margin-right: 24px;
  font-family: var(--font-body);
}
.attention-item:last-child { border-right: none; margin-right: 0; }
.attention-dot {
  width: 7px; height: 7px;
  border-radius: 999px;
  background: var(--gold-gradient);
  flex-shrink: 0;
}

/* ③ SECTION BLOCK / RECENT WORK ──────────────────────────────── */
.section-block { margin-bottom: 40px; }
.recent-work   { margin-bottom: 40px; }

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18px;
}
.section-link {
  font-size: 13px;
  font-weight: 500;
  color: var(--gold-600);
  border-bottom: 1px solid rgba(168,132,60,0.4);
  text-decoration: none;
  font-family: var(--font-body);
}

/* Stories & Collections grid (item 68) */
.sc-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 14px;
}
@media (min-width: 641px) and (max-width: 1199px) { .sc-grid { grid-template-columns: repeat(4, 1fr); } }
@media (max-width: 640px)                          { .sc-grid { grid-template-columns: repeat(3, 1fr); } }

.sc-card {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  box-shadow: 0 1px 2px rgba(20,18,16,0.04);
  padding: 8px;
  text-decoration: none;
  color: inherit;
  display: block;
  transition: box-shadow 0.15s, border-color 0.15s;
}
.sc-card:hover { box-shadow: 0 4px 12px rgba(20,18,16,0.1); border-color: var(--gold-light); }

.sc-thumb {
  aspect-ratio: 4 / 5;
  background: #1A1816;
  overflow: hidden;
  position: relative;
  border-radius: 0;               /* photos never rounded (design token) */
}
.sc-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* Branded fallback for containers with no cover/photos yet */
.sc-thumb-fallback {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  background: linear-gradient(160deg, #201C17 0%, #141210 100%);
  color: rgba(201,169,97,0.55);
}
.sc-thumb-fallback .sc-fallback-mark {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.22em;
  font-weight: 600;
}
.sc-name {
  font-size: 12px;
  font-weight: 600;
  color: var(--ink-900);
  margin-top: 8px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-family: var(--font-body);
}
.sc-meta {
  font-size: 10px;
  color: var(--ink-400);
  margin-top: 2px;
  font-family: var(--font-mono);
  letter-spacing: 0.04em;
}
.sc-card:hover .sc-name { color: var(--gold-600); }

/* Photo grid */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 14px;
}
@media (min-width: 641px) and (max-width: 1199px) { .photo-grid { grid-template-columns: repeat(4, 1fr); } }
@media (max-width: 640px)                          { .photo-grid { grid-template-columns: repeat(3, 1fr); } }

.photo-mat {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  box-shadow: 0 1px 2px rgba(20,18,16,0.04);
  padding: 8px;
  text-decoration: none;
  color: inherit;
  display: block;
  transition: box-shadow 0.15s;
}
.photo-mat:hover { box-shadow: 0 4px 12px rgba(20,18,16,0.1); }

.photo-thumb {
  aspect-ratio: 4 / 5;
  background: #1A1816;
  overflow: hidden;
  position: relative;
}
.photo-thumb img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}

.photo-thumb-empty {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
}

.photo-mat-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 4px;
  margin-top: 8px;
}
.photo-mat-title {
  font-size: 11px;
  font-weight: 600;
  color: var(--ink-900);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-family: var(--font-body);
}
.photo-vis-badge {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.08em;
  padding: 2px 5px;
  flex-shrink: 0;
  font-family: var(--font-body);
}
.photo-vis-badge--public  { background: var(--status-active-bg); color: var(--forest-600); }
.photo-vis-badge--pending { background: #FBF0E8; color: #8C6830; }
.photo-vis-badge--private { background: var(--surface-2); color: var(--ink-600); border: 1px solid var(--ink-200); }

/* Photo loading shimmer */
.photo-mat--shimmer { pointer-events: none; }
.photo-mat--shimmer .photo-thumb {
  background: linear-gradient(90deg, var(--hairline) 25%, var(--surface-2) 50%, var(--hairline) 75%);
  background-size: 200% 100%;
  animation: bg-shimmer 1.5s ease-in-out infinite;
}
.shimmer-title {
  height: 10px;
  width: 65%;
  background: linear-gradient(90deg, var(--hairline) 25%, var(--surface-2) 50%, var(--hairline) 75%);
  background-size: 200% 100%;
  animation: bg-shimmer 1.5s ease-in-out infinite;
  animation-delay: 0.1s;
  margin-top: 10px;
  border-radius: 1px;
}

.upload-tile {
  padding: 8px;
  border: 1px dashed var(--gold-light);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  text-decoration: none;
  color: var(--gold-600);
  transition: background 0.15s;
  min-height: 80px;
}
.upload-tile:hover { background: rgba(201,169,97,0.06); }
.upload-tile-plus  { font-size: 20px; line-height: 1; }
.upload-tile-label { font-size: 11px; font-weight: 500; color: var(--ink-400); text-align: center; line-height: 1.3; font-family: var(--font-body); }

/* ③b EMPTY STATE ─────────────────────────────────────────────── */
.empty-state-frame {
  border: 1px dashed var(--gold-light);
  padding: 56px 48px;
  text-align: center;
  margin-bottom: 36px;
}
.empty-title {
  font-family: var(--font-display);
  font-size: 24px;
  font-weight: 600;
  letter-spacing: -0.01em;
  color: var(--ink-900);
  margin: 0 0 10px;
}
.empty-desc {
  font-size: 14px;
  color: var(--ink-400);
  max-width: 400px;
  margin: 0 auto 24px;
  line-height: 1.7;
  font-family: var(--font-body);
}

/* ── HUB LOWER BAND ─────────────────────────────────────────────
   Desktop:        flex column — events → journey-numbers → personal
   Tablet 641–1199: grid — events | personal / journey (full-width)
   Mobile ≤640:    flex column
────────────────────────────────────────────────────────────────── */
.hub-lower-band {
  display: flex;
  flex-direction: column;
}

@media (min-width: 641px) and (max-width: 1199px) {
  .hub-lower-band {
    display: grid;
    grid-template-areas:
      "events  personal"
      "journey journey";
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
  }
  .hub-events-section { grid-area: events;   margin-bottom: 0; }
  .journey-numbers    { grid-area: journey;  margin-bottom: 0; }
  .personal-stack     { grid-area: personal; margin-top: 0; }
}

/* ④ HAPPENING AT THE CLUB ────────────────────────────────────── */
.club-announcement {
  background: var(--surface-2);
  border: 1px solid var(--hairline);
  padding: 18px 22px;
  margin-bottom: 16px;
}
.announcement-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-400);
  margin-bottom: 8px;
  font-family: var(--font-body);
}
.announcement-title {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 16px;
  color: var(--ink-900);
  margin: 0 0 5px;
}
.announcement-sub {
  font-size: 13px;
  color: var(--ink-600);
  margin: 0;
  font-family: var(--font-body);
}
.announcement-link { color: var(--gold-600); }

/* Event rows */
.event-row {
  display: grid;
  grid-template-columns: 56px 80px 1fr auto;
  gap: 18px;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid var(--hairline-soft);
  font-family: var(--font-body);
}
.event-row:last-child { border-bottom: none; }

/* No-thumb variant: empty state events and tablet/mobile */
.event-row--no-thumb {
  grid-template-columns: 56px 1fr auto;
}
.event-row--no-thumb .event-thumb { display: none; }

@media (max-width: 640px) {
  .event-row           { grid-template-columns: 44px 1fr; gap: 12px; }
  .event-thumb         { display: none; }
  .event-action-register,
  .event-action-registered { display: none; }
}

.event-date-col { text-align: center; }
.event-day {
  font-family: var(--font-display);
  font-size: 24px;
  font-weight: 700;
  line-height: 1;
  color: var(--ink-900);
}
.event-month {
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--ink-400);
  margin-top: 3px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.event-thumb {
  aspect-ratio: 3 / 2;
  background: #1A1816;
  overflow: hidden;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.event-tags {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 5px;
}
.event-type-tag {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 3px 8px;
  font-family: var(--font-body);
}
.event-type-tag--walk     { background: var(--status-active-bg); color: var(--forest-600); }
.event-type-tag--workshop { background: #F5EDD8; color: #8C6830; }
.event-type-tag--tour     { background: #EAE8F2; color: #4A4870; }
.event-type-tag--meetup   { background: var(--surface-2); color: var(--ink-600); border: 1px solid var(--ink-200); }

.event-time {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--ink-400);
}
.event-title {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 16px;
  color: var(--ink-900);
  margin: 0 0 3px;
}
.event-location { font-size: 11px; color: var(--ink-400); }

.event-action-registered {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: var(--forest-600);
  background: var(--status-active-bg);
  padding: 6px 12px;
  white-space: nowrap;
  font-family: var(--font-body);
}
.event-action-register {
  font-size: 13px;
  font-weight: 600;
  color: var(--ink-900);
  border: 1px solid var(--ink-200);
  padding: 8px 16px;
  border-radius: 2px;
  white-space: nowrap;
  text-decoration: none;
  font-family: var(--font-body);
  transition: border-color 0.15s;
}
.event-action-register:hover { border-color: var(--ink-900); }

.events-loading {
  display: flex;
  gap: 5px;
  align-items: center;
  justify-content: center;
  padding: 24px 0;
}
.hub-loading-dot {
  width: 6px; height: 6px;
  background: var(--ink-200);
  border-radius: 999px;
  animation: hub-pulse 1.2s ease-in-out infinite both;
}
.hub-loading-dot:nth-child(2) { animation-delay: 0.2s; }
