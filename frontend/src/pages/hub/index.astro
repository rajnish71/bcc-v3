---
/**
 * hub/index.astro -- Member Hub dashboard
 * Route: /hub/
 *
 * Auth-gated via HubLayout (redirects to signin if no valid JWT).
 *
 * Sections:
 *   1. Welcome header (name from bcc_user localStorage, refreshed by HubLayout)
 *   2. Identity status card (email verified / not verified)
 *   3. Membership status card (from GET /api/v1/membership/mine)
 *   4. Quick actions
 *   5. Phase 2+ coming-soon cards
 *
 * MEM-006 P1: We always show "Registered User" as the baseline.
 * Membership is a separate track displayed here if it exists.
 *
 * Public domain policy: constitutional class names are NOT shown here
 * if the user is a Basic/Student/Individual member -- they see their
 * class name. Constitutional classes (Full/Life/Patron/Founding) are
 * shown accurately inside the hub (this is NOT the public domain).
 */
import HubLayout from '../../layouts/HubLayout.astro';
---

<HubLayout title="Member Hub" description="Your Bhopal Camera Club member dashboard.">

  <div class="hub-page-inner">

    <!-- Page header -->
    <div class="hub-header">
      <div class="container">
        <div class="hub-header-inner">
          <div>
            <p class="hub-kicker">Member Hub</p>
            <h1 class="hub-welcome" id="hub-welcome-name">Welcome back</h1>
            <p class="hub-welcome-sub">Your BCC platform dashboard</p>
          </div>
          <button id="hub-signout-btn" type="button" class="btn btn-outline btn-sm hub-signout">
            Sign Out
          </button>
        </div>
      </div>
    </div>

    <div class="container hub-body-container">

      <!-- ============================================================
           Row 1: Identity + Membership status
           ============================================================ -->
      <div class="hub-grid-2">

        <!-- Identity card -->
        <div class="hub-card" id="identity-card">
          <div class="hub-card__header">
            <span class="hub-card__label">Platform Identity</span>
            <span class="hub-card__badge hub-card__badge--active" id="identity-status-badge">Registered User</span>
          </div>
          <div class="hub-card__body">
            <div class="hub-stat-row">
              <span class="hub-stat-label">Email</span>
              <span class="hub-stat-value" id="identity-email">--</span>
            </div>
            <div class="hub-stat-row">
              <span class="hub-stat-label">Email verified</span>
              <span class="hub-stat-value" id="identity-email-verified">--</span>
            </div>
            <div class="hub-stat-row">
              <span class="hub-stat-label">Member since</span>
              <span class="hub-stat-value" id="identity-since">--</span>
            </div>
          </div>
          <div id="verify-prompt" class="hub-card__action" hidden>
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.4"/>
              <path d="M8 5v3M8 10h.01" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
            <span>Check your inbox to verify your email address.</span>
            <a href="/verify-email/" class="auth-link">Resend?</a>
          </div>
        </div>

        <!-- Membership card -->
        <div class="hub-card" id="membership-card">
          <div class="hub-card__header">
            <span class="hub-card__label">Membership</span>
            <span class="hub-card__badge" id="membership-badge">Loading...</span>
          </div>
          <div class="hub-card__body" id="membership-body">
            <div class="hub-loading-inline" aria-live="polite" aria-label="Loading membership">
              <span class="hub-loading__dot"></span>
              <span class="hub-loading__dot"></span>
              <span class="hub-loading__dot"></span>
            </div>
          </div>
        </div>

      </div>

      <!-- ============================================================
           Row 2: Quick actions
           ============================================================ -->
      <div class="hub-section">
        <h2 class="hub-section-title">Quick Actions</h2>
        <div class="hub-actions-grid">

          <a href="/hub/membership/apply/" class="hub-action-card" id="action-apply" aria-label="Apply for membership">
            <div class="hub-action-card__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="12" y1="18" x2="12" y2="12"/>
                <line x1="9" y1="15" x2="15" y2="15"/>
              </svg>
            </div>
            <div>
              <p class="hub-action-card__title">Apply for Membership</p>
              <p class="hub-action-card__desc">Choose a membership class and submit your application.</p>
            </div>
          </a>

          <div class="hub-action-card hub-action-card--muted" aria-label="Download membership card (unavailable)">
            <div class="hub-action-card__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="5" width="20" height="14" rx="2"/>
                <line x1="2" y1="10" x2="22" y2="10"/>
              </svg>
            </div>
            <div>
              <p class="hub-action-card__title">Membership Card</p>
              <p class="hub-action-card__desc">Download your digital membership card. Available once membership is active.</p>
            </div>
            <span class="hub-action-card__pill">Active membership required</span>
          </div>

          <a href="/activities/" class="hub-action-card" aria-label="Browse activities">
            <div class="hub-action-card__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </div>
            <div>
              <p class="hub-action-card__title">Browse Activities</p>
              <p class="hub-action-card__desc">See upcoming photowalks, workshops, and events.</p>
            </div>
          </a>

          <a href="/showcase/" class="hub-action-card" aria-label="Explore the showcase">
            <div class="hub-action-card__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
            </div>
            <div>
              <p class="hub-action-card__title">Explore Showcase</p>
              <p class="hub-action-card__desc">Discover member photography from across the club.</p>
            </div>
          </a>

        </div>
      </div>

      <!-- ============================================================
           Row 3: Coming soon in Phase 2+
           ============================================================ -->
      <div class="hub-section">
        <h2 class="hub-section-title">Coming Soon</h2>
        <div class="hub-coming-grid">
          <div class="hub-coming-card">
            <p class="hub-coming-card__label">Phase 2a</p>
            <p class="hub-coming-card__title">Your Portfolio</p>
            <p class="hub-coming-card__desc">Upload and curate your photography portfolio.</p>
          </div>
          <div class="hub-coming-card">
            <p class="hub-coming-card__label">Phase 2b</p>
            <p class="hub-coming-card__title">Contest Entries</p>
            <p class="hub-coming-card__desc">Submit to BCC contests and track your results.</p>
          </div>
          <div class="hub-coming-card">
            <p class="hub-coming-card__label">Phase 3</p>
            <p class="hub-coming-card__title">Community</p>
            <p class="hub-coming-card__desc">Member directory, messaging, and engagement.</p>
          </div>
        </div>
      </div>

    </div><!-- /container -->
  </div><!-- /hub-page-inner -->

</HubLayout>

<style>
/* ---- Hub page chrome ---- */
.hub-page-inner { padding-bottom: var(--s-12); }

.hub-header {
  background: var(--surface-deep);
  padding: var(--s-8) 0 var(--s-6);
  margin-bottom: var(--s-6);
}

.hub-header-inner {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--s-3);
}

.hub-kicker {
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold-500);
  margin: 0 0 var(--s-1);
}

.hub-welcome {
  font-size: clamp(28px, 4vw, 40px);
  font-weight: 700;
  color: var(--ink-inverse);
  letter-spacing: -0.02em;
  margin: 0 0 4px;
}

.hub-welcome-sub {
  font-size: 13px;
  color: rgba(250,248,244,.5);
  margin: 0;
  font-family: var(--font-body);
}

.hub-signout {
  flex-shrink: 0;
  color: rgba(250,248,244,.7);
  border-color: rgba(250,248,244,.25);
  font-size: 11px;
}
.hub-signout:hover {
  color: var(--ink-inverse);
  border-color: rgba(250,248,244,.5);
  background: rgba(250,248,244,.08);
}

.hub-body-container { display: flex; flex-direction: column; gap: var(--s-6); }

/* ---- 2-column grid ---- */
.hub-grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--s-3);
}
@media (max-width: 700px) { .hub-grid-2 { grid-template-columns: 1fr; } }

/* ---- Hub card ---- */
.hub-card {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-radius: var(--r-1);
  box-shadow: var(--e-1);
  overflow: hidden;
}

.hub-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--s-2);
  padding: var(--s-2) var(--s-3);
  border-bottom: 1px solid var(--hairline-soft);
  background: var(--surface-2);
}

.hub-card__label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-400);
  font-family: var(--font-body);
}

.hub-card__badge {
  display: inline-block;
  padding: 2px 10px;
  border-radius: var(--r-full);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  font-family: var(--font-body);
  border: 1px solid var(--hairline);
  background: var(--surface-0);
  color: var(--ink-600);
}

.hub-card__badge--active  { background: #F0FDF4; border-color: #86EFAC; color: #15803D; }
.hub-card__badge--pending { background: #FFFBEB; border-color: #FDE68A; color: #92400E; }
.hub-card__badge--expired { background: #FEF2F2; border-color: #FCA5A5; color: #B91C1C; }
.hub-card__badge--none    { background: var(--surface-2); border-color: var(--hairline); color: var(--ink-400); }

.hub-card__body { padding: var(--s-3); }

.hub-stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 7px 0;
  border-bottom: 1px solid var(--hairline-soft);
  gap: var(--s-2);
}
.hub-stat-row:last-child { border-bottom: none; }

.hub-stat-label {
  font-size: 12px;
  color: var(--ink-400);
  font-family: var(--font-body);
  flex-shrink: 0;
}

.hub-stat-value {
  font-size: 12px;
  font-weight: 500;
  color: var(--ink-900);
  font-family: var(--font-body);
  text-align: right;
}

.hub-card__action {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  padding: var(--s-2) var(--s-3);
  background: #FFFBEB;
  border-top: 1px solid #FDE68A;
  font-size: 12px;
  color: #92400E;
  font-family: var(--font-body);
  line-height: 1.5;
}
.hub-card__action svg { flex-shrink: 0; margin-top: 1px; }

.auth-link {
  color: var(--gold-600);
  font-weight: 500;
  text-decoration: underline;
  text-underline-offset: 2px;
  white-space: nowrap;
}

/* Loading inline */
.hub-loading-inline {
  display: flex;
  gap: 5px;
  align-items: center;
  justify-content: center;
  padding: var(--s-4) 0;
}
.hub-loading__dot {
  width: 6px; height: 6px;
  background: var(--hairline-strong);
  border-radius: var(--r-full);
  animation: hub-pulse 1.2s ease-in-out infinite both;
}
.hub-loading__dot:nth-child(2) { animation-delay: 0.2s; }
.hub-loading__dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes hub-pulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40%           { transform: scale(1);   opacity: 1;   }
}

/* ---- Sections ---- */
.hub-section { display: flex; flex-direction: column; gap: var(--s-3); }

.hub-section-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--ink-900);
  letter-spacing: -0.01em;
  margin: 0;
}

/* ---- Action cards ---- */
.hub-actions-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--s-2);
}
@media (max-width: 600px) { .hub-actions-grid { grid-template-columns: 1fr; } }

.hub-action-card {
  display: flex;
  align-items: flex-start;
  gap: var(--s-2);
  padding: var(--s-3);
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-radius: var(--r-1);
  box-shadow: var(--e-1);
  text-decoration: none;
  color: inherit;
  transition: border-color var(--m-fast), box-shadow var(--m-fast), transform var(--m-fast);
  position: relative;
}
.hub-action-card:hover {
  border-color: var(--gold-500);
  box-shadow: var(--e-2);
  transform: translateY(-1px);
}
.hub-action-card--muted { cursor: default; }
.hub-action-card--muted:hover {
  border-color: var(--hairline);
  box-shadow: var(--e-1);
  transform: none;
}

.hub-action-card__icon {
  flex-shrink: 0;
  width: 40px; height: 40px;
  background: var(--surface-2);
  border-radius: var(--r-1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--gold-600);
}
.hub-action-card--muted .hub-action-card__icon { color: var(--ink-400); }

.hub-action-card__title {
  font-size: 14px;
  font-weight: 600;
  color: var(--ink-900);
  margin: 0 0 2px;
  font-family: var(--font-display);
}
.hub-action-card--muted .hub-action-card__title { color: var(--ink-400); }

.hub-action-card__desc {
  font-size: 12px;
  color: var(--ink-400);
  margin: 0;
  font-family: var(--font-body);
  line-height: 1.5;
}

.hub-action-card__pill {
  position: absolute;
  top: var(--s-2);
  right: var(--s-2);
  padding: 2px 8px;
  background: var(--surface-2);
  border: 1px solid var(--hairline);
  border-radius: var(--r-full);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--ink-400);
  font-family: var(--font-body);
}

/* ---- Coming soon ---- */
.hub-coming-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--s-2);
}
@media (max-width: 700px) { .hub-coming-grid { grid-template-columns: 1fr; } }

.hub-coming-card {
  padding: var(--s-3);
  background: var(--surface-0);
  border: 1px dashed var(--hairline);
  border-radius: var(--r-1);
}

.hub-coming-card__label {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--gold-600);
  margin: 0 0 4px;
  font-family: var(--font-body);
}

.hub-coming-card__title {
  font-size: 14px;
  font-weight: 600;
  color: var(--ink-400);
  margin: 0 0 4px;
  font-family: var(--font-display);
}

.hub-coming-card__desc {
  font-size: 12px;
  color: var(--ink-400);
  margin: 0;
  font-family: var(--font-body);
  line-height: 1.5;
  opacity: 0.7;
}
</style>

<script>
  import { logout } from '../../lib/auth';

  const API = '/api/v1';

  function token(): string | null { return localStorage.getItem('bcc_token'); }

  async function apiFetch(path: string, opts?: RequestInit): Promise<Response> {
    return fetch(path, {
      ...opts,
      headers: {
        'Content-Type': 'application/json',
        Authorization: `Bearer ${token() ?? ''}`,
        ...((opts?.headers) || {}),
      },
    });
  }

  /* -- Populate welcome name ------------------------------------------ */
  const raw = localStorage.getItem('bcc_user');
  if (raw) {
    try {
      const user = JSON.parse(raw) as { displayName?: string };
      const el = document.getElementById('hub-welcome-name');
      if (el && user.displayName) {
        const first = user.displayName.trim().split(/\s+/)[0];
        el.textContent = `Welcome, ${first}`;
      }
    } catch { /* ignore */ }
  }

  /* -- Sign out --------------------------------------------------------- */
  document.getElementById('hub-signout-btn')?.addEventListener('click', logout);

  /* -- Identity card ---------------------------------------------------- */
  async function loadIdentity(): Promise<void> {
    const res = await apiFetch(`${API}/users/me`);
    if (!res.ok) return;
    const user = await res.json() as {
      email?: string;
      emailVerified?: boolean;
      createdAt?: string;
    };

    const emailEl   = document.getElementById('identity-email');
    const verifiedEl = document.getElementById('identity-email-verified');
    const sinceEl   = document.getElementById('identity-since');
    const prompt    = document.getElementById('verify-prompt');

    if (emailEl)    emailEl.textContent    = user.email ?? '--';
    if (verifiedEl) {
      verifiedEl.textContent = user.emailVerified ? 'Yes' : 'No';
      verifiedEl.style.color = user.emailVerified ? '#15803D' : '#B91C1C';
    }
    if (sinceEl && user.createdAt) {
      sinceEl.textContent = new Date(user.createdAt).toLocaleDateString('en-IN', {
        day: 'numeric', month: 'long', year: 'numeric',
      });
    }
    if (prompt && !user.emailVerified) prompt.hidden = false;
  }

  /* -- Membership card -------------------------------------------------- */
  async function loadMembership(): Promise<void> {
    const badge = document.getElementById('membership-badge');
    const body  = document.getElementById('membership-body');
    if (!badge || !body) return;

    const res = await apiFetch(`${API}/membership/mine`);

    if (!res.ok) {
      body.innerHTML = `
        <div class="hub-stat-row" style="flex-direction:column;align-items:flex-start;gap:4px">
          <p style="font-size:13px;color:var(--ink-600);margin:0;font-family:var(--font-body)">
            You don't have a membership yet.
          </p>
          <a href="/hub/membership/apply/" class="btn btn-gold btn-sm" style="margin-top:8px">
            Apply for Membership
          </a>
        </div>`;
      badge.textContent = 'None';
      badge.className   = 'hub-card__badge hub-card__badge--none';
      return;
    }

    const memberships = await res.json() as Array<{
      lifecycle_state?: string;
      membership_number?: string | null;
      class_id?: number;
      expires_at?: string | null;
    }>;

    const active = memberships.find(m => m.lifecycle_state === 'ACTIVE')
      || memberships.find(m => m.lifecycle_state === 'PENDING')
      || memberships.find(m => m.lifecycle_state === 'APPROVED')
      || memberships[0];

    if (!active) {
      body.innerHTML = `
        <div style="padding:var(--s-1) 0">
          <p style="font-size:13px;color:var(--ink-600);margin:0 0 var(--s-2);font-family:var(--font-body)">No membership found.</p>
          <a href="/hub/membership/apply/" class="btn btn-gold btn-sm">Apply for Membership</a>
        </div>`;
      badge.textContent = 'None';
      badge.className   = 'hub-card__badge hub-card__badge--none';
      return;
    }

    // Map state to badge class
    const stateMap: Record<string, string> = {
      ACTIVE: 'hub-card__badge--active',
      APPROVED: 'hub-card__badge--pending',
      PENDING: 'hub-card__badge--pending',
      EXPIRED: 'hub-card__badge--expired',
      SUSPENDED: 'hub-card__badge--expired',
      TERMINATED: 'hub-card__badge--expired',
    };
    const state = active.lifecycle_state ?? 'UNKNOWN';
    badge.textContent = state.charAt(0) + state.slice(1).toLowerCase();
    badge.className   = `hub-card__badge ${stateMap[state] ?? ''}`;

    const numText = active.membership_number
      ? `<span style="font-family:var(--font-mono);font-size:11px">${active.membership_number}</span>`
      : '<span style="color:var(--ink-400);font-size:11px">Pending assignment</span>';

    const expiryText = active.expires_at
      ? new Date(active.expires_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })
      : 'Lifetime';

    body.innerHTML = `
      <div class="hub-stat-row">
        <span class="hub-stat-label">Number</span>
        <span class="hub-stat-value">${numText}</span>
      </div>
      <div class="hub-stat-row">
        <span class="hub-stat-label">Status</span>
        <span class="hub-stat-value">${state.charAt(0) + state.slice(1).toLowerCase()}</span>
      </div>
      <div class="hub-stat-row">
        <span class="hub-stat-label">Valid until</span>
        <span class="hub-stat-value">${expiryText}</span>
      </div>
      ${state === 'ACTIVE' ? `
      <div style="margin-top:var(--s-2);padding-top:var(--s-2);border-top:1px solid var(--hairline-soft)">
        <a href="/hub/membership/card/" class="btn btn-outline btn-sm" style="font-size:10px">Download Card</a>
      </div>` : ''}
      ${state === 'PENDING' || state === 'APPROVED' ? `
      <div style="margin-top:var(--s-2);padding-top:var(--s-2);border-top:1px solid var(--hairline-soft);font-size:12px;color:var(--ink-400);font-family:var(--font-body)">
        Your application is under review. We will notify you when it is processed.
      </div>` : ''}
    `;

    // Hide apply action if already has membership
    if (state === 'ACTIVE' || state === 'PENDING' || state === 'APPROVED') {
      const applyCard = document.getElementById('action-apply');
      if (applyCard) applyCard.style.display = 'none';
    }
  }

  /* -- Bootstrap -------------------------------------------------------- */
  Promise.all([loadIdentity(), loadMembership()]).catch(() => {});
</script>
