---
/**
 * hub/membership/apply.astro — V6 19 Membership Application Form (Variant A)
 * Route: /hub/membership/apply/
 *
 * Shell: SiteHeader + centered content + SiteFooter. No HubSidebar, no HubLayout.
 * The application flow is a transitional page for registered users who have not
 * yet applied for membership. It is accessible to all authenticated users.
 *
 * MEM-006: Only Basic Membership shown. No constitutional class names.
 * MEM-006 P1: Apply for Membership is a distinct CTA from Register or Sign In.
 * MEM-007: No membership number at any point. PENDING state only on submission.
 *
 * RBAC: USER role minimum (any authenticated user).
 *   - No active/pending membership → render 3-step application form.
 *   - PENDING membership → render AlreadyPendingScreen.
 *   - ACTIVE or APPROVED membership → redirect to /hub/.
 *   - Unauthenticated → redirect to /auth/signin/.
 *
 * Auth guard: client-side (AccessTokenGuard on API endpoint handles real auth).
 * All redirect logic lives in MembershipApplicationFlow.astro component.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import MembershipApplicationFlow from '../../../components/hub/MembershipApplicationFlow.astro';
---

<BaseLayout
  title="Apply for Membership"
  description="Apply for BCC Basic Membership — three simple steps."
  bodyClass="apply-flow-page"
>
  <section class="apply-flow">
    <div class="apply-flow__container">

      <!-- Breadcrumb -->
      <nav class="apply-flow__breadcrumb" aria-label="Breadcrumb">
        <span class="apply-flow__bc-item apply-flow__bc-mono">Member Hub</span>
        <span class="apply-flow__bc-sep">›</span>
        <span class="apply-flow__bc-item apply-flow__bc-active apply-flow__bc-mono">Membership Application</span>
      </nav>

      <!-- Page heading -->
      <div class="apply-flow__heading">
        <h1 class="apply-flow__title">Membership Application</h1>
        <div class="apply-flow__meta">
          <span class="apply-flow__meta-route apply-flow__bc-mono">/hub/membership/apply</span>
          <span class="apply-flow__meta-badge apply-flow__bc-mono">RBAC: USER</span>
        </div>
      </div>

      <!-- 3-step form (Variant A) -->
      <MembershipApplicationFlow variant="apply" />

    </div>
  </section>
</BaseLayout>

<style>
.apply-flow-page {}

.apply-flow {
  min-height: calc(100vh - 200px);
  padding: var(--s-8) 0 var(--s-12);
}

.apply-flow__container {
  max-width: 760px;
  margin: 0 auto;
  padding: 0 var(--s-5);
}

.apply-flow__breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: var(--s-3);
}
.apply-flow__bc-item { font-size: 12px; color: var(--ink-400); }
.apply-flow__bc-active { color: var(--gold-600); }
.apply-flow__bc-mono { font-family: var(--font-mono); }
.apply-flow__bc-sep { font-family: var(--font-mono); font-size: 12px; color: var(--ink-400); }

.apply-flow__heading { margin-bottom: var(--s-5); }
.apply-flow__title {
  font-family: var(--font-display);
  font-size: 26px;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--ink-900);
  margin: 0 0 var(--s-1);
}
.apply-flow__meta { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.apply-flow__meta-route { font-size: 11px; color: var(--ink-400); }
.apply-flow__meta-badge {
  font-size: 10px;
  background: var(--surface-2);
  border: 1px solid var(--hairline);
  padding: 3px 10px;
  color: var(--ink-600);
}

@media (max-width: 640px) {
  .apply-flow { padding: var(--s-5) 0 var(--s-8); }
  .apply-flow__container { padding: 0 var(--s-3); }
  .apply-flow__title { font-size: 22px; }
}
</style>
