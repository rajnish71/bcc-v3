---
/**
 * hub/membership/index.astro -- Membership landing & redirect gateway
 * Route: /hub/membership/
 *
 * Checks current membership state and redirects appropriately:
 *   - Active, Approved, or Pending members -> /hub/ (details on dashboard)
 *   - Guests/Draft/Expired/Lapsed/Rejected -> /hub/membership/apply/
 */
import HubLayout from '../../../layouts/HubLayout.astro';
---

<HubLayout title="Membership & Billing" description="Checking your membership status...">
  <div class="mem-gateway">
    <div class="mem-gateway__card">
      <div class="vef-dots" aria-label="Checking status" role="status">
        <span class="vef-dot"></span>
        <span class="vef-dot"></span>
        <span class="vef-dot"></span>
      </div>
      <div class="mem-gateway__text">Checking your membership status...</div>
    </div>
  </div>
</HubLayout>

<script>
  const API = '/api/v1';

  function token(): string | null {
    return localStorage.getItem('bcc_token');
  }

  async function resolveMembershipRoute() {
    const t = token();
    if (!t) {
      window.location.replace('/auth/signin/?next=/hub/membership/');
      return;
    }

    try {
      const res = await fetch(`${API}/membership/mine`, {
        headers: { Authorization: `Bearer ${t}` }
      });

      if (res.status === 401) {
        window.location.replace('/auth/signin/?next=/hub/membership/');
        return;
      }

      if (res.ok) {
        const memberships = await res.json() as any[];
        const activeOrPending = memberships.find(
          m => m.lifecycle_state === 'ACTIVE' || m.lifecycle_state === 'APPROVED' || m.lifecycle_state === 'PENDING'
        );

        if (activeOrPending) {
          // Already have active membership -- details are on the hub main view
          window.location.replace('/hub/');
        } else {
          // No active application/membership -- send to apply page
          window.location.replace('/hub/membership/apply/');
        }
      } else {
        // Fallback on unexpected server error
        window.location.replace('/hub/');
      }
    } catch {
      // Offline or network error
      window.location.replace('/hub/');
    }
  }

  resolveMembershipRoute();
</script>

<style>
  .mem-gateway {
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mem-gateway__card {
    text-align: center;
    background: var(--surface-0);
    padding: var(--s-6);
    border: 1px solid var(--hairline);
    border-radius: var(--r-1);
    box-shadow: var(--e-1);
  }
  .mem-gateway__text {
    font-family: var(--font-body);
    font-size: var(--text-small);
    color: var(--ink-600);
    margin-top: var(--s-3);
  }
  .vef-dots {
    display: inline-flex;
    gap: 8px;
  }
  .vef-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--gold-500);
    animation: vefPulse 1.2s infinite ease-in-out both;
  }
  .vef-dot:nth-child(2) { animation-delay: 0.2s; }
  .vef-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes vefPulse {
    0%, 80%, 100% { transform: scale(0); opacity: 0.3; }
    40% { transform: scale(1); opacity: 1; }
  }
</style>
