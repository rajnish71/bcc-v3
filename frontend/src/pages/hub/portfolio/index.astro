</style>

<script>
const API = '/api/v1';

function tok() { return localStorage.getItem('bcc_token') ?? ''; }
async function apiFetch(path: string, opts: RequestInit = {}) {
  return fetch(path, { ...opts, headers: { Authorization: `Bearer ${tok()}`, ...(opts.headers ?? {}) } });
}

/* ── Types ──────────────────────────────────────────────────────────────── */
interface Exif {
  camera_make?: string | null; camera_model?: string | null;
  lens_model?: string | null; focal_length?: string | null;
  aperture?: string | null; shutter_speed?: string | null;
  iso?: number | null; taken_at?: string | null;
}
interface Photo {
  uuid: string;
  title?: string | null;
  caption?: string | null;
  description?: string | null;
  exhibition_label?: string | null;
  genre?: string | null;
  visibility?: string;
  status?: string;
  created_at?: string;
  width_px?: number | null;
  height_px?: number | null;
  exif?: Exif;
  urls?: { thumbnail?: string; medium?: string; large?: string };
}

/* ── State ──────────────────────────────────────────────────────────────── */
let allPhotos: Photo[] = [];
let filtered: Photo[] = [];
let selectedUuids = new Set<string>();
let currentView: 'grid' | 'list' = 'grid';
let activeGenre = '';
let inspectorUuid = '';
let inspectorIndex = 0;
let pendingDeleteUuids: string[] = [];

/* ── Helpers ──────────────────────────────────────────────────────────────── */
function visInfo(vis: string): { cls: string; text: string } {
  if (vis === 'PUBLIC')        return { cls: 'mat-vis-chip--public',   text: 'PUBLIC' };
  if (vis === 'MEMBERS_ONLY') return { cls: 'mat-vis-chip--members',  text: 'MEMBERS' };
  if (vis === 'PRIVATE')       return { cls: 'mat-vis-chip--private',  text: 'DRAFT' };
  if (vis === 'UNLISTED')      return { cls: 'mat-vis-chip--unlisted', text: 'ARCHIVED' };
  return { cls: 'mat-vis-chip--private', text: vis };
}

function fmtDate(iso?: string | null): string {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: '2-digit' });
}

function isPublished(p: Photo)  { return p.visibility === 'PUBLIC' || p.visibility === 'MEMBERS_ONLY'; }
function isDraft(p: Photo)      { return p.visibility === 'PRIVATE'; }
function isArchived(p: Photo)   { return p.visibility === 'UNLISTED'; }

/* ── Load all own photos ─────────────────────────────────────────────────── */
async function loadPhotos() {
  const loadEl = document.getElementById('port-loading');
  const gridEl = document.getElementById('port-grid');
  const toolbarEl = document.getElementById('port-toolbar');

  if (loadEl) loadEl.style.display = 'flex';
  if (gridEl) gridEl.innerHTML = '';

  const res = await apiFetch(`${API}/gallery/photos?limit=200`);
  if (loadEl) loadEl.style.display = 'none';

  if (!res.ok) return;
  const data = await res.json() as { photos?: Photo[] };
  allPhotos = data.photos ?? [];

  // Update page header count
  updateHeaderCount();

  // Build genre chips from own photos
  buildGenreChips();

  // Show toolbar if any photos
  if (toolbarEl) toolbarEl.hidden = allPhotos.length === 0;

  applyFilters();
}

/* ── Genre chips ─────────────────────────────────────────────────────────── */
function buildGenreChips() {
  const container = document.getElementById('genre-chips');
  if (!container) return;

  const genres = [...new Set(allPhotos.map(p => p.genre).filter(Boolean) as string[])].sort();
  if (genres.length === 0) { container.hidden = true; return; }

  container.innerHTML = genres.map(g => `
    <button class="genre-chip${activeGenre === g ? ' genre-chip--active' : ''}"
            type="button" data-genre="${g}">${g}</button>
  `).join('');

  container.querySelectorAll<HTMLButtonElement>('.genre-chip').forEach(btn => {
    btn.addEventListener('click', () => {
      activeGenre = activeGenre === btn.dataset.genre ? '' : (btn.dataset.genre ?? '');
      container.querySelectorAll('.genre-chip').forEach(c => {
        c.classList.toggle('genre-chip--active', (c as HTMLElement).dataset.genre === activeGenre);
      });
      applyFilters();
    });
  });
}

/* ── Filtering & sorting ─────────────────────────────────────────────────── */
function applyFilters() {
  const search = ((document.getElementById('search-input') as HTMLInputElement)?.value ?? '').trim().toLowerCase();
  const status = (document.getElementById('status-filter') as HTMLSelectElement)?.value ?? '';
  const sort   = (document.getElementById('sort-select') as HTMLSelectElement)?.value ?? 'newest';

  filtered = allPhotos.filter(p => {
    if (activeGenre && p.genre !== activeGenre) return false;
    if (status === 'published' && !isPublished(p)) return false;
    if (status === 'drafts'    && !isDraft(p))     return false;
    if (status === 'archived'  && !isArchived(p))  return false;
    if (search) {
      const haystack = [p.title, p.caption, p.genre].filter(Boolean).join(' ').toLowerCase();
      if (!haystack.includes(search)) return false;
    }
    return true;
  });

  if (sort === 'oldest') {
    filtered = [...filtered].sort((a, b) => (a.created_at ?? '').localeCompare(b.created_at ?? ''));
  } else if (sort === 'title') {
    filtered = [...filtered].sort((a, b) => (a.title ?? '').localeCompare(b.title ?? ''));
  }
  // 'newest' = default API order (desc)

  renderWall();
}

/* ── Render wall ─────────────────────────────────────────────────────────── */
function renderWall() {
  const grid    = document.getElementById('port-grid')!;
  const emptyEl = document.getElementById('port-empty')!;
  const noResEl = document.getElementById('port-no-results')!;

  if (allPhotos.length === 0) {
    grid.innerHTML = '';
    emptyEl.hidden = false;
    noResEl.hidden = true;
    return;
  }
  emptyEl.hidden = true;

  if (filtered.length === 0) {
    grid.innerHTML = '';
    noResEl.hidden = false;
    return;
  }
  noResEl.hidden = true;

  const PH_SVG = `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
    <rect x="2" y="2" width="24" height="24" stroke="#3E3A36" stroke-width="1"/>
    <line x1="2" y1="26" x2="26" y2="2" stroke="#3E3A36" stroke-width="0.5"/>
    <circle cx="9" cy="9" r="2.5" stroke="#3E3A36" stroke-width="0.75"/>
  </svg>`;

  grid.innerHTML = filtered.map((p, idx) => {
    const thumb = p.urls?.thumbnail ?? p.urls?.medium ?? '';
    const vl = visInfo(p.visibility ?? 'PRIVATE');
    const isSelected = selectedUuids.has(p.uuid);
    const dt = fmtDate(p.created_at);

    let imgHtml: string;
    if (thumb) {
      imgHtml = `<img src="${thumb}" alt="${escHtml(p.title ?? '')}" loading="lazy" />`;
    } else {
      imgHtml = `<div class="mat-thumb-ph">${PH_SVG}</div>`;
    }

    return `<div class="mat-card${isSelected ? ' mat-card--selected' : ''}"
                 data-uuid="${p.uuid}" data-idx="${idx}"
                 tabindex="0" role="button"
                 aria-label="${escHtml(p.title ?? 'Untitled photograph')}"
                 aria-pressed="${isSelected}">
      <div class="mat-thumb">
        ${imgHtml}
        <div class="mat-select-ring" aria-hidden="true"></div>
        <div class="mat-hover-controls" aria-hidden="true">
          <button class="mat-ctrl-btn mat-ctrl-btn--edit" data-action="edit" data-uuid="${p.uuid}" title="Edit" tabindex="-1">&#9998;</button>
          <button class="mat-ctrl-btn mat-ctrl-btn--check${isSelected ? ' mat-ctrl-btn--selected' : ''}" data-action="select" data-uuid="${p.uuid}" title="${isSelected ? 'Deselect' : 'Select'}" tabindex="-1">${isSelected ? '&#10003;' : '&#9633;'}</button>
        </div>
      </div>
      <div class="mat-label">
        <div class="mat-title">${escHtml(p.title ?? 'Untitled')}</div>
        <div class="mat-label-row">
          <span class="mat-vis-chip ${vl.cls}">${vl.text}</span>
          <span class="mat-date">${dt}</span>
        </div>
      </div>
    </div>`;
  }).join('');

  // Attach click handlers
  grid.querySelectorAll<HTMLElement>('.mat-card').forEach(card => {
    card.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('[data-action]') as HTMLElement | null;
      if (btn?.dataset.action === 'edit') {
        const uuid = btn.dataset.uuid!;
        openInspector(uuid);
        return;
      }
      if (btn?.dataset.action === 'select') {
        toggleSelect(card.dataset.uuid!);
        return;
      }
      // Click on card body: open inspector if no active selection, else toggle
      if (selectedUuids.size > 0) {
        toggleSelect(card.dataset.uuid!);
      } else {
        openInspector(card.dataset.uuid!);
      }
    });
    card.addEventListener('keydown', e => {
      if (e.key === 'Enter') openInspector(card.dataset.uuid!);
      if (e.key === ' ') { e.preventDefault(); toggleSelect(card.dataset.uuid!); }
    });
  });
}

function escHtml(s: string): string {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

/* ── Header count ────────────────────────────────────────────────────────── */
function updateHeaderCount() {
  const countEl = document.getElementById('photo-count-label');
  const selEl   = document.getElementById('selected-count-label');
  const selSep  = document.getElementById('sel-sep');

  if (countEl) countEl.innerHTML = `<span style="font-family:var(--font-mono)">${allPhotos.length}</span> photograph${allPhotos.length !== 1 ? 's' : ''}`;

  const selCount = selectedUuids.size;
  if (selEl)  selEl.innerHTML = `<span style="font-family:var(--font-mono);color:#A8843C">${selCount}</span> selected`;
  if (selEl)  selEl.hidden  = selCount === 0;
  if (selSep) selSep.hidden = selCount === 0;
}

/* ── Selection ───────────────────────────────────────────────────────────── */
function toggleSelect(uuid: string) {
  if (selectedUuids.has(uuid)) {
    selectedUuids.delete(uuid);
  } else {
    selectedUuids.add(uuid);
  }
  updateSelectionBar();
  // Update specific card without full re-render
  const card = document.querySelector<HTMLElement>(`.mat-card[data-uuid="${uuid}"]`);
  if (card) {
    const selected = selectedUuids.has(uuid);
    card.classList.toggle('mat-card--selected', selected);
    card.setAttribute('aria-pressed', String(selected));
    const checkBtn = card.querySelector<HTMLElement>('.mat-ctrl-btn--check');
    if (checkBtn) {
      checkBtn.classList.toggle('mat-ctrl-btn--selected', selected);
      checkBtn.innerHTML = selected ? '&#10003;' : '&#9633;';
      checkBtn.title = selected ? 'Deselect' : 'Select';
    }
  }
  updateHeaderCount();
}

function clearSelection() {
  selectedUuids.clear();
  updateSelectionBar();
  document.querySelectorAll('.mat-card--selected').forEach(c => {
    c.classList.remove('mat-card--selected');
    c.setAttribute('aria-pressed', 'false');
    const checkBtn = c.querySelector<HTMLElement>('.mat-ctrl-btn--check');
    if (checkBtn) { checkBtn.classList.remove('mat-ctrl-btn--selected'); checkBtn.innerHTML = '&#9633;'; }
  });
  updateHeaderCount();
}

function updateSelectionBar() {
  const bar = document.getElementById('selection-bar')!;
  const badge = document.getElementById('sel-count-badge')!;
  const count = selectedUuids.size;
  bar.hidden = count === 0;
  badge.textContent = String(count);
}

/* ── Inspector ───────────────────────────────────────────────────────────── */
function openInspector(uuid: string) {
  const idx = filtered.findIndex(p => p.uuid === uuid);
  if (idx < 0) return;
  inspectorIndex = idx;
  inspectorUuid = uuid;
  populateInspector(filtered[idx]);

  document.getElementById('insp-scrim')!.hidden = false;
  document.getElementById('insp-panel')!.hidden = false;
  document.body.style.overflow = 'hidden';
}

function closeInspector() {
  document.getElementById('insp-scrim')!.hidden = true;
  document.getElementById('insp-panel')!.hidden = true;
  document.body.style.overflow = '';
  inspectorUuid = '';
}

function populateInspector(p: Photo) {
  const img = document.getElementById('insp-img') as HTMLImageElement;
  img.src = p.urls?.medium ?? p.urls?.large ?? p.urls?.thumbnail ?? '';
  img.alt = p.title ?? '';

  (document.getElementById('insp-title') as HTMLInputElement).value = p.title ?? p.caption ?? '';
  (document.getElementById('insp-description') as HTMLTextAreaElement).value = p.description ?? '';
  (document.getElementById('insp-exh-label') as HTMLInputElement).value = p.exhibition_label ?? '';
  (document.getElementById('insp-visibility') as HTMLSelectElement).value = p.visibility ?? 'PUBLIC';

  const exifEl = document.getElementById('insp-exif')!;
  const exif = p.exif;
  if (exif) {
    const chips: string[] = [];
    const cam = [exif.camera_make, exif.camera_model].filter(Boolean).join(' ');
    if (cam) chips.push(cam);
    if (exif.lens_model)    chips.push(exif.lens_model);
    if (exif.focal_length)  chips.push(`${exif.focal_length}mm`);
    if (exif.aperture)      chips.push(exif.aperture);
    if (exif.shutter_speed) chips.push(exif.shutter_speed);
    if (exif.iso)           chips.push(`ISO ${exif.iso}`);
    if (chips.length > 0) {
      exifEl.innerHTML = chips.map(c => `<span class="exif-chip">${escHtml(c)}</span>`).join('');
      exifEl.hidden = false;
    } else {
      exifEl.hidden = true;
    }
  } else {
    exifEl.hidden = true;
  }

  const errEl = document.getElementById('insp-error')!;
  errEl.hidden = true;

  // Nav label + button states
  const navLabel = document.getElementById('insp-nav-label')!;
  navLabel.textContent = `${inspectorIndex + 1} of ${filtered.length}`;
  (document.getElementById('insp-prev-btn') as HTMLButtonElement).disabled = inspectorIndex === 0;
  (document.getElementById('insp-next-btn') as HTMLButtonElement).disabled = inspectorIndex === filtered.length - 1;
}

document.getElementById('insp-prev-btn')?.addEventListener('click', () => {
  if (inspectorIndex > 0) {
    inspectorIndex--;
    inspectorUuid = filtered[inspectorIndex].uuid;
    populateInspector(filtered[inspectorIndex]);
  }
});

document.getElementById('insp-next-btn')?.addEventListener('click', () => {
  if (inspectorIndex < filtered.length - 1) {
    inspectorIndex++;
    inspectorUuid = filtered[inspectorIndex].uuid;
    populateInspector(filtered[inspectorIndex]);
  }
});

document.getElementById('insp-close-btn')?.addEventListener('click', closeInspector);
document.getElementById('insp-scrim')?.addEventListener('click', closeInspector);

/* ── Save from inspector ─────────────────────────────────────────────────── */
document.getElementById('insp-save-btn')?.addEventListener('click', async () => {
  if (!inspectorUuid) return;
  const saveBtn = document.getElementById('insp-save-btn') as HTMLButtonElement;
  saveBtn.disabled = true; saveBtn.textContent = 'Saving…';

  const title            = (document.getElementById('insp-title') as HTMLInputElement).value.trim();
  const description      = (document.getElementById('insp-description') as HTMLTextAreaElement).value.trim() || null;
  const exhibition_label = (document.getElementById('insp-exh-label') as HTMLInputElement).value.trim() || null;
  const visibility       = (document.getElementById('insp-visibility') as HTMLSelectElement).value;

  const res = await apiFetch(`${API}/gallery/photos/${inspectorUuid}`, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ title, description, exhibition_label, visibility }),
  });

  saveBtn.disabled = false; saveBtn.textContent = 'Save changes';

  if (res.ok) {
    // Update local cache
    const updated = await res.json() as Photo;
    const idx = allPhotos.findIndex(p => p.uuid === inspectorUuid);
    if (idx >= 0) allPhotos[idx] = { ...allPhotos[idx], ...updated, title, description, exhibition_label, visibility };
    closeInspector();
    applyFilters();
  } else {
    const err = await res.json().catch(() => ({})) as { message?: string };
    const errEl = document.getElementById('insp-error')!;
    errEl.textContent = err.message ?? `Save failed (${res.status})`;
    errEl.hidden = false;
  }
});

/* ── Delete from inspector ───────────────────────────────────────────────── */
document.getElementById('insp-delete-btn')?.addEventListener('click', () => {
  if (!inspectorUuid) return;
  pendingDeleteUuids = [inspectorUuid];
  openDeleteConfirm(1);
});

/* ── Batch delete from selection bar ────────────────────────────────────── */
document.getElementById('sel-delete-btn')?.addEventListener('click', () => {
  if (selectedUuids.size === 0) return;
  pendingDeleteUuids = [...selectedUuids];
  openDeleteConfirm(pendingDeleteUuids.length);
});

function openDeleteConfirm(count: number) {
  const titleEl = document.getElementById('confirm-title')!;
  const textEl  = document.getElementById('confirm-text')!;
  if (count === 1) {
    titleEl.textContent = 'Delete photograph?';
    textEl.textContent = 'This will permanently remove the photograph from your portfolio. This action cannot be undone.';
  } else {
    titleEl.textContent = `Delete ${count} photographs?`;
    textEl.textContent = `This will permanently remove ${count} photographs from your portfolio. This action cannot be undone.`;
  }
  document.getElementById('confirm-backdrop')!.hidden = false;
}

document.getElementById('confirm-cancel-btn')?.addEventListener('click', () => {
  document.getElementById('confirm-backdrop')!.hidden = true;
  pendingDeleteUuids = [];
});
document.getElementById('confirm-no-btn')?.addEventListener('click', () => {
  document.getElementById('confirm-backdrop')!.hidden = true;
  pendingDeleteUuids = [];
});

document.getElementById('confirm-yes-btn')?.addEventListener('click', async () => {
  if (pendingDeleteUuids.length === 0) return;
  document.getElementById('confirm-backdrop')!.hidden = true;

  await Promise.all(pendingDeleteUuids.map(uuid =>
    apiFetch(`${API}/gallery/photos/${uuid}`, { method: 'DELETE' })
  ));

  allPhotos = allPhotos.filter(p => !pendingDeleteUuids.includes(p.uuid));
  pendingDeleteUuids = [];
  selectedUuids.clear();
  closeInspector();
  updateSelectionBar();
  updateHeaderCount();
  applyFilters();
});

/* ── Selection bar actions ───────────────────────────────────────────────── */
document.getElementById('sel-cancel-btn')?.addEventListener('click', clearSelection);

document.getElementById('sel-visibility-btn')?.addEventListener('click', async () => {
  if (selectedUuids.size === 0) return;
  const vis = prompt('Set visibility for selected photographs:\nPUBLIC / MEMBERS_ONLY / PRIVATE / UNLISTED');
  if (!vis) return;
  const v = vis.toUpperCase().trim();
  if (!['PUBLIC','MEMBERS_ONLY','PRIVATE','UNLISTED'].includes(v)) return;
  await Promise.all([...selectedUuids].map(uuid =>
    apiFetch(`${API}/gallery/photos/${uuid}`, {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ visibility: v }),
    })
  ));
  allPhotos = allPhotos.map(p => selectedUuids.has(p.uuid) ? { ...p, visibility: v } : p);
  clearSelection();
  applyFilters();
});

/* ── Toolbar controls ────────────────────────────────────────────────────── */
document.getElementById('search-input')?.addEventListener('input', () => applyFilters());
document.getElementById('status-filter')?.addEventListener('change', () => applyFilters());
document.getElementById('sort-select')?.addEventListener('change', () => applyFilters());

document.getElementById('view-grid-btn')?.addEventListener('click', () => {
  currentView = 'grid';
  document.getElementById('port-grid')!.dataset.view = 'grid';
  document.getElementById('view-grid-btn')!.classList.add('view-btn--active');
  document.getElementById('view-list-btn')!.classList.remove('view-btn--active');
});

document.getElementById('view-list-btn')?.addEventListener('click', () => {
  currentView = 'list';
  document.getElementById('port-grid')!.dataset.view = 'list';
  document.getElementById('view-list-btn')!.classList.add('view-btn--active');
  document.getElementById('view-grid-btn')!.classList.remove('view-btn--active');
});

document.getElementById('clear-filters-btn')?.addEventListener('click', () => {
  (document.getElementById('search-input') as HTMLInputElement).value = '';
  (document.getElementById('status-filter') as HTMLSelectElement).value = '';
  activeGenre = '';
  document.querySelectorAll('.genre-chip').forEach(c => c.classList.remove('genre-chip--active'));
  applyFilters();
});

/* ── "View public portfolio" link ─────────────────────────────────────────── */
async function loadProfileLink() {
  try {
    const res = await apiFetch(`${API}/users/me`);
    if (!res.ok) return;
    const me = await res.json() as { id?: number; username?: string };
    const link = document.getElementById('view-portfolio-link') as HTMLAnchorElement;
    if (link && me.id) {
      link.href = `/photographers/${me.id}/`;
    }
  } catch { /* non-critical */ }
}

/* ── Init ────────────────────────────────────────────────────────────────── */
loadPhotos().catch(() => {});
loadProfileLink().catch(() => {});
</script>
