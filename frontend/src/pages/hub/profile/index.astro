.ph-save-btn {
  font-size:14px; font-weight:600; color:#fff;
  background:linear-gradient(135deg, #C9A961, #A8843C);
  border:none; padding:11px 24px; cursor:pointer; font-family:var(--font-body);
  box-shadow:0 2px 8px rgba(168,132,60,0.3);
  transition:box-shadow 0.2s, transform 0.15s;
}
.ph-save-btn:hover { box-shadow:0 4px 14px rgba(168,132,60,0.4); transform:translateY(-1px); }
.ph-save-btn:disabled { opacity:0.6; cursor:not-allowed; transform:none; }

/* Tab strip */
.ph-tabs {
