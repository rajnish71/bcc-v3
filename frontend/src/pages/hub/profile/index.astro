}
@media (max-width: 640px) { .mobile-save-bar { display:block; } .ph-save-wrap { display:none; } }

/* ── SECTIONS ────────────────────────────────────────────────────────────── */
.profile-body { padding:40px 32px 120px; display:flex; flex-direction:column; gap:0; }

/* Tab-panel model (item 50): only the active section is shown, so each tab
   displays only its own content and there is no long-scroll between sections.
   Visual layout/fields/spacing remain per the V6 13 wireframe. */
.ps { display:none; padding-bottom:8px; }
.ps.ps--active { display:block; animation:ps-fade 0.18s ease; }
@keyframes ps-fade { from { opacity:0; transform:translateY(4px); } to { opacity:1; transform:none; } }
.ps-head { margin-bottom:24px; }
.ps-title {
  font-family:var(--font-display); font-size:18px; font-weight:700;
  color:#141210;
}
.ps-row { display:flex; gap:16px; margin-bottom:16px; flex-wrap:wrap; }
.ps-row:last-child { margin-bottom:0; }
.ps-field-group { display:flex; flex-direction:column; gap:6px; flex:1; min-width:180px; }
.ps-field-group--full { flex:1 1 100%; }

.ps-label {
  font-size:12px; font-weight:600; color:#57514B;
  letter-spacing:0.04em; font-family:var(--font-body); display:flex; gap:8px; align-items:center;
}
.ps-counter { font-weight:400; color:#8B8378; margin-left:auto; }
.ps-hint { font-size:11px; color:#8B8378; font-family:var(--font-body); line-height:1.5; }
.ps-optional { font-weight:400; color:#8B8378; }
.ps-locked { font-size:10px; font-weight:700; letter-spacing:0.1em; color:#8B8378; background:#F4F0E8; padding:2px 7px; }
.ps-link { color:#A8843C; }
.ps-readonly-notice {
  font-size:13px; color:#57514B; background:#FAF8F4;
  border:1px solid #E7E1D6; padding:10px 14px; margin-bottom:20px;
  font-family:var(--font-body);
}
.ps-divider {
  margin:24px 0 20px; display:flex; align-items:center; gap:14px;
  font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase;
  color:#A8843C; font-family:var(--font-body);
}
.ps-divider::before, .ps-divider::after {
  content:''; flex:1; height:1px; background:#E7E1D6;
}

/* ── FORM ELEMENTS ───────────────────────────────────────────────────────── */
.form-input, .form-textarea, .form-select {
  font-family:var(--font-body); font-size:14px; color:#141210;
  border:1px solid #D8D2C6; padding:10px 14px;
  background:#fff; width:100%; box-sizing:border-box;
  transition:border-color 0.15s, box-shadow 0.15s;
}
.form-input:focus, .form-textarea:focus, .form-select:focus {
  outline:none; border-color:#C9A961; box-shadow:0 0 0 3px rgba(201,169,97,0.12);
}
