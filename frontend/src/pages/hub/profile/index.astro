<style>
/* ── Utilities ─────────────────────────────────────────────────────────────── */
.sr-only { position:absolute; width:1px; height:1px; overflow:hidden; clip:rect(0,0,0,0); }

/* ── PROFILE HEADER ─────────────────────────────────────────────────────── */
.ph { background:#fff; border-bottom:1px solid #E7E1D6; position:sticky; top:96px; z-index:50; }

/* Cover — standardised 16:5 ratio (item 48). Whole image stays visible
   (object-fit:contain, letterboxed). Height is capped so the sticky editing
   header does not grow tall enough to force extra scrolling. */
.ph-cover {
  width:100%; aspect-ratio:16 / 5; max-height:200px;
  position:relative; overflow:hidden;
  background:#1A1614;
}
.ph-cover-stripe {
  width:100%; height:100%;
  background: repeating-linear-gradient(
    -45deg, #2A2320 0px, #2A2320 10px, #1A1614 10px, #1A1614 20px
  );
}
.ph-cover-img { width:100%; height:100%; object-fit:contain; position:absolute; inset:0; }
.ph-cover-actions {
  position:absolute; top:12px; right:16px;
}
.ph-cover-btn {
  font-size:12px; font-weight:600; color:#fff; background:rgba(0,0,0,0.45);
  border:1px solid rgba(255,255,255,0.3); padding:7px 14px; cursor:pointer;
  font-family:var(--font-body); backdrop-filter:blur(4px);
  transition:background 0.15s;
}
.ph-cover-btn:hover { background:rgba(0,0,0,0.65); }

/* Identity row */
.ph-identity {
  display:flex; align-items:flex-end; gap:16px;
  padding:0 32px 16px; flex-wrap:wrap;
}
.ph-avatar-wrap {
  position:relative; flex-shrink:0;
  margin-top:-52px;
}
.ph-avatar {
  width:104px; height:104px; border-radius:999px;
