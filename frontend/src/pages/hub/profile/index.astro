/* ── MOBILE SAVE BAR ─────────────────────────────────────────────────────── */
.mobile-save-bar {
  display:none; position:fixed; bottom:64px; left:0; right:0; z-index:100;
  padding:12px 16px; background:#fff; border-top:1px solid #E7E1D6;
