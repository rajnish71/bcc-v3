---
/**
 * /hub/profile — V6 13 Member Profile Editor
 * Design authority: ProjectDocs/Wireframes/V6/13 Hub Member Profile/
 * API: GET/PUT /api/v1/hub/profile  PUT /social  PUT /gear  PUT /distinctions
 *      POST /avatar/presign + /confirm   POST /cover/presign + /confirm
 *
 * OVERRIDES (take precedence over wireframe):
 *   1. Name fields (Title/First/Middle/Last) are READ-ONLY — edit via Account Settings.
 *   2. year_joined_bcc is TEMPORARILY USER-EDITABLE (V6 13 Amendment 002).
 *      Will revert to membership application date after full platform launch.
 *   3. Public URL prefix: v3bcc.bhopal.info/photographers/{username}
 */
import HubLayout from '../../../layouts/HubLayout.astro';
import TiptapBio from '../../../components/hub/TiptapBio.astro';
---

<HubLayout title="My Profile" description="Edit your Bhopal Camera Club member profile.">

<!-- ── PROFILE HEADER ──────────────────────────────────────────────────── -->
<div class="ph" id="ph">
  <!-- Cover banner -->
  <div class="ph-cover" id="ph-cover">
    <div class="ph-cover-stripe" id="ph-cover-stripe"></div>
    <img id="ph-cover-img" class="ph-cover-img" src="" alt="" hidden />
    <div class="ph-cover-actions">
      <label class="ph-cover-btn" for="cover-file-input" title="Change cover photo">↑ Change cover</label>
      <input type="file" id="cover-file-input" accept="image/jpeg,image/png,image/webp" class="sr-only" />
    </div>
  </div>

  <!-- Avatar + identity row -->
  <div class="ph-identity">
    <div class="ph-avatar-wrap" id="ph-avatar-wrap">
      <div class="ph-avatar" id="ph-avatar">
        <span class="ph-avatar-initials" id="ph-initials">—</span>
        <img id="ph-avatar-img" class="ph-avatar-img" src="" alt="" hidden />
      </div>
      <label class="ph-avatar-edit" for="avatar-file-input" title="Change profile photo">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M8.5 1.5L10.5 3.5M1 9l.5 1.5L3 10l7-7-2-2-7 7Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </label>
      <input type="file" id="avatar-file-input" accept="image/jpeg,image/png,image/webp" class="sr-only" />
    </div>
    <div class="ph-meta">
      <div class="ph-name" id="ph-name">—</div>
      <div class="ph-badges">
        <span class="ph-tier-badge" id="ph-tier">—</span>
        <span class="ph-number" id="ph-number" style="font-family:var(--font-mono)">—</span>
      </div>
      <a class="ph-public-link" id="ph-public-link" href="#" target="_blank" rel="noopener">View public profile ↗</a>
    </div>
    <div class="ph-save-wrap">
      <span class="ph-status" id="ph-status">All changes saved</span>
      <button class="ph-save-btn" id="save-btn" type="button">Save Changes</button>
    </div>
  </div>

  <!-- Tab strip -->
  <nav class="ph-tabs" id="ph-tabs" role="tablist" aria-label="Profile sections">
    <button class="ph-tab ph-tab--active" data-section="identity" role="tab">Identity</button>
    <button class="ph-tab" data-section="personal" role="tab">Personal</button>
    <button class="ph-tab" data-section="address" role="tab">Address</button>
    <button class="ph-tab" data-section="public" role="tab">Public Profile</button>
    <button class="ph-tab" data-section="social" role="tab">Social</button>
    <button class="ph-tab" data-section="equipment" role="tab">Equipment</button>
    <button class="ph-tab" data-section="distinctions" role="tab">Distinctions</button>
    <button class="ph-tab" data-section="internal" role="tab">Internal</button>
    <button class="ph-tab" data-section="account" role="tab">Account</button>
    <button class="ph-tab" data-section="statistics" role="tab">Statistics</button>
  </nav>
</div>

<!-- ── MOBILE SAVE BAR ─────────────────────────────────────────────────── -->
<div class="mobile-save-bar" id="mobile-save-bar">
  <button class="mobile-save-btn" id="mobile-save-btn" type="button">Save Changes</button>
</div>

<!-- ── SECTIONS ───────────────────────────────────────────────────────── -->
<div class="profile-body">

  <!-- § Identity -->
  <section class="ps" id="section-identity" data-section="identity">
    <div class="ps-head"><span class="ps-title">Identity</span></div>

    <div class="ps-row">
      <div class="ps-field-group">
        <div class="ps-label">Profile Photo</div>
        <div class="ps-avatar-preview">
          <div class="ps-avatar-thumb" id="ps-avatar-thumb">
            <span id="ps-avatar-thumb-initials">—</span>
            <img id="ps-avatar-thumb-img" src="" alt="" hidden />
          </div>
          <div class="ps-avatar-actions">
            <label class="btn-secondary" for="avatar-file-input">Upload photo</label>
            <button class="btn-text-danger" id="btn-remove-avatar" type="button">Remove</button>
          </div>
        </div>
        <div class="ps-hint">JPG, PNG, WebP · max 5 MB</div>
        <div class="ps-upload-status" id="avatar-status" hidden></div>
      </div>

      <div class="ps-field-group">
        <div class="ps-label">Cover Banner</div>
        <div class="ps-cover-preview">
          <div class="ps-cover-thumb" id="ps-cover-thumb">
            <div class="ps-cover-stripe-sm" id="ps-cover-stripe-sm"></div>
            <img id="ps-cover-thumb-img" src="" alt="" hidden />
          </div>
          <div class="ps-avatar-actions">
            <label class="btn-secondary" for="cover-file-input">Upload cover</label>
            <button class="btn-text-danger" id="btn-remove-cover" type="button">Remove</button>
          </div>
        </div>
        <div class="ps-hint">JPG, PNG, WebP · max 10 MB</div>
        <div class="ps-upload-status" id="cover-status" hidden></div>
      </div>
    </div>

    <div class="ps-row">
      <div class="ps-field-group ps-field-group--full">
        <div class="ps-label">Public Profile URL</div>
        <div class="ps-url-row">
          <span class="ps-url-prefix">v3bcc.bhopal.info/photographers/</span>
          <span class="ps-url-value" id="ps-url-value">—</span>
          <button class="ps-url-copy" id="ps-url-copy" type="button">Copy</button>
          <a class="ps-url-view" id="ps-url-view" href="#" target="_blank" rel="noopener">View ↗</a>
        </div>
      </div>
    </div>

    <div class="ps-row">
      <div class="ps-field-group">
        <div class="ps-label">Membership Tier</div>
        <div class="ps-readonly-val" id="identity-tier">—</div>
      </div>
      <div class="ps-field-group">
        <div class="ps-label">Membership Number</div>
        <div class="ps-readonly-val" id="identity-number" style="font-family:var(--font-mono)">—</div>
      </div>
    </div>
  </section>

  <!-- § Personal -->
  <section class="ps" id="section-personal" data-section="personal">
    <div class="ps-head"><span class="ps-title">Personal</span></div>

    <!-- Read-only name block (OVERRIDE 1) -->
    <div class="ps-readonly-notice">Name fields are managed in <a href="/hub/account-settings" class="ps-link">Account Settings</a>.</div>

    <div class="ps-row">
      <div class="ps-field-group">
        <label class="ps-label">Title</label>
        <div class="form-input form-input--readonly" id="ro-title">—</div>
      </div>
      <div class="ps-field-group">
        <label class="ps-label">First Name</label>
        <div class="form-input form-input--readonly" id="ro-firstname">—</div>
      </div>
      <div class="ps-field-group">
        <label class="ps-label">Middle Name</label>
        <div class="form-input form-input--readonly" id="ro-middlename">—</div>
      </div>
    </div>

    <div class="ps-row">
      <div class="ps-field-group">
        <label class="ps-label">Last Name</label>
        <div class="form-input form-input--readonly" id="ro-lastname">—</div>
      </div>
      <div class="ps-field-group ps-field-group--full">
        <label class="ps-label">Email <span class="ps-locked">LOCKED</span></label>
        <div class="form-input form-input--readonly" id="ro-email">—</div>
        <div class="ps-hint">Change email in Account Settings.</div>
      </div>
    </div>

    <!-- Editable fields -->
    <div class="ps-row">
      <div class="ps-field-group">
        <label class="ps-label" for="field-phone">Phone</label>
        <div class="form-input-prefix-wrap">
          <span class="form-input-prefix">+91</span>
          <input class="form-input form-input--prefixed" type="tel" id="field-phone" name="phone"
            placeholder="10-digit number" maxlength="10" pattern="\d{10}" />
        </div>
      </div>
      <div class="ps-field-group">
        <label class="ps-label" for="field-gender">Gender</label>
        <select class="form-select" id="field-gender" name="gender">
          <option value="">— select —</option>
          <option value="MALE">Male</option>
          <option value="FEMALE">Female</option>
          <option value="OTHER">Other</option>
          <option value="PREFER_NOT_TO_SAY">Prefer not to say</option>
        </select>
      </div>
      <div class="ps-field-group">
        <label class="ps-label" for="field-dob">Date of Birth</label>
        <input class="form-input" type="date" id="field-dob" name="dateOfBirth" />
      </div>
    </div>
  </section>

  <!-- § Address -->
  <section class="ps" id="section-address" data-section="address">
    <div class="ps-head"><span class="ps-title">Address</span></div>

    <div class="ps-row">
      <div class="ps-field-group ps-field-group--full">
        <label class="ps-label" for="field-addr1">Address Line 1</label>
        <input class="form-input" type="text" id="field-addr1" name="addressLine1" maxlength="255" />
      </div>
    </div>
    <div class="ps-row">
      <div class="ps-field-group ps-field-group--full">
        <label class="ps-label" for="field-addr2">Address Line 2 <span class="ps-optional">(optional)</span></label>
        <input class="form-input" type="text" id="field-addr2" name="addressLine2" maxlength="255" />
      </div>
    </div>
    <div class="ps-row">
      <div class="ps-field-group ps-field-group--full">
        <label class="ps-label" for="field-addr3">Address Line 3 / Landmark <span class="ps-optional">(optional)</span></label>
        <input class="form-input" type="text" id="field-addr3" name="addressLine3" maxlength="255" />
      </div>
    </div>
    <div class="ps-row">
      <div class="ps-field-group">
        <label class="ps-label" for="field-city">City</label>
        <input class="form-input" type="text" id="field-city" name="city" maxlength="100" />
      </div>
      <div class="ps-field-group">
        <label class="ps-label" for="field-state">State</label>
        <select class="form-select" id="field-state" name="state">
          <option value="">— select —</option>
          <option>Andhra Pradesh</option><option>Arunachal Pradesh</option><option>Assam</option>
          <option>Bihar</option><option>Chhattisgarh</option><option>Goa</option>
          <option>Gujarat</option><option>Haryana</option><option>Himachal Pradesh</option>
          <option>Jharkhand</option><option>Karnataka</option><option>Kerala</option>
          <option>Madhya Pradesh</option><option>Maharashtra</option><option>Manipur</option>
          <option>Meghalaya</option><option>Mizoram</option><option>Nagaland</option>
          <option>Odisha</option><option>Punjab</option><option>Rajasthan</option>
          <option>Sikkim</option><option>Tamil Nadu</option><option>Telangana</option>
          <option>Tripura</option><option>Uttar Pradesh</option><option>Uttarakhand</option>
          <option>West Bengal</option>
          <option>Andaman and Nicobar Islands</option><option>Chandigarh</option>
          <option>Dadra and Nagar Haveli and Daman and Diu</option>
          <option>Delhi</option><option>Jammu and Kashmir</option>
          <option>Ladakh</option><option>Lakshadweep</option><option>Puducherry</option>
        </select>
      </div>
      <div class="ps-field-group">
        <label class="ps-label" for="field-pin">PIN Code</label>
        <input class="form-input" type="text" id="field-pin" name="pinCode" maxlength="6" pattern="\d{6}" placeholder="6 digits" />
      </div>
    </div>
    <div class="ps-row">
      <div class="ps-field-group">
        <label class="ps-label" for="field-blood">Blood Group</label>
        <select class="form-select" id="field-blood" name="bloodGroup">
          <option value="">— select —</option>
          <option>A+</option><option>A-</option><option>B+</option><option>B-</option>
          <option>AB+</option><option>AB-</option><option>O+</option><option>O-</option>
        </select>
      </div>
    </div>

    <div class="ps-divider"><span>Emergency Contact</span></div>

    <div class="ps-row">
      <div class="ps-field-group">
        <label class="ps-label" for="field-ec-name">Contact Name</label>
        <input class="form-input" type="text" id="field-ec-name" name="emergencyContactName" maxlength="150" />
      </div>
      <div class="ps-field-group">
        <label class="ps-label" for="field-ec-phone">Contact Phone</label>
        <input class="form-input" type="tel" id="field-ec-phone" name="emergencyContactPhone" maxlength="15" />
      </div>
      <div class="ps-field-group">
        <label class="ps-label" for="field-ec-rel">Relationship</label>
        <select class="form-select" id="field-ec-rel" name="emergencyContactRelationship">
          <option value="">— select —</option>
          <option value="SPOUSE">Spouse</option><option value="PARENT">Parent</option>
          <option value="SIBLING">Sibling</option><option value="CHILD">Child</option>
          <option value="FRIEND">Friend</option><option value="OTHER">Other</option>
        </select>
      </div>
    </div>
  </section>

  <!-- § Public Profile -->
  <section class="ps" id="section-public" data-section="public">
    <div class="ps-head"><span class="ps-title">Public Profile</span></div>

    <div class="ps-row">
      <div class="ps-field-group ps-field-group--full">
        <label class="ps-label" for="field-tagline">
          Tagline <span class="ps-counter" id="tagline-count">0/120</span>
        </label>
        <input class="form-input" type="text" id="field-tagline" name="tagline" maxlength="120"
          placeholder="A short line about your photography…" />
      </div>
    </div>

    <div class="ps-row">
      <div class="ps-field-group ps-field-group--full">
        <label class="ps-label" for="field-website">Personal Website</label>
        <input class="form-input" type="url" id="field-website" name="websiteUrl"
          placeholder="https://yoursite.com" maxlength="500" />
      </div>
    </div>

    <div class="ps-row">
      <div class="ps-field-group ps-field-group--full">
        <label class="ps-label">Areas of Expertise</label>
        <div class="chip-input" id="chip-expertise" data-field="areasOfExpertise"></div>
        <div class="ps-hint">Press Enter or Tab to add. Max 10 items.</div>
      </div>
    </div>

    <div class="ps-row">
      <div class="ps-field-group ps-field-group--full">
        <label class="ps-label">Favourite Subjects</label>
        <div class="chip-input" id="chip-subjects" data-field="favouriteSubjects"></div>
        <div class="ps-hint">Press Enter or Tab to add. Max 10 items.</div>
      </div>
    </div>

    <div class="ps-row">
      <div class="ps-field-group">
        <label class="ps-label" for="field-camera-system">Preferred Camera System</label>
        <select class="form-select" id="field-camera-system" name="preferredCameraSystem">
          <option value="">— select —</option>
          <option>Nikon</option><option>Canon</option><option>Sony</option>
          <option>Fujifilm</option><option>OM System</option><option>Other</option>
        </select>
      </div>
      <div class="ps-field-group">
        <label class="ps-label" for="field-year-joined">Year Joined BCC</label>
        <input class="form-input" type="number" id="field-year-joined" name="yearJoinedBcc"
          min="2016" max="2030" placeholder="e.g. 2019" />
        <div class="ps-hint">Temporary — will be replaced by membership application date after full launch.</div>
      </div>
    </div>

    <div class="ps-row">
      <div class="ps-field-group ps-field-group--full">
        <label class="ps-label">Photography Genres</label>
        <div class="genre-grid" id="genre-grid"></div>
      </div>
    </div>

    <div class="ps-row">
      <div class="ps-field-group ps-field-group--full">
        <label class="ps-label">Gallery Layout</label>
        <div class="layout-picker" id="layout-picker" role="group" aria-label="Choose your public gallery layout">
          <button type="button" class="layout-opt layout-opt--active" data-layout="justified" aria-pressed="true">
            <svg class="layout-icon" viewBox="0 0 64 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="1" y="1" width="24" height="16" fill="currentColor" opacity="0.35"/>
              <rect x="27" y="1" width="36" height="16" fill="currentColor" opacity="0.35"/>
              <rect x="1" y="20" width="36" height="16" fill="currentColor" opacity="0.35"/>
              <rect x="39" y="20" width="24" height="16" fill="currentColor" opacity="0.35"/>
            </svg>
            <span class="layout-opt-label">Justified</span>
          </button>
          <button type="button" class="layout-opt" data-layout="masonry" aria-pressed="false">
            <svg class="layout-icon" viewBox="0 0 64 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="1" y="1" width="19" height="14" fill="currentColor" opacity="0.35"/>
              <rect x="22" y="1" width="19" height="22" fill="currentColor" opacity="0.35"/>
              <rect x="43" y="1" width="20" height="10" fill="currentColor" opacity="0.35"/>
              <rect x="1" y="17" width="19" height="22" fill="currentColor" opacity="0.35"/>
              <rect x="43" y="13" width="20" height="16" fill="currentColor" opacity="0.35"/>
              <rect x="22" y="25" width="19" height="14" fill="currentColor" opacity="0.35"/>
            </svg>
            <span class="layout-opt-label">Masonry</span>
          </button>
          <button type="button" class="layout-opt" data-layout="editorial" aria-pressed="false">
            <svg class="layout-icon" viewBox="0 0 64 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="1" y="1" width="62" height="22" fill="currentColor" opacity="0.35"/>
              <rect x="1" y="25" width="30" height="14" fill="currentColor" opacity="0.35"/>
              <rect x="33" y="25" width="30" height="14" fill="currentColor" opacity="0.35"/>
            </svg>
            <span class="layout-opt-label">Editorial</span>
          </button>
          <button type="button" class="layout-opt" data-layout="modular" aria-pressed="false">
            <svg class="layout-icon" viewBox="0 0 64 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="1" y="1" width="19" height="14" fill="currentColor" opacity="0.35"/>
              <rect x="22" y="1" width="19" height="14" fill="currentColor" opacity="0.35"/>
              <rect x="43" y="1" width="20" height="14" fill="currentColor" opacity="0.35"/>
              <rect x="1" y="17" width="19" height="14" fill="currentColor" opacity="0.35"/>
              <rect x="22" y="17" width="19" height="14" fill="currentColor" opacity="0.35"/>
              <rect x="43" y="17" width="20" height="14" fill="currentColor" opacity="0.35"/>
              <rect x="1" y="33" width="19" height="6" fill="currentColor" opacity="0.35"/>
              <rect x="22" y="33" width="19" height="6" fill="currentColor" opacity="0.35"/>
              <rect x="43" y="33" width="20" height="6" fill="currentColor" opacity="0.35"/>
            </svg>
            <span class="layout-opt-label">Modular</span>
          </button>
          <button type="button" class="layout-opt" data-layout="metro" aria-pressed="false">
            <svg class="layout-icon" viewBox="0 0 64 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="1" y="1" width="30" height="28" fill="currentColor" opacity="0.35"/>
              <rect x="33" y="1" width="14" height="13" fill="currentColor" opacity="0.35"/>
              <rect x="49" y="1" width="14" height="13" fill="currentColor" opacity="0.35"/>
              <rect x="33" y="16" width="14" height="13" fill="currentColor" opacity="0.35"/>
              <rect x="49" y="16" width="14" height="13" fill="currentColor" opacity="0.35"/>
              <rect x="1" y="31" width="62" height="8" fill="currentColor" opacity="0.2"/>
            </svg>
            <span class="layout-opt-label">Metro</span>
          </button>
          <button type="button" class="layout-opt" data-layout="magazine" aria-pressed="false">
            <svg class="layout-icon" viewBox="0 0 64 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="1" y="1" width="62" height="18" fill="currentColor" opacity="0.35"/>
              <rect x="1" y="21" width="40" height="18" fill="currentColor" opacity="0.35"/>
              <rect x="43" y="21" width="20" height="8" fill="currentColor" opacity="0.25"/>
              <rect x="43" y="31" width="20" height="8" fill="currentColor" opacity="0.25"/>
            </svg>
            <span class="layout-opt-label">Magazine</span>
          </button>
        </div>
        <div class="ps-hint">Controls how your photos are displayed on your public photographer profile.</div>
      </div>
    </div>

    <div class="ps-row">
      <div class="ps-field-group ps-field-group--full">
        <label class="ps-label">Biography</label>
        <TiptapBio maxChars={3000} />
      </div>
    </div>
  </section>

  <!-- § Social Links -->
  <section class="ps" id="section-social" data-section="social">
    <div class="ps-head"><span class="ps-title">Social Links</span></div>

    <div class="social-grid">
      <div class="social-row">
        <span class="social-label">Instagram</span>
        <div class="form-input-prefix-wrap">
          <span class="form-input-prefix">instagram.com/</span>
          <input class="form-input form-input--prefixed" type="text" data-platform="INSTAGRAM" placeholder="username" maxlength="60" />
        </div>
      </div>
      <div class="social-row">
        <span class="social-label">Facebook</span>
        <div class="form-input-prefix-wrap">
          <span class="form-input-prefix">facebook.com/</span>
          <input class="form-input form-input--prefixed" type="text" data-platform="FACEBOOK" placeholder="username or page" maxlength="100" />
        </div>
      </div>
      <div class="social-row">
        <span class="social-label">X / Twitter</span>
        <div class="form-input-prefix-wrap">
          <span class="form-input-prefix">x.com/</span>
          <input class="form-input form-input--prefixed" type="text" data-platform="X_TWITTER" placeholder="username" maxlength="60" />
        </div>
      </div>
      <div class="social-row">
        <span class="social-label">YouTube</span>
        <div class="form-input-prefix-wrap">
          <span class="form-input-prefix">youtube.com/@</span>
          <input class="form-input form-input--prefixed" type="text" data-platform="YOUTUBE" placeholder="channelname" maxlength="60" />
        </div>
      </div>
      <div class="social-row">
        <span class="social-label">TikTok</span>
        <div class="form-input-prefix-wrap">
          <span class="form-input-prefix">tiktok.com/@</span>
          <input class="form-input form-input--prefixed" type="text" data-platform="TIKTOK" placeholder="username" maxlength="60" />
        </div>
      </div>
      <div class="social-row">
