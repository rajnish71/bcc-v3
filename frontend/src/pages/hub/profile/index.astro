  display:flex; align-items:center; justify-content:center; overflow:hidden;
}
.ph-avatar-initials {
  font-family:var(--font-display); font-size:36px; font-weight:700;
  color:rgba(255,255,255,0.9);
}
.ph-avatar-img { width:100%; height:100%; object-fit:cover; }
.ph-avatar-edit {
  position:absolute; bottom:4px; right:4px;
  width:28px; height:28px; border-radius:999px;
  background:linear-gradient(135deg, #C9A961, #A8843C);
  display:flex; align-items:center; justify-content:center;
  cursor:pointer; color:#fff; border:2px solid #fff;
}

.ph-meta { flex:1; padding-bottom:4px; min-width:180px; }
.ph-name {
  font-family:var(--font-display); font-size:22px; font-weight:700;
  color:#141210; margin-bottom:4px;
}
.ph-badges { display:flex; align-items:center; gap:10px; margin-bottom:6px; flex-wrap:wrap; }
.ph-tier-badge {
  font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase;
  background:#F4F0E8; color:#A8843C; padding:3px 10px; border:1px solid #C9A961;
}
.ph-number { font-size:12px; color:#8B8378; }
