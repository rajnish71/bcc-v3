<script>
const API = '/api/v1/hub/profile';
function tok(): string { return localStorage.getItem('bcc_token') ?? ''; }
async function apiFetch(url: string, opts: RequestInit = {}): Promise<Response> {
  return fetch(url, {
    ...opts,
    headers: { Authorization: `Bearer ${tok()}`, ...(opts.headers ?? {}) },
  });
}

// ── Dirty tracking ─────────────────────────────────────────────────────────
const dirty = new Set<string>();
function markDirty(section: string) {
  dirty.add(section);
  setStatus('');
}

// ── Status ──────────────────────────────────────────────────────────────────
function setStatus(msg: string, cls = '') {
  const el = document.getElementById('ph-status');
  if (!el) return;
  el.textContent = msg || 'All changes saved';
  el.className = cls ? `ob-status ${cls}` : 'ob-status';
}

// ── Genre list ──────────────────────────────────────────────────────────────
const GENRES = [
  'Landscape','Portrait','Wildlife','Street','Documentary',
  'Macro','Architecture','Aerial','Sports','Night',
  'Astro','Travel','Abstract','Fashion','Fine Art',
];

let selectedGenres: string[] = [];

function renderGenreGrid(selected: string[]) {
  selectedGenres = [...selected];
  const grid = document.getElementById('genre-grid');
  if (!grid) return;
  grid.innerHTML = '';
  GENRES.forEach(g => {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.textContent = g;
    btn.className = 'genre-chip' + (selectedGenres.includes(g) ? ' genre-chip--selected' : '');
    btn.addEventListener('click', () => {
      if (selectedGenres.includes(g)) {
        selectedGenres = selectedGenres.filter(x => x !== g);
      } else if (selectedGenres.length < 10) {
        selectedGenres.push(g);
      }
      btn.className = 'genre-chip' + (selectedGenres.includes(g) ? ' genre-chip--selected' : '');
      markDirty('main');
    });
    grid.appendChild(btn);
  });
}

// ── Chip input ──────────────────────────────────────────────────────────────
const chipData: Record<string, string[]> = {
  areasOfExpertise: [], favouriteSubjects: [],
  bodies: [], lenses: [], drones: [], otherGear: [],
};

function initChipInput(containerId: string, field: string) {
  const container = document.getElementById(containerId);
  if (!container) return;

  const input = document.createElement('input');
  input.className = 'chip-text-input';
  input.placeholder = 'Type and press Enter…';
  container.appendChild(input);

  function renderChips() {
    const existing = container!.querySelectorAll('.chip-item');
    existing.forEach(el => el.remove());
    chipData[field].forEach((val, idx) => {
      const chip = document.createElement('span');
      chip.className = 'chip-item';
      chip.textContent = val;
      const removeBtn = document.createElement('button');
      removeBtn.type = 'button'; removeBtn.textContent = '×';
      removeBtn.addEventListener('click', () => {
        chipData[field].splice(idx, 1);
        renderChips(); markDirty(field.startsWith('bodies') || field.startsWith('lenses') || field.startsWith('drones') || field.startsWith('otherGear') ? 'gear' : 'main');
      });
      chip.appendChild(removeBtn);
      container!.insertBefore(chip, input);
    });
  }

  input.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter' || e.key === 'Tab') {
      e.preventDefault();
      const val = input.value.trim();
      if (val && chipData[field].length < 10 && !chipData[field].includes(val)) {
        chipData[field].push(val);
        input.value = '';
        renderChips();
        const isGear = ['bodies','lenses','drones','otherGear'].includes(field);
        markDirty(isGear ? 'gear' : 'main');
      }
    }
  });

  container.addEventListener('click', () => input.focus());
}

// ── Load profile ────────────────────────────────────────────────────────────
async function loadProfile() {
  const res = await apiFetch(API);
  if (!res.ok) return;
  const p = await res.json() as Record<string, any>;

  // Header
  const initials = (p.fullName ?? '').trim().split(/\s+/).map((w: string) => w[0] ?? '').join('').slice(0,2).toUpperCase();
  setTxt('ph-initials', initials || '?');
  setTxt('ps-avatar-thumb-initials', initials || '?');
  setTxt('ph-name', p.fullName ?? '—');
  setTxt('ph-tier', p.membershipTier ?? '—');
  setTxt('ph-number', p.membershipNumberDisplay ?? p.membershipNumber ?? '—');
  setTxt('ph-public-link', `v3bcc.bhopal.info/photographers/${p.username ?? ''}`);
  setAttr('ph-public-link', 'href', `/photographers/${p.username ?? ''}/`);
  setTxt('ps-url-value', p.username ?? '—');
  setAttr('ps-url-view', 'href', `/photographers/${p.username ?? ''}/`);
  setTxt('identity-tier', p.membershipTier ?? '—');
  setTxt('identity-number', p.membershipNumberDisplay ?? p.membershipNumber ?? '—');

  // Avatar
  if (p.avatarUrl) {
    showImg('ph-avatar-img', 'ph-initials', p.avatarUrl);
    showImg('ps-avatar-thumb-img', 'ps-avatar-thumb-initials', p.avatarUrl);
  }
  // Cover
  if (p.coverUrl) {
    showCover(p.coverUrl);
  }

  // Personal
  setRO('ro-title', p.nameTitle ?? '—');
  setRO('ro-firstname', p.firstName ?? '—');
  setRO('ro-middlename', p.middleName ?? '—');
  setRO('ro-lastname', p.lastName ?? '—');
  setRO('ro-email', p.email ?? '—');
  setInpVal('field-phone', p.phone ?? '');
  setSelVal('field-gender', p.gender ?? '');
  setInpVal('field-dob', p.dateOfBirth ? String(p.dateOfBirth).split('T')[0] : '');

  // Address
  setInpVal('field-addr1', p.addressLine1 ?? '');
  setInpVal('field-addr2', p.addressLine2 ?? '');
  setInpVal('field-addr3', p.addressLine3 ?? '');
  setInpVal('field-city', p.city ?? '');
  setSelVal('field-state', p.state ?? '');
  setInpVal('field-pin', p.pinCode ?? '');
  setSelVal('field-blood', p.bloodGroup ?? '');
  setInpVal('field-ec-name', p.emergencyContactName ?? '');
  setInpVal('field-ec-phone', p.emergencyContactPhone ?? '');
  setSelVal('field-ec-rel', p.emergencyContactRelationship ?? '');

  // Public Profile
  setInpVal('field-tagline', p.tagline ?? '');
  updateCounter('field-tagline', 'tagline-count', 120);
  setInpVal('field-website', p.websiteUrl ?? '');
  setSelVal('field-camera-system', p.preferredCameraSystem ?? '');
  setInpVal('field-year-joined', p.yearJoinedBcc ? String(p.yearJoinedBcc) : '');
  setSelectedLayout(p.galleryLayout ?? 'justified');
  (window as any).tiptapSetContent_bio?.(p.bio ?? '');
  (window as any).tiptapSetContent_awardsHtml?.(p.awardsHtml ?? '');
  renderGenreGrid(Array.isArray(p.photographyGenres) ? p.photographyGenres : []);

  // Chips
  chipData.areasOfExpertise = Array.isArray(p.areasOfExpertise) ? [...p.areasOfExpertise] : [];
  chipData.favouriteSubjects = Array.isArray(p.favouriteSubjects) ? [...p.favouriteSubjects] : [];
  reRenderAllChips(['chip-expertise','chip-subjects']);

  // Social handles
  const socials: {platform: string; handle: string}[] = Array.isArray(p.socialLinks) ? p.socialLinks : [];
  document.querySelectorAll<HTMLInputElement>('[data-platform]').forEach(input => {
    const found = socials.find(s => s.platform === input.dataset.platform);
    input.value = found?.handle ?? '';
  });

  // Gear
  chipData.bodies = Array.isArray(p.gear?.bodies) ? [...p.gear.bodies] : [];
  chipData.lenses = Array.isArray(p.gear?.lenses) ? [...p.gear.lenses] : [];
  chipData.otherGear = Array.isArray(p.gear?.other) ? [...p.gear.other] : [];
  reRenderAllChips(['chip-bodies','chip-lenses','chip-drones','chip-other-gear']);

  // Distinctions
  setInpVal('field-fiap', p.photoTitles?.fiap ?? '');
  setInpVal('field-fip', p.photoTitles?.fip ?? '');
  setInpVal('field-psa', p.photoTitles?.psa ?? '');
  setInpVal('field-other-titles', p.photoTitles?.other ?? '');

  // Internal roles
  ['coordinator','mentor','instructor','volunteer'].forEach(role => {
    const el = document.getElementById(`toggle-${role}`);
    if (!el) return;
    if (p.internalRoles?.[role]) el.classList.add('internal-toggle--on');
    else el.classList.remove('internal-toggle--on');
  });

  // Stats
  const stats = p.stats ?? {};
  setTxt('stat-since', stats.memberSince ? new Date(stats.memberSince).getFullYear().toString() : '—');
  setTxt('stat-class', stats.membershipClass ?? '—');
  setTxt('stat-photos', String(stats.portfolioCount ?? 0));
  setTxt('stat-events', String(stats.eventAttendance ?? 0));
  setTxt('stat-awards', String(stats.contestAwards ?? 0));
  setTxt('stat-score', String(stats.activityScore ?? 0));
}

function reRenderAllChips(containerIds: string[]) {
  containerIds.forEach(id => {
    const container = document.getElementById(id);
    if (!container) return;
    const input = container.querySelector<HTMLInputElement>('.chip-text-input');
    const field = container.dataset.field ?? '';
    container.querySelectorAll('.chip-item').forEach(el => el.remove());
    (chipData[field] ?? []).forEach((val: string, idx: number) => {
      const chip = document.createElement('span');
      chip.className = 'chip-item';
      chip.textContent = val;
      const btn = document.createElement('button');
      btn.type = 'button'; btn.textContent = '×';
      btn.addEventListener('click', () => {
        chipData[field].splice(idx, 1);
        reRenderAllChips([id]);
        const isGear = ['bodies','lenses','drones','otherGear'].includes(field);
        markDirty(isGear ? 'gear' : 'main');
      });
      chip.appendChild(btn);
      if (input) container.insertBefore(chip, input);
      else container.appendChild(chip);
    });
  });
}

// ── Save ──────────────────────────────────────────────────────────────────
async function saveAll() {
  const btn = document.getElementById('save-btn') as HTMLButtonElement | null;
  const mBtn = document.getElementById('mobile-save-btn') as HTMLButtonElement | null;
  if (btn) btn.disabled = true;
  if (mBtn) mBtn.disabled = true;
  setStatus('Saving…', 'ob-status--saving');

  const promises: Promise<any>[] = [];

  // Main profile fields (always save — lightweight operation)
  const mainBody: Record<string, any> = {
    phone: (getInp('field-phone') || null),
    gender: (getSel('field-gender') || null),
    dateOfBirth: (getInp('field-dob') || null),
    addressLine1: (getInp('field-addr1') || null),
    addressLine2: (getInp('field-addr2') || null),
    addressLine3: (getInp('field-addr3') || null),
    city: (getInp('field-city') || null),
    state: (getSel('field-state') || null),
    pinCode: (getInp('field-pin') || null),
    bloodGroup: (getSel('field-blood') || null),
    emergencyContactName: (getInp('field-ec-name') || null),
    emergencyContactPhone: (getInp('field-ec-phone') || null),
    emergencyContactRelationship: (getSel('field-ec-rel') || null),
    tagline: (getInp('field-tagline') || null),
    websiteUrl: (getInp('field-website') || null),
    areasOfExpertise: chipData.areasOfExpertise,
    favouriteSubjects: chipData.favouriteSubjects,
    preferredCameraSystem: (getSel('field-camera-system') || null),
    photographyGenres: selectedGenres,
    bio: (getTxtArea('tiptap-hidden-bio') || null),
    yearJoinedBcc: getInp('field-year-joined') ? Number(getInp('field-year-joined')) : null,
    galleryLayout: getSelectedLayout(),
  };
  promises.push(apiFetch(API, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(mainBody),
  }));

  // Social links
  const links: {platform: string; handle: string}[] = [];
  document.querySelectorAll<HTMLInputElement>('[data-platform]').forEach(input => {
    const val = input.value.trim();
    if (val) links.push({ platform: input.dataset.platform!, handle: val });
  });
  promises.push(apiFetch(`${API}/social`, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ links }),
  }));

  // Gear
  promises.push(apiFetch(`${API}/gear`, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      bodies: chipData.bodies,
      lenses: chipData.lenses,
      drones: chipData.drones,
      other: chipData.otherGear,
    }),
  }));

  // Distinctions
  promises.push(apiFetch(`${API}/distinctions`, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      fiap: getInp('field-fiap') || undefined,
      fip: getInp('field-fip') || undefined,
      psa: getInp('field-psa') || undefined,
      other: getInp('field-other-titles') || undefined,
      awardsHtml: getTxtArea('tiptap-hidden-awardsHtml') || undefined,
    }),
  }));

  try {
    const results = await Promise.all(promises);
    const allOk = results.every(r => r.ok);
    if (allOk) {
      dirty.clear();
      setStatus('All changes saved');
    } else {
      const errs = results.filter(r => !r.ok);
      const msg = await errs[0].json().catch(() => ({})) as {message?: string};
      setStatus(typeof msg.message === 'string' ? msg.message : 'Save failed', 'ob-status--error');
    }
  } catch {
    setStatus('Network error — try again', 'ob-status--error');
  } finally {
    if (btn) btn.disabled = false;
    if (mBtn) mBtn.disabled = false;
  }
}

// ── Avatar upload ─────────────────────────────────────────────────────────
async function uploadMedia(file: File, type: 'avatar' | 'cover') {
  const maxBytes = type === 'cover' ? 10 * 1024 * 1024 : 5 * 1024 * 1024;
  const statusId = type === 'avatar' ? 'avatar-status' : 'cover-status';

  if (file.size > maxBytes) {
    showUploadStatus(statusId, `File too large (max ${type === 'cover' ? 10 : 5} MB)`, true);
    return;
  }
  if (!['image/jpeg','image/jpg','image/png','image/webp'].includes(file.type)) {
    showUploadStatus(statusId, 'Only JPG, PNG, or WebP allowed', true);
    return;
  }

  // Local preview
  const reader = new FileReader();
  reader.onload = ev => {
    if (type === 'avatar') {
      showImg('ph-avatar-img', 'ph-initials', String(ev.target?.result ?? ''));
      showImg('ps-avatar-thumb-img', 'ps-avatar-thumb-initials', String(ev.target?.result ?? ''));
    } else {
      showCover(String(ev.target?.result ?? ''));
    }
  };
  reader.readAsDataURL(file);

  showUploadStatus(statusId, 'Uploading…', false);

  try {
    const presignRes = await apiFetch(`${API}/${type}/presign`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mimeType: file.type, fileSizeBytes: file.size }),
    });
    if (!presignRes.ok) { showUploadStatus(statusId, 'Presign failed', true); return; }
    const { uploadUrl, r2Key } = await presignRes.json() as { uploadUrl: string; r2Key: string };

    const putRes = await fetch(uploadUrl, { method: 'PUT', body: file, headers: { 'Content-Type': file.type } });
    if (!putRes.ok) { showUploadStatus(statusId, 'Upload failed', true); return; }

    const confirmRes = await apiFetch(`${API}/${type}/confirm`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ r2Key }),
    });
    if (confirmRes.ok) {
      showUploadStatus(statusId, type === 'avatar' ? 'Photo updated!' : 'Cover updated!', false);
    } else {
      showUploadStatus(statusId, 'Upload confirmed but may take a moment to reflect.', false);
    }
  } catch {
    showUploadStatus(statusId, 'Network error during upload', true);
  }
}

function showUploadStatus(id: string, msg: string, isErr: boolean) {
  const el = document.getElementById(id);
  if (!el) return;
  el.textContent = msg;
  el.className = `ps-upload-status ps-upload-status--${isErr ? 'err' : 'ok'}`;
  el.hidden = false;
  if (!isErr) setTimeout(() => { el.hidden = true; }, 4000);
}

function showImg(imgId: string, fallbackId: string, src: string) {
  const img = document.getElementById(imgId) as HTMLImageElement | null;
  const fb = document.getElementById(fallbackId);
  if (img) { img.src = src; img.hidden = false; }
  if (fb) (fb as HTMLElement).style.display = 'none';
}

function showCover(src: string) {
  const stripe = document.getElementById('ph-cover-stripe');
  const img = document.getElementById('ph-cover-img') as HTMLImageElement | null;
  const stripeSmall = document.getElementById('ps-cover-stripe-sm');
  const imgSmall = document.getElementById('ps-cover-thumb-img') as HTMLImageElement | null;
  if (stripe) stripe.style.display = 'none';
  if (img) { img.src = src; img.hidden = false; }
  if (stripeSmall) stripeSmall.style.display = 'none';
  if (imgSmall) { imgSmall.src = src; imgSmall.hidden = false; }
}

// ── Tab navigation + IntersectionObserver ─────────────────────────────────
function initTabs() {
  document.querySelectorAll<HTMLElement>('.nav-item').forEach(tab => {
    tab.addEventListener('click', () => showSection(tab.dataset.section ?? 'identity'));
  });
  // Show the first section on load — tab-panel model (item 50).
  showSection('identity');
}

// Show only the requested section's panel; hide the rest.
function showSection(sectionKey: string) {
  document.querySelectorAll<HTMLElement>('.ps[data-section]').forEach(section => {
    section.classList.toggle('ps--active', section.dataset.section === sectionKey);
  });
  setActiveTab(sectionKey);
}

function setActiveTab(sectionKey: string) {
  document.querySelectorAll<HTMLElement>('.nav-item').forEach(tab => {
    tab.classList.toggle('nav-item--active', tab.dataset.section === sectionKey);
  });
}

// ── Copy URL ──────────────────────────────────────────────────────────────
document.getElementById('ps-url-copy')?.addEventListener('click', () => {
  const username = (document.getElementById('ps-url-value') as HTMLElement)?.textContent ?? '';
  if (username && username !== '—') {
    navigator.clipboard.writeText(`https://v3bcc.bhopal.info/photographers/${username}/`).catch(() => {});
    const btn = document.getElementById('ps-url-copy') as HTMLButtonElement;
    if (btn) { btn.textContent = 'Copied!'; setTimeout(() => { btn.textContent = 'Copy'; }, 2000); }
  }
});

// ── Field change listeners ────────────────────────────────────────────────
function listenDirty(ids: string[], section: string) {
  ids.forEach(id => {
    const el = document.getElementById(id);
    el?.addEventListener('change', () => markDirty(section));
    el?.addEventListener('input', () => markDirty(section));
  });
}

function initCounters() {
  const tagline = document.getElementById('field-tagline') as HTMLInputElement | null;
  tagline?.addEventListener('input', () => updateCounter('field-tagline', 'tagline-count', 120));
}

function updateCounter(fieldId: string, counterId: string, max: number) {
  const field = document.getElementById(fieldId) as HTMLInputElement | HTMLTextAreaElement | null;
  const counter = document.getElementById(counterId);
  if (field && counter) counter.textContent = `${field.value.length}/${max}`;
}

// ── Helpers ───────────────────────────────────────────────────────────────
function setTxt(id: string, val: string) { const el = document.getElementById(id); if (el) el.textContent = val; }
function setAttr(id: string, attr: string, val: string) { const el = document.getElementById(id); if (el) el.setAttribute(attr, val); }
function setRO(id: string, val: string) { const el = document.getElementById(id) as HTMLElement | null; if (el) el.textContent = val; }
function setInpVal(id: string, val: string) { const el = document.getElementById(id) as HTMLInputElement | null; if (el) el.value = val; }
function setTxtArea(id: string, val: string) { const el = document.getElementById(id) as HTMLTextAreaElement | null; if (el) el.value = val; }
function setSelVal(id: string, val: string) { const el = document.getElementById(id) as HTMLSelectElement | null; if (el) el.value = val; }
function getInp(id: string): string { return (document.getElementById(id) as HTMLInputElement | null)?.value.trim() ?? ''; }
function getTxtArea(id: string): string { return (document.getElementById(id) as HTMLTextAreaElement | null)?.value ?? ''; }
function getSel(id: string): string { return (document.getElementById(id) as HTMLSelectElement | null)?.value ?? ''; }

// ── Gallery Layout Picker ──────────────────────────────────────────────────
function initLayoutPicker() {
  document.getElementById('layout-picker')?.addEventListener('click', e => {
    const btn = (e.target as Element).closest<HTMLButtonElement>('.layout-opt');
    if (!btn) return;
    document.querySelectorAll<HTMLButtonElement>('.layout-opt').forEach(b => {
      const active = b === btn;
      b.classList.toggle('layout-opt--active', active);
      b.setAttribute('aria-pressed', String(active));
    });
    markDirty('main');
  });
}

function getSelectedLayout(): string {
  return document.querySelector<HTMLButtonElement>('.layout-opt[aria-pressed="true"]')?.dataset.layout ?? 'justified';
}

function setSelectedLayout(layout: string) {
  document.querySelectorAll<HTMLButtonElement>('.layout-opt').forEach(btn => {
    const active = btn.dataset.layout === layout;
    btn.classList.toggle('layout-opt--active', active);
    btn.setAttribute('aria-pressed', String(active));
  });
}

