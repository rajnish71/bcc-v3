</style>

<script>
/* ════════════════════════════════════════════════════════
   TYPES
════════════════════════════════════════════════════════ */
interface ExifData {
  cameraMake?: string; cameraModel?: string; lensModel?: string;
  iso?: number; aperture?: string; shutterSpeed?: string;
  focalLengthMm?: number; dateTaken?: string; gpsLat?: number; gpsLon?: number;
  widthPx?: number; heightPx?: number;
}

type Phase = 'empty' | 'uploading' | 'metadata' | 'complete';
type ItemStatus = 'queued' | 'uploading' | 'processing' | 'done' | 'failed' | 'duplicate';

interface FileItem {
  id: string;
  file: File;
  status: ItemStatus;
  progress: number;
  error?: string;
  duplicateInfo?: string;
  thumb?: string;
  photoUuid?: string;
  exif?: ExifData;
  selected: boolean;
  confirmedAs?: 'published' | 'drafted';
}

/* ════════════════════════════════════════════════════════
   STATE
════════════════════════════════════════════════════════ */
const MAX_BYTES = 50 * 1024 * 1024;
const CONCURRENCY = 3;

let phase: Phase = 'empty';
let items: FileItem[] = [];
let publishedCount = 0;
let draftCount = 0;
const abortMap = new Map<string, AbortController>();

// Inspector metadata state
let activeActivity: string | null = null;
let keywords: string[] = [];
let addingKeyword = false;

// Categories (item 71) — multi-select GENRE tags applied to every uploaded photo.
const selectedCategories = new Set<string>();     // tag_key
const categoryTagIds: Record<string, number> = {}; // tag_key -> tag id
let categoriesLoaded = false;

async function loadCategoryPills(): Promise<void> {
  if (categoriesLoaded) return;
  try {
    const [genreRes, projectRes] = await Promise.all([
      fetch('/api/v1/gallery/tags?category=GENRE'),
      fetch('/api/v1/gallery/tags?category=PROJECT'),
    ]);
    if (genreRes.ok) {
      const tags = await genreRes.json() as Array<{ id: number; tag_key: string; display_name: string }>;
      const group = qid('genre-pills');
      group.innerHTML = '';
      tags
        .sort((a, b) => a.display_name.localeCompare(b.display_name))
        .forEach(t => {
          categoryTagIds[t.tag_key] = t.id;
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'pill';
          btn.dataset.value = t.tag_key;
          btn.textContent = t.display_name;
          group.appendChild(btn);
        });
    }
    if (projectRes.ok) {
      const tags = await projectRes.json() as Array<{ id: number; tag_key: string; display_name: string }>;
      const group = qid('project-pills');
      group.innerHTML = '';
      tags
        .sort((a, b) => a.display_name.localeCompare(b.display_name))
        .forEach(t => {
          categoryTagIds[t.tag_key] = t.id;
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'pill';
          btn.dataset.value = t.tag_key;
          btn.textContent = t.display_name;
          group.appendChild(btn);
        });
    }
    categoriesLoaded = true;
  } catch { /* non-critical — pills just stay empty */ }
}

function uid(): string {
  return Math.random().toString(36).slice(2, 10);
}
function tok(): string {
  return localStorage.getItem('bcc_token') ?? '';
}
function qid(id: string): HTMLElement {
  return document.getElementById(id) as HTMLElement;
}

/* ════════════════════════════════════════════════════════
   PHASE MANAGEMENT
════════════════════════════════════════════════════════ */
function setPhase(p: Phase): void {
  phase = p;
  (qid('phase-empty') as HTMLElement).hidden = p !== 'empty';
  (qid('phase-uploading') as HTMLElement).hidden = p !== 'uploading';
  (qid('phase-metadata') as HTMLElement).hidden = p !== 'metadata';
  (qid('phase-complete') as HTMLElement).hidden = p !== 'complete';

  const sub = qid('page-subtitle');
  if (p === 'empty') sub.textContent = 'Photographs are processed in the order added · nothing publishes until you finish in Metadata';
  if (p === 'uploading') updateUploadingSubtitle();
  if (p === 'metadata') {
    const ready = items.filter(i => i.status === 'done').length;
    sub.textContent = `${ready} ready to caption · select photographs to begin`;
  }
  if (p === 'complete') sub.textContent = '';
}

function updateUploadingSubtitle(): void {
  const uploading = items.filter(i => i.status === 'uploading').length;
  const processing = items.filter(i => i.status === 'processing').length;
  const done = items.filter(i => i.status === 'done').length;
  const failed = items.filter(i => i.status === 'failed').length;
  const parts: string[] = [];
  if (uploading) parts.push(`${uploading} uploading`);
  if (processing) parts.push(`${processing} processing`);
  if (done) parts.push(`${done} complete`);
  if (failed) parts.push(`${failed} failed`);
  qid('page-subtitle').textContent = parts.join(' · ');
}

/* ════════════════════════════════════════════════════════
   EXIF EXTRACTION (JPEG only, plain DataView)
════════════════════════════════════════════════════════ */
async function extractExif(file: File): Promise<ExifData> {
  const base: ExifData = {};

  // Read natural pixel dimensions via browser Image API — works for all formats
  if (file.type.startsWith('image/')) {
    const objUrl = URL.createObjectURL(file);
    try {
      await new Promise<void>((resolve) => {
        const img = new Image();
        img.onload = () => { base.widthPx = img.naturalWidth; base.heightPx = img.naturalHeight; resolve(); };
        img.onerror = () => resolve();
        img.src = objUrl;
      });
    } finally {
      URL.revokeObjectURL(objUrl);
    }
  }

  // JPEG-only EXIF metadata (camera, lens, settings)
  if (!file.type.includes('jpeg') && !file.type.includes('jpg') && !file.name.match(/\.(jpg|jpeg)$/i)) return base;
  try {
    const buf = await file.slice(0, 65536).arrayBuffer();
    return { ...parseJpegExif(new DataView(buf)), ...base };
  } catch { return base; }
}

function readU16(v: DataView, o: number, le: boolean) { return v.getUint16(o, le); }
function readU32(v: DataView, o: number, le: boolean) { return v.getUint32(o, le); }
function readStr(v: DataView, o: number, n: number): string {
  let s = '';
  for (let i = 0; i < n && o + i < v.byteLength; i++) { const c = v.getUint8(o + i); if (!c) break; s += String.fromCharCode(c); }
  return s.trim();
}
function readRational(v: DataView, o: number, le: boolean): number {
  const n = v.getUint32(o, le), d = v.getUint32(o + 4, le);
  return d ? n / d : 0;
}
function readAsciiTag(v: DataView, base: number, vOff: number, count: number, le: boolean): string {
  if (count === 0 || count > 512) return '';
  // vOff is an absolute DataView offset — do NOT add base to it
  if (count <= 4) return readStr(v, vOff, count);
  const strPos = base + readU32(v, vOff, le);
  if (strPos < 0 || strPos >= v.byteLength) return '';
  return readStr(v, strPos, count);
}
function parseIFD(v: DataView, base: number, ifdOffset: number, le: boolean, res: ExifData): void {
  if (ifdOffset + 2 > v.byteLength) return;
  const n = readU16(v, ifdOffset, le);
  for (let i = 0; i < n; i++) {
    const o = ifdOffset + 2 + i * 12;
    if (o + 12 > v.byteLength) break;
    const tag = readU16(v, o, le), type = readU16(v, o + 2, le), count = readU32(v, o + 4, le), vOff = o + 8;
    try {
      if (type === 2) {
        const s = readAsciiTag(v, base, vOff, count, le);
        if (tag === 0x010F) res.cameraMake = s;
        if (tag === 0x0110) res.cameraModel = s;
        if (tag === 0xA434) res.lensModel = s;
        if (tag === 0x9003 || tag === 0x0132) res.dateTaken = s;
      } else if (type === 5 || type === 10) {
        const rO = base + readU32(v, vOff, le);
        if (tag === 0x920A) { const val = readRational(v, rO, le); res.focalLengthMm = Math.round(val); }
        else if (tag === 0x829D) { const val = readRational(v, rO, le); res.aperture = `f/${val.toFixed(1)}`; }
        else if (tag === 0x9201 && type === 10) {
          const num = v.getInt32(rO, le), den = v.getInt32(rO + 4, le);
          if (den) { const ss = Math.pow(2, -(num / den)); res.shutterSpeed = ss >= 1 ? `${ss.toFixed(0)}s` : `1/${Math.round(1 / ss)}`; }
        }
      } else if (type === 3) {
        const val = readU16(v, vOff, le);
        if (tag === 0x8827) res.iso = val;
      }
      if (tag === 0x8769 && type === 4) parseIFD(v, base, base + readU32(v, vOff, le), le, res);
    } catch { /**/ }
  }
}
function parseJpegExif(v: DataView): ExifData {
  if (v.getUint16(0) !== 0xFFD8) return {};
  let off = 2;
  while (off < v.byteLength - 1) {
    if (v.getUint8(off) !== 0xFF) break;
    const marker = v.getUint16(off); off += 2;
    if (marker === 0xFFE1) {
      const segLen = v.getUint16(off, false);
      const start = off + 2;
      if (readStr(v, start, 4) !== 'Exif') return {};
      const tiff = start + 6;
      const le = v.getUint16(tiff, false) === 0x4949;
      const res: ExifData = {};
      parseIFD(v, tiff, tiff + readU32(v, tiff + 4, le), le, res);
      return res;
    }
    off += v.getUint16(off, false);
  }
  return {};
}

/* ════════════════════════════════════════════════════════
   TILE HTML BUILDERS
════════════════════════════════════════════════════════ */
function placeholderSvg(): string {
  return `<svg width="22" height="22" viewBox="0 0 28 28" fill="none" aria-hidden="true"><rect x="2" y="2" width="24" height="24" stroke="#3E3A36" stroke-width="1"/><line x1="2" y1="26" x2="26" y2="2" stroke="#3E3A36" stroke-width="0.5"/></svg>`;
}

function progressRingSvg(pct: number): string {
  const offset = (94.25 * (1 - pct / 100)).toFixed(2);
  return `<svg width="34" height="34" viewBox="0 0 36 36" class="progress-ring" aria-hidden="true">
    <circle cx="18" cy="18" r="15" class="ring-track"/>
    <circle cx="18" cy="18" r="15" class="ring-arc" id="arc-{ID}" style="stroke-dashoffset:${offset}"/>
  </svg>`;
}

function buildQueueTile(item: FileItem): string {
  const thumb = item.thumb
    ? `<img src="${item.thumb}" alt="" class="tile-img" loading="lazy"/>`
    : `<div class="tile-placeholder">${placeholderSvg()}</div>`;

  let thumbCls = 'tile-thumb';
  let overlay = '';
  let foot = '';
  let extra = '';
  const name = item.file.name.length > 16 ? item.file.name.slice(0, 14) + '…' : item.file.name;

  if (item.status === 'queued') {
    foot = `<div class="tile-foot"><div class="tile-name">${name}</div><span class="tile-chip tile-chip--queued">QUEUED</span></div>`;
  } else if (item.status === 'uploading') {
    const ring = progressRingSvg(item.progress).replace('{ID}', item.id);
    overlay = `<div class="tile-overlay">${ring}</div>`;
    foot = `<div class="tile-foot"><div class="tile-name">${name}</div><span class="tile-chip tile-chip--pct" id="chip-${item.id}">${item.progress}%</span></div>`;
  } else if (item.status === 'processing') {
    thumbCls = 'tile-thumb tile-thumb--blur';
    foot = `<div class="tile-foot"><div class="tile-name">${name}</div><span class="tile-chip tile-chip--processing">PROCESSING</span></div>`;
  } else if (item.status === 'done') {
    foot = `<div class="tile-foot"><div class="tile-name">${name}</div><span class="tile-chip tile-chip--done">✓ DONE</span></div>`;
  } else if (item.status === 'failed') {
    thumbCls = 'tile-thumb tile-thumb--failed';
    const reason = item.error ?? 'Upload failed';
    foot = `<div class="tile-name" style="margin-top:8px">${name}</div>`;
    extra = `<div class="tile-failed-reason">${reason}</div>
      <div class="tile-failed-actions">
        <button class="tile-btn" data-action="retry" data-id="${item.id}" type="button">Retry</button>
        <button class="tile-btn tile-btn--muted" data-action="remove" data-id="${item.id}" type="button">Remove</button>
      </div>`;
  } else if (item.status === 'duplicate') {
    foot = `<div class="tile-name" style="margin-top:8px">${name}</div>`;
    extra = `<div class="tile-dup-info">${item.duplicateInfo ?? 'Already uploaded'}</div>
      <div class="tile-dup-actions">
        <button class="tile-dup-btn" data-action="dup-replace" data-id="${item.id}" type="button">Replace</button>
        <button class="tile-dup-btn" data-action="dup-keep" data-id="${item.id}" type="button">Keep Both</button>
        <button class="tile-dup-btn tile-dup-btn--muted" data-action="dup-skip" data-id="${item.id}" type="button">Skip</button>
      </div>`;
  }

  const thumbContent = item.status === 'failed'
    ? `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="#A3493B" stroke-width="1.4"/><path d="M12 7v6M12 16.5v.1" stroke="#A3493B" stroke-width="1.6" stroke-linecap="round"/></svg>`
    : thumb;

  return `<div class="q-tile q-tile--${item.status}" id="tile-${item.id}" role="listitem">
    <div class="${thumbCls}">${thumbContent}${overlay}</div>
    ${foot}${extra}
  </div>`;
}

function buildWallTile(item: FileItem): string {
  const thumb = item.thumb
    ? `<img src="${item.thumb}" alt="" class="tile-img" loading="lazy"/>`
    : `<div class="tile-placeholder">${placeholderSvg()}</div>`;

  const selectedCls = item.selected ? ' q-tile--selected' : '';
  const check = item.selected
    ? `<span class="tile-check" aria-hidden="true">✓</span>`
    : '';
  const name = item.file.name.length > 16 ? item.file.name.slice(0, 14) + '…' : item.file.name;

  return `<div class="q-tile${selectedCls}" id="tile-${item.id}" role="listitem"
    data-action="select" data-id="${item.id}" style="cursor:pointer" tabindex="0"
    aria-pressed="${item.selected}" aria-label="${item.file.name}">
    ${check}
    <div class="tile-thumb">${thumb}</div>
    <div class="tile-name" style="margin-top:8px">${name}</div>
  </div>`;
}

/* ════════════════════════════════════════════════════════
   RENDER
════════════════════════════════════════════════════════ */
function renderQueueGrid(): void {
  qid('queue-grid').innerHTML = items.map(buildQueueTile).join('');
  const total = items.length;
  qid('queue-count-text').textContent = `${total} photograph${total !== 1 ? 's' : ''} · uploads continue in the background`;
  updateUploadingSubtitle();
}

function renderPhotoWall(): void {
  const done = items.filter(i => i.status === 'done' && !i.confirmedAs);
  qid('photo-wall').innerHTML = done.map(buildWallTile).join('');
  updateSelectionBar();
}

function updateSelectionBar(): void {
  const sel = items.filter(i => i.selected);
  const bar = qid('selection-bar');
  bar.hidden = sel.length === 0;
  if (sel.length > 0) {
    qid('sel-badge').textContent = String(sel.length);
    qid('sel-hint').textContent = `Editing ${sel.length} photograph${sel.length !== 1 ? 's' : ''} together — fields left blank stay untouched`;
  }
  updateInspectorForSelection();
}

function updateInspectorForSelection(): void {
  const sel = items.filter(i => i.selected);
  const insp = qid('upload-inspector');
  if (sel.length === 0) {
    insp.classList.remove('is-open');
    insp.setAttribute('aria-hidden', 'true');
    qid('hub-main').classList.remove('insp-open');
    return;
  }
  // Open inspector
  insp.classList.add('is-open');
  insp.setAttribute('aria-hidden', 'false');
  qid('hub-main').classList.add('insp-open');
  qid('insp-title').textContent = `Inspector — ${sel.length} selected`;

  // Title: mixed or common
  const titles = [...new Set(sel.map(i => i.file.name.replace(/\.[^.]+$/, '').replace(/[-_]+/g, ' ').trim()))];
  const titleInput = qid('meta-title') as HTMLInputElement;
  if (titles.length > 1) {
    titleInput.placeholder = 'Mixed — click to overwrite all';
    titleInput.classList.add('insp-input--mixed');
    if (!titleInput.value) titleInput.value = '';
  } else {
    titleInput.placeholder = '';
    titleInput.classList.remove('insp-input--mixed');
  }

  // EXIF from first selected item
  const anchor = sel[0];
  renderExifChips(anchor.exif);

  // Publish button label
  qid('btn-publish').textContent = `Publish Now — ${sel.length} photograph${sel.length !== 1 ? 's' : ''}`;
}

function renderExifChips(exif?: ExifData): void {
  const section = qid('exif-section');
  if (!exif) { section.hidden = true; return; }
  const chips: string[] = [];
  if (exif.cameraMake || exif.cameraModel) chips.push([exif.cameraMake, exif.cameraModel].filter(Boolean).join(' '));
  if (exif.lensModel) chips.push(exif.lensModel);
  if (exif.aperture) chips.push(exif.aperture);
  if (exif.shutterSpeed) chips.push(exif.shutterSpeed);
  if (exif.iso) chips.push(`ISO ${exif.iso}`);
  if (exif.focalLengthMm) chips.push(`${exif.focalLengthMm}mm`);
  if (exif.dateTaken) chips.push(exif.dateTaken.slice(0, 10).replace(/:/g, '-'));
  if (chips.length === 0) { section.hidden = true; return; }
  section.hidden = false;
  const gps = (!exif.gpsLat) ? `<span class="exif-chip exif-chip--missing">GPS unavailable</span>` : '';
  qid('exif-chips').innerHTML = chips.map(c => `<span class="exif-chip">${c}</span>`).join('') + gps;
}

// Split raw input on commas so "a, b, c" adds three separate keywords (item 75).
function addKeywords(raw: string): void {
  raw.split(',').map(s => s.trim()).filter(Boolean).forEach(v => {
    if (!keywords.includes(v)) keywords.push(v);
  });
}

function renderKeywords(): void {
  const wrap = qid('keyword-wrap');
  wrap.innerHTML = keywords.map(k =>
    `<span class="kw-chip">${k}<button class="kw-remove" data-kw="${k}" type="button" aria-label="Remove ${k}">✕</button></span>`
  ).join('') + (addingKeyword
    ? `<input class="kw-input" id="kw-input" type="text" placeholder="tag…" maxlength="40" autofocus />`
    : `<button class="kw-add-btn" id="kw-add-btn" type="button">+ add</button>`
  );
  wrap.querySelectorAll('.kw-remove').forEach(btn => {
    btn.addEventListener('click', () => {
      const kw = (btn as HTMLElement).dataset.kw ?? '';
      keywords = keywords.filter(k => k !== kw);
      renderKeywords();
    });
  });
  if (addingKeyword) {
    const inp = document.getElementById('kw-input') as HTMLInputElement;
    inp?.focus();
    inp?.addEventListener('keydown', e => {
      // Comma commits the typed keyword(s) but keeps the field open for more.
      if (e.key === 'Enter' || e.key === ',') {
        e.preventDefault();
        addKeywords(inp.value);
        if (e.key === ',') { inp.value = ''; renderKeywords(); }
        else { addingKeyword = false; renderKeywords(); }
      }
      if (e.key === 'Escape') { addingKeyword = false; renderKeywords(); }
    });
    inp?.addEventListener('blur', () => {
      addKeywords(inp.value);
      addingKeyword = false;
      renderKeywords();
    });
  } else {
    document.getElementById('kw-add-btn')?.addEventListener('click', () => {
      addingKeyword = true;
      renderKeywords();
    });
  }
}

/* ════════════════════════════════════════════════════════
   UPLOAD LOGIC
════════════════════════════════════════════════════════ */
function checkAllTerminal(): void {
  const nonTerminal = items.filter(i => i.status === 'queued' || i.status === 'uploading' || i.status === 'processing');
  if (nonTerminal.length === 0 && items.length > 0) {
    // All resolved — move to metadata
    setTimeout(() => {
      setPhase('metadata');
      renderPhotoWall();
      renderKeywords();
    }, 400);
  }
}

function updateItemState(id: string, update: Partial<FileItem>): void {
  const item = items.find(i => i.id === id);
  if (!item) return;
  Object.assign(item, update);

  if (phase === 'uploading') {
    // Targeted DOM update for progress
    if (update.progress !== undefined && item.status === 'uploading') {
      const arc = document.getElementById(`arc-${id}`) as SVGCircleElement | null;
      if (arc) arc.style.strokeDashoffset = String(94.25 * (1 - (update.progress ?? 0) / 100));
      const chip = document.getElementById(`chip-${id}`);
      if (chip) chip.textContent = `${update.progress}%`;
      updateUploadingSubtitle();
      return;
    }
    // Full tile re-render on status change
    const existing = document.getElementById(`tile-${id}`);
    if (existing) {
      const tmp = document.createElement('div');
      tmp.innerHTML = buildQueueTile(item);
      existing.replaceWith(tmp.firstElementChild!);
    }
    updateUploadingSubtitle();
  }
}

async function uploadItem(item: FileItem): Promise<void> {
  const ac = new AbortController();
  abortMap.set(item.id, ac);

  try {
    updateItemState(item.id, { status: 'uploading', progress: 5 });

    const presignRes = await fetch('/api/v1/gallery/photos/presign', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${tok()}` },
      body: JSON.stringify({
        mime_type: item.file.type || 'image/jpeg',
        file_size_bytes: item.file.size,
        filename: item.file.name,
      }),
      signal: ac.signal,
    });

    if (!presignRes.ok) throw new Error(`Presign failed (${presignRes.status})`);
    const { photo_uuid, presign_url } = await presignRes.json() as { photo_uuid: string; presign_url: string };
    updateItemState(item.id, { photoUuid: photo_uuid });

    // XHR PUT for progress events
    await new Promise<void>((resolve, reject) => {
      const xhr = new XMLHttpRequest();
      xhr.open('PUT', presign_url);
      xhr.setRequestHeader('Content-Type', item.file.type || 'image/jpeg');
      xhr.upload.addEventListener('progress', e => {
        if (e.lengthComputable) {
          updateItemState(item.id, { progress: Math.round((e.loaded / e.total) * 88) + 7 });
        }
      });
      xhr.addEventListener('load', () => {
        if (xhr.status >= 200 && xhr.status < 300) resolve();
        else reject(new Error(`Storage PUT failed (${xhr.status})`));
      });
      xhr.addEventListener('error', () => reject(new Error('Network error')));
      ac.signal.addEventListener('abort', () => { xhr.abort(); reject(new Error('Cancelled')); });
      xhr.send(item.file);
    });

    updateItemState(item.id, { status: 'processing', progress: 100 });

    // Extract EXIF while "processing"
    const exif = await extractExif(item.file);
    updateItemState(item.id, { exif });

    await new Promise(r => setTimeout(r, 700));
    updateItemState(item.id, { status: 'done' });

  } catch (err) {
    const msg = (err as Error).message;
    if (msg === 'Cancelled') {
      updateItemState(item.id, { status: 'failed', error: 'Cancelled' });
    } else {
      updateItemState(item.id, { status: 'failed', error: msg || 'Upload failed' });
    }
  }

  abortMap.delete(item.id);
  checkAllTerminal();
}

async function runUploadQueue(): Promise<void> {
  // Parallel with CONCURRENCY limit
  let active = 0;
  const queue = [...items.filter(i => i.status === 'queued')];
  let idx = 0;
  await new Promise<void>(resolve => {
    function next() {
      while (active < CONCURRENCY && idx < queue.length) {
        const item = queue[idx++];
        active++;
        uploadItem(item).finally(() => { active--; next(); if (active === 0 && idx >= queue.length) resolve(); });
      }
      if (queue.length === 0) resolve();
    }
    next();
  });
}

/* ════════════════════════════════════════════════════════
   FILE HANDLING
════════════════════════════════════════════════════════ */
const ALLOWED = new Set([
  'image/jpeg','image/jpg','image/tiff','image/x-nikon-nef',
  'image/x-canon-cr2','image/x-canon-cr3','image/x-sony-arw','image/x-adobe-dng',
]);

function addFiles(files: FileList | File[]): void {
  const arr = Array.from(files).filter(f => {
    if (f.size > MAX_BYTES) return false;
    return ALLOWED.has(f.type) || /\.(jpg|jpeg|tiff?|nef|cr2|cr3|arw|dng)$/i.test(f.name);
  });
  if (!arr.length) return;

  const newItems: FileItem[] = arr.map(f => {
    const thumb = f.type.startsWith('image/') ? URL.createObjectURL(f) : undefined;
    return { id: uid(), file: f, status: 'queued', progress: 0, thumb, selected: false };
  });
  items.push(...newItems);

  if (phase === 'empty') setPhase('uploading');
  renderQueueGrid();
  runUploadQueue().catch(() => {});
}

/* ════════════════════════════════════════════════════════
   PUBLISH
════════════════════════════════════════════════════════ */

// Attempt silent token refresh; returns true if a new access token was stored.
async function tryRefreshToken(): Promise<boolean> {
  const refresh = localStorage.getItem('bcc_refresh');
  if (!refresh) return false;
  try {
    const res = await fetch('/api/v1/auth/refresh', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ refreshToken: refresh }),
    });
    if (!res.ok) return false;
    const data = await res.json() as { accessToken?: string; refreshToken?: string };
    if (data.accessToken) {
      localStorage.setItem('bcc_token', data.accessToken);
      if (data.refreshToken) localStorage.setItem('bcc_refresh', data.refreshToken);
      return true;
    }
    return false;
  } catch { return false; }
}

function showPubError(msg: string): void {
  let banner = document.getElementById('pub-error-banner') as HTMLElement | null;
  if (!banner) {
    banner = document.createElement('div');
    banner.id = 'pub-error-banner';
    banner.style.cssText = 'background:#FDF4F3;border:1px solid #E7C6BE;color:#A3493B;font-size:13px;padding:12px 16px;margin:0 28px 12px;line-height:1.5;';
    const pubCtrl = qid('upload-inspector');
    const pubControl = pubCtrl?.querySelector('.pub-control');
    if (pubControl) pubControl.parentNode!.insertBefore(banner, pubControl);
    else pubCtrl?.appendChild(banner);
  }
  banner.textContent = msg;
  banner.hidden = false;
}

function clearPubError(): void {
  const banner = document.getElementById('pub-error-banner');
  if (banner) banner.hidden = true;
}

// Assign the inspector's selected categories to a confirmed photo (item 71).
async function assignCategories(photoUuid: string): Promise<void> {
  for (const key of selectedCategories) {
    const tagId = categoryTagIds[key];
    if (!tagId) continue;
    try {
      await fetch(`/api/v1/gallery/photos/${photoUuid}/tags/${tagId}`, {
        method: 'POST',
        headers: { Authorization: `Bearer ${tok()}` },
      });
    } catch { /* best-effort */ }
  }
}

async function confirmItems(
  selectedIds: string[],
  visibility: string,
): Promise<{ confirmed: number; errorMsg: string | null }> {
  const title       = (qid('meta-title')        as HTMLInputElement).value.trim();
  const description = (qid('meta-description') as HTMLTextAreaElement).value.trim() || null;
  const exhibLabel  = (qid('meta-exh-label')   as HTMLInputElement).value.trim() || null;
  const location    = (qid('meta-location')    as HTMLInputElement).value.trim();
  // show_in_portfolio: true by default; false when the checkbox is checked.
  const hidePortfolio = (qid('meta-hide-portfolio') as HTMLInputElement).checked;
  const showInPortfolio = !hidePortfolio;

  let confirmed = 0;
  let errorMsg: string | null = null;

  for (const id of selectedIds) {
    const item = items.find(i => i.id === id);
    if (!item) continue;
    if (!item.photoUuid) {
      console.error('[BCC Upload] confirm skipped — photoUuid not set for', item.file.name, '(item id:', id, ')');
      errorMsg = 'Upload reference missing — please re-upload this photo.';
      continue;
    }

    const body = JSON.stringify({
      title: title || item.file.name.replace(/\.[^.]+$/, '').replace(/[-_]+/g, ' ').trim(),
      caption: location ? `Location: ${location}` : undefined,
      description: description || undefined,
      exhibition_label: exhibLabel || undefined,
      visibility,
      show_in_portfolio: showInPortfolio,
      exif: {
        width_px:      item.exif?.widthPx,
        height_px:     item.exif?.heightPx,
        camera_make:   item.exif?.cameraMake,
        camera_model:  item.exif?.cameraModel,
        lens_model:    item.exif?.lensModel,
        iso:           item.exif?.iso,
        aperture:      item.exif?.aperture ? parseFloat(item.exif.aperture.replace('f/', '')) : undefined,
        shutter_speed: item.exif?.shutterSpeed,
        focal_length:  item.exif?.focalLengthMm,
        // EXIF date is "YYYY:MM:DD HH:MM:SS" — replace date colons so Date() can parse it
        taken_at: item.exif?.dateTaken
          ? item.exif.dateTaken.replace(/^(\d{4}):(\d{2}):(\d{2})/, '$1-$2-$3')
          : undefined,
      },
    });

    try {
      let res = await fetch(`/api/v1/gallery/photos/${item.photoUuid}/confirm`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${tok()}` },
        body,
      });

      // Token expired — attempt silent refresh and retry once
      if (res.status === 401) {
        const refreshed = await tryRefreshToken();
        if (refreshed) {
          res = await fetch(`/api/v1/gallery/photos/${item.photoUuid}/confirm`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${tok()}` },
            body,
          });
        }
      }

      if (res.ok) {
        item.confirmedAs = visibility === 'PRIVATE' ? 'drafted' : 'published';
        item.selected = false;
        confirmed++;
        // Attach selected categories (item 71) — best-effort, never blocks upload.
        await assignCategories(item.photoUuid);
      } else {
        let msg = `Server error (${res.status})`;
        try {
          const errBody = await res.json() as { message?: string | string[] };
          const raw = errBody.message;
          msg = Array.isArray(raw) ? raw.join('; ') : (raw ?? msg);
        } catch { /**/ }
        console.error(`[BCC Upload] confirm failed for "${item.file.name}" — HTTP ${res.status}:`, msg);
        errorMsg = msg;
      }
    } catch (err) {
      const msg = (err as Error).message || 'Network error';
      console.error(`[BCC Upload] confirm network error for "${item.file.name}":`, msg);
      errorMsg = msg;
    }
  }

  return { confirmed, errorMsg };
}

async function handlePublish(asDraft: boolean): Promise<void> {
  const sel = items.filter(i => i.selected).map(i => i.id);
  if (!sel.length) return;

  const btnP = qid('btn-publish') as HTMLButtonElement;
  const btnD = qid('btn-draft') as HTMLButtonElement;
  btnP.disabled = true; btnD.disabled = true;
  clearPubError();

  const visibility = asDraft ? 'PRIVATE' : (qid('meta-visibility') as HTMLSelectElement).value;
  const { confirmed, errorMsg } = await confirmItems(sel, visibility);

  if (asDraft) draftCount += confirmed;
  else publishedCount += confirmed;

  if (errorMsg && confirmed === 0) {
    // All failed — keep inspector open, show error
    showPubError(errorMsg);
    btnP.disabled = false; btnD.disabled = false;
    return;
  }

  // Close inspector
  qid('upload-inspector').classList.remove('is-open');
  qid('upload-inspector').setAttribute('aria-hidden', 'true');
  qid('hub-main').classList.remove('insp-open');

  // Check if all done items are confirmed
  const unconfirmed = items.filter(i => i.status === 'done' && !i.confirmedAs);
  if (unconfirmed.length === 0) {
    // Transition to complete
    const totalPublished = items.filter(i => i.confirmedAs === 'published').length;
    const totalDrafted   = items.filter(i => i.confirmedAs === 'drafted').length;
    let headline = '';
    if (totalPublished && totalDrafted) headline = `${totalPublished} photograph${totalPublished !== 1 ? 's' : ''} published, ${totalDrafted} saved as draft${totalDrafted !== 1 ? 's' : ''}.`;
    else if (totalPublished) headline = `${totalPublished} photograph${totalPublished !== 1 ? 's' : ''} published.`;
    else headline = `${totalDrafted} photograph${totalDrafted !== 1 ? 's' : ''} saved as draft${totalDrafted !== 1 ? 's' : ''}.`;
    qid('complete-headline').textContent = headline;
    setPhase('complete');
  } else {
    if (errorMsg) showPubError(`Some photographs could not be published: ${errorMsg}`);
    renderPhotoWall();
    btnP.disabled = false; btnD.disabled = false;
  }
}

/* ════════════════════════════════════════════════════════
   EVENT WIRING
════════════════════════════════════════════════════════ */
const fileInput = qid('file-input') as HTMLInputElement;
const dropZone = qid('drop-zone');
const isMobile = () => window.innerWidth <= 640;

// Drop zone
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drop-zone--over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drop-zone--over'));
dropZone.addEventListener('drop', e => {
  e.preventDefault(); dropZone.classList.remove('drop-zone--over');
  if (e.dataTransfer?.files) addFiles(e.dataTransfer.files);
});
dropZone.addEventListener('click', () => {
  if (isMobile()) { openSourcePicker(); } else { fileInput.click(); }
});
dropZone.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); } });

// Choose button
qid('btn-choose').addEventListener('click', e => {
  e.stopPropagation();
  if (isMobile()) { openSourcePicker(); } else { fileInput.click(); }
});

// File input
fileInput.addEventListener('change', () => {
  if (fileInput.files) addFiles(fileInput.files);
  fileInput.value = '';
});

// Cancel remaining
qid('btn-cancel').addEventListener('click', () => {
  abortMap.forEach(ac => ac.abort());
  abortMap.clear();
  items.forEach(i => { if (i.status === 'queued' || i.status === 'uploading') i.status = 'failed'; });
  renderQueueGrid();
  checkAllTerminal();
});

// Queue grid — event delegation
qid('queue-grid').addEventListener('click', e => {
  const btn = (e.target as Element).closest('[data-action]') as HTMLElement | null;
  if (!btn) return;
  const id = btn.dataset.id!;
  const action = btn.dataset.action!;
  const item = items.find(i => i.id === id);
  if (!item) return;

  if (action === 'retry') {
    item.status = 'queued'; item.error = undefined; item.progress = 0;
    const existing = document.getElementById(`tile-${id}`);
    if (existing) { const tmp = document.createElement('div'); tmp.innerHTML = buildQueueTile(item); existing.replaceWith(tmp.firstElementChild!); }
    uploadItem(item).catch(() => {});
  }
  if (action === 'remove') {
    items = items.filter(i => i.id !== id);
    document.getElementById(`tile-${id}`)?.remove();
    checkAllTerminal();
  }
  if (action === 'dup-replace' || action === 'dup-keep') {
    item.status = 'queued'; item.duplicateInfo = undefined;
    uploadItem(item).catch(() => {});
  }
  if (action === 'dup-skip') {
    items = items.filter(i => i.id !== id);
    document.getElementById(`tile-${id}`)?.remove();
    checkAllTerminal();
  }
});

// Photo wall — click to select/deselect
qid('photo-wall').addEventListener('click', e => {
  const tile = (e.target as Element).closest('[data-action="select"]') as HTMLElement | null;
  if (!tile) return;
  const id = tile.dataset.id!;
  const item = items.find(i => i.id === id);
  if (!item) return;
  item.selected = !item.selected;
  renderPhotoWall();
});

qid('photo-wall').addEventListener('keydown', e => {
  if (e.key === 'Enter' || e.key === ' ') {
    const tile = (e.target as Element).closest('[data-action="select"]') as HTMLElement | null;
    if (!tile) return;
    e.preventDefault();
    tile.click();
  }
});

// Clear selection
qid('btn-clear-sel').addEventListener('click', () => {
  items.forEach(i => { i.selected = false; });
  renderPhotoWall();
});

// Inspector close
qid('btn-close-insp').addEventListener('click', () => {
  items.forEach(i => { i.selected = false; });
  renderPhotoWall();
  qid('upload-inspector').classList.remove('is-open');
  qid('upload-inspector').setAttribute('aria-hidden', 'true');
  qid('hub-main').classList.remove('insp-open');
});

// Category pills (item 71) — multi-select
qid('genre-pills').addEventListener('click', e => {
  const btn = (e.target as Element).closest('.pill') as HTMLElement | null;
  if (!btn || !btn.dataset.value) return;
  const val = btn.dataset.value;
  if (selectedCategories.has(val)) selectedCategories.delete(val);
  else selectedCategories.add(val);
  btn.classList.toggle('pill--active', selectedCategories.has(val));
});

// Auto-genre suggestions per Project. Only ADDS genres — never removes.
// Deselecting a Project leaves any previously suggested genres untouched.
const PROJECT_GENRE_SUGGESTIONS: Record<string, string[]> = {
  'birds-of-bhopal':       ['bird'],
  'butterflies-of-bhopal': ['butterflies', 'macro'],
  'wildlife-of-bhopal':    ['wildlife'],
  'heritage-of-bhopal':    ['architecture', 'monuments'],
};

function applySuggestions(projectKey: string): void {
  const suggestions = PROJECT_GENRE_SUGGESTIONS[projectKey];
  if (!suggestions) return;
  const genreGroup = qid('genre-pills');
  suggestions.forEach(genreKey => {
    if (!selectedCategories.has(genreKey)) {
      selectedCategories.add(genreKey);
      const pill = genreGroup.querySelector<HTMLElement>(`[data-value="${genreKey}"]`);
      if (pill) pill.classList.add('pill--active');
    }
  });
}

// Project pills — multi-select; activating a project triggers genre suggestions.
qid('project-pills').addEventListener('click', e => {
  const btn = (e.target as Element).closest('.pill') as HTMLElement | null;
  if (!btn || !btn.dataset.value) return;
  const val = btn.dataset.value;
  if (selectedCategories.has(val)) {
    selectedCategories.delete(val);
  } else {
    selectedCategories.add(val);
    applySuggestions(val);
  }
  btn.classList.toggle('pill--active', selectedCategories.has(val));
});

// Activity pills
qid('activity-pills').addEventListener('click', e => {
  const btn = (e.target as Element).closest('.pill') as HTMLElement | null;
  if (!btn) return;
  const val = btn.dataset.value!;
  activeActivity = activeActivity === val ? null : val;
  qid('activity-pills').querySelectorAll('.pill').forEach(p => p.classList.toggle('pill--active', (p as HTMLElement).dataset.value === activeActivity));
});

// Publish / Draft
qid('btn-publish').addEventListener('click', () => handlePublish(false).catch((err: unknown) => {
  console.error('[BCC Upload] handlePublish crashed:', err);
  showPubError('Unexpected error — please try again. (Check console for details.)');
  (qid('btn-publish') as HTMLButtonElement).disabled = false;
  (qid('btn-draft') as HTMLButtonElement).disabled = false;
}));
qid('btn-draft').addEventListener('click', () => handlePublish(true).catch((err: unknown) => {
  console.error('[BCC Upload] handlePublish crashed:', err);
  showPubError('Unexpected error — please try again. (Check console for details.)');
  (qid('btn-publish') as HTMLButtonElement).disabled = false;
  (qid('btn-draft') as HTMLButtonElement).disabled = false;
}));

// Upload More
qid('btn-upload-more').addEventListener('click', () => {
  items = []; publishedCount = 0; draftCount = 0;
  activeActivity = null; keywords = [];
  selectedCategories.clear();
  qid('genre-pills').querySelectorAll('.pill').forEach(p => p.classList.remove('pill--active'));
  qid('project-pills').querySelectorAll('.pill').forEach(p => p.classList.remove('pill--active'));
  setPhase('empty');
});

