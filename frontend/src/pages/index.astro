</style>


<script>
  /**
   * Home page scripts:
   * 1. PageHero — Hero Assignment Architecture via loadHomeHero()
   * 2. Gallery wall — fetch + justified layout
   * 3. Club cards — dynamic genre photo backgrounds
   * 4. Journal — fetch latest 3 posts
   */
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { loadHomeHero } from '../lib/hero-loader';
  gsap.registerPlugin(ScrollTrigger);

  /* ── 1. PageHero — Hero Assignment Architecture ── */
  loadHomeHero();

  /* ── 1b. Club cards — dynamic genre photo backgrounds ── */
  (() => {
    const CARD_GENRES = [
      { id: 'card-img-photowalk',   tag: 'street'    },
      { id: 'card-img-contests',    tag: 'wildlife'  },
      { id: 'card-img-exhibitions', tag: 'landscape' },
      { id: 'card-img-school',      tag: 'portrait'  },
    ];
    for (const { id, tag } of CARD_GENRES) {
      const area = document.getElementById(id);
      if (!area) continue;
      fetch(`/api/v1/gallery/feed?tag=${tag}&limit=5&shuffle=true`)
        .then(r => r.ok ? r.json() : null)
        .then(data => {
          const p = data?.photos?.[0];
          const imgUrl = p?.urls?.medium ?? p?.urls?.thumbnail ?? '';
          if (!imgUrl) return;
          const img = document.createElement('img');
          img.src = imgUrl;
          img.alt = '';
          img.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;';
          area.style.position = 'relative';
          area.insertBefore(img, area.firstChild);
          const grad = area.querySelector('.club-card__gradient') as HTMLElement | null;
          if (grad) { grad.style.position = 'absolute'; grad.style.inset = '0'; grad.style.zIndex = '1'; }
        })
        .catch(() => { /* gradient fallback */ });
    }
  })();

  /* ── 2. Gallery wall — justified layout ── */
  function buildRows(
    photos: Array<{ aspect: number }>,
    containerWidth: number,
    targetH = 240,
    gap = 8
  ) {
    const rows: Array<{ height: number; items: typeof photos }> = [];
    let row: typeof photos = [], rowW = 0;

    const flush = (last = false) => {
      if (!row.length) return;
      const totalGap = gap * (row.length - 1);
      const scale = last ? Math.min(1, (containerWidth - totalGap) / rowW) : (containerWidth - totalGap) / rowW;
      const h = targetH * scale;
      rows.push({ height: h, items: row.map(p => ({ ...p, width: p.aspect * h })) });
      row = []; rowW = 0;
    };

    for (const p of photos) {
      const iW = p.aspect * targetH;
      row.push(p); rowW += iW;
      if (rowW + gap * (row.length - 1) >= containerWidth * 0.88) flush();
    }
    
    // Discard incomplete final row entirely per editorial rules.
    // We only return rows that completed naturally inside the loop.
    return rows;
  }

  (async () => {
    const grid = document.getElementById('gallery-grid');
    const skel = document.getElementById('gallery-skeleton');
    if (!grid) return;

    let photos: any[] = [];
    try {
      // gallery/feed returns { photos: [...], total: N }.
      // Normalise each item to the shape buildRows() expects.
      const res = await fetch('/api/v1/gallery/feed?limit=20');
      if (res.ok) {
        const { photos: _raw } = await res.json();
        photos = (Array.isArray(_raw) ? _raw : []).map((p: any) => ({
          id:           p.uuid,
          title:        p.title ?? '',
          photographer: p.photographer ? {
            name: p.photographer.name ?? 'BCC Member',
            username: p.photographer.username ?? ''
          } : null,
          imageUrl:     p.urls?.medium ?? p.urls?.original ?? '',
          aspect:       (p.width_px && p.height_px) ? p.width_px / p.height_px : 1.5,
        }));
      }
    } catch { /* empty */ }

    skel?.remove();
    if (photos.length === 0) return; // No photos yet — gallery wall stays empty (Phase 2a)

    const containerWidth = grid.clientWidth;
    buildRows(photos, containerWidth).forEach(row => {
      const rowEl = document.createElement('div');
      rowEl.className = 'jrow';

      (row.items as any[]).forEach((p: any) => {
        const a = document.createElement('a');
        if (p.photographer && p.photographer.username) {
          a.href = `/photographers/${p.photographer.username}/`;
        } else {
          a.href = `/showcase/${p.id}/`;
        }
        a.className = 'photo-card';
        a.style.cssText = `width:${p.width}px;height:${row.height}px;`;

        // Render viewfinder corners
        const corners = ['top-left', 'top-right', 'bottom-left', 'bottom-right'];
        corners.forEach(c => {
          const div = document.createElement('div');
          div.className = `viewfinder-corner ${c}`;
          a.appendChild(div);
        });

        const img = document.createElement('img');
        img.src = p.imageUrl ?? '';
        img.alt = p.photographer
          ? `${p.title || 'Untitled'} by ${p.photographer.name} · Bhopal Camera Club`
          : (p.title ? `${p.title} · Bhopal Camera Club` : 'Bhopal Camera Club member photograph');
        img.loading = 'lazy'; img.decoding = 'async';
        img.onload = () => img.classList.add('loaded');

        const cap = document.createElement('div');
        cap.className = 'photo-caption';

        const ph = document.createElement('div');
        ph.className = 'photo-caption__photographer';
        ph.textContent = p.photographer ? p.photographer.name : 'BCC Member';
        cap.appendChild(ph);

        const lk = document.createElement('div');
        lk.className = 'photo-caption__link';
        if (p.photographer && p.photographer.username) {
          lk.textContent = `→ /photographers/${p.photographer.username}`;
        } else {
          lk.textContent = 'View in Showcase';
        }
        cap.appendChild(lk);

        a.appendChild(img); a.appendChild(cap);
        rowEl.appendChild(a);
      });
      grid.appendChild(rowEl);
    });

    gsap.from('#gallery-grid .photo-card', { opacity: 0, y: 20, duration: 0.6, stagger: { amount: 0.4, from: 'random' }, ease: 'power2.out', scrollTrigger: { trigger: grid, start: 'top 85%', once: true } });
  })();

  /* ── 3. Upcoming events ── */
  // Statically pre-rendered via Astro from ActivityService

  /* ── 4. Journal preview — uses EditorialCard (V6 62) class names ── */
  (async () => {
    const grid = document.getElementById('journal-grid');
    if (!grid) return;
    const showEmpty = () => {
      grid.innerHTML = `<div style="grid-column: 1 / -1; padding: var(--s-8) 0; text-align: center; color: var(--ink-400); font-family: var(--font-body); font-size: var(--text-small); border: 1px dashed var(--hairline-strong); background: var(--surface-0);">No journal articles available yet.</div>`;
    };
    try {
      const res = await fetch('/api/v1/journal?limit=3');
      if (!res.ok) { showEmpty(); return; }
      const { data } = await res.json();
      const posts = Array.isArray(data) ? data : [];
      if (!posts.length) { showEmpty(); return; }

      grid.innerHTML = '';
      posts.forEach((post: any) => {
        const card = document.createElement('a');
        card.href = `/journal/${post.slug ?? post.id}/`;
        card.className = 'editorial-card editorial-card--card';

        const imageUrl = post.heroImage;
        const category = post.category ?? 'Journal';
        const title = post.title ?? '';
        const excerpt = post.excerpt ?? post.description ?? '';
        const authorName = post.author?.name ?? 'Bhopal Camera Club';
        const readTime = post.readingTime ?? '5 min';
        const date = post.pubDate
          ? new Date(post.pubDate).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })
          : '';
        const metaParts = [date, authorName, `${readTime} read`].filter(Boolean);

        card.innerHTML = `
          <div class="editorial-card__img-wrap">
            ${imageUrl
              ? `<img src="${imageUrl}" alt="${title}" class="editorial-card__img" loading="lazy" decoding="async" />`
              : `<div class="editorial-card__img-placeholder" aria-hidden="true"></div>`
            }
          </div>
          <div class="editorial-card__body">
            <span class="editorial-card__category">${category}</span>
            <h3 class="editorial-card__title">${title}</h3>
            ${excerpt ? `<p class="editorial-card__excerpt">${excerpt}</p>` : ''}
            <div class="editorial-card__meta">
              ${metaParts.map((p, i) => i === 0 ? `<span>${p}</span>` : `<span class="editorial-card__sep" aria-hidden="true">·</span><span>${p}</span>`).join('')}
            </div>
          </div>
        `;
        grid.appendChild(card);
      });
    } catch {
      showEmpty();
    }
  })();
</script>
