---
/**
 * index.astro — Home Page
 * Hierarchy per BCC_V3_Design_System.md §14 (frozen):
 *   1. BCC Spotlight hero (full-bleed, museum label plate)
 *   2. StatBand (GSAP counter)
 *   3. Gallery Wall — "Our members, on the wall."
 *   4. Upcoming Events (3 rows from API)
 *   5. Full-bleed photo band (parallax)
 *   6. Membership tiers (3 public: Basic · Student · Individual)
 *   7. Journal preview (3 cards)
 *
 * Design: "Refined Editorial Luxury" — no glassmorphism, light surfaces,
 * square photo frames, one gold CTA per view (nav "Become a Member" is it).
 *
 * MEM-006: only Basic, Student, Individual classes on this public page.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
---

<BaseLayout
  title="Home"
  description="Bhopal Camera Club — photography community since 2016. Explore member portfolios, upcoming events, and join Bhopal's most active photography club."
>

  <!-- ══════════════════════════════════════════════════
       1. HERO SPOTLIGHT
       Full-bleed member photo + museum label plate.
       Committee-curated — no fixed cadence.
       ══════════════════════════════════════════════════ -->
  <section class="spotlight" aria-label="BCC Spotlight" style={`padding-top: var(--nav-h);`}>

    <!-- Image -->
    <div class="spotlight-img" id="spotlight-img" data-gsap="parallax-soft">
      <!-- Fallback gradient — replaced by JS when API returns a photo -->
      <div class="spotlight-fallback" id="spotlight-fallback" aria-hidden="true"></div>
      <img
        id="spotlight-photo"
        src=""
        alt=""
        class="spotlight-photo"
        loading="eager"
        decoding="async"
        aria-hidden="true"
      />
    </div>

    <!-- Dark overlay -->
    <div class="spotlight-overlay" aria-hidden="true"></div>

    <!-- BCC Spotlight chip -->
    <div class="spotlight-chip" aria-label="BCC Spotlight">BCC Spotlight</div>

    <!-- Museum label plate — bottom-left -->
    <div class="spotlight-plate" id="spotlight-plate">
      <div class="spotlight-plate__meta label-plate" id="spotlight-activity"></div>
      <h1 class="spotlight-plate__title" id="spotlight-title">
        Light, Frame,&thinsp;Moment.
      </h1>
      <div class="spotlight-plate__credit" id="spotlight-credit"></div>
      <div class="spotlight-plate__ctas">
        <a href="/showcase/" class="btn btn-dark btn-lg">Explore Showcase</a>
      </div>
    </div>

  </section>


  <!-- ══════════════════════════════════════════════════
       2. STAT BAND
       ══════════════════════════════════════════════════ -->
  <div class="statband surface-white" aria-label="Club statistics">
    <div class="container">
      <div class="statband-inner" data-gsap="stagger">

        <div class="stat">
          <div class="stat-value">
            <span data-gsap="counter" data-target="20">—</span>
          </div>
          <div class="stat-label">Active Members</div>
        </div>

        <div class="statband-divider" aria-hidden="true"></div>

        <div class="stat">
          <div class="stat-value">
            <span data-gsap="counter" data-target="311">—</span>
          </div>
          <div class="stat-label">Portfolio Photographs</div>
        </div>

        <div class="statband-divider" aria-hidden="true"></div>

        <div class="stat">
          <div class="stat-value">
            <span data-gsap="counter" data-target="47">—</span>
          </div>
          <div class="stat-label">Events Hosted</div>
        </div>

        <div class="statband-divider" aria-hidden="true"></div>

        <div class="stat">
          <div class="stat-value">
            <span data-gsap="counter" data-target="4">—</span>
          </div>
          <div class="stat-label">Exhibitions Curated</div>
        </div>

      </div>
    </div>
  </div>


  <!-- ══════════════════════════════════════════════════
       3. GALLERY WALL — Justified grid
       "Our members, on the wall."
       Max one frame per photographer. Flickr algorithm.
       ══════════════════════════════════════════════════ -->
  <section class="section gallery-wall" id="gallery-wall" aria-label="Member gallery wall">
    <div class="container">

      <div class="gallery-wall-header">
        <SectionHeader
          eyebrow="On the Wall"
          title="Our members, on the wall."
          subtitle="One frame per photographer — original aspect ratios preserved, as composed."
        />
        <a href="/showcase/" class="btn btn-outline btn-md">View all in Showcase</a>
      </div>

      <!-- Justified grid — populated by JS -->
      <div class="justified-grid" id="gallery-grid" aria-label="Member photographs">
        <!-- Skeleton rows -->
        <div id="gallery-skeleton">
          {[[3.2,1.5,4.0,1.0],[1.0,2.5,1.2,2.0,1.8],[2.4,1.5,3.0,1.0]].map(row => (
            <div class="jrow">
              {row.map(flex => <div class="skel" style={`flex:${flex};height:240px;`}></div>)}
            </div>
          ))}
        </div>
      </div>

      <p class="gallery-footnote auth-hide">
        Your frame could hang here —&nbsp;
        <a href="/join/" class="btn-text">Become a Member</a>
      </p>

    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       4. THE CLUB
       ══════════════════════════════════════════════════ -->
  <section class="section the-club" id="the-club" aria-label="The Club">
    <div class="container">
      <!-- The Club content scaffold -->
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       5. FEATURED ACTIVITY (Conditional)
       ══════════════════════════════════════════════════ -->
  <section class="featured-activity" id="featured-activity" aria-label="Featured Activity">
    <!-- Featured Activity content scaffold -->
  </section>


  <!-- ══════════════════════════════════════════════════
       6. UPCOMING ACTIVITIES
       ══════════════════════════════════════════════════ -->
  <section class="section section-sm surface-alt events-section" id="upcoming-activities" aria-label="Upcoming activities">
    <div class="container">

      <div class="events-header">
        <SectionHeader
          eyebrow="What's On"
          title="Upcoming activities"
        />
        <a href="/activities/" class="btn btn-outline btn-md">All activities</a>
      </div>

      <div class="events-list" id="events-list" aria-label="Upcoming events list">
        <!-- Skeleton rows -->
        {[1,2,3].map(() => (
          <div class="event-row-skel">
            <div class="skel" style="width:52px;height:60px;"></div>
            <div style="flex:1;">
              <div class="skel" style="width:30%;height:9px;margin-bottom:8px;"></div>
              <div class="skel" style="width:70%;height:14px;margin-bottom:8px;"></div>
              <div class="skel" style="width:45%;height:9px;"></div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       7. PHOTO SERIES
       Heritage series, soft parallax, dark surface.
       ══════════════════════════════════════════════════ -->
  <section class="photo-band surface-deep" id="photo-series" aria-label="Photo Series">
    <div class="photo-band-img" data-gsap="parallax-soft" id="photo-band-img">
      <!-- Loaded from API /api/v1/photos/band; fallback is dark surface -->
    </div>
    <div class="photo-band-overlay"></div>
  </section>


  <!-- ══════════════════════════════════════════════════
       8. MEMBERSHIP
       3 public classes only (MEM-006 public domain policy)
       ══════════════════════════════════════════════════ -->
  <section class="section membership-section" id="membership" aria-label="Membership tiers">
    <div class="container">

      <SectionHeader
        eyebrow="Membership"
        title="Join Bhopal Camera Club"
        subtitle="Three classes open to new applicants — registration is always free and comes first."
        align="center"
        data-gsap="reveal"
      />

      <!-- 3-step flow: Register Free → Apply → Participate -->
      <div class="flow-strip" data-gsap="stagger">
        <div class="flow-step">
          <div class="flow-num">01</div>
          <div class="flow-label">Register Free</div>
          <div class="flow-sub">Create your BCC platform identity — no cost.</div>
        </div>
        <div class="flow-arrow" aria-hidden="true">→</div>
        <div class="flow-step">
          <div class="flow-num">02</div>
          <div class="flow-label">Apply for Membership</div>
          <div class="flow-sub">Choose a class and submit. Committee reviews in days.</div>
        </div>
        <div class="flow-arrow" aria-hidden="true">→</div>
        <div class="flow-step">
          <div class="flow-num">03</div>
          <div class="flow-label">Start Participating</div>
          <div class="flow-sub">Events, workshops, exhibitions, and the BCC community.</div>
        </div>
      </div>

      <div class="tier-grid" data-gsap="stagger">

        <!-- Basic -->
        <div class="tier-card">
          <div class="tier-card__accent" style="background:var(--badge-basic)"></div>
          <div class="tier-card__body">
            <div class="tier-chip" style="--chip-c:var(--badge-basic)">Basic</div>
            <div class="tier-title">Basic Member</div>
            <div class="tier-price">Free</div>
            <p class="tier-desc">Platform identity, public showcase access, event announcements, BCC newsletter.</p>
            <ul class="tier-feats">
              <li>Platform profile</li>
              <li>Public showcase access</li>
              <li>Event announcements</li>
              <li>BCC newsletter</li>
            </ul>
            <a href="/join/#apply" class="btn btn-dark btn-md tier-cta auth-hide">Apply for Membership</a>
          </div>
        </div>

        <!-- Student -->
        <div class="tier-card tier-card--featured">
          <div class="tier-card__accent" style="background:var(--badge-student)"></div>
          <div class="tier-card__body">
            <div class="tier-chip" style="--chip-c:var(--badge-student)">Student</div>
            <div class="tier-title">Student Member</div>
            <div class="tier-price">Annual fee</div>
            <p class="tier-desc">For photography students. Workshops, mentored sessions, and events at concession rates.</p>
            <ul class="tier-feats">
              <li>Everything in Basic</li>
              <li>Workshop participation</li>
              <li>Mentored feedback sessions</li>
              <li>Portfolio on Showcase</li>
              <li>Event participation (student rate)</li>
            </ul>
            <a href="/join/#apply" class="btn btn-dark btn-md tier-cta auth-hide">Apply for Membership</a>
          </div>
        </div>

        <!-- Individual -->
        <div class="tier-card">
          <div class="tier-card__accent" style="background:var(--badge-individual)"></div>
          <div class="tier-card__body">
            <div class="tier-chip" style="--chip-c:var(--badge-individual)">Individual</div>
            <div class="tier-title">Individual Member</div>
            <div class="tier-price">Annual fee</div>
            <p class="tier-desc">Full participation — contests, exhibitions, club governance, and a digital membership card.</p>
            <ul class="tier-feats">
              <li>Everything in Student</li>
              <li>Contest submissions</li>
              <li>Exhibition participation</li>
              <li>Voting rights</li>
              <li>Digital membership card</li>
            </ul>
            <a href="/join/#apply" class="btn btn-dark btn-md tier-cta auth-hide">Apply for Membership</a>
          </div>
        </div>

      </div>

      <p class="tier-footnote">
        <a href="/join/" class="btn-text">Full membership details →</a>
      </p>

    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       9. OPEN CONTEST (Conditional)
       ══════════════════════════════════════════════════ -->
  <section class="section surface-alt open-contest" id="open-contest" aria-label="Open Contest">
    <div class="container">
      <!-- Open Contest content scaffold -->
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       10. JOURNAL
       ══════════════════════════════════════════════════ -->
  <section class="section section-sm surface-alt journal-section" id="journal" aria-label="From the journal">
    <div class="container">

      <div class="journal-header">
        <SectionHeader eyebrow="Journal" title="From the journal" />
        <a href="/journal/" class="btn btn-outline btn-md">All articles</a>
      </div>

      <div class="journal-grid" id="journal-grid" data-gsap="stagger">
        <!-- Skeleton cards -->
        {[1,2,3].map(() => (
          <div class="journal-card-skel surface-white">
            <div class="skel" style="width:100%;height:180px;"></div>
            <div style="padding:var(--s-3);">
              <div class="skel" style="width:35%;height:9px;margin-bottom:10px;"></div>
              <div class="skel" style="width:80%;height:14px;margin-bottom:8px;"></div>
              <div class="skel" style="width:60%;height:10px;"></div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

</BaseLayout>


<style>
/* ── Spotlight hero ── */
.spotlight {
  position: relative;
  min-height: 100svh;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
  background: var(--surface-deep);
}

.spotlight-img {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.spotlight-fallback {
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg, #1A1816 0%, #2A2622 100%);
}
.spotlight-photo {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0;
  transition: opacity 0.8s ease;
}
.spotlight-photo.loaded { opacity: 1; }

.spotlight-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background:
    linear-gradient(to top, rgba(20,18,16,.82) 0%, rgba(20,18,16,.3) 40%, transparent 65%),
    linear-gradient(to right, rgba(20,18,16,.4) 0%, transparent 55%);
}

.spotlight-chip {
  position: absolute;
  top: calc(var(--nav-h) + var(--s-4));
  left: var(--gutter);
  z-index: 10;
  display: inline-flex;
  align-items: center;
  gap: var(--s-1);
  padding: 4px 12px;
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.18);
  border-radius: var(--r-full);
  font-family: var(--font-body);
  font-size: var(--text-label);
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(250,248,244,.75);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.spotlight-plate {
  position: relative;
  z-index: 10;
  max-width: 600px;
  padding: var(--s-8) var(--gutter);
}
.spotlight-plate__meta {
  color: rgba(201,169,97,.8);
  margin-bottom: var(--s-2);
  min-height: 1.2em;
}
.spotlight-plate__title {
  font-size: var(--text-display);
  font-weight: 700;
  letter-spacing: -0.035em;
  line-height: 0.95;
  color: var(--ink-inverse);
  margin-bottom: var(--s-4);
}
.spotlight-plate__credit {
  font-size: var(--text-small);
  color: rgba(250,248,244,.55);
  margin-bottom: var(--s-4);
  font-family: var(--font-body);
  min-height: 1.4em;
}
.spotlight-plate__ctas { display: flex; gap: var(--s-2); flex-wrap: wrap; }

/* ── Stat band ── */
.statband {
  border-top: 1px solid var(--hairline);
  border-bottom: 1px solid var(--hairline);
  padding: var(--s-4) 0;
}
.statband-inner {
  display: flex;
  align-items: center;
  justify-content: center;
}
.stat {
  flex: 1;
  text-align: center;
  padding: var(--s-3) var(--s-4);
}
.stat-value {
  font-family: var(--font-display);
  font-size: clamp(28px, 3.5vw, 42px);
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--ink-900);
  line-height: 1;
  margin-bottom: 4px;
}
.stat-label {
  font-size: var(--text-label);
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-400);
}
.statband-divider { width: 1px; height: 40px; background: var(--hairline); flex-shrink: 0; }

/* ── Gallery wall ── */
.gallery-wall-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--s-4);
  margin-bottom: var(--s-4);
}
:global(.jrow) { display: flex; gap: 8px; margin-bottom: 8px; }
:global(.jrow:last-child) { margin-bottom: 0; }
.gallery-footnote {
  margin-top: var(--s-4);
  font-size: var(--text-small);
  color: var(--ink-400);
}
/* Real photo cards in grid */
:global(.jrow .photo-card) {
  overflow: hidden;
  flex-shrink: 0;
  border-radius: var(--r-0);
  background: var(--surface-2);
  position: relative;
  cursor: pointer;
  display: block;
  text-decoration: none;
}
:global(.jrow .photo-card img) {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  border-radius: var(--r-0);
  transition: transform var(--m-image);
}
:global(.jrow .photo-card:hover img) { transform: scale(1.03); }
/* Caption on hover */
:global(.jrow .photo-card .photo-caption) {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: var(--s-3);
  background: linear-gradient(to top, rgba(20,18,16,.75) 0%, transparent 100%);
  opacity: 0;
  transition: opacity var(--m-fast);
}
:global(.jrow .photo-card:hover .photo-caption) { opacity: 1; }
:global(.photo-caption__title)       { font-family: var(--font-display); font-size: 13px; font-weight: 600; color: var(--ink-inverse); }
:global(.photo-caption__photographer) { font-size: 11px; color: rgba(250,248,244,.65); }

/* ── Events ── */
.events-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--s-4);
  margin-bottom: var(--s-4);
}
.events-list { display: flex; flex-direction: column; }
.event-row {
  display: grid;
  grid-template-columns: 72px auto 1fr auto;
  gap: var(--s-4);
  align-items: center;
  padding: var(--s-3) 0;
  border-bottom: 1px solid var(--hairline);
  text-decoration: none;
  color: inherit;
  transition: background var(--m-fast);
}
.event-row:first-child { border-top: 1px solid var(--hairline); }
.event-row:hover { background: rgba(201,169,97,.04); }

.event-date { text-align: center; }
.event-date__day   { font-family: var(--font-display); font-size: 32px; font-weight: 700; color: var(--ink-900); line-height: 1; }
.event-date__month { font-size: var(--text-label); font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-400); }

.event-thumb {
  width: 64px;
  height: 42px; /* 3:2 */
  overflow: hidden;
  flex-shrink: 0;
  background: var(--surface-2);
  border-radius: var(--r-0);
}
.event-thumb img { width: 100%; height: 100%; object-fit: cover; }

.event-title { font-family: var(--font-display); font-size: var(--text-h3); font-weight: 600; color: var(--ink-900); }
.event-meta  { font-size: 12px; color: var(--ink-400); margin-top: 2px; }
.event-action { font-size: 12px; font-weight: 600; color: var(--gold-600); white-space: nowrap; }

.event-row-skel {
  display: flex;
  align-items: center;
  gap: var(--s-4);
  padding: var(--s-3) 0;
  border-bottom: 1px solid var(--hairline);
}

/* ── Photo band ── */
.photo-band {
  height: 360px;
  position: relative;
  overflow: hidden;
}
.photo-band-img {
  position: absolute;
  inset: -10% 0;
  background: var(--image-backdrop);
}
.photo-band-img img { width: 100%; height: 100%; object-fit: cover; }
.photo-band-overlay {
  position: absolute;
  inset: 0;
  background: rgba(20,18,16,.4);
}

/* ── Membership tiers ── */
.flow-strip {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: var(--s-4);
  margin: var(--s-6) 0 var(--s-8);
  flex-wrap: wrap;
}
.flow-step { text-align: center; max-width: 200px; }
.flow-num  { font-family: var(--font-mono); font-size: var(--text-label); color: var(--gold-600); letter-spacing: 0.12em; margin-bottom: var(--s-1); }
.flow-label { font-family: var(--font-display); font-size: 16px; font-weight: 600; color: var(--ink-900); margin-bottom: 4px; }
.flow-sub   { font-size: 12px; color: var(--ink-400); line-height: 1.6; }
.flow-arrow { font-size: 20px; color: var(--hairline-strong); margin-top: var(--s-4); flex-shrink: 0; }

.tier-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--s-3);
  margin-bottom: var(--s-4);
}
.tier-card {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-top: none;
  box-shadow: var(--e-1);
  display: flex;
  flex-direction: column;
  transition: box-shadow var(--m-fast), transform var(--m-fast);
  border-radius: var(--r-0);
  overflow: hidden;
}
.tier-card:hover { box-shadow: var(--e-2); transform: translateY(-2px); }
.tier-card--featured {
  border-color: var(--gold-500);
  box-shadow: var(--e-2);
}
.tier-card__accent { height: 4px; flex-shrink: 0; }
.tier-card__body { padding: var(--s-4); display: flex; flex-direction: column; gap: var(--s-2); flex: 1; }

.tier-chip {
  display: inline-block;
  width: fit-content;
  padding: 2px 10px;
  border-radius: var(--r-full);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--chip-c);
  background: color-mix(in srgb, var(--chip-c) 12%, transparent);
  border: 1px solid color-mix(in srgb, var(--chip-c) 30%, transparent);
}
@supports not (background: color-mix(in srgb, red 50%, blue)) {
  .tier-chip { background: rgba(0,0,0,.04); border-color: rgba(0,0,0,.12); }
}
.tier-title { font-family: var(--font-display); font-size: 18px; font-weight: 700; color: var(--ink-900); }
.tier-price { font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--gold-600); }
.tier-desc  { font-size: 13px; color: var(--ink-600); line-height: 1.65; flex: 1; }
.tier-feats { list-style: none; display: flex; flex-direction: column; gap: 6px; }
.tier-feats li {
  font-size: 13px;
  color: var(--ink-600);
  padding-left: 16px;
  position: relative;
}
.tier-feats li::before {
  content: '';
  position: absolute;
  left: 0; top: 9px;
  width: 8px; height: 1px;
  background: var(--gold-500);
}
.tier-cta { width: 100%; justify-content: center; margin-top: var(--s-2); }
.tier-footnote { text-align: center; font-size: var(--text-small); color: var(--ink-400); }

/* ── Journal ── */
.journal-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--s-4);
  margin-bottom: var(--s-4);
}
.journal-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--s-3);
}
.journal-card-skel {
  border: 1px solid var(--hairline);
  border-radius: var(--r-0);
  overflow: hidden;
}
.journal-card {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-radius: var(--r-0);
  overflow: hidden;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  transition: box-shadow var(--m-fast), transform var(--m-fast);
}
.journal-card:hover { box-shadow: var(--e-2); transform: translateY(-2px); }
.journal-card__img { height: 180px; background: var(--surface-2); overflow: hidden; }
.journal-card__img img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--m-image); }
.journal-card:hover .journal-card__img img { transform: scale(1.04); }
.journal-card__body { padding: var(--s-3); display: flex; flex-direction: column; gap: var(--s-1); flex: 1; }
.journal-card__tag { display: inline-block; }
.journal-card__title { font-family: var(--font-display); font-size: 16px; font-weight: 600; color: var(--ink-900); line-height: 1.3; }
.journal-card__meta  { font-size: 12px; color: var(--ink-400); margin-top: auto; }

/* ── Responsive ── */
@media (max-width: 900px) {
  .spotlight-plate { padding: var(--s-6) var(--gutter-mob); }
  .spotlight-chip  { left: var(--gutter-mob); }
  .statband-inner  { flex-wrap: wrap; }
  .stat            { flex: 1 1 50%; }
  .statband-divider { display: none; }
  .gallery-wall-header,
  .events-header,
  .journal-header { flex-direction: column; align-items: flex-start; }
  .tier-grid   { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto var(--s-4); }
  .journal-grid { grid-template-columns: 1fr; }
  .flow-arrow  { display: none; }
  .event-row   { grid-template-columns: 60px 1fr; }
  .event-thumb,
  .event-action { display: none; }
}
@media (max-width: 640px) {
  .spotlight-plate__title { font-size: clamp(36px, 8vw, 56px); }
  .journal-grid { grid-template-columns: 1fr; }
}
</style>


<script>
  /**
   * Home page scripts:
   * 1. Spotlight hero — load from /api/v1/gallery/feed (latest photo)
   * 2. Gallery wall — fetch + justified layout
   * 3. Events — fetch upcoming 3
   * 4. Journal — fetch latest 3 posts
   * 5. Photo band — load a featured photo
   */
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  /* ── 1. Spotlight ── */
  (async () => {
    try {
      // Phase 2a: latest gallery feed photo used as spotlight.
      // Dedicated curation endpoint (with credit + origin) is Phase 2b.
      const res = await fetch('/api/v1/gallery/feed?limit=1');
      if (!res.ok) return;
      const { photos: _sp } = await res.json();
      const sp = Array.isArray(_sp) && _sp.length > 0 ? _sp[0] : null;
      if (!sp) return;

      const imageUrl = sp.urls?.large ?? sp.urls?.original ?? '';
      if (!imageUrl) return;

      const img = document.getElementById('spotlight-photo') as HTMLImageElement | null;
      if (img) { img.src = imageUrl; img.alt = sp.title ?? ''; img.onload = () => img.classList.add('loaded'); }

      const title = document.getElementById('spotlight-title');
      if (title && sp.title) title.textContent = sp.title;
    } catch { /* fallback gradient stays */ }
  })();

  /* ── 2. Gallery wall — justified layout ── */
  function buildRows(
    photos: Array<{ aspect: number }>,
    containerWidth: number,
    targetH = 240,
    gap = 8
  ) {
    const rows: Array<{ height: number; items: typeof photos }> = [];
    let row: typeof photos = [], rowW = 0;

    const flush = (last = false) => {
      if (!row.length) return;
      const totalGap = gap * (row.length - 1);
      const scale = last ? Math.min(1, (containerWidth - totalGap) / rowW) : (containerWidth - totalGap) / rowW;
      const h = targetH * scale;
      rows.push({ height: h, items: row.map(p => ({ ...p, width: p.aspect * h })) });
      row = []; rowW = 0;
    };

    for (const p of photos) {
      const iW = p.aspect * targetH;
      row.push(p); rowW += iW;
      if (rowW + gap * (row.length - 1) >= containerWidth * 0.88) flush();
    }
    flush(true);
    return rows;
  }

  (async () => {
    const grid = document.getElementById('gallery-grid');
    const skel = document.getElementById('gallery-skeleton');
    if (!grid) return;

    let photos: any[] = [];
    try {
      // gallery/feed returns { photos: [...], total: N }.
      // Normalise each item to the shape buildRows() expects.
      const res = await fetch('/api/v1/gallery/feed?limit=12');
      if (res.ok) {
        const { photos: _raw } = await res.json();
        photos = (Array.isArray(_raw) ? _raw : []).map((p: any) => ({
          id:           p.uuid,
          title:        p.title ?? '',
          photographer: null,
          imageUrl:     p.urls?.medium ?? p.urls?.original ?? '',
          aspect:       (p.width_px && p.height_px) ? p.width_px / p.height_px : 1.5,
        }));
      }
    } catch { /* empty */ }

    skel?.remove();
    if (photos.length === 0) return; // No photos yet — gallery wall stays empty (Phase 2a)

    const containerWidth = grid.clientWidth;
    buildRows(photos, containerWidth).forEach(row => {
      const rowEl = document.createElement('div');
      rowEl.className = 'jrow';

      (row.items as any[]).forEach((p: any) => {
        const a = document.createElement('a');
        a.href = p.href ?? `/showcase/${p.id}/`;
        a.className = 'photo-card';
        a.style.cssText = `width:${p.width}px;height:${row.height}px;`;

        const img = document.createElement('img');
        img.src = p.imageUrl ?? ''; img.alt = p.title ?? ''; img.loading = 'lazy'; img.decoding = 'async';
        img.onload = () => img.classList.add('loaded');

        const cap = document.createElement('div');
        cap.className = 'photo-caption';
        if (p.title) { const t = document.createElement('div'); t.className = 'photo-caption__title'; t.textContent = p.title; cap.appendChild(t); }
        if (p.photographer) { const ph = document.createElement('div'); ph.className = 'photo-caption__photographer'; ph.textContent = p.photographer; cap.appendChild(ph); }

        a.appendChild(img); a.appendChild(cap);
        rowEl.appendChild(a);
      });
      grid.appendChild(rowEl);
    });

    gsap.from('#gallery-grid .photo-card', { opacity: 0, y: 20, duration: 0.6, stagger: { amount: 0.4, from: 'random' }, ease: 'power2.out', scrollTrigger: { trigger: grid, start: 'top 85%', once: true } });
  })();

  /* ── 3. Upcoming events ── */
  (async () => {
    const list = document.getElementById('events-list');
    if (!list) return;
    try {
      const res = await fetch('/api/v1/events?upcoming=true&limit=3');
      if (!res.ok) {
        list.innerHTML = `<p style="padding:var(--s-6) 0;color:var(--ink-400);font-size:var(--text-small);border-top:1px solid var(--hairline);border-bottom:1px solid var(--hairline);">No upcoming activities right now. Check back soon!</p>`;
        return;
      }
      const { data } = await res.json();
      const events = Array.isArray(data) ? data : [];
      if (!events.length) {
        list.innerHTML = `<p style="padding:var(--s-6) 0;color:var(--ink-400);font-size:var(--text-small);border-top:1px solid var(--hairline);border-bottom:1px solid var(--hairline);">No upcoming activities right now. Check back soon!</p>`;
        return;
      }

      list.innerHTML = '';
      events.forEach((ev: any) => {
        const d = ev.date ? new Date(ev.date) : null;
        const day   = d ? d.getDate().toString().padStart(2,'0') : '—';
        const month = d ? d.toLocaleString('en-IN', { month: 'short' }).toUpperCase() : '—';

        const row = document.createElement('a');
        row.href = `/activities/${ev.slug ?? ev.id}/`;
        row.className = 'event-row';
        row.innerHTML = `
          <div class="event-date">
            <div class="event-date__day">${day}</div>
            <div class="event-date__month">${month}</div>
          </div>
          <div class="event-thumb">${ev.imageUrl ? `<img src="${ev.imageUrl}" alt="" loading="lazy" width="64" height="42" />` : ''}</div>
          <div class="event-info">
            <div class="event-title">${ev.title ?? 'Upcoming Event'}</div>
            <div class="event-meta">${[ev.time, ev.location].filter(Boolean).join(' · ')}</div>
          </div>
          <div class="event-action">Details →</div>
        `;
        list.appendChild(row);
      });
    } catch {
      list.innerHTML = `<p style="padding:var(--s-6) 0;color:var(--ink-400);font-size:var(--text-small);border-top:1px solid var(--hairline);border-bottom:1px solid var(--hairline);">No upcoming activities right now. Check back soon!</p>`;
    }
  })();

  /* ── 4. Journal preview ── */
  (async () => {
    const grid = document.getElementById('journal-grid');
    if (!grid) return;
    const showEmpty = () => {
      grid.innerHTML = `<div style="grid-column: 1 / -1; padding: var(--s-8) 0; text-align: center; color: var(--ink-400); font-family: var(--font-body); font-size: var(--text-small); border: 1px dashed var(--hairline-strong); background: var(--surface-0);">No journal articles available yet.</div>`;
    };
    try {
      const res = await fetch('/api/v1/journal?limit=3');
      if (!res.ok) { showEmpty(); return; }
      const { data } = await res.json();
      const posts = Array.isArray(data) ? data : [];
      if (!posts.length) { showEmpty(); return; }

      grid.innerHTML = '';
      posts.forEach((post: any) => {
        const card = document.createElement('a');
        card.href = `/journal/${post.slug ?? post.id}/`;
        card.className = 'journal-card';
        card.innerHTML = `
          <div class="journal-card__img">${post.imageUrl ? `<img src="${post.imageUrl}" alt="${post.title ?? ''}" loading="lazy" />` : ''}</div>
          <div class="journal-card__body">
            <div class="journal-card__tag"><span class="eyebrow">${post.category ?? 'Journal'}</span></div>
            <div class="journal-card__title">${post.title ?? ''}</div>
            <div class="journal-card__meta">${[post.author, post.readTime].filter(Boolean).join(' · ')}</div>
          </div>
        `;
        grid.appendChild(card);
      });
    } catch {
      showEmpty();
    }
  })();
</script>
