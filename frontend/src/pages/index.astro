---
/**
 * index.astro — Home Page
 * V6 01 Home Ver2 — Architectural Reconciliation
 *   1. PageHero (home variant) — Hero Assignment Architecture · heroManager.location("home")
 *   2. StatBand (GSAP counter)
 *   3. Gallery Wall — "Our members, on the wall."
 *   4. AboutClub — "Photography is our discipline. Bhopal is our subject."
 *   5. TheClub — Four Ways To Participate
 *   6. FeaturedActivity (conditional)
 *   7. UpcomingActivities (3 rows from API)
 *   8. PhotoSeries
 *   9. SpecialProjects — Three flagship BCC initiatives
 *  10. Membership — Three-step educational flow
 *  11. OpenContest (conditional)
 *  12. Journal preview
 *
 * MEM-006: only Basic, Student, Individual classes on this public page.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import { getUpcomingActivities, getFeaturedActivities } from '../lib/services/activity.service';
import { PROJECTS } from '../data/projects';

const upcomingEvents = (await getUpcomingActivities()).slice(0, 3);
const featuredActs = await getFeaturedActivities();
const featuredAct = featuredActs[0];

const formatMetaDate = (dateStr: string) => {
  const d = new Date(dateStr);
  const day = d.getDate().toString().padStart(2, '0');
  const month = d.toLocaleString('en-IN', { month: 'short' });
  const year = d.getFullYear();
  return `${day} ${month} ${year}`;
};

const featuredActivity = featuredAct ? {
  enabled: true,
  title: featuredAct.title,
  description: featuredAct.summary,
  meta: `${formatMetaDate(featuredAct.startDate)} · ${featuredAct.duration} · ${featuredAct.venue}, ${featuredAct.city}`,
  registerUrl: `/activities/${featuredAct.slug ?? featuredAct.id}/`,
  learnMoreUrl: `/activities/${featuredAct.slug ?? featuredAct.id}/`
} : {
  enabled: false,
  title: "",
  description: "",
  meta: "",
  registerUrl: "",
  learnMoreUrl: ""
};

const activeContest = {
  enabled: false, // Set to true to enable active contest block
  title: "Monsoon Reflections 2026",
  description: "Capture the spirit of the monsoons in Bhopal. Submit your best shots of rains, streets, lakes, and life under the clouds.",
  deadline: "30 Aug 2026",
  eligibility: "Open to All Members",
  submitUrl: "/contests/monsoon-reflections-2026/submit/",
  detailsUrl: "/contests/monsoon-reflections-2026/"
};

const specialProjects = Object.values(PROJECTS).slice(0, 3);
---

<BaseLayout
  title="Home"
  description="Bhopal Camera Club — photography community since 2016. Explore member portfolios, upcoming events, and join Bhopal's most active photography club."
>

  <!-- ══════════════════════════════════════════════════
       1. PAGE HERO
       Hero Assignment Architecture · heroManager.location("home")
       Supports Fixed Hero and Rotation Pool.
       PageHero is presentation-only — no API calls inside.
       ══════════════════════════════════════════════════ -->
  <PageHero
    variant="home"
    eyebrow="BCC Spotlight"
    title="Photography Is Our Discipline."
    subtitle="Bhopal Camera Club is a community of photographers dedicated to the craft, the city, and each other. Join us and photograph the extraordinary city we call home."
    primaryCtaText="Become a Member →"
    primaryCtaHref="/join/"
    secondaryCtaText="Browse the Gallery"
    secondaryCtaHref="/showcase/"
  />


  <!-- ══════════════════════════════════════════════════
       2. STAT BAND
       ══════════════════════════════════════════════════ -->
  <section class="statband" aria-label="Club statistics">
    <div class="container">
      <div class="statband-inner" data-gsap="stagger">

        <div class="stat">
          <div class="stat-value">
            <span data-gsap="counter" data-target="340" data-suffix="+">—</span>
          </div>
          <div class="stat-label">Active Members</div>
        </div>

        <div class="stat">
          <div class="stat-value">
            <span data-gsap="counter" data-target="87">—</span>
          </div>
          <div class="stat-label">Photowalks</div>
        </div>

        <div class="stat">
          <div class="stat-value">
            <span data-gsap="counter" data-target="10" data-suffix="th">—</span>
          </div>
          <div class="stat-label">Year · 2026</div>
        </div>

        <div class="stat">
          <div class="stat-value">
            <span data-gsap="counter" data-target="4200" data-suffix="+">—</span>
          </div>
          <div class="stat-label">Gallery Photos</div>
        </div>

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       3. GALLERY WALL — Justified grid
       "Our members, on the wall."
       Max one frame per photographer. Flickr algorithm.
       ══════════════════════════════════════════════════ -->
  <section class="section gallery-wall" id="gallery-wall" aria-label="Member gallery wall">
    <div class="container">

      <div class="gallery-wall-header">
        <SectionHeader
          eyebrow="Our members, on the wall."
          title="The Collective Eye"
          subtitle='Explore the gallery wall featuring selected Bhopal Camera Club members. This showcase highlights the artistry of our photography community, capturing powerful stories with precise focus, cameras, and lenses.'


        />
        <a href="/showcase/" class="btn btn-outline btn-md">View all in Showcase</a>
      </div>

      <!-- Justified grid — populated by JS -->
      <div class="justified-grid" id="gallery-grid" aria-label="Member photographs">
        <!-- Skeleton rows -->
        <div id="gallery-skeleton">
          {[[3.2,1.5,4.0,1.0],[1.0,2.5,1.2,2.0,1.8],[2.4,1.5,3.0,1.0]].map(row => (
            <div class="jrow">
              {row.map(flex => <div class="skel" style={`flex:${flex};height:240px;`}></div>)}
            </div>
          ))}
        </div>
      </div>

      <p class="gallery-footnote auth-hide">
        Your frame could hang here —&nbsp;
        <a href="/join/" class="btn-text">Become a Member</a>
      </p>

    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       4. ABOUT BCC
       "Photography is our discipline. Bhopal is our subject."
       New in Ver2 — positioned after GalleryWall.
       ══════════════════════════════════════════════════ -->
  <section class="section about-club" id="about-club" aria-label="About Bhopal Camera Club">
    <div class="container">
      <div class="about-club__grid">

        <!-- Left: editorial copy -->
        <div class="about-club__copy">
          <div class="about-club__kicker">About Bhopal Camera Club</div>
          <h3 class="about-club__title">Photography is our discipline.<br/>Bhopal is our subject.</h3>
          <p class="about-club__para">Bhopal Camera Club was founded in 2016 by a group of photographers who believed a camera club should do more than host contests. We wanted to build a genuine learning community — one where a beginner could walk beside an experienced photographer, where critique happened with generosity, and where the practice of photography was valued as much as any prize.</p>
          <p class="about-club__para">Today, more than 340 members explore Bhopal's remarkable visual world together — its forts and lakes, wildlife corridors and monsoon skies. We organise monthly photowalks, host workshops with nationally recognised photographers, and exhibit member work at the city's cultural institutions. We are affiliated members of the Federation of Indian Photography, the only camera club in Central India with this recognition.</p>
          <a href="/about/" class="about-club__link">Read More <span aria-hidden="true">→</span></a>
        </div>

        <!-- Right: community photograph -->
        <div class="about-club__photo-col">
          <div class="about-club__photo-placeholder" aria-hidden="true"></div>
          <div class="about-club__caption-bar">
            <div class="about-club__caption-text">BCC members · Photowalk at Manav Sangralaya · 2018<br/>Photograph from the club archive</div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       5. THE CLUB
       ══════════════════════════════════════════════════ -->
  <section class="section the-club" id="the-club" aria-label="The Club">
    <div class="container">
      
      <div class="the-club-header">
        <div class="the-club-header__kicker">The Club</div>
        <h3 class="the-club-header__title">One Community. Four Ways To Participate.</h3>
      </div>

      <div class="the-club-grid">
        
        <!-- Card 1: Photowalks -->
        <a href="/activities?type=photowalk" class="club-card active-card" aria-label="Photowalks: Walk the city with us">
          <div class="club-card__image-area" id="card-img-photowalk">
            <div class="club-card__gradient" style="background: linear-gradient(160deg, #0D1B2A 0%, #1A2D4A 50%, #0A1520 100%);"></div>
          </div>
          <div class="club-card__body">
            <div class="club-card__kicker">Photowalks</div>
            <h4 class="club-card__title">Walk the city with us</h4>
            <p class="club-card__desc">Monthly guided walks through Bhopal's heritage neighbourhoods, lakes, forests, and markets. Each photowalk is led by an experienced member who knows the light, the streets, and the stories. Open to all skill levels — the city is the classroom, the camera the only credential you need.</p>
            <div class="club-card__link">Explore Photowalks <span class="arrow">→</span></div>
          </div>
        </a>

        <!-- Card 2: Photo Contests -->
        <a href="/activities/contests" class="club-card active-card" aria-label="Photo Contests: Compete and be seen">
          <div class="club-card__image-area" id="card-img-contests">
            <div class="club-card__gradient" style="background: linear-gradient(160deg, #2A1A06 0%, #4A2E10 50%, #1E1208 100%);"></div>
          </div>
          <div class="club-card__body">
            <div class="club-card__kicker">Photo Contests</div>
            <h4 class="club-card__title">Compete and be seen</h4>
            <p class="club-card__desc">Theme-based photography competitions open to all members. Each contest is jury-judged by practising photographers, with selected work exhibited at club events and cultural venues. Entry is free with active membership. Categories change each season; the standard does not.</p>
            <div class="club-card__link">View Contests <span class="arrow">→</span></div>
          </div>
        </a>

        <!-- Card 3: Exhibitions -->
        <a href="/activities/exhibitions" class="club-card active-card" aria-label="Exhibitions: Print and exhibit your work">
          <div class="club-card__image-area" id="card-img-exhibitions">
            <div class="club-card__gradient" style="background: linear-gradient(160deg, #141210 0%, #221E1A 50%, #0E0C0A 100%);"></div>
          </div>
          <div class="club-card__body">
            <div class="club-card__kicker">Exhibitions</div>
            <h4 class="club-card__title">Print and exhibit your work</h4>
            <p class="club-card__desc">Annual and themed exhibitions at Bhopal's cultural venues — curated from member submissions and mounted with full production support. The club handles printing, framing, and hanging. For many members, their first public exhibition begins here.</p>
            <div class="club-card__link">See Exhibitions <span class="arrow">→</span></div>
          </div>
        </a>

        <!-- Card 4: Photography School (Coming Soon) -->
        <div class="club-card disabled-card" aria-label="Photography School: Learn with the club (Coming Soon)">
          <div class="club-card__image-area" id="card-img-school">
            <div class="club-card__gradient" style="background: linear-gradient(160deg, #1A1E28 0%, #262C3A 50%, #141820 100%);"></div>
            <div class="club-card__badge-overlay">
              <span class="badge">COMING SOON</span>
            </div>
          </div>
          <div class="club-card__body">
            <div class="club-card__kicker">Photography School</div>
            <h4 class="club-card__title">Learn with the club</h4>
            <p class="club-card__desc">Structured education — workshops, modules, mentorship. Coming soon.</p>
            <div class="club-card__link">Coming Soon</div>
          </div>
        </div>

      </div>

    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       5. FEATURED ACTIVITY (Conditional)
       ══════════════════════════════════════════════════ -->
  {featuredActivity.enabled && (
    <section class="featured-activity" id="featured-activity" aria-label="Featured Activity">
      <div class="container">
        <div class="featured-activity-card">
          <div class="featured-activity-card__gradient"></div>
          <div class="featured-activity-card__overlay"></div>
          <div class="featured-activity-card__content">
            <div class="featured-activity-card__kicker">Featured Activity</div>
            <h2 class="featured-activity-card__title">{featuredActivity.title}</h2>
            <p class="featured-activity-card__desc">{featuredActivity.description}</p>
            <div class="featured-activity-card__meta">{featuredActivity.meta}</div>
            <div class="featured-activity-card__ctas">
              <a href={featuredActivity.registerUrl} class="featured-activity-btn-gold">Register →</a>
              <a href={featuredActivity.learnMoreUrl} class="featured-activity-btn-outline">Learn More</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}


  <!-- ══════════════════════════════════════════════════
       6. UPCOMING ACTIVITIES
       ══════════════════════════════════════════════════ -->
  <section class="section section-sm surface-alt events-section" id="upcoming-activities" aria-label="Upcoming activities">
    <div class="container">

      <div class="events-header">
        <div>
          <div class="events-header__kicker">Upcoming</div>
          <h3 class="events-header__title">What's happening</h3>
        </div>
        <a href="/activities/" class="events-header__all-link">ALL ACTIVITIES →</a>
      </div>

      <div class="events-list" id="events-list" aria-label="Upcoming events list">
        {upcomingEvents.map((ev) => {
          const d = new Date(ev.startDate);
          const day = d.getDate().toString().padStart(2, '0');
          const month = d.toLocaleString('en-IN', { month: 'short' }).toUpperCase();
          const year = d.getFullYear();
          const monthText = `${month} ${year}`;
          const time = '07:30 AM'; // default time for mornings in seed records

          let tagClass = 'tag-default';
          let typeLabel = ev.category;
          let sA = '#0D1520', sB = '#1A2840';
          const catNorm = ev.category.toLowerCase();
          if (catNorm.includes('walk')) {
            typeLabel = 'Photowalk';
            tagClass = 'tag-photowalk';
            sA = '#0C1E30'; sB = '#1B3F5A';
          } else if (catNorm.includes('workshop')) {
            typeLabel = 'Workshop';
            tagClass = 'tag-workshop';
            sA = '#1E1200'; sB = '#3A2400';
          } else if (catNorm.includes('exhibition')) {
            typeLabel = 'Exhibition';
            tagClass = 'tag-exhibition';
            sA = '#1A0D0D'; sB = '#321515';
          }

          const isMembersOnly = ev.visibility === 'Members Only';
          const isFree = !ev.registrationRequired;

          return (
            <a href={`/activities/${ev.slug ?? ev.id}/`} class="event-row">
              <div class="event-row__date">
                <div class="event-row__day">{day}</div>
                <div class="event-row__month">{monthText}</div>
              </div>
              <div class="event-row__thumb">
                {ev.coverImage ? (
                  <img class="event-row__thumb-img" src={ev.coverImage} alt={`${typeLabel}: ${ev.title}`} loading="lazy" />
                ) : (
                  <div class="event-row__thumb-gradient" style={`background: linear-gradient(160deg, ${sA} 0%, ${sB} 100%);`}></div>
                )}
                <div class:list={["event-row__thumb-tag", tagClass]}>{typeLabel}</div>
              </div>
              <div class="event-row__info">
                <div class="event-row__time-row">
                  <span class="event-row__time">{time}</span>
                  {isMembersOnly && <span class="event-row__members-badge">MEMBERS ONLY</span>}
                  {isFree && <span class="event-row__free-badge">FREE</span>}
                </div>
                <h4 class="event-row__title">{ev.title}</h4>
                <div class="event-row__venue">{ev.venue}</div>
                {ev.summary && <div class="event-row__desc">{ev.summary.slice(0, 90)}{ev.summary.length > 90 ? '…' : ''}</div>}
              </div>
              <span class="event-row__btn">Register →</span>
            </a>
          );
        })}
        {upcomingEvents.length === 0 && (
          <p style="padding:var(--s-6) 0;color:var(--ink-400);font-size:var(--text-small);border-top:1px solid var(--hairline);border-bottom:1px solid var(--hairline);">No upcoming activities right now. Check back soon!</p>
        )}
      </div>

    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       7. PHOTO SERIES
       ══════════════════════════════════════════════════ -->
  <section class="section" id="photo-series" aria-label="Photo Series">
    <div class="container">

      <div class="photo-series-card-wrapper">
        <div class="photo-series-card">
          <div class="photo-series-card__bg" aria-hidden="true"></div>
          <div class="photo-series-card__overlay"></div>
          <div class="photo-series-card__content">
            <div class="photo-series-card__kicker">Photo Series</div>
            <h2 class="photo-series-card__title">The City Is Our Muse.</h2>
            <p class="photo-series-card__desc">Lakes, forts, mosques and markets — our members document the extraordinary visual richness of Bhopal and beyond.</p>
            <p class="photo-series-card__credit">Serene Morning around Tajul Masajid · Photo by Kshitij Patle</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       9. SPECIAL PROJECTS
       Three flagship BCC long-running initiatives.
       Static from projects.ts registry — /projects/[slug]
       ══════════════════════════════════════════════════ -->
  <section class="section" id="special-projects" aria-label="BCC Special Projects">
    <div class="container">

      <div class="special-projects-header">
        <div>
          <div class="special-projects-header__kicker">Special Projects</div>
          <h3 class="special-projects-header__title">BCC Special Projects</h3>
        </div>
        <a href="/projects/" class="special-projects-header__all-link">All Projects →</a>
      </div>

      <div class="special-projects-grid">
        {specialProjects.map((project) => (
          <a href={`/projects/${project.slug}/`} class="sp-card">
            <div class="sp-card__img-wrap">
              {project.heroImage && !project.heroImage.startsWith('/images/')
                ? <img class="sp-card__img" src={project.heroImage} alt={project.title} loading="lazy" decoding="async" />
                : <div class="sp-card__img-placeholder" aria-hidden="true"></div>
              }
            </div>
            <div class="sp-card__body">
              <h4 class="sp-card__title">{project.title}</h4>
              <p class="sp-card__desc">{project.description}</p>
              <span class="sp-card__link">View Project <span aria-hidden="true">→</span></span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       10. MEMBERSHIP
       ══════════════════════════════════════════════════ -->
  <section class="section" id="membership" aria-label="Membership tiers">
    <div class="container">

      <div class="membership-box">
        <div class="membership-box__inner">
          <div class="membership-box__header">
            <div class="membership-box__kicker">Become a Member</div>
            <h3 class="membership-box__title">Join Bhopal Camera Club</h3>
            <p class="membership-box__desc">Photography community, mentorship, and exhibitions. Three clear steps to membership.</p>
          </div>

          <!-- Three-step flow -->
          <div class="membership-steps">
            <div class="membership-step">
              <div class="membership-step__circle">1</div>
              <div class="membership-step__label">Registration</div>
              <p class="membership-step__body">Create your identity. Free. Immediate access to public content.</p>
              <a href="/auth/register/" class="membership-step__link">/auth/register</a>
            </div>
            <div class="membership-steps__arrow">
              <div class="membership-steps__line"></div>
              <span class="membership-steps__symbol">→</span>
            </div>
            <div class="membership-step">
              <div class="membership-step__circle">2</div>
              <div class="membership-step__label">Membership Application</div>
              <p class="membership-step__body">Complete the application. Select tier. Await committee review and approval.</p>
              <a href="/hub/membership/apply/" class="membership-step__link">/hub/membership/apply</a>
            </div>
            <div class="membership-steps__arrow">
              <div class="membership-steps__line"></div>
              <span class="membership-steps__symbol">→</span>
            </div>
            <div class="membership-step membership-step--active">
              <div class="membership-step__circle">3</div>
              <div class="membership-step__label">Membership Active</div>
              <p class="membership-step__body">Full member entitlements. Member Hub access. All activities and exhibitions.</p>
              <span class="membership-step__link">ACTIVE · MEM-007 number assigned</span>
            </div>
          </div>

          <!-- Tier cards -->
          <div class="membership-tiers">
            <!-- Student -->
            <div class="membership-tier-card">
              <div class="membership-tier-card__name">Student</div>
              <div class="membership-tier-card__price">₹500<span> /year</span></div>
              <div class="membership-tier-card__note">Valid student ID required</div>
              <div class="membership-tier-card__feats">
                ✓ All monthly photowalks<br/>
                ✓ Workshop access<br/>
                ✓ Gallery submissions
              </div>
            </div>

            <!-- Individual -->
            <div class="membership-tier-card membership-tier-card--featured">
              <div class="membership-tier-card__pop-badge">Most Popular</div>
              <div class="membership-tier-card__name">Individual</div>
              <div class="membership-tier-card__price">₹1,200<span> /year</span></div>
              <div class="membership-tier-card__note">Most popular membership</div>
              <div class="membership-tier-card__feats">
                ✓ All events, unlimited<br/>
                ✓ Mentorship programme<br/>
                ✓ Voting rights
              </div>
            </div>

            <!-- Basic -->
            <div class="membership-tier-card">
              <div class="membership-tier-card__name">Basic</div>
              <div class="membership-tier-card__price">₹800<span> /year</span></div>
              <div class="membership-tier-card__note">Introductory membership</div>
              <div class="membership-tier-card__feats">
                ✓ Monthly photowalks<br/>
                ✓ Basic access<br/>
                ✓ Member newsletter
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       9. OPEN CONTEST (Conditional)
       ══════════════════════════════════════════════════ -->
  <!-- ══════════════════════════════════════════════════
       9. OPEN CONTEST (Conditional)
       ══════════════════════════════════════════════════ -->
  {activeContest.enabled && (
    <section class="section open-contest" id="open-contest" aria-label="Open Contest">
      <div class="container">
        <div style="display:flex;align-items:baseline;gap:20px;margin-bottom:16px;">
          <span style="font-family:var(--font-mono);font-size:13px;color:var(--gold-600);">11</span>
          <h2 style="font-family:var(--font-display);font-size:40px;font-weight:700;letter-spacing:-0.025em;color:var(--ink-900);">Open Contest — Conditional</h2>
        </div>
        <p style="font-size:16px;line-height:1.7;color:var(--ink-600);max-width:680px;margin-bottom:32px;">Entire section renders only when an active contest exists. When absent: no placeholder, no empty state. Page flows from Membership directly to Journal.</p>

        <div class="contest-card">
          <div class="contest-card__info">
            <div class="contest-card__kicker">Open Contest</div>
            <h3 class="contest-card__title">{activeContest.title}</h3>
            <p class="contest-card__desc">{activeContest.description}</p>
            <div class="contest-card__meta-row">
              <div class="contest-card__meta-item">
                <div class="contest-card__meta-label">Deadline</div>
                <div class="contest-card__meta-val">{activeContest.deadline}</div>
              </div>
              <div class="contest-card__meta-divider"></div>
              <div class="contest-card__meta-item">
                <div class="contest-card__meta-label">Eligibility</div>
                <div class="contest-card__meta-val">{activeContest.eligibility}</div>
              </div>
            </div>
          </div>
          <div class="contest-card__action-box">
            <div class="contest-card__action-title">Enter the Contest</div>
