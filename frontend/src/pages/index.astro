---
/**
 * index.astro — Home Page
 * Hierarchy per BCC_V3_Design_System.md §14 (frozen):
 *   1. BCC Spotlight hero (full-bleed, museum label plate)
 *   2. StatBand (GSAP counter)
 *   3. Gallery Wall — "Our members, on the wall."
 *   4. Upcoming Events (3 rows from API)
 *   5. Full-bleed photo band (parallax)
 *   6. Membership tiers (3 public: Basic · Student · Individual)
 *   7. Journal preview (3 cards)
 *
 * Design: "Refined Editorial Luxury" — no glassmorphism, light surfaces,
 * square photo frames, one gold CTA per view (nav "Become a Member" is it).
 *
 * MEM-006: only Basic, Student, Individual classes on this public page.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';

const featuredActivity = {
  enabled: false, // Set to true to enable featured activity block
  title: "Monsoon Frames 2026",
  description: "Bhopal Camera Club's annual monsoon exhibition showcase, presenting selected prints from members at Bharat Bhavan.",
  meta: "20 Jul 2026 · 11:00 AM · Bharat Bhavan, Bhopal",
  registerUrl: "/activities/monsoon-reflections-exhibition/",
  learnMoreUrl: "/activities/monsoon-reflections-exhibition/"
};

const activeContest = {
  enabled: false, // Set to true to enable active contest block
  title: "Monsoon Reflections 2026",
  description: "Capture the spirit of the monsoons in Bhopal. Submit your best shots of rains, streets, lakes, and life under the clouds.",
  deadline: "30 Aug 2026",
  eligibility: "Open to All Members",
  submitUrl: "/contests/monsoon-reflections-2026/submit/",
  detailsUrl: "/contests/monsoon-reflections-2026/"
};
---

<BaseLayout
  title="Home"
  description="Bhopal Camera Club — photography community since 2016. Explore member portfolios, upcoming events, and join Bhopal's most active photography club."
>

  <!-- ══════════════════════════════════════════════════
       1. HERO SPOTLIGHT
       Full-bleed member photo + museum label plate.
       Committee-curated — no fixed cadence.
       ══════════════════════════════════════════════════ -->
  <section class="spotlight" aria-label="BCC Spotlight" style={`padding-top: var(--nav-h);`}>

    <!-- Image -->
    <div class="spotlight-img" id="spotlight-img" data-gsap="parallax-soft">
      <!-- Fallback gradient — replaced by JS when API returns a photo -->
      <div class="spotlight-fallback" id="spotlight-fallback" aria-hidden="true"></div>
      <img
        id="spotlight-photo"
        src=""
        alt=""
        class="spotlight-photo"
        loading="eager"
        decoding="async"
        aria-hidden="true"
      />
    </div>

    <!-- Dark overlay -->
    <div class="spotlight-overlay" aria-hidden="true"></div>

    <!-- Museum label plate — bottom-left -->
    <div class="spotlight-plate" id="spotlight-plate">
      <div class="spotlight-plate__meta">
        <span></span>BCC Spotlight
      </div>
      <h1 class="spotlight-plate__title" id="spotlight-title">
        Light, Frame,&thinsp;Moment.
      </h1>
      <div class="spotlight-plate__credit" id="spotlight-credit"></div>
      <div class="spotlight-plate__activity" id="spotlight-activity"></div>
      <div class="spotlight-plate__ctas">
        <a href="#gallery-wall" class="spotlight-btn-gold">Explore Gallery Wall</a>
        <a href="#membership" class="spotlight-btn-outline">Become a Member</a>
      </div>
    </div>

  </section>


  <!-- ══════════════════════════════════════════════════
       2. STAT BAND
       ══════════════════════════════════════════════════ -->
  <section class="statband" aria-label="Club statistics">
    <div class="container">
      <div class="statband-inner" data-gsap="stagger">

        <div class="stat">
          <div class="stat-value">
            <span data-gsap="counter" data-target="340" data-suffix="+">—</span>
          </div>
          <div class="stat-label">Active Members</div>
        </div>

        <div class="stat">
          <div class="stat-value">
            <span data-gsap="counter" data-target="87">—</span>
          </div>
          <div class="stat-label">Photowalks</div>
        </div>

        <div class="stat">
          <div class="stat-value">
            <span data-gsap="counter" data-target="10" data-suffix="th">—</span>
          </div>
          <div class="stat-label">Year · 2026</div>
        </div>

        <div class="stat">
          <div class="stat-value">
            <span data-gsap="counter" data-target="4200" data-suffix="+">—</span>
          </div>
          <div class="stat-label">Gallery Photos</div>
        </div>

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       3. GALLERY WALL — Justified grid
       "Our members, on the wall."
       Max one frame per photographer. Flickr algorithm.
       ══════════════════════════════════════════════════ -->
  <section class="section gallery-wall" id="gallery-wall" aria-label="Member gallery wall">
    <div class="container">

      <div class="gallery-wall-header">
        <SectionHeader
          eyebrow="On the Wall"
          title="Our members, on the wall."
          subtitle="One frame per photographer — original aspect ratios preserved, as composed."
        />
        <a href="/showcase/" class="btn btn-outline btn-md">View all in Showcase</a>
      </div>

      <!-- Justified grid — populated by JS -->
      <div class="justified-grid" id="gallery-grid" aria-label="Member photographs">
        <!-- Skeleton rows -->
        <div id="gallery-skeleton">
          {[[3.2,1.5,4.0,1.0],[1.0,2.5,1.2,2.0,1.8],[2.4,1.5,3.0,1.0]].map(row => (
            <div class="jrow">
              {row.map(flex => <div class="skel" style={`flex:${flex};height:240px;`}></div>)}
            </div>
          ))}
        </div>
      </div>

      <p class="gallery-footnote auth-hide">
        Your frame could hang here —&nbsp;
        <a href="/join/" class="btn-text">Become a Member</a>
      </p>

    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       4. THE CLUB
       ══════════════════════════════════════════════════ -->
  <section class="section the-club" id="the-club" aria-label="The Club">
    <div class="container">
      
      <div class="the-club-header">
        <div class="the-club-header__kicker">The Club</div>
        <h3 class="the-club-header__title">One Community. Four Ways To Participate.</h3>
      </div>

      <div class="the-club-grid">
        
        <!-- Card 1: Photowalks -->
        <a href="/activities?type=photowalk" class="club-card active-card" aria-label="Photowalks: Walk the city with us">
          <div class="club-card__image-area">
            <div class="club-card__gradient" style="background: repeating-linear-gradient(135deg, #1A1816 0px, #1A1816 20px, #201E1C 20px, #201E1C 40px);"></div>
          </div>
          <div class="club-card__body">
            <div class="club-card__kicker">Photowalks</div>
            <h4 class="club-card__title">Walk the city with us</h4>
            <p class="club-card__desc">Monthly guided walks through Bhopal's heritage, lakes, and markets.</p>
            <div class="club-card__link">Explore Photowalks <span class="arrow">→</span></div>
          </div>
        </a>

        <!-- Card 2: Photo Contests -->
        <a href="/activities/contests" class="club-card active-card" aria-label="Photo Contests: Compete and be seen">
          <div class="club-card__image-area">
            <div class="club-card__gradient" style="background: repeating-linear-gradient(135deg, #1C1A18 0px, #1C1A18 20px, #222020 20px, #222020 40px);"></div>
          </div>
          <div class="club-card__body">
            <div class="club-card__kicker">Photo Contests</div>
            <h4 class="club-card__title">Compete and be seen</h4>
            <p class="club-card__desc">Theme-based competitions open to members. Jury-judged with exhibition prizes.</p>
            <div class="club-card__link">View Contests <span class="arrow">→</span></div>
          </div>
        </a>

        <!-- Card 3: Exhibitions -->
        <a href="/activities/exhibitions" class="club-card active-card" aria-label="Exhibitions: Print and exhibit your work">
          <div class="club-card__image-area">
            <div class="club-card__gradient" style="background: repeating-linear-gradient(135deg, #181614 0px, #181614 20px, #1E1C1A 20px, #1E1C1A 40px);"></div>
          </div>
          <div class="club-card__body">
            <div class="club-card__kicker">Exhibitions</div>
            <h4 class="club-card__title">Print and exhibit your work</h4>
            <p class="club-card__desc">Annual and themed exhibitions at Bhopal's cultural venues.</p>
            <div class="club-card__link">See Exhibitions <span class="arrow">→</span></div>
          </div>
        </a>

        <!-- Card 4: Photography School (Coming Soon) -->
        <div class="club-card disabled-card" aria-label="Photography School: Learn with the club (Coming Soon)">
          <div class="club-card__image-area">
            <div class="club-card__gradient" style="background: repeating-linear-gradient(135deg, #2A2826 0px, #2A2826 20px, #2E2C2A 20px, #2E2C2A 40px);"></div>
            <div class="club-card__badge-overlay">
              <span class="badge">COMING SOON</span>
            </div>
          </div>
          <div class="club-card__body">
            <div class="club-card__kicker">Photography School</div>
            <h4 class="club-card__title">Learn with the club</h4>
            <p class="club-card__desc">Structured education — workshops, modules, mentorship. Coming soon.</p>
            <div class="club-card__link">Coming Soon</div>
          </div>
        </div>

      </div>

    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       5. FEATURED ACTIVITY (Conditional)
       ══════════════════════════════════════════════════ -->
  {featuredActivity.enabled && (
    <section class="featured-activity" id="featured-activity" aria-label="Featured Activity">
      <div class="container">
        <div class="featured-activity-card">
          <div class="featured-activity-card__gradient"></div>
          <div class="featured-activity-card__overlay"></div>
          <div class="featured-activity-card__content">
            <div class="featured-activity-card__kicker">Featured Activity</div>
            <h2 class="featured-activity-card__title">{featuredActivity.title}</h2>
            <p class="featured-activity-card__desc">{featuredActivity.description}</p>
            <div class="featured-activity-card__meta">{featuredActivity.meta}</div>
            <div class="featured-activity-card__ctas">
              <a href={featuredActivity.registerUrl} class="featured-activity-btn-gold">Register →</a>
              <a href={featuredActivity.learnMoreUrl} class="featured-activity-btn-outline">Learn More</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}


  <!-- ══════════════════════════════════════════════════
       6. UPCOMING ACTIVITIES
       ══════════════════════════════════════════════════ -->
  <section class="section section-sm surface-alt events-section" id="upcoming-activities" aria-label="Upcoming activities">
    <div class="container">

      <div class="events-header">
        <div>
          <div class="events-header__kicker">Upcoming</div>
          <h3 class="events-header__title">What's happening</h3>
        </div>
        <a href="/activities/" class="events-header__all-link">ALL ACTIVITIES →</a>
      </div>

      <div class="events-list" id="events-list" aria-label="Upcoming events list">
        <!-- Skeleton rows matching new layout exactly -->
        {[1,2,3].map(() => (
          <div class="event-row-skel" style="display:grid;grid-template-columns:80px 188px 1fr auto;align-items:center;gap:28px;padding:22px 32px;border-bottom:1px solid #F0EBE0;background:#FFFFFF;">
            <div class="skel" style="width:50px;height:50px;margin:0 auto;background:#F0EBE0;border-radius:0;"></div>
            <div class="skel" style="width:188px;height:112px;background:#F0EBE0;border-radius:0;"></div>
            <div style="flex:1;display:flex;flex-direction:column;gap:8px;">
              <div class="skel" style="width:30%;height:9px;background:#F0EBE0;border-radius:0;"></div>
              <div class="skel" style="width:70%;height:14px;background:#F0EBE0;border-radius:0;"></div>
              <div class="skel" style="width:45%;height:9px;background:#F0EBE0;border-radius:0;"></div>
            </div>
            <div class="skel" style="width:100px;height:36px;background:#F0EBE0;border-radius:0;"></div>
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       7. PHOTO SERIES
       ══════════════════════════════════════════════════ -->
  <section class="section" id="photo-series" aria-label="Photo Series">
    <div class="container">
      <div style="display:flex;align-items:baseline;gap:20px;margin-bottom:16px;">
        <span style="font-family:var(--font-mono);font-size:13px;color:#A8843C;">09</span>
        <h2 style="font-family:var(--font-display);font-size:40px;font-weight:700;letter-spacing:-0.025em;color:var(--ink-900);">Photo Series — The City Is Our Muse</h2>
      </div>
      <p style="font-size:16px;line-height:1.7;color:#57514B;max-width:680px;margin-bottom:32px;">Editorial storytelling band. Full-bleed image-led section with parallax-soft scroll effect. Provides visual rhythm break between UpcomingActivities and Membership. No interactive elements.</p>

      <div class="photo-series-card-wrapper">
        <div class="photo-series-card">
          <div class="photo-series-card__gradient"></div>
          <div class="photo-series-card__overlay"></div>
          <div class="photo-series-card__content">
            <div class="photo-series-card__kicker">Photo Series</div>
            <h2 class="photo-series-card__title">The City Is Our Muse.</h2>
            <p class="photo-series-card__desc">Lakes, forts, mosques and markets — our members document the extraordinary visual richness of Bhopal and beyond.</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       8. MEMBERSHIP
       ══════════════════════════════════════════════════ -->
  <section class="section" id="membership" aria-label="Membership tiers">
    <div class="container">
      <div style="display:flex;align-items:baseline;gap:20px;margin-bottom:16px;">
        <span style="font-family:var(--font-mono);font-size:13px;color:#A8843C;">10</span>
        <h2 style="font-family:var(--font-display);font-size:40px;font-weight:700;letter-spacing:-0.025em;color:var(--ink-900);">Membership — Three-Step Educational Flow</h2>
      </div>
      <p style="font-size:16px;line-height:1.7;color:#57514B;max-width:680px;margin-bottom:32px;">Three-step educational flow communicating the membership journey. Registration, Application, and Membership Active are presented as distinct milestones. Do not collapse into a single CTA.</p>

      <div class="membership-box">
        <div class="membership-box__inner">
          <div class="membership-box__header">
            <div class="membership-box__kicker">Become a Member</div>
            <h3 class="membership-box__title">Join Bhopal Camera Club</h3>
            <p class="membership-box__desc">Photography community, mentorship, and exhibitions. Three clear steps to membership.</p>
          </div>

          <!-- Three-step flow -->
          <div class="membership-steps">
            <div class="membership-step">
              <div class="membership-step__circle">1</div>
              <div class="membership-step__label">Registration</div>
              <p class="membership-step__body">Create your identity. Free. Immediate access to public content.</p>
              <a href="/auth/register/" class="membership-step__link">/auth/register</a>
            </div>
            <div class="membership-steps__arrow">
              <div class="membership-steps__line"></div>
              <span class="membership-steps__symbol">→</span>
            </div>
            <div class="membership-step">
              <div class="membership-step__circle">2</div>
              <div class="membership-step__label">Membership Application</div>
              <p class="membership-step__body">Complete the application. Select tier. Await committee review and approval.</p>
              <a href="/hub/membership/apply/" class="membership-step__link">/hub/membership/apply</a>
            </div>
            <div class="membership-steps__arrow">
              <div class="membership-steps__line"></div>
              <span class="membership-steps__symbol">→</span>
            </div>
            <div class="membership-step membership-step--active">
              <div class="membership-step__circle">3</div>
              <div class="membership-step__label">Membership Active</div>
              <p class="membership-step__body">Full member entitlements. Member Hub access. All activities and exhibitions.</p>
              <span class="membership-step__link">ACTIVE · MEM-007 number assigned</span>
            </div>
          </div>

          <!-- Tier cards -->
          <div class="membership-tiers">
            <!-- Student -->
            <div class="membership-tier-card">
              <div class="membership-tier-card__name">Student</div>
              <div class="membership-tier-card__price">₹500<span> /year</span></div>
              <div class="membership-tier-card__note">Valid student ID required</div>
              <div class="membership-tier-card__feats">
                ✓ All monthly photowalks<br/>
                ✓ Workshop access<br/>
                ✓ Gallery submissions
              </div>
            </div>

            <!-- Individual -->
            <div class="membership-tier-card membership-tier-card--featured">
              <div class="membership-tier-card__pop-badge">Most Popular</div>
              <div class="membership-tier-card__name">Individual</div>
              <div class="membership-tier-card__price">₹1,200<span> /year</span></div>
              <div class="membership-tier-card__note">Most popular membership</div>
              <div class="membership-tier-card__feats">
                ✓ All events, unlimited<br/>
                ✓ Mentorship programme<br/>
                ✓ Voting rights
              </div>
            </div>

            <!-- Basic -->
            <div class="membership-tier-card">
              <div class="membership-tier-card__name">Basic</div>
              <div class="membership-tier-card__price">₹800<span> /year</span></div>
              <div class="membership-tier-card__note">Introductory membership</div>
              <div class="membership-tier-card__feats">
                ✓ Monthly photowalks<br/>
                ✓ Basic access<br/>
                ✓ Member newsletter
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════
       9. OPEN CONTEST (Conditional)
       ══════════════════════════════════════════════════ -->
  <!-- ══════════════════════════════════════════════════
       9. OPEN CONTEST (Conditional)
       ══════════════════════════════════════════════════ -->
  {activeContest.enabled && (
    <section class="section open-contest" id="open-contest" aria-label="Open Contest">
      <div class="container">
        <div style="display:flex;align-items:baseline;gap:20px;margin-bottom:16px;">
          <span style="font-family:var(--font-mono);font-size:13px;color:#A8843C;">11</span>
          <h2 style="font-family:var(--font-display);font-size:40px;font-weight:700;letter-spacing:-0.025em;color:var(--ink-900);">Open Contest — Conditional</h2>
        </div>
        <p style="font-size:16px;line-height:1.7;color:#57514B;max-width:680px;margin-bottom:32px;">Entire section renders only when an active contest exists. When absent: no placeholder, no empty state. Page flows from Membership directly to Journal.</p>

        <div class="contest-card">
          <div class="contest-card__info">
            <div class="contest-card__kicker">Open Contest</div>
            <h3 class="contest-card__title">{activeContest.title}</h3>
            <p class="contest-card__desc">{activeContest.description}</p>
            <div class="contest-card__meta-row">
              <div class="contest-card__meta-item">
                <div class="contest-card__meta-label">Deadline</div>
                <div class="contest-card__meta-val">{activeContest.deadline}</div>
              </div>
              <div class="contest-card__meta-divider"></div>
              <div class="contest-card__meta-item">
                <div class="contest-card__meta-label">Eligibility</div>
                <div class="contest-card__meta-val">{activeContest.eligibility}</div>
              </div>
            </div>
          </div>
          <div class="contest-card__action-box">
            <div class="contest-card__action-title">Enter the Contest</div>
            <a href={activeContest.submitUrl} class="contest-card__submit-btn">Submit Entry →</a>
            <a href={activeContest.detailsUrl} class="contest-card__details-btn">View Details</a>
          </div>
        </div>
      </div>
    </section>
  )}


  <!-- ══════════════════════════════════════════════════
       10. JOURNAL
       ══════════════════════════════════════════════════ -->
  <section class="section" id="journal" aria-label="From the journal">
    <div class="container">
      <div style="display:flex;align-items:baseline;gap:20px;margin-bottom:16px;">
        <span style="font-family:var(--font-mono);font-size:13px;color:#A8843C;">12</span>
        <h2 style="font-family:var(--font-display);font-size:40px;font-weight:700;letter-spacing:-0.025em;color:var(--ink-900);">Journal — Latest From The Journal</h2>
      </div>
      <p style="font-size:16px;line-height:1.7;color:#57514B;max-width:680px;margin-bottom:32px;">Three JournalCard components in standard layout. Final editorial section before the footer. All Stories → links to /journal.</p>

      <div class="journal-header">
        <div>
          <div class="journal-header__kicker">Field Notes</div>
          <h3 class="journal-header__title">Latest from the journal</h3>
        </div>
        <a href="/journal/" class="journal-header__all-link">All Stories →</a>
      </div>

      <div class="journal-grid" id="journal-grid" data-gsap="stagger">
        <!-- Skeleton cards matching V6 layouts exactly -->
        {[1,2,3].map(() => (
          <div class="journal-card">
            <div class="journal-card__img">
              <div class="journal-card__img-gradient"></div>
            </div>
            <div class="journal-card__body">
              <div class="skel" style="width:35%;height:9px;background:#F0EBE0;margin-bottom:10px;border-radius:0;"></div>
              <div class="skel" style="width:80%;height:14px;background:#F0EBE0;margin-bottom:8px;border-radius:0;"></div>
              <div class="skel" style="width:60%;height:10px;background:#F0EBE0;border-radius:0;margin-top:auto;"></div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

</BaseLayout>


<style>
/* ── Spotlight hero ── */
.spotlight {
  position: relative;
  height: 580px;
  overflow: hidden;
  background: var(--image-backdrop);
}

.spotlight-img {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.spotlight-fallback {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(135deg, #1A1816 0px, #1A1816 32px, #1E1C1A 32px, #1E1C1A 64px);
}
.spotlight-photo {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0;
  transition: opacity 0.8s ease;
}
.spotlight-photo.loaded { opacity: 1; }

.spotlight-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(180deg, rgba(20,18,16,0.12) 0%, rgba(20,18,16,0) 35%, rgba(20,18,16,0.5) 100%);
}

.spotlight-plate {
  position: absolute;
  left: 48px;
  bottom: 48px;
  z-index: 10;
  max-width: 420px;
  background: rgba(255, 255, 255, 0.97);
  border: 1px solid #E7E1D6;
  box-shadow: 0 24px 64px rgba(20, 18, 16, 0.22);
  padding: 32px 36px;
  border-radius: var(--r-0);
  display: flex;
  flex-direction: column;
  color: #141210;
}
.spotlight-plate__meta {
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #A8843C;
  font-weight: 600;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 10px;
  min-height: auto;
}
.spotlight-plate__meta span {
  display: block;
  width: 20px;
  height: 1px;
  background: #C9A961;
}
.spotlight-plate__title {
  font-family: var(--font-display);
  font-size: 26px;
  font-weight: 700;
  letter-spacing: -0.025em;
  line-height: 1.1;
  color: #141210;
  margin-bottom: 10px;
}
.spotlight-plate__credit {
  font-size: 13px;
  font-weight: 500;
  color: #141210;
  margin-bottom: 4px;
  font-family: var(--font-body);
  min-height: auto;
}
.spotlight-plate__activity {
  font-size: 12px;
  color: #8B8378;
  font-family: var(--font-body);
}
.spotlight-plate__ctas {
  display: flex;
  gap: 10px;
  margin-top: 20px;
  flex-wrap: wrap;
}

/* Gold CTA button matching V6 style exactly */
.spotlight-btn-gold {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: #141210 !important;
  background: linear-gradient(135deg, #C9A961, #A8843C);
  padding: 10px 18px;
  display: inline-block;
  text-decoration: none;
  border: none;
  transition: opacity var(--m-fast);
}
.spotlight-btn-gold:hover {
  opacity: 0.9;
}

/* Outline CTA button matching V6 style exactly */
.spotlight-btn-outline {
  font-size: 11px;
  font-weight: 500;
  color: #141210 !important;
  border: 1px solid #C9A961;
  padding: 9px 16px;
  display: inline-block;
  text-decoration: none;
  background: transparent;
  transition: background var(--m-fast);
}
.spotlight-btn-outline:hover {
  background: rgba(201, 169, 97, 0.08);
}

/* ── Stat band ── */
.statband {
  padding: 0;
}
.statband-inner {
  display: flex;
  background: #FFFFFF;
  border: 1px solid var(--hairline);
  border-top: 3px solid var(--gold-600);
  overflow: hidden;
}
.stat {
  flex: 1;
  text-align: left;
  padding: 32px 36px;
  border-right: 1px solid var(--hairline);
}
.stat:last-child {
  border-right: none;
}
.stat-value {
  font-family: var(--font-display);
  font-size: 44px;
  font-weight: 700;
  letter-spacing: -0.04em;
  color: var(--ink-900);
  line-height: 1;
  margin-bottom: 8px;
}
.stat-label {
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-400);
  margin-bottom: 6px;
}

/* ── The Club ── */
.the-club-header {
  background: #FFFFFF;
  border: 1px solid var(--hairline);
  border-bottom: none;
  padding: 28px 32px 24px;
}
.the-club-header__kicker {
  font-family: var(--font-body);
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: 600;
  margin-bottom: 12px;
}
.the-club-header__title {
  font-family: var(--font-display);
  font-size: 30px;
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--ink-900);
  margin: 0;
}

.the-club-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border: 1px solid var(--hairline);
  margin-bottom: 14px;
  background: #FFFFFF;
}

.club-card {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  border-right: 1px solid var(--hairline);
  position: relative;
  background: #FFFFFF;
  transition: outline 0.2s ease, z-index 0.2s ease;
}
.club-card:last-child {
  border-right: none;
}

.club-card__image-area {
  height: 192px;
  position: relative;
  overflow: hidden;
}
.club-card__gradient {
  position: absolute;
  inset: 0;
}

/* Active card hover outline */
.club-card.active-card:hover {
  outline: 2px solid var(--gold-500);
  z-index: 10;
}

/* Disabled card styling */
.club-card.disabled-card {
  opacity: 0.55;
  pointer-events: none;
  cursor: default;
  background: #FAF8F4;
}
.club-card.disabled-card .club-card__image-area {
  opacity: 0.55;
}
.club-card__badge-overlay {
  position: absolute;
  inset: 0;
  background: rgba(250, 248, 244, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
}
.club-card__badge-overlay .badge {
  font-family: var(--font-mono);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  background: #141210;
  color: var(--gold-500);
  padding: 4px 12px;
}

.club-card__body {
  padding: 22px 22px 26px;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.club-card__kicker {
  font-family: var(--font-body);
  font-size: 10px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: 600;
  margin-bottom: 8px;
}
.club-card.disabled-card .club-card__kicker {
  color: #8B8378;
}
.club-card__title {
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 600;
  letter-spacing: -0.01em;
  color: var(--ink-900);
  margin: 0 0 8px 0;
  line-height: 1.25;
}
.club-card.disabled-card .club-card__title {
  color: #8B8378;
}
.club-card__desc {
  font-family: var(--font-body);
  font-size: 13px;
  line-height: 1.7;
  color: var(--ink-600);
  margin: 0 0 16px 0;
  flex: 1;
}
.club-card.disabled-card .club-card__desc {
  color: #8B8378;
}
.club-card__link {
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 600;
  color: var(--gold-600);
  letter-spacing: 0.04em;
  margin-top: auto;
}
.club-card__link .arrow {
  font-size: 10px;
}
.club-card.disabled-card .club-card__link {
  color: #8B8378;
}

/* ── Featured Activity ── */
.featured-activity {
  padding: 96px 0;
}
.featured-activity-card {
  position: relative;
  min-height: 460px;
  background: #181614;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  overflow: hidden;
  border: 1px solid #2C2820;
}
.featured-activity-card__gradient {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(135deg, #181614 0px, #181614 40px, #1C1A18 40px, #1C1A18 80px);
  z-index: 0;
}
.featured-activity-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(20, 18, 16, 0.7) 0%, rgba(20, 18, 16, 0.1) 65%);
  z-index: 1;
}
.featured-activity-card__content {
  position: relative;
  z-index: 2;
  max-width: 560px;
  padding: 48px 64px;
}
.featured-activity-card__kicker {
  font-family: var(--font-body);
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #C9A961;
  font-weight: 600;
  margin-bottom: 14px;
}
.featured-activity-card__title {
  font-family: var(--font-display);
  font-size: 38px;
  font-weight: 700;
  letter-spacing: -0.025em;
  color: #FFFFFF;
  line-height: 1.05;
  margin: 0 0 14px 0;
}
.featured-activity-card__desc {
  font-family: var(--font-body);
  font-size: 15px;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.8);
  margin: 0 0 28px 0;
  font-weight: 300;
  max-width: 420px;
}
.featured-activity-card__meta {
  font-family: var(--font-mono);
  font-size: 11px;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 24px;
}
.featured-activity-card__ctas {
  display: flex;
  gap: 12px;
}
.featured-activity-btn-gold {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: #141210 !important;
  background: linear-gradient(135deg, #C9A961, #A8843C);
  padding: 13px 30px;
  border: none;
  border-radius: 2px;
  text-decoration: none;
  display: inline-block;
  transition: opacity var(--m-fast);
}
.featured-activity-btn-gold:hover {
  opacity: 0.9;
}
.featured-activity-btn-outline {
  font-size: 12px;
  font-weight: 500;
  color: #FFFFFF !important;
  border: 1px solid rgba(255, 255, 255, 0.35);
  padding: 12px 26px;
  border-radius: 2px;
  text-decoration: none;
  display: inline-block;
  background: transparent;
  transition: background var(--m-fast);
}
.featured-activity-btn-outline:hover {
  background: rgba(255, 255, 255, 0.08);
}

/* ── Gallery wall ── */
.gallery-wall-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--s-4);
  margin-bottom: var(--s-4);
}
:global(.jrow) { display: flex; gap: 8px; margin-bottom: 8px; }
:global(.jrow:last-child) { margin-bottom: 0; }
.gallery-footnote {
  margin-top: var(--s-4);
  font-size: var(--text-small);
  color: var(--ink-400);
}
/* Real photo cards in grid */
:global(.jrow .photo-card) {
  overflow: hidden;
  flex-shrink: 0;
  border-radius: var(--r-0);
  background: var(--surface-2);
  position: relative;
  cursor: pointer;
  display: block;
  text-decoration: none;
}
/* Corner brackets styling */
:global(.viewfinder-corner) {
  position: absolute;
  width: 16px;
  height: 16px;
  opacity: 0;
  transition: opacity var(--m-fast);
  pointer-events: none;
  z-index: 2;
}
:global(.viewfinder-corner.top-left) {
  top: 10px;
  left: 10px;
  border-top: 2px solid #FFFFFF;
  border-left: 2px solid #FFFFFF;
}
:global(.viewfinder-corner.top-right) {
  top: 10px;
  right: 10px;
  border-top: 2px solid #FFFFFF;
  border-right: 2px solid #FFFFFF;
}
:global(.viewfinder-corner.bottom-left) {
  bottom: 10px;
  left: 10px;
  border-bottom: 2px solid #FFFFFF;
  border-left: 2px solid #FFFFFF;
}
:global(.viewfinder-corner.bottom-right) {
  bottom: 10px;
  right: 10px;
  border-bottom: 2px solid #FFFFFF;
  border-right: 2px solid #FFFFFF;
}
:global(.jrow .photo-card:hover .viewfinder-corner) {
  opacity: 1;
}

/* Dark overlay on hover */
:global(.jrow .photo-card::before) {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(20, 18, 16, 0.45);
  opacity: 0;
  transition: opacity var(--m-fast);
  z-index: 1;
  pointer-events: none;
}
:global(.jrow .photo-card:hover::before) {
  opacity: 1;
}

:global(.jrow .photo-card img) {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: var(--r-0);
  transition: transform var(--m-image);
}

/* Caption on hover */
:global(.jrow .photo-card .photo-caption) {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 8px 10px;
  background: rgba(20, 18, 16, 0.65);
  opacity: 0;
  transform: translateY(10px);
  transition: opacity var(--m-fast), transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  z-index: 2;
}
:global(.jrow .photo-card:hover .photo-caption) {
  opacity: 1;
  transform: translateY(0);
}
:global(.photo-caption__photographer) {
  font-family: var(--font-display);
  font-size: 11px;
  font-weight: 600;
  color: #FFFFFF;
}
:global(.photo-caption__link) {
  font-family: var(--font-mono);
  font-size: 9px;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 2px;
}

/* ── Events ── */
.events-header {
  background: #FFFFFF;
  border: 1px solid var(--hairline);
  border-bottom: none;
  padding: 22px 32px 18px;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}
.events-header__kicker {
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: 600;
  margin-bottom: 10px;
}
.events-header__title {
  font-family: var(--font-display);
  font-size: 30px;
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--ink-900);
  margin: 0;
}
.events-header__all-link {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--gold-600);
  border-bottom: 1px solid var(--gold-500);
  padding-bottom: 2px;
  text-decoration: none;
  cursor: pointer;
}

.events-list {
  display: flex;
  flex-direction: column;
  border: 1px solid var(--hairline);
  border-top: none;
  margin-bottom: 14px;
  background: #FFFFFF;
}

.event-row {
  display: grid;
  grid-template-columns: 80px 188px 1fr auto;
  align-items: center;
  gap: 28px;
  padding: 22px 32px;
  border-bottom: 1px solid #F0EBE0;
  background: #FFFFFF;
  text-decoration: none;
  color: inherit;
  transition: background var(--m-fast);
}
.event-row:last-child {
  border-bottom: none;
}
.event-row:hover {
  background: #FAF8F4;
}

.event-row__date {
  text-align: center;
}
.event-row__day {
  font-family: var(--font-display);
  font-size: 36px;
  font-weight: 700;
  letter-spacing: -0.04em;
  color: #141210;
  line-height: 1;
}
.event-row__month {
  font-family: var(--font-body);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #8B8378;
  margin-top: 3px;
}

.event-row__thumb {
  height: 112px;
  width: 188px;
  position: relative;
  overflow: hidden;
}
.event-row__thumb-gradient {
  position: absolute;
  inset: 0;
}
.event-row__thumb-tag {
  position: absolute;
  top: 6px;
  left: 8px;
  font-family: var(--font-body);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 2px 8px;
}
.event-row__thumb-tag.tag-photowalk {
  background: #E8EFE9;
  color: #3E5A48;
}
.event-row__thumb-tag.tag-workshop {
  background: #F5EDD8;
  color: #8C6830;
}
.event-row__thumb-tag.tag-exhibition {
  background: #141210;
  color: #FAF8F4;
}
.event-row__thumb-tag.tag-default {
  background: #F0EBE0;
  color: #8B8378;
}

.event-row__info {
  display: flex;
  flex-direction: column;
}
.event-row__time-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 6px;
}
.event-row__time {
  font-family: var(--font-mono);
  font-size: 11px;
  color: #8B8378;
}
.event-row__members-badge {
  font-family: var(--font-mono);
  font-size: 9px;
  background: #F0EBE0;
  color: #8B8378;
  padding: 2px 8px;
  letter-spacing: 0.08em;
}
.event-row__title {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 600;
  letter-spacing: -0.01em;
  color: #141210;
  margin: 0 0 4px 0;
  line-height: 1.2;
}
.event-row__venue {
  font-family: var(--font-body);
  font-size: 12px;
  color: #8B8378;
}

.event-row__btn {
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #A8843C !important;
  border: 1px solid #C9A961;
  padding: 11px 22px;
  border-radius: 2px;
  background: linear-gradient(180deg, rgba(201, 169, 97, 0.04), rgba(201, 169, 97, 0.10));
  white-space: nowrap;
  text-decoration: none;
  transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
}
.event-row__btn:hover {
  background: linear-gradient(135deg, #C9A961, #A8843C);
  color: #FFFFFF !important;
  border-color: #A8843C;
}

.event-row-skel {
  display: flex;
  align-items: center;
  gap: var(--s-4);
  padding: var(--s-3) 0;
  border-bottom: 1px solid var(--hairline);
}

/* ── Photo Series ── */
.photo-series-card-wrapper {
  border: 1px solid #2C2820;
  overflow: hidden;
  margin-bottom: 14px;
}
.photo-series-card {
  position: relative;
  height: 400px;
  background: #181614;
  overflow: hidden;
}
.photo-series-card__gradient {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(165deg, #181614 0px, #181614 40px, #1C1A18 40px, #1C1A18 80px);
}
.photo-series-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(20, 18, 16, 0.62) 0%, rgba(20, 18, 16, 0.12) 55%, rgba(20, 18, 16, 0) 100%);
}
.photo-series-card__content {
  position: relative;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 64px;
  max-width: 560px;
  z-index: 2;
}
.photo-series-card__kicker {
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #C9A961;
  font-weight: 600;
  margin-bottom: 18px;
}
.photo-series-card__title {
  font-family: var(--font-display);
  font-size: 46px;
  font-weight: 700;
  letter-spacing: -0.025em;
  color: #FFFFFF;
  line-height: 1.05;
  margin: 0 0 18px 0;
}
.photo-series-card__desc {
  font-size: 15px;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.8);
  max-width: 390px;
  font-weight: 300;
  margin: 0;
}

/* ── Membership ── */
.membership-box {
  background: linear-gradient(180deg, #FAF8F4, #F4F0E8);
  border: 1px solid #E7E1D6;
  overflow: hidden;
  margin-bottom: 14px;
}
.membership-box__inner {
  padding: 56px 64px 0;
}

.membership-box__header {
  text-align: center;
  margin-bottom: 48px;
}
.membership-box__kicker {
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #A8843C;
  font-weight: 600;
  margin-bottom: 12px;
}
.membership-box__title {
  font-family: var(--font-display);
  font-size: 38px;
  font-weight: 700;
  letter-spacing: -0.025em;
  margin: 0 0 14px 0;
  color: var(--ink-900);
}
.membership-box__desc {
  font-size: 16px;
  color: #57514B;
  max-width: 460px;
  margin: 0 auto;
  line-height: 1.7;
  font-weight: 300;
}

/* Steps Flow */
.membership-steps {
  max-width: 700px;
  margin: 0 auto 48px;
  display: flex;
  align-items: flex-start;
  gap: 0;
}
.membership-step {
  flex: 1;
  text-align: center;
  padding: 0 16px;
}
.membership-step__circle {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: #FFFFFF;
  border: 1px solid #E7E1D6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 700;
  color: #141210;
  margin: 0 auto 14px;
  box-shadow: 0 2px 8px rgba(20, 18, 16, 0.06);
}
.membership-step--active .membership-step__circle {
  background: linear-gradient(135deg, #3E5A48, #2A3E32);
  color: #FFFFFF;
  box-shadow: 0 4px 16px rgba(62, 90, 72, 0.28);
  border: none;
}
.membership-step__label {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: #8B8378;
  font-weight: 600;
  margin-bottom: 8px;
}
.membership-step--active .membership-step__label {
  color: #3E5A48;
}
.membership-step__body {
  font-size: 13px;
  line-height: 1.7;
  color: #57514B;
  margin-bottom: 8px;
}
.membership-step__link {
  font-family: var(--font-mono);
  font-size: 10px;
  color: #A8843C;
  text-decoration: none;
  display: inline-block;
}
.membership-step--active .membership-step__link {
  color: #3E5A48;
}
.membership-steps__arrow {
  padding-top: 22px;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}
.membership-steps__line {
  width: 28px;
  height: 1px;
  background: #D8D2C6;
  margin-bottom: 4px;
}
.membership-steps__symbol {
  font-size: 16px;
  color: #C9A961;
  line-height: 1;
}

/* Tiers */
.membership-tiers {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  padding-bottom: 56px;
  max-width: 860px;
  margin: 0 auto;
}
.membership-tier-card {
  background: #FFFFFF;
  border: 1px solid #E7E1D6;
  padding: 34px 28px;
  position: relative;
  box-shadow: 0 1px 2px rgba(20, 18, 16, 0.04);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
