---
/**
 * journal/index.astro — Journal Index Page
 * Route: /journal/
 *
 * Displays a list of guides, field reports, and tutorials.
 * Fetches dynamic content from the NestJS backend `/api/v1/journal`
 * and falls back to pre-seeded editorial logs.
 *
 * Uses EditorialCard (V6 62) for both featured and grid cards.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import EditorialCard from '../../components/ui/EditorialCard.astro';

const fallbackPosts = [
  {
    id: 'old-city-heritage-walk-field-report',
    slug: 'old-city-heritage-walk-field-report',
    title: 'Old City Heritage Walk: A Field Report',
    pubDate: '2026-06-23T10:00:00Z',
    heroImage: '/images/Orchha-Reflection-Ankit-Tiwari-1024x737.jpeg',
    category: 'Field Report',
    readingTime: '4 min',
    excerpt: 'Last weekend, over 25 photographers joined us in the narrow lanes of Chowk Bazaar to document the historic monuments and daily street life of Bhopal...'
  },
  {
    id: 'golden-hour-photography-guide',
    slug: 'golden-hour-photography-guide',
    title: 'Mastering the Golden Hour',
    pubDate: '2026-07-01T15:00:00Z',
    heroImage: '/images/StreetLife-Rahil-Khan-1024x768.jpeg',
    category: 'Guide',
    readingTime: '6 min',
    excerpt: 'Shooting during the golden hour presents unique opportunities and challenges. Learn how to manage high dynamic range, preserve highlight details, and capture warm compositions...'
  }
];

const featuredPost = fallbackPosts[0];
const gridPosts = fallbackPosts.slice(1);

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-IN', {
    year: 'numeric', month: 'long', day: 'numeric'
  });
}
---

<BaseLayout
  title="Journal"
  description="Guides, tutorials, field reports, and perspectives written by the Bhopal Camera Club community."
>
  <div class="journal-wrapper">

    <!-- Header -->
    <header class="journal-header surface-white">
      <div class="container">
        <SectionHeader
          eyebrow="Stories & Craft"
          title="The Journal"
          subtitle="Guides, tutorial logs, event field reports, and artistic perspectives written by the Bhopal Camera Club community."
          as="h1"
          data-gsap="reveal"
        />
      </div>
      <div class="hairline"></div>
    </header>

    <!-- Featured Post -->
    {featuredPost && (
      <section class="section featured-section" aria-label="Featured article">
        <div class="container">
          <div id="featured-wrap">
            <EditorialCard
              variant="featured"
              href={`/journal/${featuredPost.slug}/`}
              image={featuredPost.heroImage}
              imageAlt={featuredPost.title}
              category={featuredPost.category}
              title={featuredPost.title}
              excerpt={featuredPost.excerpt}
              date={formatDate(featuredPost.pubDate)}
              readingTime={featuredPost.readingTime}
              headingLevel="h2"
            />
          </div>
        </div>
      </section>
    )}

    <!-- Grid List -->
    <section class="section archive-section" aria-label="Latest articles">
      <div class="container">
        <SectionHeader
          eyebrow="Archive Logs"
          title="Latest Articles"
          align="left"
        />

        <div id="journal-grid" class="journal-index-grid" data-gsap="stagger">
          {gridPosts.map(post => (
            <EditorialCard
              variant="card"
              href={`/journal/${post.slug}/`}
              image={post.heroImage}
              imageAlt={post.title}
              category={post.category}
              title={post.title}
              excerpt={post.excerpt}
              date={formatDate(post.pubDate)}
              readingTime={post.readingTime}
            />
          ))}
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
.journal-wrapper {
  background-color: var(--surface-1);
  min-height: 100vh;
}
.journal-header {
  padding-top: calc(var(--nav-h) + var(--s-8));
  padding-bottom: var(--s-6);
}
.featured-section {
  padding-top: 0;
}
.archive-section {
  padding-top: var(--s-8);
  padding-bottom: var(--s-12);
}
.journal-index-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--s-3);
  margin-top: var(--s-6);
}
@media (max-width: 640px) {
  .journal-index-grid {
    grid-template-columns: 1fr;
  }
}
</style>

<script>
  async function loadJournalIndex() {
    try {
      const res = await fetch('/api/v1/journal?limit=20');
      if (!res.ok) throw new Error('API error');
      const { data } = await res.json();
      const posts = Array.isArray(data) ? data : [];
      if (posts.length > 0) {
        renderFeatured(posts[0]);
        if (posts.length > 1) {
          renderGrid(posts.slice(1));
        }
      }
    } catch {
      // Keep static pre-seeded fallback
    }
  }

  function formatDate(iso: string) {
    return new Date(iso).toLocaleDateString('en-IN', {
      year: 'numeric', month: 'long', day: 'numeric'
    });
  }

  function renderFeatured(post: any) {
    const wrap = document.getElementById('featured-wrap');
    if (!wrap) return;
    const date = formatDate(post.pubDate);
    const readingTime = post.readingTime || '5 min';
    wrap.innerHTML = `
      <a href="/journal/${post.slug}/" class="editorial-card editorial-card--featured">
        <div class="editorial-card__img-wrap">
          ${post.heroImage
            ? `<img src="${post.heroImage}" alt="${post.title}" class="editorial-card__img" loading="lazy" decoding="async" />`
            : `<div class="editorial-card__img-placeholder" aria-hidden="true"></div>`
          }
        </div>
        <div class="editorial-card__body">
          ${post.category ? `<span class="editorial-card__category">${post.category}</span>` : ''}
          <h2 class="editorial-card__title">${post.title}</h2>
          ${post.excerpt ? `<p class="editorial-card__excerpt">${post.excerpt}</p>` : ''}
          <div class="editorial-card__meta">
            <span>${date}</span>
            <span class="editorial-card__sep" aria-hidden="true">·</span>
            <span>${readingTime} read</span>
          </div>
        </div>
      </a>
    `;
  }

  function renderGrid(posts: any[]) {
    const grid = document.getElementById('journal-grid');
    if (!grid) return;
    grid.innerHTML = '';
    posts.forEach((post: any) => {
      const date = formatDate(post.pubDate);
      const readingTime = post.readingTime || '5 min';
      const card = document.createElement('a');
      card.href = `/journal/${post.slug}/`;
      card.className = 'editorial-card editorial-card--card';
      card.innerHTML = `
        <div class="editorial-card__img-wrap">
          ${post.heroImage
            ? `<img src="${post.heroImage}" alt="${post.title}" class="editorial-card__img" loading="lazy" decoding="async" />`
            : `<div class="editorial-card__img-placeholder" aria-hidden="true"></div>`
          }
        </div>
        <div class="editorial-card__body">
          ${post.category ? `<span class="editorial-card__category">${post.category}</span>` : ''}
          <h3 class="editorial-card__title">${post.title}</h3>
          ${post.excerpt ? `<p class="editorial-card__excerpt">${post.excerpt}</p>` : ''}
          <div class="editorial-card__meta">
            <span>${date}</span>
            <span class="editorial-card__sep" aria-hidden="true">·</span>
            <span>${readingTime} read</span>
          </div>
        </div>
      `;
      grid.appendChild(card);
    });
  }

  loadJournalIndex();
</script>
