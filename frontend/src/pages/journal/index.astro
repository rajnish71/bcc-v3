---

<BaseLayout
  title="Journal"
  description="The editorial publication of Bhopal Camera Club — photography, nature, heritage and the stories that only a club of this age can tell."
>
  <div class="journal-page">

    <!-- §01 PageHero — 16:9, editorial overlay, no CTA -->
    <PageHero
      variant="journal"
      eyebrow="BCC Journal · Editorial Publication"
      title="The BCC Journal"
      subtitle={SEO_INTRO}
    />

    <!-- SEO editorial intro (crawlable, below hero) -->
    <section class="journal-seo-intro" aria-label="About the Journal">
      <div class="journal-container">
        <p class="journal-seo-intro__copy">
          The Journal is not a blog. It is the editorial publication of Bhopal Camera Club —
          a record of what we see, where we go, and what we find worth documenting.
          It exists to preserve the photographic practice of our members: the planning behind
          a dawn shoot at the Upper Lake, the patience required to photograph a Painted Stork
          colony in winter, the history of a haveli that will not exist in ten years. You will
          find photo essays here, field reports from wildlife corridors and heritage sites,
          accounts of club expeditions to the Chambal, the Pench and the Western Ghats, and
          essays on the nature of light, the ethics of street photography, and the relationship
          between a photographer and a place photographed over twenty years. Every essay that
          appears in this publication becomes part of the permanent record of Bhopal Camera
          Club. We have been photographing this city since 1965. This is what we have seen.
        </p>
      </div>
    </section>

    <!-- §03 Featured Hero Article -->
    <section class="journal-section" aria-label="Featured article">
      <div class="journal-container">
        <FeaturedHeroArticle {...FEATURED_HERO} />
      </div>
    </section>

    <!-- §04 Category Pivot — sticky behavior deferred to J2 -->
    <JournalCategoryPivot categories={CATEGORIES} />

    <!-- §05 Editor's Picks -->
    <section class="journal-section" aria-label="Editor's Picks">
      <div class="journal-container">
        <SectionHeader
          title="Editor's Picks"
          align="left"
          spacing="md"
          cta={{ label: "All Picks", href: "/journal/picks/" }}
        />
        <JournalEditorsPicks picks={EDITORS_PICKS} />
      </div>
    </section>

    <!-- §06 Featured Category Stories (conditional) -->
    {FEATURED_STORIES.length > 0 && (
      <section class="journal-section" aria-label="Featured stories">
        <div class="journal-container">
          <SectionHeader
            title="Featured Stories"
            align="left"
            spacing="md"
            cta={{ label: "View All", href: "/journal/" }}
          />
          <FeaturedCategoryStories stories={FEATURED_STORIES} />
        </div>
      </section>
    )}

    <!-- §07 Latest Articles -->
    <section class="journal-section" aria-label="Latest articles">
      <div class="journal-container">
        <SectionHeader
          title="Latest Articles"
          subtitle="Chronological feed — most recent first. Featured Hero article excluded."
          align="left"
          spacing="md"
        />
        <LatestArticles articles={LATEST_ARTICLES} totalCount={47} />
      </div>
    </section>

    <!-- §08 Browse by Topic -->
    <section class="journal-section" aria-label="Browse by topic">
      <div class="journal-container">
        <SectionHeader
          title="Browse by Topic"
          subtitle="Subject tags — a finer layer of discovery and internal linking."
          align="left"
          spacing="md"
        />
        <BrowseTopicsGrid topics={TOPICS} />
      </div>
    </section>

    <!-- §09 Meet Our Contributors -->
    <section class="journal-section" aria-label="Meet our contributors">
      <div class="journal-container">
        <SectionHeader
          title="Meet Our Contributors"
          align="left"
          spacing="md"
          cta={{ label: "All Photographers", href: "/photographers/" }}
        />
        <JournalContributors contributors={CONTRIBUTORS} />
      </div>
    </section>

    <!-- §10 Join / Subscribe CTA -->
    <section class="journal-section journal-section--cta" aria-label="Join the journal community">
      <div class="journal-container">
        <JournalJoinCTA />
      </div>
    </section>

  </div>
</BaseLayout>

<style>
.journal-page {
  background: var(--surface-bg);
  min-height: 100vh;
}

/* Journal content container — 1140px per wireframe */
.journal-container {
  width: 100%;
  max-width: var(--container-content);
  margin: 0 auto;
  padding: 0 var(--gutter, 48px);
}

/* Standard section rhythm — 120px top padding matches wireframe sections */
.journal-section {
  padding-top: var(--s-15);
}
.journal-section--cta {
  padding-bottom: var(--s-15);
}

/* SEO intro — below hero, before FeaturedHeroArticle */
.journal-seo-intro {
  padding-top: var(--s-5);
  padding-bottom: 0;
}
.journal-seo-intro__copy {
  font-size: 14px;
  line-height: 1.8;
  color: var(--ink-600);
  max-width: var(--container-text);
  font-style: italic;
}

@media (max-width: 900px) {
  .journal-section { padding-top: var(--s-10); }
  .journal-container { padding: 0 var(--s-4); }
}
@media (max-width: 768px) {
  .journal-section { padding-top: var(--s-8); }
  .journal-section--cta { padding-bottom: var(--s-8); }
  .journal-container { padding: 0 var(--gutter-mob, 20px); }
}
</style>

<script>
  import { loadPageHero } from '../../lib/hero-loader';
  // Loads hero image from heroManager.location("journal") — API-backed, graceful fallback
  loadPageHero('journal').then(() => {
    const img = document.getElementById('page-hero-img') as HTMLImageElement | null;
    if (img && img.src) {
      img.onload = () => img.classList.add('loaded');
      if (img.complete) img.classList.add('loaded');
    }
  });
</script>
