let profileDisplayName = '';
let currentGalleryLayout = 'justified';

// ── Justified grid layout — inherited verbatim from /showcase (item 70) ────
// Rows fill to the container width; the trailing partial row is kept as
// `leftovers` so the next load-more page can complete it (identical to
// Showcase). flushLeftovers() renders any remainder once no more pages exist.
function buildJustifiedLayout(
  photos: Array<{ aspect: number } & Record<string, any>>,
  containerWidth: number,
  targetHeight = 240,
  gap = 8
) {
  const rows: Array<{ height: number; photos: typeof photos }> = [];
  let row: typeof photos = [];
  let rowWidth = 0;

  const flush = () => {
    if (!row.length) return;
    const totalGap = gap * (row.length - 1);
    const scale = (containerWidth - totalGap) / rowWidth;
    const height = targetHeight * scale;
    rows.push({ height, photos: row.map(p => ({ ...p, width: p.aspect * height })) });
    row = [];
    rowWidth = 0;
  };

  for (const photo of photos) {
    row.push(photo);
    rowWidth += photo.aspect * targetHeight;
    if (rowWidth + gap * (row.length - 1) >= containerWidth * 0.88) flush();
  }

  return { rows, leftovers: row };
}

