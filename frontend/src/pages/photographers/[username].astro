<script>
// ── Data ──────────────────────────────────────────────────────────────────
const username = window.location.pathname.split('/').filter(Boolean).pop() ?? '';

interface PhotoEntry {
  id: number;
  uuid: string;
  title: string;
  caption?: string | null;
  genre?: string | null;
  urls: { medium?: string; original?: string };
  width_px?: number | null;
  height_px?: number | null;
  exif?: {
    taken_at?: string | null;
    aperture?: string | null;
    shutter_speed?: string | null;
    iso?: number | null;
    camera_make?: string | null;
    camera_model?: string | null;
    lens_model?: string | null;
    focal_length?: string | null;
  } | null;
}
let allPhotos: PhotoEntry[] = [];
let profileDisplayName = '';

// ── Justified grid layout (same algorithm as homepage gallery wall) ────────
function buildProfileRows(
  photos: Array<{ aspect: number }>,
  containerWidth: number,
  targetH = 220,
  gap = 8
) {
  const rows: Array<{ height: number; items: typeof photos }> = [];
  let row: typeof photos = [], rowW = 0;

  const flush = (last = false) => {
    if (!row.length) return;
    const totalGap = gap * (row.length - 1);
    const scale = last ? Math.min(1, (containerWidth - totalGap) / rowW) : (containerWidth - totalGap) / rowW;
    const h = targetH * scale;
    rows.push({ height: h, items: row.map(p => ({ ...p, width: (p as any).aspect * h })) });
    row = []; rowW = 0;
  };

  for (const p of photos) {
    const iW = (p as any).aspect * targetH;
    row.push(p); rowW += iW;
    if (rowW + gap * (row.length - 1) >= containerWidth * 0.88) flush();
  }
  flush(true); // include partial last row for profile (show all photos)
  return rows;
}

