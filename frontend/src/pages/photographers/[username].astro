---
/**
 * photographers/[username].astro
 * Dynamic Route: /photographers/[username]/
 *
 * Design authority: V6 05 Photographer Profile.dc.html
 * Layout: BaseLayout · Cover banner · Profile hero · 4-tab (Portfolio · About · Contests · Activity)
 *
 * MEM-006 constraints enforced here:
 *   1. PRIVATE profiles excluded at API layer — never in getStaticPaths.
 *   2. 'basic' memberClass: no class badge.
 *   3. No membership CTA anywhere on this page.
 *   4. Founding member badge only when isFoundingMember === true.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BUILD_API_URL } from '../../lib/api';

export async function getStaticPaths() {
  let photographers: any[] = [];
  try {
    const res = await fetch(`${BUILD_API_URL}/photographers?limit=200`);
    if (res.ok) {
      const json = await res.json();
      photographers = json.data || [];
    }
  } catch {
    // Backend unavailable at build time — fall through to hardcoded paths below.
  }

  const paths: { params: { username: string } }[] = [
    { params: { username: '_profile' } },      // Nginx fallback shell — served for any unknown slug
    { params: { username: 'rajnishkhare' } },
    { params: { username: 'ankittiwari' } },
    { params: { username: 'rahilkhan' } },
    { params: { username: 'sauvikacharyya' } },
    { params: { username: 'kshitijpatle' } },
    { params: { username: 'anupamkharegupta' } },
  ];

  photographers.forEach((p: any) => {
    if (p.username && !paths.some(path => path.params.username === p.username)) {
      paths.push({ params: { username: p.username } });
    }
  });

  return paths;
}

const { username } = Astro.params;
---

<BaseLayout
  title={`Photographer · Bhopal Camera Club`}
  description={`Photography portfolio and profile on Bhopal Camera Club.`}
>

<!-- ── COVER BANNER ────────────────────────────────────────────────────────── -->
<div class="cover-banner" id="cover-banner">
  <div class="cover-default" id="cover-default"></div>
  <img id="cover-img" class="cover-img" src="" alt="" hidden />
</div>

<!-- ── PROFILE HERO ───────────────────────────────────────────────────────── -->
<div class="profile-hero" id="profile-hero">
  <div class="ph-inner">

    <!-- Avatar -->
    <div class="ph-avatar-wrap">
      <div class="ph-avatar" id="ph-avatar">
        <span class="ph-avatar-initials" id="ph-initials">—</span>
        <img class="ph-avatar-img" id="ph-avatar-img" src="" alt="" hidden />
      </div>
    </div>

    <!-- Identity -->
    <div class="ph-identity">
      <h1 class="ph-name" id="ph-name">—</h1>
      <div class="ph-username" id="ph-username">@—</div>
      <p class="ph-tagline" id="ph-tagline" hidden></p>
      <div class="ph-location-row" id="ph-location-row" hidden>
        <span id="ph-location"></span>
        <span class="ph-dot" aria-hidden="true"></span>
        <span id="ph-since"></span>
      </div>
      <div class="ph-badges" id="ph-badges">
        <span class="ph-class-badge" id="ph-class-badge" hidden></span>
        <span class="ph-founding-badge" id="ph-founding-badge" hidden>★ FOUNDING MEMBER</span>
      </div>
    </div>

    <!-- Stats -->
    <div class="ph-stats">
      <div class="ph-stat">
        <div class="ph-stat-val" id="ph-photo-count">0</div>
        <div class="ph-stat-label">Photos</div>
      </div>
    </div>

  </div><!-- /.ph-inner -->

  <!-- Tab Navigation -->
  <nav class="tab-nav" role="tablist" aria-label="Photographer sections">
    <div class="tab-nav-inner">
      <button class="tab-btn tab-btn--active" data-tab="portfolio" role="tab" aria-selected="true">Portfolio</button>
      <button class="tab-btn" data-tab="about" role="tab" aria-selected="false">About</button>
      <button class="tab-btn" data-tab="contests" role="tab" aria-selected="false">Contests</button>
      <button class="tab-btn" data-tab="activity" role="tab" aria-selected="false">Activity</button>
    </div>
  </nav>
</div>

<!-- ── TAB CONTENT ────────────────────────────────────────────────────────── -->
<div class="tab-content-area">

  <!-- § PORTFOLIO TAB -->
  <div id="tab-portfolio" class="tab-panel" role="tabpanel">
    <div class="portfolio-layout">

      <!-- Left Rail: Profile at a Glance (sticky) -->
      <aside class="left-rail" id="left-rail">
        <div class="rail-section-head">Profile at a Glance</div>

        <div class="rail-row" id="rail-since-row" hidden>
          <div class="rail-label">Member Since</div>
          <div class="rail-val" id="rail-since">—</div>
        </div>

        <div class="rail-row" id="rail-class-row" hidden>
          <div class="rail-label">Membership Class</div>
          <div class="rail-badge-wrap" id="rail-class-badge"></div>
        </div>

        <div class="rail-row" id="rail-system-row" hidden>
          <div class="rail-label">Camera System</div>
          <div class="rail-val" id="rail-camera-system">—</div>
        </div>

        <div class="rail-row" id="rail-genres-row" hidden>
          <div class="rail-label">Genres</div>
          <div class="rail-genres" id="rail-genres"></div>
        </div>

        <div class="rail-row" id="rail-social-row" hidden>
          <div class="rail-label">Links</div>
          <div class="rail-social" id="rail-social"></div>
        </div>
      </aside>

      <!-- Main: bio snippet + photo grid -->
      <main class="portfolio-main">

        <div class="bio-snippet" id="bio-snippet" hidden>
          <p id="bio-text"></p>
          <a class="bio-more-link" data-tab-trigger="about">Full biography →</a>
        </div>

        <div class="photo-grid-header" id="photo-grid-header" hidden>
          <span class="photo-grid-count" id="photo-grid-count"></span>
        </div>

        <div id="portfolio-grid" class="profile-justified-grid">
          <div class="grid-empty" id="grid-loading">Loading portfolio…</div>
        </div>

      </main>
    </div>
  </div>

  <!-- § ABOUT TAB -->
  <div id="tab-about" class="tab-panel" hidden role="tabpanel">
    <div class="about-layout">

      <!-- Main left (2/3) -->
      <div class="about-main">

        <!-- Full biography -->
        <div class="about-card">
          <div class="about-card-head">Full Biography</div>
          <div class="about-bio" id="about-bio">
            <p class="about-no-bio">No biography provided yet.</p>
          </div>
          <div class="about-bio-meta" id="about-bio-meta" hidden>
            <span class="about-class-badge" id="about-class-badge"></span>
            <span class="about-since" id="about-since"></span>
          </div>
          <div class="about-social-links" id="about-social-links" hidden></div>
        </div>

      </div>

      <!-- Right rail (1/3) -->
      <aside class="about-rail">

        <!-- Awards & Distinctions -->
        <div class="about-card" id="about-awards-card" hidden>
          <div class="about-card-head">Awards &amp; Distinctions</div>
          <div class="about-awards" id="about-awards"></div>
        </div>

        <!-- Photography Society Titles -->
        <div class="about-card" id="about-titles-card" hidden>
          <div class="about-card-head">Photography Society Titles</div>
          <div class="about-titles" id="about-titles"></div>
        </div>

        <!-- Camera Gear -->
        <div class="about-card" id="about-gear-card" hidden>
          <div class="about-card-head">Camera Gear</div>
          <div class="about-gear" id="about-gear"></div>
          <p class="about-gear-note">Self-declared · unverified.</p>
        </div>

        <!-- Photography Genres -->
        <div class="about-card" id="about-genres-card" hidden>
          <div class="about-card-head">Photography Genres</div>
          <div class="about-genres" id="about-genres"></div>
        </div>

        <!-- Areas of expertise -->
        <div class="about-card" id="about-expertise-card" hidden>
          <div class="about-card-head">Areas of Expertise</div>
          <div class="about-genres" id="about-expertise"></div>
        </div>

      </aside>
    </div>
  </div>

  <!-- § CONTESTS TAB -->
  <div id="tab-contests" class="tab-panel" hidden role="tabpanel">
    <div class="placeholder-panel">
      <div class="placeholder-inner">
        <div class="placeholder-icon">🏆</div>
        <div class="placeholder-title">Contest History</div>
        <p class="placeholder-desc">Contest participation and awards for this photographer will be available in a future update.</p>
      </div>
    </div>
  </div>

  <!-- § ACTIVITY TAB -->
  <div id="tab-activity" class="tab-panel" hidden role="tabpanel">
    <div class="placeholder-panel">
      <div class="placeholder-inner">
        <div class="placeholder-icon">📅</div>
        <div class="placeholder-title">Activity Log</div>
        <p class="placeholder-desc">Event attendance and club activity history will be available in a future update.</p>
      </div>
    </div>
  </div>

</div><!-- /.tab-content-area -->

</BaseLayout>

<style>
