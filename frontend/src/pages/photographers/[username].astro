---
/**
 * photographers/[username].astro
 * Dynamic Route: /photographers/[username]/
 *
 * Design authority: V6 05 Photographer Profile.dc.html
 * Layout: BaseLayout · Cover banner · Profile hero · 4-tab (Portfolio · About · Contests · Activity)
 *
 * MEM-006 constraints enforced here:
 *   1. PRIVATE profiles excluded at API layer — never in getStaticPaths.
 *   2. 'basic' memberClass: no class badge.
 *   3. No membership CTA anywhere on this page.
 *   4. Founding member badge only when isFoundingMember === true.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BUILD_API_URL } from '../../lib/api';

export async function getStaticPaths() {
  let photographers: any[] = [];
  try {
    const res = await fetch(`${BUILD_API_URL}/photographers?limit=200`);
    if (res.ok) {
      const json = await res.json();
      photographers = json.data || [];
    }
  } catch {
    // Backend unavailable at build time — fall through to hardcoded paths below.
  }

  const paths: { params: { username: string } }[] = [
    { params: { username: '_profile' } },      // Nginx fallback shell — served for any unknown slug
    { params: { username: 'rajnishkhare' } },
    { params: { username: 'ankittiwari' } },
    { params: { username: 'rahilkhan' } },
    { params: { username: 'sauvikacharyya' } },
    { params: { username: 'kshitijpatle' } },
    { params: { username: 'anupamkharegupta' } },
  ];

  photographers.forEach((p: any) => {
    if (p.username && !paths.some(path => path.params.username === p.username)) {
      paths.push({ params: { username: p.username } });
    }
  });

  return paths;
}

const { username } = Astro.params;
---

<BaseLayout
  title={`Photographer · Bhopal Camera Club`}
  description={`Photography portfolio and profile on Bhopal Camera Club.`}
>

<!-- ── COVER BANNER ────────────────────────────────────────────────────────── -->
<div class="cover-banner" id="cover-banner">
  <div class="cover-default" id="cover-default"></div>
  <img id="cover-img" class="cover-img" src="" alt="" hidden />
</div>

<!-- ── PROFILE HERO ───────────────────────────────────────────────────────── -->
<div class="profile-hero" id="profile-hero">
  <div class="ph-inner">

    <!-- Avatar -->
    <div class="ph-avatar-wrap">
      <div class="ph-avatar" id="ph-avatar">
        <span class="ph-avatar-initials" id="ph-initials">—</span>
        <img class="ph-avatar-img" id="ph-avatar-img" src="" alt="" hidden />
      </div>
    </div>

    <!-- Identity -->
    <div class="ph-identity">
      <h1 class="ph-name" id="ph-name">—</h1>
      <div class="ph-username" id="ph-username">@—</div>
      <p class="ph-tagline" id="ph-tagline" hidden></p>
      <div class="ph-location-row" id="ph-location-row" hidden>
        <span id="ph-location"></span>
        <span class="ph-dot" aria-hidden="true"></span>
        <span id="ph-since"></span>
      </div>
      <div class="ph-badges" id="ph-badges">
        <span class="ph-class-badge" id="ph-class-badge" hidden></span>
        <span class="ph-founding-badge" id="ph-founding-badge" hidden>★ FOUNDING MEMBER</span>
        <span class="ph-recognition-badge" id="ph-recognition-badge" hidden></span>
      </div>
    </div>

    <!-- Stats -->
    <div class="ph-stats">
      <div class="ph-stat">
        <div class="ph-stat-val" id="ph-photo-count">0</div>
        <div class="ph-stat-label">Photos</div>
      </div>
    </div>

  </div><!-- /.ph-inner -->

  <!-- Tab Navigation -->
  <nav class="tab-nav" role="tablist" aria-label="Photographer sections">
    <div class="tab-nav-inner">
      <button class="tab-btn tab-btn--active" data-tab="portfolio" role="tab" aria-selected="true">Portfolio</button>
      <button class="tab-btn" data-tab="about" role="tab" aria-selected="false">About</button>
      <button class="tab-btn" data-tab="contests" role="tab" aria-selected="false">Contests</button>
      <button class="tab-btn" data-tab="activity" role="tab" aria-selected="false">Activity</button>
    </div>
  </nav>
</div>

<!-- ── TAB CONTENT ────────────────────────────────────────────────────────── -->
<div class="tab-content-area">

  <!-- § PORTFOLIO TAB -->
  <div id="tab-portfolio" class="tab-panel" role="tabpanel">
    <div class="portfolio-layout">

      <!-- Left Rail: Profile at a Glance (sticky) — V6 05 spec -->
      <aside class="left-rail" id="left-rail">
        <div class="rail-section-head">Profile at a Glance</div>

        <!-- Contact: website + social — shown first, hidden until data loads -->
        <div class="rail-row rail-contact-block" id="rail-contact-row" hidden>
          <div class="rail-label">Contact &amp; Links</div>
          <div class="rail-contact-links" id="rail-contact-links"></div>
        </div>

        <div class="rail-row" id="rail-since-row" hidden>
          <div class="rail-label">Member Since</div>
          <div class="rail-val" id="rail-since">—</div>
        </div>

        <div class="rail-row" id="rail-class-row" hidden>
          <div class="rail-label">Membership Class</div>
          <div class="rail-badge-wrap" id="rail-class-badge"></div>
        </div>

        <div class="rail-row" id="rail-primary-genre-row" hidden>
          <div class="rail-label">Primary Genre</div>
          <div class="rail-val" id="rail-primary-genre">—</div>
        </div>

        <div class="rail-row" id="rail-expertise-row" hidden>
          <div class="rail-label">Areas of Expertise</div>
          <div class="rail-genres" id="rail-expertise"></div>
        </div>

        <div class="rail-row" id="rail-favsubjects-row" hidden>
          <div class="rail-label">Favourite Subject</div>
          <div class="rail-val" id="rail-favsubjects">—</div>
        </div>

        <div class="rail-row" id="rail-system-row" hidden>
          <div class="rail-label">Preferred Camera</div>
          <div class="rail-val" id="rail-camera-system">—</div>
          <div class="rail-note">Self-declared · unverified</div>
        </div>

        <div class="rail-row" id="rail-distinctions-row" hidden>
          <div class="rail-label">Distinctions &amp; Awards</div>
          <div class="rail-distinctions" id="rail-distinctions"></div>
        </div>

        <div class="rail-row" id="rail-gear-row" hidden>
          <div class="rail-label">Equipment Bag</div>
          <div class="rail-gear" id="rail-gear"></div>
        </div>
      </aside>

      <!-- Main: stories + bio snippet + photo grid -->
      <main class="portfolio-main">

        <!-- Stories / Collections (item 53) — near the top of the profile -->
        <section class="stories-strip" id="stories-strip" hidden>
          <div class="stories-head">Stories &amp; Collections</div>
          <div class="stories-row" id="stories-row"></div>
        </section>

        <div class="bio-snippet" id="bio-snippet" hidden>
          <p id="bio-text"></p>
          <a class="bio-more-link" data-tab-trigger="about">Full biography →</a>
        </div>

        <div class="photo-grid-header" id="photo-grid-header" hidden>
          <span class="photo-grid-count" id="photo-grid-count"></span>
        </div>

        <!-- Category filter (item 71) — hidden until chips load -->
        <div class="profile-filter" id="profile-filter" role="group" aria-label="Filter by category" hidden>
          <button class="profile-filter-chip is-on" data-tag="" type="button" aria-pressed="true">All</button>
        </div>

        <div id="portfolio-grid" class="profile-justified-grid" data-target-height="240" data-gap="8">
          <div class="grid-empty" id="grid-loading">Loading portfolio…</div>
        </div>

        <!-- Load more — mirrors /showcase pagination (20 initial, +20 per click) -->
        <div class="profile-load-more-wrap" id="profile-load-more-wrap" hidden>
          <button class="profile-load-more-btn" id="profile-load-more-btn" type="button">
            Load More Photographs
          </button>
        </div>

      </main>
    </div>
  </div>

  <!-- § ABOUT TAB -->
  <div id="tab-about" class="tab-panel" hidden role="tabpanel">
    <div class="about-layout">

      <!-- Main left (2/3) -->
      <div class="about-main">

        <!-- Full biography -->
        <div class="about-card">
          <div class="about-card-head">Full Biography</div>
          <div class="about-bio" id="about-bio">
            <p class="about-no-bio">No biography provided yet.</p>
          </div>
          <div class="about-bio-meta" id="about-bio-meta" hidden>
            <span class="about-class-badge" id="about-class-badge"></span>
            <span class="about-since" id="about-since"></span>
          </div>
          <div class="about-social-links" id="about-social-links" hidden></div>
        </div>

        <!-- Journal articles by this photographer (item 53) -->
        <div class="about-card" id="about-journal-card" hidden>
          <div class="about-card-head">From the Journal</div>
          <div class="about-journal" id="about-journal"></div>
        </div>

      </div>

      <!-- Right rail (1/3) -->
      <aside class="about-rail">

        <!-- Awards & Distinctions -->
        <div class="about-card" id="about-awards-card" hidden>
          <div class="about-card-head">Awards &amp; Distinctions</div>
          <div class="about-awards" id="about-awards"></div>
        </div>

        <!-- Photography Society Titles -->
        <div class="about-card" id="about-titles-card" hidden>
          <div class="about-card-head">Photography Society Titles</div>
          <div class="about-titles" id="about-titles"></div>
        </div>

        <!-- Camera Gear -->
        <div class="about-card" id="about-gear-card" hidden>
          <div class="about-card-head">Camera Gear</div>
          <div class="about-gear" id="about-gear"></div>
          <p class="about-gear-note">Self-declared · unverified.</p>
        </div>

        <!-- Photography Genres -->
        <div class="about-card" id="about-genres-card" hidden>
          <div class="about-card-head">Photography Genres</div>
          <div class="about-genres" id="about-genres"></div>
        </div>

        <!-- Areas of expertise -->
        <div class="about-card" id="about-expertise-card" hidden>
          <div class="about-card-head">Areas of Expertise</div>
          <div class="about-genres" id="about-expertise"></div>
        </div>

      </aside>
    </div>
  </div>

  <!-- § CONTESTS TAB -->
  <div id="tab-contests" class="tab-panel" hidden role="tabpanel">
    <div class="placeholder-panel">
      <div class="placeholder-inner">
        <div class="placeholder-icon">🏆</div>
        <div class="placeholder-title">Contest History</div>
        <p class="placeholder-desc">Contest participation and awards for this photographer will be available in a future update.</p>
      </div>
    </div>
  </div>

  <!-- § ACTIVITY TAB -->
  <div id="tab-activity" class="tab-panel" hidden role="tabpanel">
    <div class="placeholder-panel">
      <div class="placeholder-inner">
        <div class="placeholder-icon">📅</div>
        <div class="placeholder-title">Activity Log</div>
        <p class="placeholder-desc">Event attendance and club activity history will be available in a future update.</p>
      </div>
    </div>
  </div>

</div><!-- /.tab-content-area -->

</BaseLayout>

<style>
/* ── Cover Banner ────────────────────────────────────────────────────────── */
/* Standardised 16:5 banner (item 48). Fixed aspect ratio, never cropped
   vertically — the whole cover image stays visible (object-fit:contain),
   letterboxed against the dark surface. Capped to the content container on
   desktop so ultrawide viewports don't produce excessive letterboxing. */
.cover-banner {
  width: 100%;
  max-width: 1140px;
  margin: var(--nav-h, 64px) auto 0;
  aspect-ratio: 16 / 5;
  position: relative;
  overflow: hidden;
  background: #1A1614;
}
.cover-default {
  width: 100%;
  height: 100%;
  background: repeating-linear-gradient(
    135deg, #2A2420 0px, #2A2420 28px, #241E1A 28px, #241E1A 56px
  );
}
.cover-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
}

/* ── Profile Hero ────────────────────────────────────────────────────────── */
.profile-hero {
  background: #FFFFFF;
  border-bottom: 1px solid #E7E1D6;
}
.ph-inner {
  max-width: 1140px;
  margin: 0 auto;
  padding: 0 40px 28px;
  display: flex;
  align-items: flex-end;
  gap: 24px;
  flex-wrap: wrap;
}

/* Avatar */
.ph-avatar-wrap { flex-shrink: 0; margin-top: -60px; }
.ph-avatar {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: linear-gradient(135deg, #3E5A48, #2A3E32);
  border: 4px solid #FFFFFF;
  box-shadow: 0 4px 20px rgba(20,18,16,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.ph-avatar-initials {
  font-family: 'Outfit', sans-serif;
  font-size: 30px;
  font-weight: 700;
  color: rgba(255,255,255,0.9);
}
.ph-avatar-img { width: 100%; height: 100%; object-fit: cover; }

/* Identity */
.ph-identity { flex: 1; padding-bottom: 4px; min-width: 200px; }
.ph-name {
  font-family: 'Outfit', sans-serif;
  font-size: 32px;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: #141210;
  line-height: 1.1;
  margin-bottom: 4px;
}
.ph-username {
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px;
  color: #A8843C;
  margin-bottom: 6px;
}
.ph-tagline {
  font-size: 15px;
  color: #57514B;
  line-height: 1.5;
  margin-bottom: 6px;
}
.ph-location-row {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: #8B8378;
  margin-bottom: 10px;
}
.ph-dot {
  display: block;
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: #D8D2C6;
}
.ph-badges { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.ph-class-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: #3E5A48;
  color: #FFFFFF;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 999px;
}
.ph-class-badge::before {
  content: '';
  display: block;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #C9A961;
}
.ph-class-badge--basic { display: none; }
.ph-founding-badge {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #C9A961;
  background: #141210;
  border: 1px solid #C9A961;
  padding: 4px 12px;
}
.ph-recognition-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #A8843C;
  background: #F4F0E8;
  border: 1px solid #C9A961;
  padding: 4px 10px;
}

/* Stats */
.ph-stats { flex-shrink: 0; padding-bottom: 8px; }
.ph-stat { text-align: center; }
.ph-stat-val {
  font-family: 'Outfit', sans-serif;
  font-size: 32px;
  font-weight: 700;
  color: #141210;
  line-height: 1;
}
.ph-stat-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #8B8378;
  margin-top: 4px;
}

/* Tab Navigation */
.tab-nav {
  border-top: 1px solid #F0EBE0;
  overflow-x: auto;
  scrollbar-width: none;
}
.tab-nav::-webkit-scrollbar { display: none; }
.tab-nav-inner {
  max-width: 1140px;
  margin: 0 auto;
  padding: 0 40px;
  display: flex;
  gap: 0;
}
.tab-btn {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 500;
  color: #8B8378;
  background: none;
  border: none;
  padding: 12px 18px;
  cursor: pointer;
  white-space: nowrap;
  position: relative;
  border-bottom: 2px solid transparent;
  transition: color 0.15s, border-color 0.15s;
}
.tab-btn:hover { color: #141210; }
.tab-btn--active { color: #141210; font-weight: 700; border-bottom-color: #C9A961; }

/* ── Tab Content Area ────────────────────────────────────────────────────── */
.tab-content-area {
  background: #F2EFE9;
  min-height: 60vh;
}
.tab-panel { display: block; }
.tab-panel[hidden] { display: none; }

/* ── PORTFOLIO TAB ───────────────────────────────────────────────────────── */
.portfolio-layout {
  max-width: 1140px;
  margin: 0 auto;
  padding: 32px 40px 80px;
  display: flex;
  gap: 24px;
  align-items: flex-start;
}

/* Left Rail */
.left-rail {
  width: 260px;
  flex-shrink: 0;
  background: #FFFFFF;
  border: 1px solid #E7E1D6;
  position: sticky;
  top: calc(var(--nav-h, 64px) + 16px);
  max-height: calc(100vh - var(--nav-h, 64px) - 48px);
  overflow-y: auto;
  scrollbar-width: thin;
}
.rail-section-head {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #A8843C;
  padding: 14px 18px;
  border-bottom: 1px solid #F0EBE0;
  background: #FAF8F4;
}
.rail-row {
  padding: 12px 18px;
  border-bottom: 1px solid #F0EBE0;
}
.rail-row:last-child { border-bottom: none; }
.rail-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #8B8378;
  margin-bottom: 5px;
}
.rail-val {
  font-size: 14px;
  font-weight: 600;
  color: #141210;
}
.rail-badge-wrap .rail-class-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: #3E5A48;
  color: #FFFFFF;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 999px;
}
.rail-genres { display: flex; flex-wrap: wrap; gap: 5px; }
.rail-genre-tag {
  font-size: 11px;
  color: #57514B;
  background: #F4F0E8;
  border: 1px solid #E7E1D6;
  padding: 3px 8px;
}
.rail-contact-links {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
:global(.rail-contact-website) {
  font-size: 13px;
  font-weight: 600;
  color: var(--gold-600, #A8843C);
  text-decoration: none;
  word-break: break-all;
}
:global(.rail-contact-website:hover) { text-decoration: underline; }
:global(.rail-contact-socials) {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6px;
}
:global(.rail-social-link) {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  background: #F4F0E8;
  border: 1px solid #E7E1D6;
  color: #57514B;
  text-decoration: none;
  transition: border-color 0.15s, color 0.15s;
}
:global(.rail-social-link:hover) { border-color: #C9A961; color: #A8843C; }
:global(.rail-social-link svg) { display: block; }
.rail-note { font-size: 11px; color: #8B8378; margin-top: 2px; }
.rail-distinctions { font-size: 12px; line-height: 1.8; color: #57514B; }
.rail-distinctions :is(ul, ol) { padding-left: 16px; margin: 0; }
.rail-distinctions li { margin-bottom: 2px; }
.rail-distinctions p { margin: 0 0 6px; }
.rail-gear-group { margin-bottom: 10px; }
.rail-gear-group:last-child { margin-bottom: 0; }
.rail-gear-label { font-size: 11px; font-weight: 600; color: #57514B; margin-bottom: 3px; }
.rail-gear-items { font-size: 12px; line-height: 1.8; color: #57514B; }

/* Portfolio Main */
.portfolio-main { flex: 1; min-width: 0; }
.bio-snippet {
  background: #FFFFFF;
  border: 1px solid #E7E1D6;
  padding: 20px 24px;
  margin-bottom: 20px;
}
.bio-snippet p {
  font-size: 14px;
  line-height: 1.8;
  color: #37322C;
  margin-bottom: 10px;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}
.bio-more-link {
  font-size: 12px;
  color: #A8843C;
  cursor: pointer;
  text-decoration: none;
  font-family: 'Inter', sans-serif;
}
.bio-more-link:hover { text-decoration: underline; }

/* ── Stories / Collections strip (item 53) ───────────────────────────────── */
.stories-strip { margin-bottom: 20px; }
.stories-head {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #A8843C;
  margin-bottom: 12px;
}
.stories-row {
  display: flex;
  gap: 14px;
  overflow-x: auto;
  scrollbar-width: thin;
  padding-bottom: 4px;
}
.story-card {
  flex: 0 0 auto;
  width: 200px;
  background: #FFFFFF;
  border: 1px solid #E7E1D6;
  text-decoration: none;
  cursor: pointer;
  padding: 0;
  text-align: left;
  transition: border-color 0.15s, transform 0.15s;
}
.story-card:hover { border-color: #C9A961; transform: translateY(-2px); }
.story-cover {
  width: 100%;
  aspect-ratio: 16 / 10;
  background: #241E1A repeating-linear-gradient(135deg, #2A2420 0, #2A2420 20px, #241E1A 20px, #241E1A 40px);
  overflow: hidden;
}
.story-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
.story-body { padding: 10px 12px 12px; }
.story-kind {
  display: inline-block;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #A8843C;
  background: #F4F0E8;
  border: 1px solid #E7E1D6;
  padding: 2px 7px;
  margin-bottom: 6px;
}
.story-title {
  font-family: 'Outfit', sans-serif;
  font-size: 14px;
  font-weight: 600;
  color: #141210;
  line-height: 1.3;
  margin-bottom: 4px;
}
.story-count {
  font-size: 11px;
  color: #8B8378;
  font-family: 'JetBrains Mono', monospace;
}

/* ── Journal articles on profile (item 53) ───────────────────────────────── */
.about-journal { display: flex; flex-direction: column; gap: 12px; }
.about-journal-item {
  display: flex;
