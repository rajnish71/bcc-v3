function socialUrl(platform: string, handle: string): string {
  if (platform === 'website') return handle.startsWith('http') ? handle : `https://${handle}`;
  const base = SOCIAL_BASE[platform];
  return base ? `${base}${handle}` : '#';
}

function socialIcon(platform: string): string {
  return SOCIAL_SVG[platform] ?? `<span style="font-size:9px;font-family:monospace;">${platform.slice(0,2).toUpperCase()}</span>`;
}

// ── Badge helpers ─────────────────────────────────────────────────────────
function classBadgeHtml(memberClass: string): string {
  if (!memberClass || memberClass === 'basic') return '';
  const label = memberClass.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  return `<span class="about-class-badge">${label}</span>`;
}

function railBadgeHtml(memberClass: string): string {
  if (!memberClass || memberClass === 'basic') return '';
  const label = memberClass.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  return `<span class="rail-class-badge">${label}</span>`;
}

// ── Load photographer profile ─────────────────────────────────────────────
async function loadProfile() {
  if (!username) return;

  let profile: Record<string, any>;
  try {
    const res = await fetch(`/api/v1/photographers/${username}`);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const json = await res.json();
    profile = json.data;
    if (!profile) throw new Error('Empty profile');
  } catch {
    setTxt('ph-name', 'Photographer');
    setTxt('grid-loading', 'Unable to load profile. Please try again later.');
    return;
  }

  // Page title
  document.title = `${profile.displayName} · Photographer · Bhopal Camera Club`;

  // Cover
  if (profile.coverUrl) {
    const coverImg = document.getElementById('cover-img') as HTMLImageElement | null;
    const coverDefault = document.getElementById('cover-default');
    if (coverImg) { coverImg.src = profile.coverUrl; coverImg.hidden = false; }
    if (coverDefault) coverDefault.style.display = 'none';
  }

  // Avatar
  const initials = (profile.displayName ?? '?').trim().split(/\s+/).map((w: string) => w[0] ?? '').join('').slice(0, 2).toUpperCase();
  setTxt('ph-initials', initials);
  if (profile.avatarUrl) {
    const img = document.getElementById('ph-avatar-img') as HTMLImageElement | null;
    const fallback = document.getElementById('ph-initials');
    if (img) { img.src = profile.avatarUrl; img.hidden = false; }
    if (fallback) (fallback as HTMLElement).style.display = 'none';
  }

  // Capture display name for alt-text
  profileDisplayName = profile.displayName ?? '';

  // Name + username
  setTxt('ph-name', profile.displayName ?? '—');
  setTxt('ph-username', `@${profile.username ?? ''}`);

  // Tagline
  if (profile.tagline) {
    const tagEl = document.getElementById('ph-tagline');
    if (tagEl) { tagEl.textContent = profile.tagline; tagEl.hidden = false; }
  }

  // Location + Since
  const locationParts: string[] = [];
  if (profile.city) locationParts.push(profile.city);
  if (profile.state) locationParts.push(profile.state);
  const since = profile.memberSince ? `Since ${profile.memberSince}` : null;

  if (locationParts.length || since) {
    const locRow = document.getElementById('ph-location-row');
    if (locRow) locRow.hidden = false;
    if (locationParts.length) setTxt('ph-location', locationParts.join(', '));
    if (since) setTxt('ph-since', since);
    // If no location but since, hide the dot
    if (!locationParts.length) {
      const dot = document.querySelector('.ph-dot') as HTMLElement | null;
      if (dot) dot.style.display = 'none';
    }
  }

  // Class badge
  if (profile.memberClass && profile.memberClass !== 'basic') {
    const badge = document.getElementById('ph-class-badge');
    if (badge) {
      const label = profile.memberClass.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
      badge.textContent = label;
      badge.hidden = false;
    }
  }

  // Founding member badge (MEM-006 constraint 4)
  if (profile.isFoundingMember) {
    const fb = document.getElementById('ph-founding-badge');
    if (fb) fb.hidden = false;
  }

  // Recognition badge (Senior / Honorary member) — migrated field, previously a UI gap
  if (profile.recognition && profile.recognition.label) {
    const rb = document.getElementById('ph-recognition-badge');
    if (rb) { rb.textContent = `★ ${profile.recognition.label}`; rb.hidden = false; }
  }

  // Photo count
  setTxt('ph-photo-count', String(profile.photoCount ?? 0));

  // ── Left Rail ──────────────────────────────────────────────────────────
  // Member Since
  if (profile.memberSince) {
    const row = document.getElementById('rail-since-row');
    if (row) row.hidden = false;
    setTxt('rail-since', String(profile.memberSince));
  }

  // Membership class
  if (profile.memberClass && profile.memberClass !== 'basic') {
    const row = document.getElementById('rail-class-row');
    const wrap = document.getElementById('rail-class-badge');
    if (row) row.hidden = false;
    if (wrap) wrap.innerHTML = railBadgeHtml(profile.memberClass);
  }

  // Preferred camera system
  if (profile.preferredCameraSystem) {
    const row = document.getElementById('rail-system-row');
    if (row) row.hidden = false;
    setTxt('rail-camera-system', profile.preferredCameraSystem);
  }

  // Genres — rail shows Primary Genre (first); full list remains in About tab
  const genres: string[] = Array.isArray(profile.photographyGenres) ? profile.photographyGenres : [];
  if (genres.length) {
    const row = document.getElementById('rail-primary-genre-row');
    if (row) row.hidden = false;
    setTxt('rail-primary-genre', genres[0]);
  }

  // Areas of Expertise (rail)
  const railExpertise: string[] = Array.isArray(profile.areasOfExpertise) ? profile.areasOfExpertise : [];
  if (railExpertise.length) {
    const row = document.getElementById('rail-expertise-row');
    const container = document.getElementById('rail-expertise');
    if (row) row.hidden = false;
    if (container) container.innerHTML = railExpertise.map(g => `<span class="rail-genre-tag">${esc(g)}</span>`).join('');
  }

  // Favourite Subject(s) (rail)
  const favSubjects: string[] = Array.isArray(profile.favouriteSubjects) ? profile.favouriteSubjects : [];
  if (favSubjects.length) {
    const row = document.getElementById('rail-favsubjects-row');
    if (row) row.hidden = false;
    setTxt('rail-favsubjects', favSubjects.join(', '));
  }

  // Distinctions & Awards (rail) — society titles + awards HTML
  const railTitles: Array<{ bodyName: string; titleCode: string }> = Array.isArray(profile.photoTitles) ? profile.photoTitles : [];
  const railAwardsHtml = (profile.awardsHtml && String(profile.awardsHtml).trim()) ? String(profile.awardsHtml) : '';
  if (railTitles.length || railAwardsHtml) {
    const row = document.getElementById('rail-distinctions-row');
    const el = document.getElementById('rail-distinctions');
    if (row) row.hidden = false;
    if (el) {
      const titleLines = railTitles
        .map(t => `${esc(t.titleCode)}${t.bodyName ? ` <span style="color:#8B8378">${esc(t.bodyName)}</span>` : ''}`)
        .join('<br/>');
      el.innerHTML = (titleLines ? `<div>${titleLines}</div>` : '') + railAwardsHtml;
    }
  }

  // Equipment Bag (rail) — cameras / lenses / other
  const railGear = profile.gear ?? {};
  const gearGroups: string[] = [];
  if (railGear.bodies?.length)      gearGroups.push(`<div class="rail-gear-group"><div class="rail-gear-label">Cameras</div><div class="rail-gear-items">${railGear.bodies.map(esc).join('<br/>')}</div></div>`);
  if (railGear.lenses?.length)      gearGroups.push(`<div class="rail-gear-group"><div class="rail-gear-label">Lenses</div><div class="rail-gear-items">${railGear.lenses.map(esc).join('<br/>')}</div></div>`);
  if (railGear.accessories?.length) gearGroups.push(`<div class="rail-gear-group"><div class="rail-gear-label">Other</div><div class="rail-gear-items">${railGear.accessories.map(esc).join('<br/>')}</div></div>`);
  if (gearGroups.length) {
    const row = document.getElementById('rail-gear-row');
    const el = document.getElementById('rail-gear');
    if (row) row.hidden = false;
    if (el) el.innerHTML = gearGroups.join('');
  }

  // Contact block — website + social icons in Portfolio sidebar (item 82)
  const handles = profile.socialHandles ?? {};
  {
    const contactRow = document.getElementById('rail-contact-row');
    const contactLinks = document.getElementById('rail-contact-links');
    const website = profile.websiteUrl ?? handles['website'] ?? null;
    const socialPlatforms = Object.keys(handles).filter(p => p !== 'website');
    if (contactLinks && (website || socialPlatforms.length)) {
      const parts: string[] = [];
      if (website) {
        const display = website.replace(/^https?:\/\//, '').replace(/\/$/, '');
        parts.push(`<a class="rail-contact-website" href="${website.startsWith('http') ? website : 'https://' + website}" target="_blank" rel="noopener noreferrer">${esc(display)}</a>`);
      }
      if (socialPlatforms.length) {
        const icons = socialPlatforms
          .map(p => `<a class="rail-social-link" href="${socialUrl(p, handles[p])}" target="_blank" rel="noopener noreferrer" title="${p}">${socialIcon(p)}</a>`)
          .join('');
        parts.push(`<div class="rail-contact-socials">${icons}</div>`);
      }
      contactLinks.innerHTML = parts.join('');
      if (contactRow) contactRow.hidden = false;
    }
  }

  // ── Bio Snippet (portfolio tab) ────────────────────────────────────────
  if (profile.bio) {
    const snippetEl = document.getElementById('bio-snippet');
    const bioTextEl = document.getElementById('bio-text');
    const stripTags = (html: string) => html.replace(/<[^>]*>/g, '');
    if (snippetEl) snippetEl.hidden = false;
    if (bioTextEl) bioTextEl.textContent = stripTags(profile.bio).trim();
  }

  // ── About tab ─────────────────────────────────────────────────────────
  // Bio
  const aboutBioEl = document.getElementById('about-bio');
  if (aboutBioEl) {
    if (profile.bio) {
      aboutBioEl.innerHTML = profile.bio;
    } else {
      aboutBioEl.innerHTML = '<p class="about-no-bio">No biography provided yet.</p>';
    }
  }

  // Bio meta (class badge + since)
  if (profile.memberClass && profile.memberClass !== 'basic' && profile.memberSince) {
    const metaEl = document.getElementById('about-bio-meta');
    const cbEl = document.getElementById('about-class-badge');
    const sinceEl = document.getElementById('about-since');
    if (metaEl) metaEl.hidden = false;
    if (cbEl) {
      const label = profile.memberClass.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
      cbEl.textContent = label;
    }
    if (sinceEl) sinceEl.textContent = `Member Since ${profile.memberSince}`;
  }

  // Social links in About tab
  const allPlatforms = Object.keys(handles);
  if (allPlatforms.length) {
    const socialEl = document.getElementById('about-social-links');
    if (socialEl) {
      socialEl.hidden = false;
      const parts: string[] = [];
      allPlatforms.forEach(p => {
        const url = socialUrl(p, handles[p]);
        if (p === 'website') {
          const display = handles[p].replace(/^https?:\/\//, '').replace(/\/$/, '');
          parts.push(`<a class="about-website-link" href="${url}" target="_blank" rel="noopener noreferrer">${esc(display)}</a>`);
        } else {
          parts.push(`<a class="about-social-icon" href="${url}" target="_blank" rel="noopener noreferrer" title="${p}">${socialIcon(p)}</a>`);
        }
      });
      socialEl.innerHTML = parts.join('');
    }
  }

  // Awards in About rail
  const awards: Array<{ name: string; awardingBody?: string | null; year?: number | null; description?: string | null }> =
    Array.isArray(profile.awards) ? profile.awards : [];
  if (awards.length) {
    const card = document.getElementById('about-awards-card');
    const el = document.getElementById('about-awards');
    if (card) card.hidden = false;
    if (el) {
      el.innerHTML = awards.map(a => `
        <div class="about-award-item">
          <div class="about-award-name">${esc(a.name)}</div>
          ${a.awardingBody ? `<div class="about-award-body">${esc(a.awardingBody)}</div>` : ''}
          ${a.year ? `<div class="about-award-year">${a.year}</div>` : ''}
          ${a.description ? `<div class="about-award-desc">${esc(a.description)}</div>` : ''}
        </div>
      `).join('');
    }
  } else if (profile.awardsHtml && String(profile.awardsHtml).trim()) {
    // Fallback: legacy members whose awards were migrated only as rich-text
    // (users.awards_html) with no structured user_awards rows.
    const card = document.getElementById('about-awards-card');
    const el = document.getElementById('about-awards');
    if (card) card.hidden = false;
    if (el) el.innerHTML = `<div class="about-awards-html">${profile.awardsHtml}</div>`;
  }

  // Photography society titles in About rail
  const photoTitles: Array<{ bodyCode: string; bodyName: string; titleCode: string }> =
    Array.isArray(profile.photoTitles) ? profile.photoTitles : [];
  if (photoTitles.length) {
    const card = document.getElementById('about-titles-card');
    const el = document.getElementById('about-titles');
    if (card) card.hidden = false;
    if (el) {
      el.innerHTML = photoTitles.map(t => `
        <div class="about-title-row">
          <span class="about-title-code">${esc(t.titleCode)}</span>
          <span class="about-title-body">${esc(t.bodyName)}</span>
        </div>
      `).join('');
    }
  }

  // Gear in About rail
  const gear = profile.gear ?? {};
  const gearItems: string[] = [];
  if (gear.bodies?.length) {
    gearItems.push(`<div class="gear-group-label">Camera Bodies</div><div class="gear-items">${gear.bodies.map(esc).join('<br/>')}</div>`);
  }
  if (gear.lenses?.length) {
    gearItems.push(`<div class="gear-group-label">Lenses</div><div class="gear-items">${gear.lenses.map(esc).join('<br/>')}</div>`);
  }
  if (gear.accessories?.length) {
    gearItems.push(`<div class="gear-group-label">Other Equipment</div><div class="gear-items">${gear.accessories.map(esc).join('<br/>')}</div>`);
  }
  if (gearItems.length) {
    const gearCard = document.getElementById('about-gear-card');
    const gearEl = document.getElementById('about-gear');
    if (gearCard) gearCard.hidden = false;
    if (gearEl) gearEl.innerHTML = gearItems.join('');
  }

  // Genres in About rail
  if (genres.length) {
    const card = document.getElementById('about-genres-card');
    const el = document.getElementById('about-genres');
    if (card) card.hidden = false;
    if (el) el.innerHTML = genres.map(g => `<span class="about-genre-tag">${esc(g)}</span>`).join('');
  }

  // Areas of expertise in About rail
  const expertise: string[] = Array.isArray(profile.areasOfExpertise) ? profile.areasOfExpertise : [];
  if (expertise.length) {
    const card = document.getElementById('about-expertise-card');
    const el = document.getElementById('about-expertise');
    if (card) card.hidden = false;
    if (el) el.innerHTML = expertise.map(g => `<span class="about-genre-tag">${esc(g)}</span>`).join('');
  }

  // Gallery layout — apply before photos load so the grid is ready
  currentGalleryLayout = profile.galleryLayout ?? 'justified';
  const portfolioGrid = document.getElementById('portfolio-grid');
  if (portfolioGrid && currentGalleryLayout !== 'justified') {
    portfolioGrid.classList.remove('profile-justified-grid');
    portfolioGrid.classList.add(`profile-${currentGalleryLayout}-grid`);
    portfolioGrid.setAttribute('data-layout', currentGalleryLayout);
  }

  // Stories / Collections + Journal articles (item 53) — non-blocking
  loadStories(profile.id).catch(() => {});
  loadJournal(profile.id).catch(() => {});
  loadProfileFilterChips(profile.id).catch(() => {});

  // Now load photos
  await loadPhotos(profile.id);
}

// ── Stories / Collections (item 53) ────────────────────────────────────────
async function loadStories(userId: number) {
  const res = await fetch(`/api/v1/gallery/albums/user/${userId}`);
  if (!res.ok) return;
  const albums = await res.json();
  const list: any[] = Array.isArray(albums) ? albums.filter((a: any) => (a.photo_count ?? 0) > 0) : [];
  if (!list.length) return;

  const strip = document.getElementById('stories-strip');
  const row = document.getElementById('stories-row');
  if (!strip || !row) return;
  strip.hidden = false;
  row.innerHTML = '';

  list.forEach((a: any) => {
    const card = document.createElement('button');
    card.type = 'button';
    card.className = 'story-card';

    const cover = document.createElement('div');
    cover.className = 'story-cover';
    if (a.cover_image_url) {
      const img = document.createElement('img');
      img.src = a.cover_image_url;
      img.alt = a.title ?? 'Collection';
      img.loading = 'lazy';
      cover.appendChild(img);
    }

    const body = document.createElement('div');
    body.className = 'story-body';
    if (a.kind === 'STORY') {
      const kindBadge = document.createElement('span');
      kindBadge.className = 'story-kind';
      kindBadge.textContent = 'Story';
      body.appendChild(kindBadge);
    }
    const t = document.createElement('div');
    t.className = 'story-title';
    t.textContent = a.title ?? 'Untitled';
    const c = document.createElement('div');
    c.className = 'story-count';
    c.textContent = `${a.photo_count} ${a.photo_count === 1 ? 'photo' : 'photos'}`;
    body.appendChild(t);
    body.appendChild(c);

    card.appendChild(cover);
    card.appendChild(body);
    card.addEventListener('click', () => openStory(a.uuid, a.title));
    row.appendChild(card);
  });
}

async function openStory(uuid: string, label: string) {
  try {
    const res = await fetch(`/api/v1/gallery/albums/${uuid}`);
    if (!res.ok) return;
    const data = await res.json();
    const photos: any[] = data.photos ?? [];
    if (!photos.length) return;
    const ids = photos.map((p: any) => p.id);
    sessionStorage.setItem('bcc_photo_ctx', JSON.stringify({
      type: 'collection', ctxId: uuid, ctxLabel: label || 'Collection', ids,
    }));
    window.location.href = `/showcase/${ids[0]}/`;
  } catch { /* ignore */ }
}

// ── Journal articles by this photographer (item 53) ────────────────────────
async function loadJournal(userId: number) {
  const res = await fetch(`/api/v1/journal/author/${userId}?limit=8`);
  if (!res.ok) return;
  const json = await res.json();
  const posts: any[] = Array.isArray(json.data) ? json.data : [];
  if (!posts.length) return;

  const card = document.getElementById('about-journal-card');
  const el = document.getElementById('about-journal');
  if (!card || !el) return;
  card.hidden = false;
  el.innerHTML = posts.map((p: any) => {
    const date = p.pubDate ? new Date(p.pubDate).toLocaleDateString('en-IN', { month: 'short', year: 'numeric' }) : '';
    const thumb = p.heroImage ? `<img class="about-journal-thumb" src="${esc(p.heroImage)}" alt="" loading="lazy" />` : '';
    return `<a class="about-journal-item" href="/journal/${esc(p.slug ?? '')}/">
        ${thumb}
        <div class="about-journal-meta">
          <div class="about-journal-title">${esc(p.title ?? 'Untitled')}</div>
          <div class="about-journal-date">${esc(date)}</div>
        </div>
      </a>`;
  }).join('');
}

// ── Render one card (identical hover treatment to /showcase) ───────────────
function renderProfilePhotoCard(p: any): HTMLElement {
  const btn = document.createElement('button');
  btn.className = 'photo-card vf-card';
  btn.type = 'button';
  btn.style.cssText = `width:${p.width}px;height:${p.height}px;flex-shrink:0;`;
  btn.setAttribute('data-aspect', String(p.aspect));

  const altTitle = p.title ? esc(p.title) : 'Untitled';
  const altCredit = profileDisplayName ? ` by ${esc(profileDisplayName)}` : '';
  btn.setAttribute('aria-label', `${altTitle}${altCredit} · Bhopal Camera Club`);

  const img = document.createElement('img');
  img.src = p.imageUrl ?? '';
  img.alt = `${altTitle}${altCredit} · Bhopal Camera Club`;
  img.loading = 'lazy';
  img.decoding = 'async';
  img.className = 'photo-card__img';

  const overlay = document.createElement('div');
  overlay.className = 'photo-overlay';
  overlay.setAttribute('aria-hidden', 'true');

  const br = document.createElement('span');
  br.className = 'vf-br'; br.setAttribute('aria-hidden', 'true');
  const bl = document.createElement('span');
  bl.className = 'vf-bl'; bl.setAttribute('aria-hidden', 'true');

  // Caption block — Showcase treatment; title + caption sub-line (photographer
  // is implicit on their own profile, so the sub-line carries the caption).
  const titleText = (p.title ?? '').trim();
  const capText = (p.caption ?? '').trim();
  if (titleText || capText) {
    const info = document.createElement('div');
    info.className = 'photo-card__info';
    info.setAttribute('aria-hidden', 'true');
    const t = document.createElement('div');
    t.className = 'photo-card__title';
    t.textContent = titleText || 'Untitled';
    info.appendChild(t);
    if (capText && capText !== titleText) {
      const c = document.createElement('div');
      c.className = 'photo-card__photographer';
      c.textContent = capText;
      info.appendChild(c);
    }
    btn.appendChild(info);
  }

  btn.appendChild(img);
  btn.appendChild(overlay);
  btn.appendChild(br);
  btn.appendChild(bl);

  // Click → canonical photo page; store full portfolio context in sessionStorage
  // so prev/next navigation works without polluting the URL.
  btn.addEventListener('click', () => {
    sessionStorage.setItem('bcc_photo_ctx', JSON.stringify({
      type: 'portfolio', ctxId: username,
      ctxLabel: profileDisplayName || username,
      ids: allPhotos.map(ph => ph.id),
    }));
    window.location.href = `/showcase/${p.id}/`;
  });

  return btn;
}

// ── Alt-layout photo card (no explicit width/height — CSS grid/columns size it) ──
function renderAltPhotoCard(p: any, isMasonry: boolean): HTMLElement {
  const btn = document.createElement('button');
  btn.className = 'photo-card vf-card profile-alt-card' + (isMasonry ? ' profile-masonry-card' : '');
  btn.type = 'button';

  const altTitle = p.title ? esc(p.title) : 'Untitled';
  const altCredit = profileDisplayName ? ` by ${esc(profileDisplayName)}` : '';
  btn.setAttribute('aria-label', `${altTitle}${altCredit} · Bhopal Camera Club`);

  const img = document.createElement('img');
  img.src = p.imageUrl ?? '';
  img.alt = `${altTitle}${altCredit} · Bhopal Camera Club`;
  img.loading = 'lazy';
  img.decoding = 'async';
  img.className = 'photo-card__img';
  // Masonry: natural height so columns balance correctly.
  // Grid layouts: fill the cell produced by the grid CSS.
  img.style.cssText = isMasonry
    ? 'width:100%;height:auto;object-fit:cover;'
    : 'width:100%;height:100%;object-fit:cover;';

  const overlay = document.createElement('div');
  overlay.className = 'photo-overlay';
  overlay.setAttribute('aria-hidden', 'true');

  const br = document.createElement('span');
  br.className = 'vf-br'; br.setAttribute('aria-hidden', 'true');
  const bl = document.createElement('span');
  bl.className = 'vf-bl'; bl.setAttribute('aria-hidden', 'true');

  const titleText = (p.title ?? '').trim();
  const capText = (p.caption ?? '').trim();
  if (titleText || capText) {
    const info = document.createElement('div');
    info.className = 'photo-card__info';
    info.setAttribute('aria-hidden', 'true');
    const t = document.createElement('div');
    t.className = 'photo-card__title';
    t.textContent = titleText || 'Untitled';
    info.appendChild(t);
    if (capText && capText !== titleText) {
      const c = document.createElement('div');
      c.className = 'photo-card__photographer';
      c.textContent = capText;
      info.appendChild(c);
    }
    btn.appendChild(info);
  }

  btn.appendChild(img);
  btn.appendChild(overlay);
  btn.appendChild(br);
  btn.appendChild(bl);

  btn.addEventListener('click', () => {
    sessionStorage.setItem('bcc_photo_ctx', JSON.stringify({
      type: 'portfolio', ctxId: username,
      ctxLabel: profileDisplayName || username,
      ids: allPhotos.map(ph => ph.id),
    }));
    window.location.href = `/showcase/${p.id}/`;
  });

  return btn;
}

// ── Render alt-layout photos (masonry / grid variants) ────────────────────
function renderProfileAltGrid(newPhotos: any[]) {
  const grid = document.getElementById('portfolio-grid') as HTMLElement | null;
  if (!grid) return;
  const isMasonry = currentGalleryLayout === 'masonry';
  const fragment = document.createDocumentFragment();
  for (const p of newPhotos) {
    allPhotos.push(p);
    fragment.appendChild(renderAltPhotoCard({ ...p, imageUrl: p.imageUrl ?? '' }, isMasonry));
  }
  grid.appendChild(fragment);
}

// ── Render a page of photos into justified rows (mirrors /showcase) ────────
function renderProfileGrid(newPhotos: any[], flushRemainder: boolean) {
  if (currentGalleryLayout !== 'justified') {
    renderProfileAltGrid(newPhotos);
    return;
  }

  const grid = document.getElementById('portfolio-grid') as HTMLElement | null;
  if (!grid) return;

  const candidates = [...profileBuffer, ...newPhotos];
  const containerWidth = grid.clientWidth || 700;
  const { rows, leftovers } = buildJustifiedLayout(candidates, containerWidth, 240, 8);
  profileBuffer = leftovers;

  const fragment = document.createDocumentFragment();
  rows.forEach(row => {
    const rowEl = document.createElement('div');
    rowEl.className = 'profile-jrow';
    row.photos.forEach((p: any) => {
      rowEl.appendChild(renderProfilePhotoCard({ ...p, height: row.height }));
      allPhotos.push(p);          // only *rendered* photos accumulate (offset math)
    });
    fragment.appendChild(rowEl);
  });

  // On the final page, render any trailing partial row at natural height so
  // every photo is shown (Showcase leaves leftovers buffered indefinitely).
  if (flushRemainder && profileBuffer.length) {
    const gap = 8;
    const totalGap = gap * (profileBuffer.length - 1);
    const rowWidth = profileBuffer.reduce((s, p) => s + p.aspect * 240, 0);
    const scale = Math.min(1, (containerWidth - totalGap) / rowWidth);
    const height = 240 * scale;
    const rowEl = document.createElement('div');
    rowEl.className = 'profile-jrow';
    profileBuffer.forEach((p: any) => {
      rowEl.appendChild(renderProfilePhotoCard({ ...p, width: p.aspect * height, height }));
      allPhotos.push(p);
    });
    fragment.appendChild(rowEl);
    profileBuffer = [];
  }

  grid.appendChild(fragment);
}

// ── Load a page of photos — justified gallery scoped to this photographer ──
async function loadPhotos(userId: number, append = false) {
  const grid = document.getElementById('portfolio-grid') as HTMLElement | null;
  if (!grid || profileLoading) return;
  profileLoading = true;
  profileUserId = userId;

  const loadMoreWrap = document.getElementById('profile-load-more-wrap');
  const loadMoreBtn  = document.getElementById('profile-load-more-btn') as HTMLButtonElement | null;
  if (loadMoreBtn) loadMoreBtn.disabled = true;

  try {
    const token = localStorage.getItem('bcc_token') ?? '';
    const headers: Record<string, string> = token ? { Authorization: `Bearer ${token}` } : {};
    // Fresh loads (filter change / first load) always start at offset 0.
    const offset = append ? (allPhotos.length + profileBuffer.length) : 0;
    const tagParam = currentProfileTag ? `&tag=${encodeURIComponent(currentProfileTag)}` : '';
    const res = await fetch(
      `/api/v1/gallery/photographer/${userId}?limit=${PROFILE_PAGE_SIZE}&offset=${offset}${tagParam}`,
      { headers },
    );
    if (!res.ok) throw new Error('Photos fetch failed');
    const payload = await res.json();
    const photos: PhotoEntry[] = Array.isArray(payload.photos) ? payload.photos : [];
    profileTotal = payload.total ?? photos.length;

    // On a fresh load, reset the accumulators only after the response arrives
    // (so a failed fetch doesn't wipe the grid).
    if (!append) { allPhotos = []; profileBuffer = []; grid.innerHTML = ''; }

    if (photos.length === 0 && allPhotos.length === 0) {
      grid.innerHTML = currentProfileTag
        ? `<div class="grid-empty">No photographs in this category.</div>`
        : `<div class="grid-empty">No photographs uploaded to the showcase yet.</div>`;
      loadMoreWrap?.setAttribute('hidden', '');
      return;
    }

    const mapped = photos.map((p: PhotoEntry) => ({
      ...p,
      aspect: (p.width_px && p.height_px) ? p.width_px / p.height_px : 1.5,
      imageUrl: p.urls?.medium ?? p.urls?.original ?? '',
    }));

    // hasMore is computed from what has been *fetched* (rendered + buffered),
    // independent of how many end up in the trailing buffer this page.
    const fetchedSoFar = offset + mapped.length;
    const hasMore = fetchedSoFar < profileTotal;
    renderProfileGrid(mapped, !hasMore);

    // Photo count header + stat
    setTxt('ph-photo-count', String(profileTotal));
    const header = document.getElementById('photo-grid-header');
    const countEl = document.getElementById('photo-grid-count');
    if (header) header.hidden = false;
    if (countEl) countEl.textContent = `${profileTotal} ${profileTotal === 1 ? 'photograph' : 'photographs'}`;

    if (hasMore) loadMoreWrap?.removeAttribute('hidden');
    else loadMoreWrap?.setAttribute('hidden', '');

  } catch {
    if (!append && allPhotos.length === 0) {
      grid.innerHTML = `<div class="grid-empty">Unable to load portfolio. Please try again later.</div>`;
    }
  } finally {
    profileLoading = false;
    if (loadMoreBtn) loadMoreBtn.disabled = false;
  }
}

// Load-more click → next page
document.getElementById('profile-load-more-btn')?.addEventListener('click', () => {
  if (profileUserId) loadPhotos(profileUserId, true);
});

// ── Category filter chips (item 71) ────────────────────────────────────────
async function loadProfileFilterChips(userId: number) {
  try {
    // Only genres present in this photographer's visible photos (item 76).
    const res = await fetch(`/api/v1/gallery/photographer/${userId}/genres`);
    if (!res.ok) return;
    const tags = await res.json() as Array<{ tag_key: string; display_name: string }>;
    const strip = document.getElementById('profile-filter');
    if (!strip || !tags.length) return;   // no categories → keep strip hidden
    tags
      .sort((a, b) => a.display_name.localeCompare(b.display_name))
      .forEach(t => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'profile-filter-chip';
        btn.dataset.tag = t.tag_key;
        btn.setAttribute('aria-pressed', 'false');
        btn.textContent = t.display_name;
        strip.appendChild(btn);
      });
    strip.hidden = false;

    // If a genre was pre-set from the URL, activate the matching chip now
    if (currentProfileTag) {
      strip.querySelectorAll<HTMLButtonElement>('.profile-filter-chip').forEach(b => {
        const on = b.dataset.tag === currentProfileTag;
        b.classList.toggle('is-on', on);
        b.setAttribute('aria-pressed', String(on));
      });
    }
  } catch { /* non-critical */ }
}

document.getElementById('profile-filter')?.addEventListener('click', e => {
  const btn = (e.target as Element).closest<HTMLButtonElement>('.profile-filter-chip');
  if (!btn) return;
  const tag = btn.dataset.tag ?? '';
  if (tag === currentProfileTag) return;
  currentProfileTag = tag;
  document.querySelectorAll('.profile-filter-chip').forEach(b => {
    const on = b === btn;
    b.classList.toggle('is-on', on);
    b.setAttribute('aria-pressed', String(on));
  });
  if (profileUserId) loadPhotos(profileUserId, false);
});

// Re-justify on resize (rebuild from the full loaded set — mirrors /showcase)
// Alt layouts (masonry/grid) are pure CSS — no JS rebuild needed.
let profileResizeTimer: ReturnType<typeof setTimeout>;
window.addEventListener('resize', () => {
  clearTimeout(profileResizeTimer);
  profileResizeTimer = setTimeout(() => {
    const grid = document.getElementById('portfolio-grid');
    if (!grid || allPhotos.length === 0 || currentGalleryLayout !== 'justified') return;
    // Rebuild justified rows from the full loaded set. Snapshot first, then
    // reset the accumulators so renderProfileGrid re-populates them cleanly.
    const full = [...allPhotos, ...profileBuffer];
    allPhotos = [];
    profileBuffer = [];
    grid.querySelectorAll('.profile-jrow').forEach(r => r.remove());
    const hasMore = full.length < profileTotal;
    renderProfileGrid(full, !hasMore);
  }, 200);
});

// ── Tab navigation ────────────────────────────────────────────────────────
function activateTab(tabKey: string) {
  document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(btn => {
    const active = btn.dataset.tab === tabKey;
    btn.classList.toggle('tab-btn--active', active);
    btn.setAttribute('aria-selected', String(active));
  });
  document.querySelectorAll<HTMLElement>('.tab-panel').forEach(panel => {
    panel.hidden = panel.id !== `tab-${tabKey}`;
  });
}

document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => activateTab(btn.dataset.tab ?? 'portfolio'));
});

// "Full biography →" link in bio snippet triggers About tab
document.querySelector<HTMLElement>('.bio-more-link')?.addEventListener('click', () => {
  activateTab('about');
  window.scrollTo({ top: 0, behavior: 'smooth' });
});

// ── Helpers ───────────────────────────────────────────────────────────────
function setTxt(id: string, val: string) {
  const el = document.getElementById(id);
  if (el) el.textContent = val;
}
function esc(str: string): string {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

// ── Boot ──────────────────────────────────────────────────────────────────
loadProfile().catch(() => {
  setTxt('ph-name', 'Photographer');
  const grid = document.getElementById('portfolio-grid');
  if (grid) grid.innerHTML = `<div class="grid-empty">Unable to load profile. Please try again later.</div>`;
});
</script>
