}
.placeholder-icon { font-size: 32px; margin-bottom: 16px; }
.placeholder-title {
  font-family: 'Outfit', sans-serif;
  font-size: 20px;
  font-weight: 700;
  color: #141210;
  margin-bottom: 12px;
}
.placeholder-desc {
  font-size: 14px;
  line-height: 1.7;
  color: #8B8378;
}

/* ── LIGHTBOX ────────────────────────────────────────────────────────────── */
.lightbox {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.lightbox[hidden] { display: none; }
.lightbox-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(20,18,16,0.92);
  cursor: pointer;
}
.lightbox-panel {
  position: relative;
  z-index: 1;
  max-width: 90vw;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}
.lightbox-close {
  position: absolute;
  top: -48px;
  right: -8px;
  width: 36px;
  height: 36px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  color: #FFFFFF;
  font-size: 16px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s;
}
.lightbox-close:hover { background: rgba(255,255,255,0.2); }
.lightbox-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 44px;
  height: 44px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  color: #FFFFFF;
  font-size: 28px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s;
  z-index: 2;
}
.lightbox-arrow:hover { background: rgba(255,255,255,0.2); }
.lightbox-prev { left: -60px; }
.lightbox-next { right: -60px; }
.lightbox-image-wrap {
  max-width: 80vw;
  max-height: 78vh;
  display: flex;
  align-items: center;
  justify-content: center;
}
.lightbox-img {
  max-width: 100%;
  max-height: 78vh;
  object-fit: contain;
  display: block;
}
.lightbox-info { text-align: center; }
.lightbox-title {
  font-family: 'Outfit', sans-serif;
  font-size: 15px;
  font-weight: 600;
  color: #FAF8F4;
  margin-bottom: 4px;
}
.lightbox-counter {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: #8B8378;
}

/* ── RESPONSIVE ──────────────────────────────────────────────────────────── */
@media (max-width: 1024px) {
  .portfolio-layout { padding: 24px 24px 60px; }
  .about-layout { padding: 24px 24px 60px; }
  .left-rail { width: 220px; position: relative; top: auto; max-height: none; }
  .photo-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 768px) {
  .ph-inner { padding: 0 16px 24px; gap: 12px; }
  .ph-name { font-size: 24px; }
  .cover-banner { height: 240px; }
  .ph-avatar { width: 96px; height: 96px; }
  .ph-avatar-wrap { margin-top: -48px; }
  .ph-avatar-initials { font-size: 24px; }
  .tab-nav-inner { padding: 0 16px; }

  .portfolio-layout { flex-direction: column; padding: 16px 16px 60px; }
  .left-rail { width: 100%; position: relative; top: auto; max-height: none; }
  .photo-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; }

  .about-layout { flex-direction: column; padding: 16px 16px 60px; }
  .about-rail { order: -1; }

  .placeholder-panel { padding: 40px 16px; }
  .placeholder-inner { padding: 40px 24px; }

  .lightbox-prev { left: -52px; }
  .lightbox-next { right: -52px; }
}

@media (max-width: 480px) {
  .photo-grid { grid-template-columns: 1fr; }
  .lightbox-arrow { display: none; }
}
</style>

<script>
// ── Data ──────────────────────────────────────────────────────────────────
const username = window.location.pathname.split('/').filter(Boolean).pop() ?? '';

interface PhotoEntry { uuid: string; title: string; urls: { medium?: string; original?: string } }
let allPhotos: PhotoEntry[] = [];
let lightboxIdx = 0;

// ── Social link helpers ────────────────────────────────────────────────────
const SOCIAL_META: Record<string, { abbr: string; baseUrl: string; prefix: string }> = {
  instagram:      { abbr: 'IG',  baseUrl: 'https://instagram.com/', prefix: '' },
  facebook:       { abbr: 'FB',  baseUrl: 'https://facebook.com/', prefix: '' },
  x_twitter:      { abbr: 'X',   baseUrl: 'https://x.com/', prefix: '' },
  youtube:        { abbr: 'YT',  baseUrl: 'https://youtube.com/@', prefix: '' },
  tiktok:         { abbr: 'TK',  baseUrl: 'https://tiktok.com/@', prefix: '' },
  linkedin:       { abbr: 'LI',  baseUrl: 'https://linkedin.com/in/', prefix: '' },
  flickr:         { abbr: 'FL',  baseUrl: 'https://flickr.com/', prefix: '' },
  five_hundred_px:{ abbr: '500', baseUrl: 'https://500px.com/', prefix: '' },
};

function socialUrl(platform: string, handle: string): string {
  if (platform === 'website') return handle.startsWith('http') ? handle : `https://${handle}`;
  const m = SOCIAL_META[platform];
  return m ? `${m.baseUrl}${handle}` : '#';
}

function socialAbbr(platform: string): string {
  return SOCIAL_META[platform]?.abbr ?? platform.slice(0, 3).toUpperCase();
}

// ── Badge helpers ─────────────────────────────────────────────────────────
function classBadgeHtml(memberClass: string): string {
  if (!memberClass || memberClass === 'basic') return '';
  const label = memberClass.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  return `<span class="about-class-badge">${label}</span>`;
}

function railBadgeHtml(memberClass: string): string {
  if (!memberClass || memberClass === 'basic') return '';
  const label = memberClass.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  return `<span class="rail-class-badge">${label}</span>`;
}

// ── Load photographer profile ─────────────────────────────────────────────
async function loadProfile() {
  if (!username) return;

  let profile: Record<string, any>;
  try {
    const res = await fetch(`/api/v1/photographers/${username}`);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const json = await res.json();
    profile = json.data;
    if (!profile) throw new Error('Empty profile');
  } catch {
    setTxt('ph-name', 'Photographer');
    setTxt('grid-loading', 'Unable to load profile. Please try again later.');
    return;
  }

  // Page title
  document.title = `${profile.displayName} · Photographer · Bhopal Camera Club`;

  // Cover
  if (profile.coverUrl) {
    const coverImg = document.getElementById('cover-img') as HTMLImageElement | null;
    const coverDefault = document.getElementById('cover-default');
    if (coverImg) { coverImg.src = profile.coverUrl; coverImg.hidden = false; }
    if (coverDefault) coverDefault.style.display = 'none';
  }

  // Avatar
  const initials = (profile.displayName ?? '?').trim().split(/\s+/).map((w: string) => w[0] ?? '').join('').slice(0, 2).toUpperCase();
  setTxt('ph-initials', initials);
  if (profile.avatarUrl) {
    const img = document.getElementById('ph-avatar-img') as HTMLImageElement | null;
    const fallback = document.getElementById('ph-initials');
    if (img) { img.src = profile.avatarUrl; img.hidden = false; }
    if (fallback) (fallback as HTMLElement).style.display = 'none';
  }

  // Name + username
  setTxt('ph-name', profile.displayName ?? '—');
  setTxt('ph-username', `@${profile.username ?? ''}`);

  // Tagline
  if (profile.tagline) {
    const tagEl = document.getElementById('ph-tagline');
    if (tagEl) { tagEl.textContent = profile.tagline; tagEl.hidden = false; }
  }

  // Location + Since
  const locationParts: string[] = [];
  if (profile.city) locationParts.push(profile.city);
  if (profile.state) locationParts.push(profile.state);
  const since = profile.memberSince ? `Since ${profile.memberSince}` : null;

  if (locationParts.length || since) {
    const locRow = document.getElementById('ph-location-row');
    if (locRow) locRow.hidden = false;
    if (locationParts.length) setTxt('ph-location', locationParts.join(', '));
    if (since) setTxt('ph-since', since);
    // If no location but since, hide the dot
    if (!locationParts.length) {
      const dot = document.querySelector('.ph-dot') as HTMLElement | null;
      if (dot) dot.style.display = 'none';
    }
  }

  // Class badge
  if (profile.memberClass && profile.memberClass !== 'basic') {
    const badge = document.getElementById('ph-class-badge');
    if (badge) {
      const label = profile.memberClass.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
      badge.textContent = label;
      badge.hidden = false;
    }
  }

  // Founding member badge (MEM-006 constraint 4)
  if (profile.isFoundingMember) {
    const fb = document.getElementById('ph-founding-badge');
    if (fb) fb.hidden = false;
  }

  // Photo count
  setTxt('ph-photo-count', String(profile.photoCount ?? 0));

  // ── Left Rail ──────────────────────────────────────────────────────────
  // Member Since
  if (profile.memberSince) {
    const row = document.getElementById('rail-since-row');
    if (row) row.hidden = false;
    setTxt('rail-since', String(profile.memberSince));
  }

  // Membership class
  if (profile.memberClass && profile.memberClass !== 'basic') {
    const row = document.getElementById('rail-class-row');
    const wrap = document.getElementById('rail-class-badge');
    if (row) row.hidden = false;
    if (wrap) wrap.innerHTML = railBadgeHtml(profile.memberClass);
  }

  // Preferred camera system
  if (profile.preferredCameraSystem) {
    const row = document.getElementById('rail-system-row');
    if (row) row.hidden = false;
    setTxt('rail-camera-system', profile.preferredCameraSystem);
  }

  // Genres
  const genres: string[] = Array.isArray(profile.photographyGenres) ? profile.photographyGenres : [];
  if (genres.length) {
    const row = document.getElementById('rail-genres-row');
    const container = document.getElementById('rail-genres');
    if (row) row.hidden = false;
    if (container) {
      container.innerHTML = genres.map(g => `<span class="rail-genre-tag">${esc(g)}</span>`).join('');
    }
  }

  // Social links in rail
  const handles = profile.socialHandles ?? {};
  const socialPlatforms = Object.keys(handles).filter(p => p !== 'website');
  if (socialPlatforms.length) {
    const row = document.getElementById('rail-social-row');
    const container = document.getElementById('rail-social');
    if (row) row.hidden = false;
    if (container) {
      container.innerHTML = socialPlatforms.map(p =>
        `<a class="rail-social-link" href="${socialUrl(p, handles[p])}" target="_blank" rel="noopener noreferrer" title="${p}">${socialAbbr(p)}</a>`
      ).join('');
    }
  }

  // ── Bio Snippet (portfolio tab) ────────────────────────────────────────
  if (profile.bio) {
    const snippetEl = document.getElementById('bio-snippet');
    const bioTextEl = document.getElementById('bio-text');
    const stripTags = (html: string) => html.replace(/<[^>]*>/g, '');
    if (snippetEl) snippetEl.hidden = false;
    if (bioTextEl) bioTextEl.textContent = stripTags(profile.bio).trim();
  }

  // ── About tab ─────────────────────────────────────────────────────────
  // Bio
  const aboutBioEl = document.getElementById('about-bio');
  if (aboutBioEl) {
    if (profile.bio) {
      aboutBioEl.innerHTML = profile.bio;
    } else {
      aboutBioEl.innerHTML = '<p class="about-no-bio">No biography provided yet.</p>';
    }
  }

  // Bio meta (class badge + since)
  if (profile.memberClass && profile.memberClass !== 'basic' && profile.memberSince) {
    const metaEl = document.getElementById('about-bio-meta');
    const cbEl = document.getElementById('about-class-badge');
    const sinceEl = document.getElementById('about-since');
    if (metaEl) metaEl.hidden = false;
    if (cbEl) {
      const label = profile.memberClass.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
      cbEl.textContent = label;
    }
    if (sinceEl) sinceEl.textContent = `Member Since ${profile.memberSince}`;
  }

  // Social links in About tab
  const allPlatforms = Object.keys(handles);
  if (allPlatforms.length) {
    const socialEl = document.getElementById('about-social-links');
    if (socialEl) {
      socialEl.hidden = false;
      const parts: string[] = [];
      allPlatforms.forEach(p => {
        const url = socialUrl(p, handles[p]);
        if (p === 'website') {
          const display = handles[p].replace(/^https?:\/\//, '').replace(/\/$/, '');
          parts.push(`<a class="about-website-link" href="${url}" target="_blank" rel="noopener noreferrer">${esc(display)}</a>`);
        } else {
          parts.push(`<a class="about-social-icon" href="${url}" target="_blank" rel="noopener noreferrer" title="${p}">${socialAbbr(p)}</a>`);
        }
      });
      socialEl.innerHTML = parts.join('');
    }
  }

  // Gear in About rail
  const gear = profile.gear ?? {};
  const gearItems: string[] = [];
  if (gear.bodies?.length) {
    gearItems.push(`<div class="gear-group-label">Camera Bodies</div><div class="gear-items">${gear.bodies.map(esc).join('<br/>')}</div>`);
  }
  if (gear.lenses?.length) {
    gearItems.push(`<div class="gear-group-label">Lenses</div><div class="gear-items">${gear.lenses.map(esc).join('<br/>')}</div>`);
  }
  if (gear.accessories?.length) {
    gearItems.push(`<div class="gear-group-label">Other Equipment</div><div class="gear-items">${gear.accessories.map(esc).join('<br/>')}</div>`);
  }
  if (gearItems.length) {
    const gearCard = document.getElementById('about-gear-card');
    const gearEl = document.getElementById('about-gear');
    if (gearCard) gearCard.hidden = false;
    if (gearEl) gearEl.innerHTML = gearItems.join('');
  }

  // Genres in About rail
  if (genres.length) {
    const card = document.getElementById('about-genres-card');
    const el = document.getElementById('about-genres');
    if (card) card.hidden = false;
    if (el) el.innerHTML = genres.map(g => `<span class="about-genre-tag">${esc(g)}</span>`).join('');
  }

  // Areas of expertise in About rail
  const expertise: string[] = Array.isArray(profile.areasOfExpertise) ? profile.areasOfExpertise : [];
  if (expertise.length) {
    const card = document.getElementById('about-expertise-card');
    const el = document.getElementById('about-expertise');
    if (card) card.hidden = false;
    if (el) el.innerHTML = expertise.map(g => `<span class="about-genre-tag">${esc(g)}</span>`).join('');
  }

  // Now load photos
  await loadPhotos(profile.id);
}

// ── Load photos ───────────────────────────────────────────────────────────
async function loadPhotos(userId: number) {
  const grid = document.getElementById('portfolio-grid') as HTMLElement | null;
  if (!grid) return;

  try {
    const res = await fetch(`/api/v1/gallery/photographer/${userId}?limit=200`);
    if (!res.ok) throw new Error('Photos fetch failed');
    const { photos } = await res.json();

    if (!Array.isArray(photos) || photos.length === 0) {
      grid.innerHTML = `<div class="grid-empty">No photographs uploaded to the showcase yet.</div>`;
      return;
    }

    allPhotos = photos;

    // Update photo count stat
    setTxt('ph-photo-count', String(photos.length));

    // Photo grid count header
    const header = document.getElementById('photo-grid-header');
    const countEl = document.getElementById('photo-grid-count');
    if (header) header.hidden = false;
    if (countEl) countEl.textContent = `${photos.length} ${photos.length === 1 ? 'photograph' : 'photographs'}`;

    grid.innerHTML = '';
    photos.forEach((photo: PhotoEntry, idx: number) => {
      const src = photo.urls?.medium ?? photo.urls?.original ?? '';
      const btn = document.createElement('button');
      btn.className = 'photo-card';
      btn.type = 'button';
      btn.setAttribute('aria-label', photo.title || `Photo ${idx + 1}`);
      btn.innerHTML = `
        <img class="photo-card-img" src="${src}" alt="${esc(photo.title ?? '')}" loading="lazy" />
        <div class="photo-card-overlay">
          <span class="photo-card-title">${esc(photo.title ?? '')}</span>
        </div>
      `;
      btn.addEventListener('click', () => openLightbox(idx));
      grid.appendChild(btn);
    });

  } catch {
    if (grid) grid.innerHTML = `<div class="grid-empty">Unable to load portfolio. Please try again later.</div>`;
  }
}

// ── Lightbox ──────────────────────────────────────────────────────────────
function openLightbox(idx: number) {
  lightboxIdx = idx;
  updateLightbox();
  const lb = document.getElementById('lightbox');
  if (lb) lb.hidden = false;
  document.body.style.overflow = 'hidden';
}

function closeLightbox() {
  const lb = document.getElementById('lightbox');
  if (lb) lb.hidden = true;
  document.body.style.overflow = '';
}

function updateLightbox() {
  const photo = allPhotos[lightboxIdx];
  if (!photo) return;
  const img = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const title = document.getElementById('lightbox-title');
  const counter = document.getElementById('lightbox-counter');
  if (img) img.src = photo.urls?.original ?? photo.urls?.medium ?? '';
  if (title) title.textContent = photo.title ?? '';
  if (counter) counter.textContent = `${lightboxIdx + 1} / ${allPhotos.length}`;

  const prev = document.getElementById('lightbox-prev') as HTMLButtonElement | null;
  const next = document.getElementById('lightbox-next') as HTMLButtonElement | null;
  if (prev) prev.style.display = allPhotos.length <= 1 ? 'none' : '';
  if (next) next.style.display = allPhotos.length <= 1 ? 'none' : '';
}

document.getElementById('lightbox-backdrop')?.addEventListener('click', closeLightbox);
document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
document.getElementById('lightbox-prev')?.addEventListener('click', () => {
  lightboxIdx = (lightboxIdx - 1 + allPhotos.length) % allPhotos.length;
  updateLightbox();
});
document.getElementById('lightbox-next')?.addEventListener('click', () => {
  lightboxIdx = (lightboxIdx + 1) % allPhotos.length;
  updateLightbox();
});
document.addEventListener('keydown', (e: KeyboardEvent) => {
  const lb = document.getElementById('lightbox');
  if (!lb || lb.hidden) return;
  if (e.key === 'Escape') closeLightbox();
  if (e.key === 'ArrowLeft') { lightboxIdx = (lightboxIdx - 1 + allPhotos.length) % allPhotos.length; updateLightbox(); }
  if (e.key === 'ArrowRight') { lightboxIdx = (lightboxIdx + 1) % allPhotos.length; updateLightbox(); }
});

// ── Tab navigation ────────────────────────────────────────────────────────
function activateTab(tabKey: string) {
  document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(btn => {
    const active = btn.dataset.tab === tabKey;
    btn.classList.toggle('tab-btn--active', active);
    btn.setAttribute('aria-selected', String(active));
  });
  document.querySelectorAll<HTMLElement>('.tab-panel').forEach(panel => {
    panel.hidden = panel.id !== `tab-${tabKey}`;
  });
}

document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => activateTab(btn.dataset.tab ?? 'portfolio'));
});

// "Full biography →" link in bio snippet triggers About tab
document.querySelector<HTMLElement>('.bio-more-link')?.addEventListener('click', () => {
  activateTab('about');
  window.scrollTo({ top: 0, behavior: 'smooth' });
});

// ── Helpers ───────────────────────────────────────────────────────────────
function setTxt(id: string, val: string) {
  const el = document.getElementById(id);
  if (el) el.textContent = val;
}
function esc(str: string): string {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

// ── Boot ──────────────────────────────────────────────────────────────────
loadProfile().catch(() => {
  setTxt('ph-name', 'Photographer');
  const grid = document.getElementById('portfolio-grid');
  if (grid) grid.innerHTML = `<div class="grid-empty">Unable to load profile. Please try again later.</div>`;
});
</script>
