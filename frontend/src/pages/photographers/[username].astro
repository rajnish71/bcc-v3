/* Justified gallery — inherits the /showcase justified grid (item 70).
   Rows are created at runtime by JS, so they never receive Astro's scoping
   attribute — the row rule MUST be :global() or it won't apply (CLAUDE.md §4.4,
   same as /showcase's :global(.grid-row)). */
.profile-justified-grid { display: flex; flex-direction: column; gap: 0; }
:global(.profile-jrow) { display: flex; gap: 8px; margin-bottom: 8px; }
:global(.profile-jrow:last-child) { margin-bottom: 0; }

/* ── Masonry layout — CSS columns, natural image heights ─────────────────── */
/* #portfolio-grid gets this class dynamically; the element IS in the template
   so it carries Astro's scoping attribute and scoped selectors work on it.
   Child .profile-alt-card elements are runtime-created → they need :global(). */
.profile-masonry-grid { display: block; column-count: 3; column-gap: 8px; }
:global(.profile-masonry-card) {
  break-inside: avoid; display: block; margin-bottom: 8px; width: 100%;
}
:global(.profile-masonry-card .photo-card__img) { height: auto; object-fit: cover; }

/* ── Modular — uniform fixed-aspect grid ─────────────────────────────────── */
.profile-modular-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 8px;
}

/* ── Editorial — full-width hero alternating with 2-col rows ─────────────── */
/* Pattern repeats every 3 items: 1,4,7… hero (span-2 cols, span-2 rows);
   items 2-3, 5-6… fill a normal 2-column row beside/below the hero. */
.profile-editorial-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-auto-rows: 240px;
  gap: 8px;
}
:global(.profile-editorial-grid .profile-alt-card:nth-child(3n+1)) {
  grid-column: span 2;
  grid-row: span 2;
}

/* ── Metro — mosaic of large (2×2) and small (1×1) tiles ────────────────── */
/* Pattern: 1,6,11… large; the 4 items between fill the remaining 2×2 cells. */
.profile-metro-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: 200px;
  grid-auto-flow: dense;
  gap: 8px;
}
:global(.profile-metro-grid .profile-alt-card:nth-child(5n+1)) {
  grid-column: span 2;
  grid-row: span 2;
}

/* ── Magazine — full-width feature + 2-column body ───────────────────────── */
