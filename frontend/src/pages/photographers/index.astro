---
/**
 * photographers/index.astro
 * Route: /photographers/
 * Design authority: V6 04 Photographers Directory.dc.html
 *
 * V6 Layout:
 *   PageHero (white · 3px amber top-border · stats band)
 *   → FilterTabs (All · Basic · Student · Individual · Life)
 *   → ResultsCountBar
 *   → PhotographerCard grid (4/3/2-col)
 *   → EmptyState (zero filter results)
 *
 * MEM-006 constraints enforced:
 *   1. PRIVATE profiles excluded at API layer.
 *   2. Filter tabs: lookup only, no CTA/upgrade pathway.
 *   3. No joining CTA anywhere on this page.
 *   4. Basic Member badge shown on cards (permitted here, not on profile page).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import FilterChips from '../../components/search/FilterChips.astro';
---

<BaseLayout
  title="Our Photographers · Bhopal Camera Club"
  description="A community of dedicated image-makers based in Bhopal. Members of the Bhopal Camera Club sharing their vision, craft, and stories with the world."
>

<!-- ── PAGE HERO ──────────────────────────────────────────────────────────── -->
<div class="page-hero">
  <div class="hero-inner">
    <div class="hero-breadcrumb">Photographers Directory · /photographers/</div>
    <h1 class="hero-title">Our Photographers</h1>
    <p class="hero-intro">A community of dedicated image-makers based in Bhopal. Members of the Bhopal Camera Club sharing their vision, craft, and stories with the world.</p>
    <div class="hero-stats">
      <div class="hero-stat">
        <div class="hero-stat-val" id="stat-ph-count">—</div>
        <div class="hero-stat-label">Active Photographers</div>
      </div>
      <div class="hero-stat-sep" aria-hidden="true"></div>
      <div class="hero-stat">
        <div class="hero-stat-val" id="stat-photo-count">—</div>
        <div class="hero-stat-label">Photos in Showcase</div>
      </div>
    </div>
  </div>
</div>

<!-- ── FILTER TABS ────────────────────────────────────────────────────────── -->
<div class="filter-area">
  <div class="filter-area-inner">
    <FilterChips
      id="filter-tabs"
      label="Filter photographers by membership class"
      options={[
        { value: 'all',        label: 'All' },
        { value: 'basic',      label: 'Basic' },
        { value: 'student',    label: 'Student' },
        { value: 'individual', label: 'Individual' },
        { value: 'life',       label: 'Life' },
      ]}
      value="all"
    />
  </div>
</div>

<!-- ── RESULTS BAR ───────────────────────────────────────────────────────── -->
<div class="results-bar">
  <div class="results-bar-inner">
    <span class="results-count" id="results-count" aria-live="polite">
      <span id="results-num">—</span> photographers
    </span>
    <span class="results-sort-note">Sorted: random · No sort control in this version</span>
  </div>
</div>

<!-- ── CARD GRID ─────────────────────────────────────────────────────────── -->
<div class="grid-area">
  <div class="grid-container">

    <div class="ph-grid" id="ph-grid" aria-label="Photographer directory">
      {[...Array(8)].map(() => (
        <div class="ph-card-skel" aria-hidden="true">
          <div class="skel-avatar-wrap">
            <div class="skel skel-avatar"></div>
          </div>
          <div class="skel-body">
            <div class="skel" style="width:68%;height:14px;"></div>
            <div class="skel" style="width:48%;height:10px;margin-top:7px;"></div>
            <div class="skel" style="width:58%;height:22px;margin-top:12px;border-radius:999px;"></div>
            <div class="skel-divider"></div>
            <div class="skel" style="width:88%;height:10px;"></div>
            <div class="skel" style="width:72%;height:10px;margin-top:5px;"></div>
          </div>
        </div>
      ))}
    </div>

    <div id="ph-empty" hidden class="ph-empty">
      <svg class="ph-empty-icon" width="64" height="52" viewBox="0 0 64 52" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="2" y="14" width="60" height="36" rx="4" stroke="currentColor" stroke-width="2"/>
        <circle cx="32" cy="32" r="12" stroke="currentColor" stroke-width="2"/>
        <circle cx="32" cy="32" r="5.5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M22 14V10C22 8.9 22.9 8 24 8H40C41.1 8 42 8.9 42 10V14" stroke="currentColor" stroke-width="2"/>
        <rect x="6" y="7" width="8" height="7" rx="2" stroke="currentColor" stroke-width="1.5"/>
      </svg>
      <div class="ph-empty-title">No photographers found matching your filters</div>
      <p class="ph-empty-desc">Try a different class filter or clear all filters to see everyone.</p>
      <button class="btn-clear-filters" id="ph-clear">Clear Filters</button>
    </div>

  </div>
</div>

</BaseLayout>

<style>
/* ── PAGE HERO ───────────────────────────────────────────────────────────── */
.page-hero {
  margin-top: var(--nav-h, 64px);
  background: var(--surface-0);
  border-top: 3px solid var(--gold-600);
  border-bottom: 1px solid var(--hairline);
}
.hero-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 72px 40px 56px;
}
.hero-breadcrumb {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-400);
  margin-bottom: 24px;
}
.hero-title {
  font-family: var(--font-display);
  font-size: clamp(44px, 5.5vw, 72px);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.0;
  color: var(--ink-900);
  margin-bottom: 20px;
}
.hero-intro {
  font-size: 18px;
  line-height: 1.7;
  color: var(--ink-600);
  max-width: 580px;
  font-weight: 300;
  margin-bottom: 48px;
}
.hero-stats {
  display: flex;
  align-items: flex-start;
  gap: 0;
  border-top: 1px solid var(--hairline);
  padding-top: 32px;
  flex-wrap: wrap;
}
.hero-stat { padding-right: 48px; }
.hero-stat-val {
  font-family: var(--font-display);
  font-size: 44px;
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--ink-900);
  line-height: 1;
}
.hero-stat-label {
  font-size: 11px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--ink-400);
  font-weight: 600;
  margin-top: 6px;
}
.hero-stat-sep {
  width: 1px;
  background: var(--hairline);
  height: 56px;
  margin-right: 48px;
  flex-shrink: 0;
  align-self: flex-start;
  margin-top: 4px;
}

/* ── FILTER TABS ─────────────────────────────────────────────────────────── */
.filter-area {
  background: var(--surface-1);
  border-bottom: 1px solid var(--hairline);
}
.filter-area-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 20px 40px;
}
/* ── RESULTS BAR ─────────────────────────────────────────────────────────── */
.results-bar {
  background: var(--surface-0);
  border-bottom: 1px solid var(--hairline);
}
.results-bar-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 14px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
}
.results-count {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--ink-600);
  font-weight: 500;
}
#results-num { color: var(--ink-900); }
.results-sort-note {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--ink-400);
  letter-spacing: 0.06em;
}

/* ── GRID AREA ───────────────────────────────────────────────────────────── */
.grid-area {
  background: var(--surface-bg);
  min-height: 50vh;
  padding: 32px 0 80px;
}
.grid-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 40px;
}

/* ── CARD GRID ───────────────────────────────────────────────────────────── */
.ph-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}

/* ── PHOTOGRAPHER CARD ───────────────────────────────────────────────────── */
:global(.ph-card) {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  cursor: pointer;
  position: relative;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}
:global(.ph-card:hover) {
  border-color: var(--gold-500);
  box-shadow: 0 8px 32px rgba(20,18,16,0.09);
}
:global(.ph-card-avatar-wrap) {
  display: flex;
  justify-content: center;
  padding: 24px 24px 12px;
}
:global(.ph-card-avatar) {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 700;
  color: var(--surface-0);
  flex-shrink: 0;
  letter-spacing: -0.02em;
  overflow: hidden;
}
:global(.ph-card-avatar img) {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
:global(.ph-card-body) {
  text-align: center;
  padding: 0 18px 20px;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
:global(.ph-card-name) {
  font-family: var(--font-display);
  font-size: 17px;
  font-weight: 700;
  color: var(--ink-900);
  margin-bottom: 4px;
  line-height: 1.25;
  word-break: break-word;
  transition: color 0.2s ease;
}
:global(.ph-card:hover .ph-card-name) { color: var(--gold-600); }
:global(.ph-card-username) {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--gold-600);
  margin-bottom: 10px;
}
:global(.ph-card-class-badge) {
  display: inline-flex;
  align-items: center;
  border: 1.5px solid currentColor;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.06em;
  padding: 3px 12px;
  border-radius: 999px;
  white-space: nowrap;
  margin-bottom: 8px;
}
:global(.ph-card-recognition) {
  display: inline-flex;
  align-items: center;
  border: 1px solid var(--hairline);
  color: var(--ink-400);
  font-size: 10px;
  font-weight: 500;
  padding: 2px 10px;
  border-radius: 999px;
  letter-spacing: 0.03em;
  white-space: nowrap;
  margin-bottom: 8px;
}
:global(.ph-card-divider) {
  width: 100%;
  height: 1px;
  background: var(--hairline);
  margin: 8px 0;
  flex-shrink: 0;
}
:global(.ph-card-tagline) {
  font-size: 13px;
  line-height: 1.5;
  color: var(--ink-600);
  margin-bottom: 8px;
  text-align: center;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  width: 100%;
}
:global(.ph-card-meta-row) {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 10px;
  min-height: 20px;
}
:global(.ph-card-city) {
  font-size: 12px;
  color: var(--ink-400);
}
:global(.ph-card-genre) {
  font-size: 11px;
  background: var(--surface-2);
  color: var(--ink-600);
  padding: 2px 10px;
  border-radius: var(--r-1);
  font-weight: 500;
}
:global(.ph-card-photo-count) {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-400);
  margin-top: auto;
}
:global(.ph-card-arrow) {
  position: absolute;
  bottom: 12px;
  right: 12px;
  opacity: 0;
  transition: opacity 0.2s ease;
  color: var(--gold-600);
}
:global(.ph-card:hover .ph-card-arrow) { opacity: 1; }

/* ── SKELETON ────────────────────────────────────────────────────────────── */
.ph-card-skel {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  display: flex;
  flex-direction: column;
  align-items: center;
}
.skel-avatar-wrap {
  display: flex;
  justify-content: center;
  padding: 24px 24px 12px;
}
.skel-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
}
.skel-body {
  width: 100%;
  padding: 0 18px 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}
.skel-divider {
  width: 100%;
  height: 1px;
  background: var(--hairline-soft);
  margin: 12px 0;
}
.skel {
  background: linear-gradient(90deg, var(--hairline-soft) 25%, var(--surface-1) 50%, var(--hairline-soft) 75%);
  background-size: 200% 100%;
  animation: bg-shimmer 1.4s infinite;
  border-radius: 2px;
}

/* ── EMPTY STATE ─────────────────────────────────────────────────────────── */
.ph-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 32px;
  text-align: center;
  gap: 24px;
}
.ph-empty-icon { color: var(--ink-200); }
.ph-empty-title {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 600;
  color: var(--ink-400);
  margin-bottom: 8px;
}
.ph-empty-desc {
  font-size: 14px;
  color: var(--ink-400);
  margin-bottom: 4px;
}
.btn-clear-filters {
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.05em;
  padding: 12px 28px;
  border: 1.5px solid var(--gold-600);
  background: transparent;
  color: var(--gold-600);
  border-radius: var(--r-1);
  cursor: pointer;
  font-family: inherit;
  transition: background var(--m-fast), color var(--m-fast);
}
.btn-clear-filters:hover { background: var(--gold-600); color: var(--surface-0); }

/* ── RESPONSIVE ──────────────────────────────────────────────────────────── */
@media (max-width: 1100px) {
  .ph-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 860px) {
  .hero-inner { padding: 56px 32px 40px; }
  .filter-area-inner { padding: 20px 32px 0; }
  .results-bar-inner { padding: 12px 32px; }
  .grid-container { padding: 0 32px; }
  .results-sort-note { display: none; }
}
@media (max-width: 768px) {
  .hero-title { font-size: 40px; }
  .hero-intro { font-size: 16px; margin-bottom: 32px; }
  .hero-stat-val { font-size: 36px; }
  .ph-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
  .hero-inner { padding: 40px 20px 36px; }
  .filter-area-inner { padding: 16px 20px 0; }
  .results-bar-inner { padding: 12px 20px; }
  .grid-container { padding: 0 20px; }
  .filter-tabs { flex-wrap: nowrap; overflow-x: auto; }
}
@media (max-width: 480px) {
  .ph-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
}
</style>

<script>
// ── Types ─────────────────────────────────────────────────────────────────
interface Photographer {
  id: number;
  username: string;
  displayName: string;
  tagline: string | null;
  bio: string | null;
  city: string | null;
  memberClass: string;
  memberSince: number | null;
  photoCount: number;
  avatarUrl: string | null;
}

// ── Constants ─────────────────────────────────────────────────────────────
const CLASS_LABELS: Record<string, string> = {
  founding:   'Founding Member',
  life:       'Life Member',
  patron:     'Patron Member',
  full:       'Full Member',
  individual: 'Individual Member',
  student:    'Student Member',
  basic:      'Basic Member',
};

const CLASS_COLORS: Record<string, string> = {
  founding:   '#8A6A2E',
  life:       '#A8843C',
  patron:     '#8A6A2E',
  full:       '#C47A20',
  individual: '#3E5A48',
  student:    '#1A9DAE',
  basic:      '#5C5876',
};

const AVATAR_BG_PALETTE = [
  '#3E5A48', '#9A7A30', '#1A6A6A', '#4A5068',
  '#47514B', '#6B4A2A', '#3A5868', '#5C4A6A',
  '#6A4A3A', '#2A5C5C',
];

// ── State ─────────────────────────────────────────────────────────────────
let allPhotographers: Photographer[] = [];
let activeClass = 'all';

// ── Helpers ───────────────────────────────────────────────────────────────
function avatarBg(username: string): string {
  let h = 0;
  for (let i = 0; i < username.length; i++) h = username.charCodeAt(i) + ((h << 5) - h);
  return AVATAR_BG_PALETTE[Math.abs(h) % AVATAR_BG_PALETTE.length];
}

function esc(str: string): string {
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

function initials(name: string): string {
  return name.trim().split(/\s+/).map(w => w[0] ?? '').join('').slice(0, 2).toUpperCase();
}

// ── Load data ─────────────────────────────────────────────────────────────
async function load() {
  try {
    const [phRes, feedRes] = await Promise.allSettled([
      fetch('/api/v1/photographers?limit=200&sort=name'),
      fetch('/api/v1/gallery/feed?limit=1'),
    ]);

    // Photographers
    if (phRes.status === 'fulfilled' && phRes.value.ok) {
      const { data, meta } = await phRes.value.json();
      allPhotographers = Array.isArray(data) ? data : [];
      const total = meta?.total_count ?? allPhotographers.length;
      const statEl = document.getElementById('stat-ph-count');
      if (statEl) statEl.textContent = total.toLocaleString('en-IN');
    }

    // Photos in showcase
    if (feedRes.status === 'fulfilled' && feedRes.value.ok) {
      const feedJson = await feedRes.value.json();
      const photoTotal = feedJson?.total ?? feedJson?.meta?.total ?? null;
      const photoStatEl = document.getElementById('stat-photo-count');
      if (photoStatEl && photoTotal !== null) {
        photoStatEl.textContent = Number(photoTotal).toLocaleString('en-IN');
      }
    }
  } catch {
    // Graceful — render with whatever we have
  }

  render();
}

// ── Render ────────────────────────────────────────────────────────────────
function render() {
  const grid    = document.getElementById('ph-grid')!;
  const emptyEl = document.getElementById('ph-empty')!;
  const numEl   = document.getElementById('results-num')!;

  grid.innerHTML = '';

  const filtered = activeClass === 'all'
    ? allPhotographers
    : allPhotographers.filter(ph => ph.memberClass === activeClass);

  numEl.textContent = filtered.length.toLocaleString('en-IN');

  if (!filtered.length) {
    emptyEl.removeAttribute('hidden');
    return;
  }
  emptyEl.setAttribute('hidden', '');

  filtered.forEach(ph => {
    const inits   = initials(ph.displayName ?? '?');
    const bgColor = avatarBg(ph.username);
    const classKey   = ph.memberClass ?? 'basic';
    const classLabel = CLASS_LABELS[classKey] ?? classKey;
    const classColor = CLASS_COLORS[classKey] ?? '#8B8378';
    const photoLabel = (ph.photoCount ?? 0).toLocaleString('en-IN') + ' photos';

    const card = document.createElement('a');
    card.href      = `/photographers/${esc(ph.username)}/`;
    card.className = 'ph-card';

    let avatarHtml: string;
    if (ph.avatarUrl) {
      avatarHtml = `<img src="${esc(ph.avatarUrl)}" alt="${esc(ph.displayName ?? '')}" loading="lazy" width="80" height="80" />`;
    } else {
      avatarHtml = esc(inits);
    }

    const taglineHtml = ph.tagline
      ? `<div class="ph-card-tagline">${esc(ph.tagline)}</div>`
      : '';

    const cityHtml = ph.city
      ? `<span class="ph-card-city">${esc(ph.city)}</span>`
      : '';

    const metaRowHtml = (ph.city)
      ? `<div class="ph-card-meta-row">${cityHtml}</div>`
      : '';

    card.innerHTML = `
      <div class="ph-card-avatar-wrap">
        <div class="ph-card-avatar" style="background:${bgColor};">${avatarHtml}</div>
      </div>
      <div class="ph-card-body">
        <div class="ph-card-name">${esc(ph.displayName ?? '')}</div>
        <div class="ph-card-username">@${esc(ph.username)}</div>
        <span class="ph-card-class-badge" style="color:${classColor};">${esc(classLabel)}</span>
        <div class="ph-card-divider"></div>
        ${taglineHtml}
        ${metaRowHtml}
        <div class="ph-card-photo-count">${photoLabel}</div>
      </div>
      <svg class="ph-card-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M2 12L12 2M12 2H4.5M12 2V9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    `;

    grid.appendChild(card);
  });
}

// ── Filter chips ──────────────────────────────────────────────────────────
document.getElementById('filter-tabs')?.addEventListener('bcc:filter', e => {
  activeClass = (e as CustomEvent<{ value: string }>).detail.value ?? 'all';
  render();
});

// ── Clear filters ─────────────────────────────────────────────────────────
document.getElementById('ph-clear')?.addEventListener('click', () => {
  // Programmatically click the 'all' chip so FilterChips updates its own state
  document.querySelector<HTMLButtonElement>('#filter-tabs [data-value="all"]')?.click();
});

// ── Boot ──────────────────────────────────────────────────────────────────
load();
</script>
