---
/**
 * showcase.astro — Showcase Page
 *
 * Justified photo grid of all publicly visible member photos.
 * Filter bar: All / by photographer / by tag
 * Phase 1: data fetched client-side from /api/v1/photos
 * Phase 2a (Module 05) will add server-side pagination and full tagging.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Showcase"
  description="The Bhopal Camera Club member portfolio — photography from Bhopal and beyond. Justified gallery preserving each photo's original aspect ratio."
>

  <!-- Page hero -->
  <div class="showcase-hero container">
    <div class="showcase-hero-inner">
      <div class="showcase-hero-content">
        <div class="showcase-kicker">
          <span class="showcase-kicker-line"></span>
          Showcase
        </div>
        <h1 class="showcase-title">Member Portfolio</h1>
        <p class="showcase-lead">Photographs by BCC members. Every image displayed at its original aspect ratio — as the photographer intended.</p>
      </div>
    </div>
  </div>

  <!-- Filter bar -->
  <div class="filter-bar sticky" id="filter-bar">
    <div class="container">
      <div class="filter-inner">

        <!-- Category filters -->
        <div class="filter-chips" id="filter-chips" role="group" aria-label="Filter by type">
          <button class="filter-chip active" data-filter="all" aria-pressed="true">All</button>
          <button class="filter-chip" data-filter="landscape" aria-pressed="false">Landscape</button>
          <button class="filter-chip" data-filter="portrait" aria-pressed="false">Portrait</button>
          <button class="filter-chip" data-filter="street" aria-pressed="false">Street</button>
          <button class="filter-chip" data-filter="wildlife" aria-pressed="false">Wildlife</button>
          <button class="filter-chip" data-filter="macro" aria-pressed="false">Macro</button>
          <button class="filter-chip" data-filter="architecture" aria-pressed="false">Architecture</button>
        </div>

        <!-- Sort + photographer filter -->
        <div class="filter-right">
          <select class="filter-select" id="sort-select" aria-label="Sort photographs">
            <option value="recent">Most Recent</option>
            <option value="popular">Most Liked</option>
            <option value="random">Shuffle</option>
          </select>
          <select class="filter-select" id="photographer-select" aria-label="Filter by photographer">
            <option value="">All Photographers</option>
            <!-- Populated by JS -->
          </select>
        </div>

      </div>
    </div>
  </div>

  <!-- Photo count + status -->
  <div class="container">
    <div class="photo-count" id="photo-count" aria-live="polite" aria-atomic="true">
      <span id="count-number">—</span> photographs
    </div>
  </div>

  <!-- Justified grid -->
  <div class="container">
    <div class="justified-grid" id="showcase-grid" data-target-height="260" data-gap="8" aria-label="Photo showcase grid">

      <!-- Loading skeleton -->
      <div id="showcase-skeleton" aria-busy="true">
        {[
          [3.2, 1.5, 4.0, 1.0],
          [1.0, 2.5, 1.2, 2.0, 1.8],
          [2.4, 1.5, 3.0, 1.0],
          [1.5, 3.5, 1.0, 2.8],
          [2.0, 1.2, 4.2, 1.6],
        ].map((row) => (
          <div class="grid-row">
            {row.map((flex) => (
              <div class="skel-photo" style={`flex:${flex};height:260px;`}></div>
            ))}
          </div>
        ))}
      </div>

    </div>

    <!-- Load more -->
    <div class="load-more-wrap" id="load-more-wrap" hidden>
      <button class="btn btn-ghost" id="load-more-btn">
        Load more photographs
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M7 2v10M2 9l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <!-- Empty state -->
    <div id="showcase-empty" hidden class="gallery-empty" style="padding:var(--s-12) 0;">
      <div class="gallery-empty__icon">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
          <circle cx="24" cy="24" r="22.5" stroke="rgba(20,18,16,0.1)" stroke-width="1.5"/>
          <circle cx="24" cy="24" r="8" stroke="rgba(168,132,60,0.4)" stroke-width="1.5"/>
          <circle cx="24" cy="24" r="2" fill="rgba(168,132,60,0.6)"/>
        </svg>
      </div>
      <p class="gallery-empty__text">No photographs match this filter.</p>
      <button class="btn btn-outline btn-md" id="clear-filter-btn">Clear filter</button>
    </div>

  </div>

  <!-- Photographer Profiles Section -->
  <section class="photographers-section container" data-gsap="reveal" style="margin-top: 120px; padding: 0 var(--s-12) var(--s-16);">
    <div class="photographers-header">
      <div class="photographers-kicker">The Photographers</div>
      <h3 class="photographers-title">Meet the members behind the wall.</h3>
    </div>
    <div class="photographers-grid" id="photographers-grid">
      <!-- Populated dynamically by JS -->
    </div>
  </section>

</BaseLayout>


<style>
/* ── Showcase hero ── */
.showcase-hero {
  padding-top: calc(var(--nav-h) + var(--s-12));
  padding-bottom: var(--s-8);
}
.showcase-hero-inner {
  background: #FFFFFF;
  border: 1px solid var(--hairline);
  border-top: 3px solid var(--gold-600);
  overflow: hidden;
}
.showcase-hero-content {
  padding: 64px 72px 56px;
}
.showcase-kicker {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: 600;
  margin-bottom: 18px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.showcase-kicker-line {
  display: block;
  width: 28px;
  height: 1px;
  background: #C9A961;
}
.showcase-title {
  font-family: var(--font-display);
  font-size: clamp(40px, 5vw, 64px);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.0;
  color: var(--ink-900);
  margin-bottom: 20px;
}
.showcase-lead {
  font-size: 17px;
  line-height: 1.8;
  color: var(--ink-600);
  max-width: 520px;
  font-weight: 300;
}

@media (max-width: 1024px) {
  .showcase-hero-content {
    padding: 48px var(--gutter-mob);
  }
}
@media (max-width: 768px) {
  .showcase-hero-content {
    padding: 32px var(--gutter-mob);
  }
}

/* ── Filter bar ── */
.filter-bar {
  position: sticky;
  top: var(--nav-h);
  z-index: 100;
  background: rgba(250, 248, 244, 0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--hairline);
  padding: var(--s-2) 0;
  margin-bottom: var(--s-8);
}

.filter-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--s-4);
  flex-wrap: wrap;
}

.filter-chips {
  display: flex;
  align-items: center;
  gap: var(--s-2);
  flex-wrap: wrap;
}
.filter-chip {
  padding: 4px 12px;
  font-family: var(--font-body);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--ink-600);
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-radius: var(--r-full);
  cursor: pointer;
  transition: border-color var(--m-fast), color var(--m-fast);
}
.filter-chip:hover { border-color: var(--hairline-strong); color: var(--ink-900); }
.filter-chip.active {
  border-color: var(--gold-500);
  color: var(--gold-600);
  border-top: 3px solid var(--gold-500);
  padding-top: 2px;
}

.filter-right {
  display: flex;
  align-items: center;
  gap: var(--s-2);
  flex-shrink: 0;
}
.filter-select {
  padding: 8px 12px;
  background: var(--surface-0);
  border: 1px solid var(--hairline-strong);
  border-radius: var(--r-2);
  color: var(--ink-900);
  font-size: var(--text-small);
  font-family: var(--font-body);
  outline: none;
  cursor: pointer;
  transition: border-color var(--m-fast);
  -webkit-appearance: none;
}
.filter-select:focus { border-color: var(--gold-500); }

/* ── Photo count ── */
.photo-count {
  font-size: var(--text-small);
  color: var(--ink-600);
  margin-bottom: var(--s-4);
  letter-spacing: 0.02em;
}
#count-number { font-weight: 600; color: var(--ink-900); }

/* ── Grid + skeleton (shared via global.css) ── */
:global(.grid-row)   { display: flex; gap: 8px; margin-bottom: 8px; }
:global(.grid-row:last-child) { margin-bottom: 0; }
.skel-photo { background: var(--surface-2); border-radius: 0; animation: shimmer 1.6s ease-in-out infinite; }
@keyframes shimmer { 0%,100% { opacity:.4; } 50% { opacity:.7; } }

/* ── Load more ── */
.load-more-wrap { display: flex; justify-content: center; padding: var(--s-8) 0 var(--s-12); }

/* ── Gallery empty ── */
.gallery-empty { text-align: center; color: var(--ink-600); }
.gallery-empty__icon { margin-bottom: var(--s-3); display: flex; justify-content: center; }
.gallery-empty__text { font-size: var(--text-body); color: var(--ink-900); margin-bottom: var(--s-4); }

/* ── Responsive ── */
@media (max-width: 768px) {
  .filter-inner { flex-direction: column; align-items: flex-start; }
  .filter-right { width: 100%; }
  .filter-select { flex: 1; }
}

/* ── Photographer Profiles ── */
.photographers-section {
  display: flex;
  flex-direction: column;
}
.photographers-header {
  background: #FFFFFF;
  border: 1px solid var(--hairline);
  border-bottom: none;
  padding: 22px 32px 18px;
}
.photographers-kicker {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: 600;
  margin-bottom: 10px;
}
.photographers-title {
  font-family: var(--font-display);
  font-size: 30px;
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--ink-900);
}
.photographers-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border-top: 1px solid var(--hairline);
  border-left: 1px solid var(--hairline);
  margin-bottom: var(--s-4);
  background: var(--surface-1);
}
.photographer-card {
  background: #FFFFFF;
  border-right: 1px solid var(--hairline);
  border-bottom: 1px solid var(--hairline);
  padding: 28px 24px;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  transition: background-color var(--m-fast), outline var(--m-fast);
}
.photographer-card:hover {
  background: #FAF8F4;
  outline: 1.5px solid var(--gold-500);
  outline-offset: -1.5px;
  z-index: 1;
}
.photographer-avatar {
  width: 52px;
  height: 52px;
  border-radius: var(--r-full);
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid var(--hairline);
  background: var(--forest-gradient);
  color: #FFFFFF;
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 700;
  overflow: hidden;
}
.photographer-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.photographer-name {
  font-family: var(--font-display);
  font-size: 15px;
  font-weight: 600;
  color: var(--ink-900);
  margin-bottom: 4px;
}
.photographer-meta {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--gold-600);
  margin-bottom: 10px;
  letter-spacing: 0.04em;
}
.photographer-bio {
  font-size: 12px;
  line-height: 1.7;
  color: var(--ink-600);
}

@media (max-width: 900px) {
  .photographers-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}
@media (max-width: 600px) {
  .photographers-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>


<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  /* ── State ── */
  let allPhotos: any[] = [];
  let photoBuffer: any[] = []; // Incomplete row memory buffer
  let currentFilter = 'all';
  let currentSort = 'recent';
  let currentPhotographer = '';
  const PAGE_SIZE = 20;

  /* ── Justified layout ── */
  function buildJustifiedLayout(
    photos: Array<{ aspect: number; id: string; title: string; photographer: string; photographerUsername: string; imageUrl: string }>,
    containerWidth: number,
    targetHeight = 240, // Match target height 240px from V6 spec
    gap = 8
  ) {
    const rows: Array<{ height: number; photos: typeof photos }> = [];
    let row: typeof photos = [];
    let rowWidth = 0;

    const flush = () => {
      if (!row.length) return;
      const totalGap = gap * (row.length - 1);
      const scale = (containerWidth - totalGap) / rowWidth;
      const height = targetHeight * scale;
      rows.push({ height, photos: row.map(p => ({ ...p, width: p.aspect * height })) });
      row = [];
      rowWidth = 0;
    };

    for (const photo of photos) {
      const idealW = photo.aspect * targetHeight;
      row.push(photo);
      rowWidth += idealW;
      if (rowWidth + gap * (row.length - 1) >= containerWidth * 0.88) {
        flush();
      }
    }

    // Return completed rows and the leftover photos forming the incomplete final row
    return {
      rows,
      leftovers: row
    };
  }

  function renderGrid(newPhotos: any[], append = false) {
    const grid = document.getElementById('showcase-grid')!;
    if (!append) {
      // Remove old rows, keep skeleton/empty elements
      grid.querySelectorAll('.grid-row').forEach(el => el.remove());
      photoBuffer = [];
      allPhotos = [];
    }

    // Prepend buffered photographers to newly fetched ones
    const candidates = [...photoBuffer, ...newPhotos];
    const containerWidth = grid.clientWidth;
    const { rows, leftovers } = buildJustifiedLayout(candidates, containerWidth);

    // Save the new leftovers back to the buffer
    photoBuffer = leftovers;

    const fragment = document.createDocumentFragment();

    rows.forEach((row: any) => {
      const rowEl = document.createElement('div');
      rowEl.className = 'grid-row';
      row.photos.forEach((p: any) => {
        const link = document.createElement('a');
        link.href = `/photographers/${p.photographerUsername}/`;
        link.className = 'photo-card vf-card';
        link.style.cssText = `width:${p.width}px;height:${row.height}px;flex-shrink:0;`;
        link.setAttribute('data-aspect', String(p.aspect));
        link.setAttribute('aria-label', p.title ?? 'Photo by BCC member');

        const img = document.createElement('img');
        img.src = p.imageUrl ?? '';
        img.alt = p.title ?? '';
        img.loading = 'lazy';
        img.decoding = 'async';
        img.className = 'photo-card__img';
        img.style.cssText = 'width:100%;height:100%;object-fit:cover;';
        img.onload = () => img.classList.add('loaded');

        const overlay = document.createElement('div');
        overlay.className = 'photo-overlay';
        overlay.setAttribute('aria-hidden', 'true');

        const br = document.createElement('span');
        br.className = 'vf-br'; br.setAttribute('aria-hidden', 'true');
        const bl = document.createElement('span');
        bl.className = 'vf-bl'; bl.setAttribute('aria-hidden', 'true');

        if (p.title || p.photographer) {
          const info = document.createElement('div');
          info.className = 'photo-card__info';
          info.setAttribute('aria-hidden', 'true');
          if (p.title) { const t = document.createElement('div'); t.className = 'photo-card__title'; t.textContent = p.title; info.appendChild(t); }
          if (p.photographer) { const ph = document.createElement('div'); ph.className = 'photo-card__photographer'; ph.textContent = p.photographer; info.appendChild(ph); }
          link.appendChild(info);
        }

        link.appendChild(img);
        link.appendChild(overlay);
        link.appendChild(br);
        link.appendChild(bl);
        rowEl.appendChild(link);

        // Track rendered photo
        allPhotos.push(p);
      });
      fragment.appendChild(rowEl);
    });

    grid.appendChild(fragment);

    gsap.from(grid.querySelectorAll('.grid-row:not(.was-visible) .photo-card'), {
      opacity: 0, y: 20, duration: 0.5, stagger: { amount: 0.3, from: 'start' }, ease: 'power2.out',
    });
    grid.querySelectorAll('.grid-row').forEach(r => r.classList.add('was-visible'));
  }

  /* ── Fetch ── */
  async function fetchPhotos(reset = true) {
    if (reset) {
      photoBuffer = [];
      allPhotos = [];
    }

    const offset = allPhotos.length + photoBuffer.length;
    const params = new URLSearchParams({
      limit: String(PAGE_SIZE),
      offset: String(offset),
      shuffle: 'false' // Deterministic editorial ordering for Showcase
    });
    if (currentFilter !== 'all') params.set('tag', currentFilter);
    if (currentSort) params.set('sort', currentSort);
    if (currentPhotographer) params.set('photographer', currentPhotographer);

    const skel = document.getElementById('showcase-skeleton');
    const emptyEl = document.getElementById('showcase-empty');
    const loadMore = document.getElementById('load-more-wrap');
    const countEl = document.getElementById('count-number');

    if (reset) {
      skel?.removeAttribute('hidden');
      emptyEl?.setAttribute('hidden', '');
      loadMore?.setAttribute('hidden', '');
      document.querySelectorAll('.grid-row').forEach(r => r.remove());
    }

    try {
      const res = await fetch(`/api/v1/gallery/feed?${params}`);
      if (!res.ok) throw new Error('API error');
      const payload = await res.json();
      const raw: any[] = Array.isArray(payload.photos) ? payload.photos : [];
      const total: number = payload.total ?? raw.length;

      // Normalize gallery feed shape to what renderGrid expects
      const photos = raw.map((p: any) => ({
        id:                   p.uuid,
        title:                p.title ?? '',
        photographer:         p.photographer?.name ?? photographerMap[p.owner_user_id] ?? '',
        photographerUsername: p.photographer?.username ?? '',
        imageUrl:             p.urls?.medium ?? p.urls?.original ?? '',
        aspect:               (p.width_px && p.height_px) ? p.width_px / p.height_px : 1.5,
      }));

      skel?.setAttribute('hidden', '');

      if (photos.length === 0 && allPhotos.length === 0 && photoBuffer.length === 0) {
        emptyEl?.removeAttribute('hidden');
        if (countEl) countEl.textContent = '0';
        return;
      }

      renderGrid(photos, !reset);

      if (countEl) countEl.textContent = total.toLocaleString('en-IN');
      
      // Determine if more photographers are available on the backend
      const hasMore = (allPhotos.length + photoBuffer.length) < total;
      if (hasMore) {
        loadMore?.removeAttribute('hidden');
      } else {
        loadMore?.setAttribute('hidden', '');
      }

    } catch (err) {
      skel?.setAttribute('hidden', '');
      if (allPhotos.length === 0 && photoBuffer.length === 0) emptyEl?.removeAttribute('hidden');
    }
  }

  /* ── Filter chips ── */
  document.querySelectorAll<HTMLButtonElement>('.filter-chip').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-chip').forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');
      currentFilter = btn.dataset.filter ?? 'all';
      fetchPhotos(true);
    });
  });

  /* ── Sort ── */
  document.getElementById('sort-select')?.addEventListener('change', (e) => {
    currentSort = (e.target as HTMLSelectElement).value;
    fetchPhotos(true);
  });

  /* ── Photographer filter ── */
  document.getElementById('photographer-select')?.addEventListener('change', (e) => {
    currentPhotographer = (e.target as HTMLSelectElement).value;
    fetchPhotos(true);
  });

  /* ── Load more ── */
  document.getElementById('load-more-btn')?.addEventListener('click', () => fetchPhotos(false));

  /* ── Clear filter ── */
  document.getElementById('clear-filter-btn')?.addEventListener('click', () => {
    currentFilter = 'all';
    document.querySelectorAll('.filter-chip').forEach(b => {
      b.classList.toggle('active', b.dataset.filter === 'all');
      b.setAttribute('aria-pressed', b.dataset.filter === 'all' ? 'true' : 'false');
    });
    fetchPhotos(true);
  });

  /* ── Photographer map (id -> displayName) ──
     Loaded FIRST so photo cards can show photographer names on first render. */
  const photographerMap: Record<number, string> = {};
  async function loadPhotographers(): Promise<void> {
    try {
      const res = await fetch('/api/v1/photographers?limit=100&hasApprovedPhotos=true');
      if (!res.ok) return;
      const { data } = await res.json();
      const sel = document.getElementById('photographer-select') as HTMLSelectElement | null;
      const grid = document.getElementById('photographers-grid');
      
      if (!Array.isArray(data)) return;

      const fragment = document.createDocumentFragment();

      data.forEach((ph: any) => {
        if (ph.id != null) photographerMap[ph.id] = ph.displayName ?? '';
        
        // Populate select option
        if (sel) {
          const opt = document.createElement('option');
          opt.value = ph.id ?? ph.username;
          opt.textContent = ph.displayName;
          sel.appendChild(opt);
        }

        // Render card in photographer directory grid
        if (grid) {
          const initials = ph.displayName ? ph.displayName.split(' ').map((n: string) => n[0]).join('').slice(0, 2).toUpperCase() : '??';
          const card = document.createElement('a');
          card.href = `/photographers/${ph.username}/`;
          card.className = 'photographer-card';

          const avatarDiv = document.createElement('div');
          avatarDiv.className = 'photographer-avatar';
          if (ph.avatarUrl) {
            const img = document.createElement('img');
            img.src = ph.avatarUrl;
            img.alt = ph.displayName;
            img.loading = 'lazy';
            avatarDiv.appendChild(img);
          } else {
            const span = document.createElement('span');
            span.textContent = initials;
            avatarDiv.appendChild(span);
          }

          const nameDiv = document.createElement('div');
          nameDiv.className = 'photographer-name';
          nameDiv.textContent = ph.displayName;

          const metaDiv = document.createElement('div');
          metaDiv.className = 'photographer-meta';
          metaDiv.textContent = `${ph.photoCount || 0} photos · /photographers/${ph.username}`;

          const bioDiv = document.createElement('div');
          bioDiv.className = 'photographer-bio';
          // Truncate bio to 80 chars max
          const rawBio = ph.bio || '';
          bioDiv.textContent = rawBio.length > 80 ? rawBio.slice(0, 77) + '...' : rawBio;

          card.appendChild(avatarDiv);
          card.appendChild(nameDiv);
          card.appendChild(metaDiv);
          card.appendChild(bioDiv);

          fragment.appendChild(card);
        }
      });

      if (grid) {
        grid.appendChild(fragment);
      }
    } catch { /* silent */ }
  }

  /* ── Initial load: photographers first, then photos ── */
  loadPhotographers().then(() => fetchPhotos(true));

  /* ── Recompute grid on resize ── */
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      if (allPhotos.length > 0) {
        // Redraw full set by concatenating displayed + buffer and passing as new reset render
        const fullSet = [...allPhotos, ...photoBuffer];
        renderGrid(fullSet, false);
      }
    }, 200);
  });

