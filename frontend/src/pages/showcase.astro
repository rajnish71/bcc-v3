---
/**
 * showcase.astro — Showcase Page
 * V6 02 — All approved member photos, justified layout, no per-photographer limit.
 * Design authority: V6 02 Showcase.dc.html
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import JustifiedPhotoGrid from '../components/gallery/JustifiedPhotoGrid.astro';
---

<BaseLayout
  title="Showcase"
  description="Every approved photograph from every BCC member, displayed at its natural proportions. No cropping. No ranking."
>

  <PageHero
    eyebrow="Member Showcase · /showcase"
    title="Our members,<br/>on the wall."
    subtitle="Every approved photograph from every member, displayed at its natural proportions. No cropping. No ranking. Photography as it was taken."
  />

  <!-- Gallery Wall: justified grid in unified container -->
  <div class="container">

    <!-- Justified grid -->
    <div class="gallery-wrap">
      <JustifiedPhotoGrid
        id="showcase"
        ariaLabel="Photo showcase grid"
        onePerPhotographer={true}
        pageSize={20}
      />
    </div>

  </div>

  <!-- Photographer Profiles Section -->
  <section class="photographers-section container" style="margin-top: 120px; padding: 0 var(--s-12) var(--s-16);">
    <div class="photographers-header">
      <div class="photographers-kicker">The Photographers</div>
      <h3 class="photographers-title">
        <a href="/photographers/" class="photographers-title-link">Meet the members behind the wall.</a>
      </h3>
    </div>
    <div class="ph-grid" id="photographers-grid">
      <!-- Populated dynamically by JS -->
    </div>
    <div class="photographers-footer">
      <a href="/photographers/" class="photographers-see-all">
        View all photographers
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 12L12 2M12 2H4.5M12 2V9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

</BaseLayout>


<style>
/* ── Showcase hero ── */
.showcase-hero {
  padding-top: calc(var(--nav-h) + var(--s-12));
  padding-bottom: var(--s-8);
}
.showcase-hero-inner {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-top: 3px solid var(--gold-600);
  overflow: hidden;
}
.showcase-hero-content {
  padding: 64px 72px 56px;
}
.showcase-kicker {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: 600;
  margin-bottom: 18px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.showcase-kicker-line {
  display: block;
  width: 28px;
  height: 1px;
  background: var(--gold-600);
}
.showcase-title {
  font-family: var(--font-display);
  font-size: clamp(40px, 5vw, 64px);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.05;
  color: var(--ink-900);
  margin-bottom: 20px;
}
.showcase-lead {
  font-size: 17px;
  line-height: 1.8;
  color: var(--ink-600);
  max-width: 520px;
  font-weight: 300;
}

@media (max-width: 1024px) {
  .showcase-hero-content { padding: 48px var(--gutter-mob); }
}
@media (max-width: 768px) {
  .showcase-hero-content { padding: 32px var(--gutter-mob); }
}

/* ── Filter strip (inline, not sticky) ── */
.filter-strip {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-bottom: none;
  padding: 18px 32px;
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 0;
}
.filter-label {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--ink-400);
  font-weight: 600;
  flex-shrink: 0;
  margin-right: 8px;
}
.filter-chips {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}
.filter-chip {
  padding: 6px 16px;
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--ink-600);
  background: var(--surface-0);
  border: 1px solid var(--hairline-strong);
  border-radius: 0;
  cursor: pointer;
  transition: background-color 0.2s, color 0.2s, border-color 0.2s;
}
.filter-chip:hover {
  border-color: var(--gold-500);
  color: var(--ink-900);
}
.filter-chip.active {
  background: var(--gold-gradient);
  border-color: var(--gold-600);
  color: #FFFFFF;
}

@media (max-width: 768px) {
  .filter-strip {
    padding: 14px var(--gutter-mob);
    overflow-x: auto;
    flex-wrap: nowrap;
  }
  .filter-chips { flex-wrap: nowrap; }
}

/* ── Gallery wrap (unified border) ── */
.gallery-wrap {
  border: 1px solid var(--hairline);
  border-top: none;
  margin-bottom: var(--s-8);
}

/* ── Photographer Profiles ── */
.photographers-section {
  display: flex;
  flex-direction: column;
}
.photographers-header {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-bottom: none;
  padding: 22px 32px 18px;
}
.photographers-kicker {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: 600;
  margin-bottom: 10px;
}
.photographers-title {
  font-family: var(--font-display);
  font-size: 30px;
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--ink-900);
}
.photographers-title-link {
  color: inherit;
  text-decoration: none;
  transition: color var(--m-fast);
}
.photographers-title-link:hover { color: var(--gold-600); }

/* ph-grid: matches /photographers/ page layout */
.ph-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  border: 1px solid var(--hairline);
  border-top: none;
  padding: 20px;
  background: #F2EFE9;
}

.photographers-footer {
  border: 1px solid var(--hairline);
  border-top: none;
  background: var(--surface-0);
  padding: 16px 32px;
  display: flex;
  justify-content: flex-end;
}
.photographers-see-all {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--gold-600);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: color var(--m-fast);
}
.photographers-see-all:hover { color: var(--ink-900); }

/* ── ph-card (mirrors /photographers/ global styles) ── */
:global(.ph-card) {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  cursor: pointer;
  position: relative;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}
:global(.ph-card:hover) {
  border-color: #C9A961;
  box-shadow: 0 8px 32px rgba(20,18,16,0.09);
}
:global(.ph-card-avatar-wrap) {
  display: flex;
  justify-content: center;
  padding: 24px 24px 12px;
}
:global(.ph-card-avatar) {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Outfit', sans-serif;
  font-size: 22px;
  font-weight: 700;
  color: #FFFFFF;
  flex-shrink: 0;
  letter-spacing: -0.02em;
  overflow: hidden;
}
:global(.ph-card-avatar img) {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
:global(.ph-card-body) {
  text-align: center;
  padding: 0 18px 20px;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
:global(.ph-card-name) {
  font-family: 'Outfit', sans-serif;
  font-size: 17px;
  font-weight: 700;
  color: var(--ink-900);
  margin-bottom: 4px;
  line-height: 1.25;
  word-break: break-word;
  transition: color 0.2s ease;
}
:global(.ph-card:hover .ph-card-name) { color: var(--gold-600); }
:global(.ph-card-username) {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--gold-600);
  margin-bottom: 10px;
}
:global(.ph-card-class-badge) {
  display: inline-flex;
  align-items: center;
  border: 1.5px solid currentColor;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.06em;
  padding: 3px 12px;
  border-radius: 999px;
  white-space: nowrap;
  margin-bottom: 8px;
}
:global(.ph-card-divider) {
  width: 100%;
  height: 1px;
  background: var(--hairline-soft);
  margin: 8px 0;
  flex-shrink: 0;
}
:global(.ph-card-tagline) {
  font-size: 13px;
  line-height: 1.5;
  color: var(--ink-600);
  margin-bottom: 8px;
  text-align: center;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  width: 100%;
}
:global(.ph-card-meta-row) {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 10px;
  min-height: 20px;
}
:global(.ph-card-city) {
  font-size: 12px;
  color: var(--ink-400);
}
:global(.ph-card-photo-count) {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--ink-400);
  margin-top: auto;
}
:global(.ph-card-arrow) {
  position: absolute;
  bottom: 12px;
  right: 12px;
  opacity: 0;
  transition: opacity 0.2s ease;
  color: var(--gold-600);
}
:global(.ph-card:hover .ph-card-arrow) { opacity: 1; }

@media (max-width: 1100px) {
  .ph-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 768px) {
  .ph-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
}
@media (max-width: 480px) {
  .ph-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
}
</style>


<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);



  /* ── Photographer card helpers (mirrors /photographers/ page) ── */
  const CLASS_LABELS: Record<string, string> = {
    founding:   'Founding Member',
    life:       'Life Member',
    patron:     'Patron Member',
    full:       'Full Member',
    individual: 'Individual Member',
    student:    'Student Member',
    basic:      'Basic Member',
  };
  const CLASS_COLORS: Record<string, string> = {
    founding:   '#8A6A2E',
    life:       '#A8843C',
    patron:     '#8A6A2E',
    full:       '#C47A20',
    individual: '#3E5A48',
    student:    '#1A9DAE',
    basic:      '#5C5876',
  };
  const AVATAR_PALETTE = ['#3E5A48','#9A7A30','#1A6A6A','#4A5068','#47514B','#6B4A2A','#3A5868','#5C4A6A','#6A4A3A','#2A5C5C'];

  function avatarBg(username: string): string {
    let h = 0;
    for (let i = 0; i < username.length; i++) h = username.charCodeAt(i) + ((h << 5) - h);
    return AVATAR_PALETTE[Math.abs(h) % AVATAR_PALETTE.length];
  }
  function esc(s: string): string {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  function phInitials(name: string): string {
    return name.trim().split(/\s+/).map((w: string) => w[0] ?? '').join('').slice(0, 2).toUpperCase();
  }
  function shuffle<T>(arr: T[]): T[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  /* ── Photographer map (id -> displayName) ── */
  const photographerMap: Record<number, string> = {};
  async function loadPhotographers(): Promise<void> {
    try {
      const res = await fetch('/api/v1/photographers?limit=200');
      if (!res.ok) return;
      const { data } = await res.json();
      if (!Array.isArray(data)) return;

      // Build id→name map for photo cards
      data.forEach((ph: any) => { if (ph.id != null) photographerMap[ph.id] = ph.displayName ?? ''; });

      const grid = document.getElementById('photographers-grid');
      if (!grid) return;

      // Pick 16 random photographers
      const sample = shuffle(data).slice(0, 16);
      const fragment = document.createDocumentFragment();

      sample.forEach((ph: any) => {
        const inits      = phInitials(ph.displayName ?? '?');
        const bg         = avatarBg(ph.username);
        const classKey   = ph.memberClass ?? 'basic';
        const classLabel = CLASS_LABELS[classKey] ?? classKey;
        const classColor = CLASS_COLORS[classKey] ?? '#8B8378';
        const photoLabel = (ph.photoCount ?? 0).toLocaleString('en-IN') + ' photos';

        const card = document.createElement('a');
        card.href      = `/photographers/${esc(ph.username)}/`;
        card.className = 'ph-card';

        const avatarHtml = ph.avatarUrl
          ? `<img src="${esc(ph.avatarUrl)}" alt="${esc(ph.displayName ?? '')}" loading="lazy" width="80" height="80"/>`
          : esc(inits);

        const taglineHtml = ph.tagline
          ? `<div class="ph-card-tagline">${esc(ph.tagline)}</div>`
          : '';
        const cityHtml = ph.city
          ? `<div class="ph-card-meta-row"><span class="ph-card-city">${esc(ph.city)}</span></div>`
          : '';

        card.innerHTML = `
          <div class="ph-card-avatar-wrap">
            <div class="ph-card-avatar" style="background:${bg};">${avatarHtml}</div>
          </div>
          <div class="ph-card-body">
            <div class="ph-card-name">${esc(ph.displayName ?? '')}</div>
            <div class="ph-card-username">@${esc(ph.username)}</div>
            <span class="ph-card-class-badge" style="color:${classColor};">${esc(classLabel)}</span>
            <div class="ph-card-divider"></div>
            ${taglineHtml}
            ${cityHtml}
            <div class="ph-card-photo-count">${photoLabel}</div>
          </div>
          <svg class="ph-card-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 12L12 2M12 2H4.5M12 2V9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        `;
        fragment.appendChild(card);
      });

      grid.appendChild(fragment);
    } catch { /* silent */ }
  }

  import { loadPageHero } from '../lib/hero-loader';
  loadPageHero('showcase');

  /* ── Initial load ── */
  loadPhotographers();

  /* ── GSAP entrance ── */
  gsap.from('.page-hero', {
    opacity: 0, y: 24, duration: 0.6, ease: 'power3.out', delay: 0.1,
  });
</script>
