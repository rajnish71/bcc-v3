---
/**
 * showcase.astro — Showcase Page
 * V6 02 — All approved member photos, justified layout, no per-photographer limit.
 * Design authority: V6 02 Showcase.dc.html
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Showcase"
  description="Every approved photograph from every BCC member, displayed at its natural proportions. No cropping. No ranking."
>

  <!-- Page hero -->
  <div class="showcase-hero container">
    <div class="showcase-hero-inner">
      <div class="showcase-hero-content">
        <div class="showcase-kicker">
          <span class="showcase-kicker-line"></span>
          Member Showcase · /showcase
        </div>
        <h1 class="showcase-title">Our members,<br/>on the wall.</h1>
        <p class="showcase-lead">Every approved photograph from every member, displayed at its natural proportions. No cropping. No ranking. Photography as it was taken.</p>
      </div>
    </div>
  </div>

  <!-- Gallery Wall: filter strip + justified grid in unified container -->
  <div class="container">

    <!-- Filter strip -->
    <div class="filter-strip" id="filter-strip">
      <span class="filter-label">Filter</span>
      <div class="filter-chips" id="filter-chips" role="group" aria-label="Filter by category">
        <!-- "All" is static; category chips are injected from the GENRE taxonomy (item 71). -->
        <button class="filter-chip active" data-filter="all" aria-pressed="true">All</button>
      </div>
    </div>

    <!-- Justified grid -->
    <div class="gallery-wrap">
      <div class="justified-grid" id="showcase-grid" data-target-height="240" data-gap="8" aria-label="Photo showcase grid">

        <!-- Loading skeleton -->
        <div id="showcase-skeleton" class="skeleton-wrap" aria-busy="true">
          {[
            [1.78, 0.78, 1.5, 0.85, 1.2],
            [2.4, 1.4, 0.8, 1.6],
            [1.0, 1.5, 0.75, 1.3, 0.9],
          ].map((row) => (
            <div class="grid-row">
              {row.map((flex) => (
                <div class="skel-photo" style={`flex:${flex};height:220px;`}></div>
              ))}
            </div>
          ))}
        </div>

      </div>

      <!-- Load more -->
      <div class="load-more-wrap" id="load-more-wrap" hidden>
        <button class="load-more-btn" id="load-more-btn">
          Load More Photographs
        </button>
      </div>

      <!-- Empty state -->
      <div id="showcase-empty" hidden class="gallery-empty">
        <div class="gallery-empty__icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
            <circle cx="24" cy="24" r="22.5" stroke="rgba(20,18,16,0.1)" stroke-width="1.5"/>
            <circle cx="24" cy="24" r="8" stroke="rgba(168,132,60,0.4)" stroke-width="1.5"/>
            <circle cx="24" cy="24" r="2" fill="rgba(168,132,60,0.6)"/>
          </svg>
        </div>
        <p class="gallery-empty__text">No photographs match this filter.</p>
        <button class="btn btn-outline btn-md" id="clear-filter-btn">Clear filter</button>
      </div>
    </div>

  </div>

  <!-- Photographer Profiles Section -->
  <section class="photographers-section container" style="margin-top: 120px; padding: 0 var(--s-12) var(--s-16);">
    <div class="photographers-header">
      <div class="photographers-kicker">The Photographers</div>
      <h3 class="photographers-title">
        <a href="/photographers/" class="photographers-title-link">Meet the members behind the wall.</a>
      </h3>
    </div>
    <div class="ph-grid" id="photographers-grid">
      <!-- Populated dynamically by JS -->
    </div>
    <div class="photographers-footer">
      <a href="/photographers/" class="photographers-see-all">
        View all photographers
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 12L12 2M12 2H4.5M12 2V9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

</BaseLayout>


<style>
/* ── Showcase hero ── */
.showcase-hero {
  padding-top: calc(var(--nav-h) + var(--s-12));
  padding-bottom: var(--s-8);
}
.showcase-hero-inner {
  background: #FFFFFF;
  border: 1px solid var(--hairline);
  border-top: 3px solid var(--gold-600);
  overflow: hidden;
}
.showcase-hero-content {
  padding: 64px 72px 56px;
}
.showcase-kicker {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: 600;
  margin-bottom: 18px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.showcase-kicker-line {
  display: block;
  width: 28px;
  height: 1px;
  background: var(--gold-600);
}
.showcase-title {
  font-family: var(--font-display);
  font-size: clamp(40px, 5vw, 64px);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.05;
  color: var(--ink-900);
  margin-bottom: 20px;
}
.showcase-lead {
  font-size: 17px;
  line-height: 1.8;
  color: var(--ink-600);
  max-width: 520px;
  font-weight: 300;
}

@media (max-width: 1024px) {
  .showcase-hero-content { padding: 48px var(--gutter-mob); }
}
@media (max-width: 768px) {
  .showcase-hero-content { padding: 32px var(--gutter-mob); }
}

/* ── Filter strip (inline, not sticky) ── */
.filter-strip {
  background: #FFFFFF;
  border: 1px solid var(--hairline);
  border-bottom: none;
  padding: 18px 32px;
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 0;
}
.filter-label {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--ink-400);
  font-weight: 600;
  flex-shrink: 0;
  margin-right: 8px;
}
.filter-chips {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}
.filter-chip {
  padding: 6px 16px;
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--ink-600);
  background: #FFFFFF;
  border: 1px solid var(--hairline-strong);
  border-radius: 0;
  cursor: pointer;
  transition: background-color 0.2s, color 0.2s, border-color 0.2s;
}
.filter-chip:hover {
  border-color: var(--gold-500);
  color: var(--ink-900);
}
.filter-chip.active {
  background: linear-gradient(135deg, #C9A961, #A8843C);
  border-color: #A8843C;
  color: #FFFFFF;
}

@media (max-width: 768px) {
  .filter-strip {
    padding: 14px var(--gutter-mob);
    overflow-x: auto;
    flex-wrap: nowrap;
  }
  .filter-chips { flex-wrap: nowrap; }
}

/* ── Gallery wrap (unified border) ── */
.gallery-wrap {
  border: 1px solid var(--hairline);
  border-top: none;
  margin-bottom: var(--s-8);
}

/* ── Justified grid ── */
.justified-grid {
  padding: 8px;
}

/* ── Skeleton ── */
.skeleton-wrap { padding: 0; }
.skel-photo {
  background: var(--surface-2);
  border-radius: 0;
  animation: shimmer 1.6s ease-in-out infinite;
}
@keyframes shimmer { 0%,100% { opacity:.4; } 50% { opacity:.7; } }

/* ── Grid rows (global: applied to runtime-created nodes) ── */
:global(.grid-row) { display: flex; gap: 8px; margin-bottom: 8px; }
:global(.grid-row:last-child) { margin-bottom: 0; }

/* ── Load more ── */
.load-more-wrap {
  display: flex;
  justify-content: center;
  background: #181614;
  border-top: 1px solid #2C2820;
  padding: 12px 24px;
}
.load-more-btn {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #C9A961;
  border: 1px solid rgba(201, 169, 97, 0.4);
  padding: 10px 32px;
  background: transparent;
  cursor: pointer;
  transition: border-color 0.2s;
}
.load-more-btn:hover { border-color: #C9A961; }

/* ── Gallery empty ── */
.gallery-empty {
  text-align: center;
  color: var(--ink-600);
  padding: var(--s-12) 0;
}
.gallery-empty__icon { margin-bottom: var(--s-3); display: flex; justify-content: center; }
.gallery-empty__text { font-size: var(--text-body); color: var(--ink-900); margin-bottom: var(--s-4); }

/* ── Photographer Profiles ── */
.photographers-section {
  display: flex;
  flex-direction: column;
}
.photographers-header {
  background: #FFFFFF;
  border: 1px solid var(--hairline);
  border-bottom: none;
  padding: 22px 32px 18px;
}
.photographers-kicker {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold-600);
  font-weight: 600;
  margin-bottom: 10px;
}
.photographers-title {
  font-family: var(--font-display);
  font-size: 30px;
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--ink-900);
}
.photographers-title-link {
  color: inherit;
  text-decoration: none;
  transition: color var(--m-fast);
}
.photographers-title-link:hover { color: var(--gold-600); }

/* ph-grid: matches /photographers/ page layout */
.ph-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  border: 1px solid var(--hairline);
  border-top: none;
  padding: 20px;
  background: #F2EFE9;
}

.photographers-footer {
  border: 1px solid var(--hairline);
  border-top: none;
  background: #FFFFFF;
  padding: 16px 32px;
  display: flex;
  justify-content: flex-end;
}
.photographers-see-all {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--gold-600);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: color var(--m-fast);
}
.photographers-see-all:hover { color: var(--ink-900); }

/* ── ph-card (mirrors /photographers/ global styles) ── */
:global(.ph-card) {
  background: #FFFFFF;
  border: 1px solid #E7E1D6;
  cursor: pointer;
  position: relative;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}
:global(.ph-card:hover) {
  border-color: #C9A961;
  box-shadow: 0 8px 32px rgba(20,18,16,0.09);
}
:global(.ph-card-avatar-wrap) {
  display: flex;
  justify-content: center;
  padding: 24px 24px 12px;
}
:global(.ph-card-avatar) {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Outfit', sans-serif;
  font-size: 22px;
  font-weight: 700;
  color: #FFFFFF;
  flex-shrink: 0;
  letter-spacing: -0.02em;
  overflow: hidden;
}
:global(.ph-card-avatar img) {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
:global(.ph-card-body) {
  text-align: center;
  padding: 0 18px 20px;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
:global(.ph-card-name) {
  font-family: 'Outfit', sans-serif;
  font-size: 17px;
  font-weight: 700;
  color: #141210;
  margin-bottom: 4px;
  line-height: 1.25;
  word-break: break-word;
  transition: color 0.2s ease;
}
:global(.ph-card:hover .ph-card-name) { color: #A8843C; }
:global(.ph-card-username) {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: #A8843C;
  margin-bottom: 10px;
}
:global(.ph-card-class-badge) {
  display: inline-flex;
  align-items: center;
  border: 1.5px solid currentColor;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.06em;
  padding: 3px 12px;
  border-radius: 999px;
  white-space: nowrap;
  margin-bottom: 8px;
}
:global(.ph-card-divider) {
  width: 100%;
  height: 1px;
  background: #F0EBE0;
  margin: 8px 0;
  flex-shrink: 0;
}
:global(.ph-card-tagline) {
  font-size: 13px;
  line-height: 1.5;
  color: #57514B;
  margin-bottom: 8px;
  text-align: center;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  width: 100%;
}
:global(.ph-card-meta-row) {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 10px;
  min-height: 20px;
}
:global(.ph-card-city) {
  font-size: 12px;
  color: #8B8378;
}
:global(.ph-card-photo-count) {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: #8B8378;
  margin-top: auto;
}
:global(.ph-card-arrow) {
  position: absolute;
  bottom: 12px;
  right: 12px;
  opacity: 0;
  transition: opacity 0.2s ease;
  color: #A8843C;
}
:global(.ph-card:hover .ph-card-arrow) { opacity: 1; }

@media (max-width: 1100px) {
  .ph-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 768px) {
  .ph-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
}
@media (max-width: 480px) {
  .ph-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
}
</style>


<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  /* ── State ── */
  let allPhotos: any[] = [];
  let photoBuffer: any[] = [];
  let currentFilter = 'all';
  const PAGE_SIZE = 24;

  /* ── Justified layout ── */
  function buildJustifiedLayout(
    photos: Array<{ aspect: number; id: string; title: string; photographer: string; photographerUsername: string; imageUrl: string }>,
    containerWidth: number,
    targetHeight = 240,
    gap = 8
  ) {
    const rows: Array<{ height: number; photos: typeof photos }> = [];
    let row: typeof photos = [];
    let rowWidth = 0;

    const flush = () => {
      if (!row.length) return;
      const totalGap = gap * (row.length - 1);
      const scale = (containerWidth - totalGap) / rowWidth;
      const height = targetHeight * scale;
      rows.push({ height, photos: row.map(p => ({ ...p, width: p.aspect * height })) });
      row = [];
      rowWidth = 0;
    };

    for (const photo of photos) {
      const idealW = photo.aspect * targetHeight;
      row.push(photo);
      rowWidth += idealW;
      if (rowWidth + gap * (row.length - 1) >= containerWidth * 0.88) {
        flush();
      }
    }

    return { rows, leftovers: row };
  }

  function renderGrid(newPhotos: any[], append = false) {
    const grid = document.getElementById('showcase-grid')!;
    if (!append) {
      grid.querySelectorAll('.grid-row').forEach(el => el.remove());
      photoBuffer = [];
      allPhotos = [];
    }

    const candidates = [...photoBuffer, ...newPhotos];
    const containerWidth = grid.clientWidth;
    const { rows, leftovers } = buildJustifiedLayout(candidates, containerWidth);
    photoBuffer = leftovers;

    const fragment = document.createDocumentFragment();

    rows.forEach((row: any) => {
      const rowEl = document.createElement('div');
      rowEl.className = 'grid-row';
      row.photos.forEach((p: any) => {
        const link = document.createElement('a');
        link.href = `/photographers/${p.photographerUsername}/`;
        link.className = 'photo-card vf-card';
        link.style.cssText = `width:${p.width}px;height:${row.height}px;flex-shrink:0;`;
        link.setAttribute('data-aspect', String(p.aspect));
        link.setAttribute('aria-label', p.title ?? 'Photo by BCC member');

        const img = document.createElement('img');
        img.src = p.imageUrl ?? '';
        img.alt = p.title ?? '';
        img.loading = 'lazy';
        img.decoding = 'async';
        img.className = 'photo-card__img';
        img.style.cssText = 'width:100%;height:100%;display:block;';
        img.onload = () => img.classList.add('loaded');

        const overlay = document.createElement('div');
        overlay.className = 'photo-overlay';
        overlay.setAttribute('aria-hidden', 'true');

        const br = document.createElement('span');
        br.className = 'vf-br'; br.setAttribute('aria-hidden', 'true');
        const bl = document.createElement('span');
        bl.className = 'vf-bl'; bl.setAttribute('aria-hidden', 'true');

        if (p.title || p.photographer) {
          const info = document.createElement('div');
          info.className = 'photo-card__info';
          info.setAttribute('aria-hidden', 'true');
          if (p.title) { const t = document.createElement('div'); t.className = 'photo-card__title'; t.textContent = p.title; info.appendChild(t); }
          if (p.photographer) { const ph = document.createElement('div'); ph.className = 'photo-card__photographer'; ph.textContent = p.photographer; info.appendChild(ph); }
          link.appendChild(info);
        }

        link.appendChild(img);
        link.appendChild(overlay);
        link.appendChild(br);
        link.appendChild(bl);
        rowEl.appendChild(link);

        allPhotos.push(p);
      });
      fragment.appendChild(rowEl);
    });

    grid.appendChild(fragment);

    gsap.from(grid.querySelectorAll('.grid-row:not(.was-visible) .photo-card'), {
      opacity: 0, y: 20, duration: 0.5, stagger: { amount: 0.3, from: 'start' }, ease: 'power2.out',
    });
    grid.querySelectorAll('.grid-row').forEach(r => r.classList.add('was-visible'));
  }

  /* ── Fetch ── */
  async function fetchPhotos(reset = true) {
    if (reset) {
      photoBuffer = [];
      allPhotos = [];
    }

    const offset = allPhotos.length + photoBuffer.length;
    const params = new URLSearchParams({
      limit: String(PAGE_SIZE),
      offset: String(offset),
      shuffle: 'false',
    });
    if (currentFilter !== 'all') params.set('tag', currentFilter);

    const skel = document.getElementById('showcase-skeleton');
    const emptyEl = document.getElementById('showcase-empty');
    const loadMore = document.getElementById('load-more-wrap');

    if (reset) {
      skel?.removeAttribute('hidden');
      emptyEl?.setAttribute('hidden', '');
      loadMore?.setAttribute('hidden', '');
      document.querySelectorAll('.grid-row').forEach(r => r.remove());
    }

    try {
      const res = await fetch(`/api/v1/gallery/feed?${params}`);
      if (!res.ok) throw new Error('API error');
      const payload = await res.json();
      const raw: any[] = Array.isArray(payload.photos) ? payload.photos : [];
      const total: number = payload.total ?? raw.length;

      const photos = raw.map((p: any) => ({
        id:                   p.uuid,
        title:                p.title ?? '',
        photographer:         p.photographer?.name ?? photographerMap[p.owner_user_id] ?? '',
        photographerUsername: p.photographer?.username ?? '',
        imageUrl:             p.urls?.medium ?? p.urls?.original ?? '',
        aspect:               (p.width_px && p.height_px) ? p.width_px / p.height_px : 1.5,
      }));

      skel?.setAttribute('hidden', '');

      if (photos.length === 0 && allPhotos.length === 0 && photoBuffer.length === 0) {
        emptyEl?.removeAttribute('hidden');
        return;
      }

      renderGrid(photos, !reset);

      const hasMore = (allPhotos.length + photoBuffer.length) < total;
      if (hasMore) {
        loadMore?.removeAttribute('hidden');
      } else {
        loadMore?.setAttribute('hidden', '');
      }

    } catch {
      skel?.setAttribute('hidden', '');
      if (allPhotos.length === 0 && photoBuffer.length === 0) emptyEl?.removeAttribute('hidden');
    }
  }

  /* ── Filter chips — load the GENRE taxonomy, then delegate clicks ── */
  async function loadFilterChips() {
    try {
      const res = await fetch('/api/v1/gallery/tags?category=GENRE');
      if (!res.ok) return;
      const tags = await res.json() as Array<{ tag_key: string; display_name: string }>;
      const chips = document.getElementById('filter-chips');
      if (!chips) return;
      tags
        .sort((a, b) => a.display_name.localeCompare(b.display_name))
        .forEach(t => {
          const btn = document.createElement('button');
          btn.className = 'filter-chip';
          btn.dataset.filter = t.tag_key;
          btn.setAttribute('aria-pressed', 'false');
          btn.textContent = t.display_name;
          chips.appendChild(btn);
        });
    } catch { /* non-critical — "All" still works */ }
  }

  document.getElementById('filter-chips')?.addEventListener('click', e => {
    const btn = (e.target as Element).closest<HTMLButtonElement>('.filter-chip');
    if (!btn) return;
    document.querySelectorAll('.filter-chip').forEach(b => {
      b.classList.remove('active');
      b.setAttribute('aria-pressed', 'false');
    });
    btn.classList.add('active');
    btn.setAttribute('aria-pressed', 'true');
    currentFilter = btn.dataset.filter ?? 'all';
    fetchPhotos(true);
  });

  /* ── Load more ── */
  document.getElementById('load-more-btn')?.addEventListener('click', () => fetchPhotos(false));

  /* ── Clear filter ── */
  document.getElementById('clear-filter-btn')?.addEventListener('click', () => {
    currentFilter = 'all';
    document.querySelectorAll('.filter-chip').forEach(b => {
      b.classList.toggle('active', b.dataset.filter === 'all');
      b.setAttribute('aria-pressed', b.dataset.filter === 'all' ? 'true' : 'false');
    });
    fetchPhotos(true);
  });

  /* ── Photographer card helpers (mirrors /photographers/ page) ── */
  const CLASS_LABELS: Record<string, string> = {
    founding:   'Founding Member',
    life:       'Life Member',
    patron:     'Patron Member',
    full:       'Full Member',
    individual: 'Individual Member',
    student:    'Student Member',
    basic:      'Basic Member',
  };
  const CLASS_COLORS: Record<string, string> = {
    founding:   '#8A6A2E',
    life:       '#A8843C',
    patron:     '#8A6A2E',
    full:       '#C47A20',
    individual: '#3E5A48',
    student:    '#1A9DAE',
    basic:      '#5C5876',
  };
  const AVATAR_PALETTE = ['#3E5A48','#9A7A30','#1A6A6A','#4A5068','#47514B','#6B4A2A','#3A5868','#5C4A6A','#6A4A3A','#2A5C5C'];

  function avatarBg(username: string): string {
    let h = 0;
    for (let i = 0; i < username.length; i++) h = username.charCodeAt(i) + ((h << 5) - h);
    return AVATAR_PALETTE[Math.abs(h) % AVATAR_PALETTE.length];
  }
  function esc(s: string): string {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  function phInitials(name: string): string {
    return name.trim().split(/\s+/).map((w: string) => w[0] ?? '').join('').slice(0, 2).toUpperCase();
  }
  function shuffle<T>(arr: T[]): T[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  /* ── Photographer map (id -> displayName) ── */
  const photographerMap: Record<number, string> = {};
  async function loadPhotographers(): Promise<void> {
    try {
      const res = await fetch('/api/v1/photographers?limit=200');
      if (!res.ok) return;
      const { data } = await res.json();
      if (!Array.isArray(data)) return;

      // Build id→name map for photo cards
      data.forEach((ph: any) => { if (ph.id != null) photographerMap[ph.id] = ph.displayName ?? ''; });

      const grid = document.getElementById('photographers-grid');
      if (!grid) return;

      // Pick 16 random photographers
      const sample = shuffle(data).slice(0, 16);
      const fragment = document.createDocumentFragment();

      sample.forEach((ph: any) => {
        const inits      = phInitials(ph.displayName ?? '?');
        const bg         = avatarBg(ph.username);
        const classKey   = ph.memberClass ?? 'basic';
        const classLabel = CLASS_LABELS[classKey] ?? classKey;
        const classColor = CLASS_COLORS[classKey] ?? '#8B8378';
        const photoLabel = (ph.photoCount ?? 0).toLocaleString('en-IN') + ' photos';

        const card = document.createElement('a');
        card.href      = `/photographers/${esc(ph.username)}/`;
        card.className = 'ph-card';

        const avatarHtml = ph.avatarUrl
          ? `<img src="${esc(ph.avatarUrl)}" alt="${esc(ph.displayName ?? '')}" loading="lazy" width="80" height="80"/>`
          : esc(inits);

        const taglineHtml = ph.tagline
          ? `<div class="ph-card-tagline">${esc(ph.tagline)}</div>`
          : '';
        const cityHtml = ph.city
          ? `<div class="ph-card-meta-row"><span class="ph-card-city">${esc(ph.city)}</span></div>`
          : '';

        card.innerHTML = `
          <div class="ph-card-avatar-wrap">
            <div class="ph-card-avatar" style="background:${bg};">${avatarHtml}</div>
          </div>
          <div class="ph-card-body">
            <div class="ph-card-name">${esc(ph.displayName ?? '')}</div>
            <div class="ph-card-username">@${esc(ph.username)}</div>
            <span class="ph-card-class-badge" style="color:${classColor};">${esc(classLabel)}</span>
            <div class="ph-card-divider"></div>
            ${taglineHtml}
            ${cityHtml}
            <div class="ph-card-photo-count">${photoLabel}</div>
          </div>
          <svg class="ph-card-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 12L12 2M12 2H4.5M12 2V9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        `;
        fragment.appendChild(card);
      });

      grid.appendChild(fragment);
    } catch { /* silent */ }
  }

  /* ── Initial load ── */
  loadFilterChips();
  loadPhotographers().then(() => fetchPhotos(true));

  /* ── Recompute grid on resize ── */
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      if (allPhotos.length > 0) {
        const fullSet = [...allPhotos, ...photoBuffer];
        renderGrid(fullSet, false);
      }
    }, 200);
  });

  /* ── GSAP entrance ── */
  gsap.from('.showcase-hero .showcase-hero-content', {
    opacity: 0, y: 24, duration: 0.6, ease: 'power3.out', delay: 0.1,
  });
</script>
