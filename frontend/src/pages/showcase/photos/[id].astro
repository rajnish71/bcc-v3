</style>

<script define:vars={{ photoId: id }}>
  const API = '/api/v1';
  const CANONICAL = `/showcase/photos/${photoId}`;

  // ── Auth state ──
  function tok() { return localStorage.getItem('bcc_token') ?? ''; }
  function authHeaders() {
    const t = tok();
    return t ? { 'Content-Type': 'application/json', 'Authorization': `Bearer ${t}` } : { 'Content-Type': 'application/json' };
  }
  function isAuthenticated() { return !!tok(); }

  let currentRole = 'guest'; // guest | user | member | admin
  let photoData = null;
  let reactionsData = { likes: 0, favourites: 0, bookmarks: 0, userReactions: { liked: false, favourited: false, bookmarked: false } };
  let commentOffset = 0;
  const COMMENT_LIMIT = 20;
  let totalComments = 0;
  let viewCtx = { label: 'Showcase', crumbs: ['Home', 'Showcase'], position: '', prevLabel: '', nextLabel: '', prevId: null, nextId: null, phLink: '/photographers' };

  // ── Tab logic ──
  function setTab(tab) {
    ['info','exif','tags'].forEach(t => {
      document.getElementById(`tab-${t}`)?.classList.toggle('tab-active', t === tab);
      const pane = document.getElementById(`pane-${t}`);
      if (pane) pane.style.display = t === tab ? 'block' : 'none';
    });
  }
  window.setTab = setTab;

  // ── Viewing Context from URL ──
  function resolveViewingContext() {
    const params = new URLSearchParams(window.location.search);
    const ctx    = params.get('ctx') || 'showcase';
    const ctxId  = params.get('ctxId') || '';
    const pos    = parseInt(params.get('pos') || '0', 10);
    const total  = parseInt(params.get('total') || '0', 10);
    const prevId = params.get('prevId') || null;
    const nextId = params.get('nextId') || null;

    const MAP = {
      showcase:   { label: 'Showcase',    crumbs: ['Home', 'Showcase'],                                                      prevLabel: '← Previous Photo',       nextLabel: 'Next Photo →'         },
      portfolio:  { label: 'Portfolio',   crumbs: ['Home', 'Photographers', ctxId],                                          prevLabel: '← Previous in Portfolio', nextLabel: 'Next in Portfolio →'  },
      story:      { label: 'Story',       crumbs: ['Home', 'Stories', ctxId],                                                prevLabel: '← Previous in Story',     nextLabel: 'Next in Story →'      },
      collection: { label: 'Collection',  crumbs: ['Home', 'Collections', ctxId],                                            prevLabel: '← Previous',              nextLabel: 'Next →'               },
      activity:   { label: 'Activity',    crumbs: ['Home', 'Activities', ctxId],                                             prevLabel: '← Previous Photo',        nextLabel: 'Next Photo →'         },
      contest:    { label: 'Contest',     crumbs: ['Home', 'Contests', ctxId],                                               prevLabel: '← Previous Entry',        nextLabel: 'Next Entry →'         },
    };

    const def = MAP[ctx] || MAP.showcase;
    viewCtx = {
      label:     def.label,
      crumbs:    def.crumbs,
      position:  total > 0 ? `Photo ${pos} of ${total}` : '',
      prevLabel: def.prevLabel,
      nextLabel: def.nextLabel,
      prevId,
      nextId,
      phLink:    ctx === 'portfolio' ? `/photographers/${ctxId}` : '/photographers',
    };
  }

  function renderViewingContext() {
    const crumbsEl = document.getElementById('vc-crumbs');
    if (crumbsEl) {
      let html = '';
      viewCtx.crumbs.forEach(c => {
        html += `<span class="crumb">${c}</span><span class="crumb-sep">›</span>`;
      });
      html += `<span class="crumb crumb-current" id="vc-photo-title">${photoData?.title || 'Photograph'}</span>`;
      crumbsEl.innerHTML = html;
    }

    const posEl = document.getElementById('vc-position');
    if (posEl) posEl.textContent = viewCtx.position;

    const prevBtn = document.getElementById('nav-prev');
    const nextBtn = document.getElementById('nav-next');
    const prevLabel = document.getElementById('prev-label');
    const nextLabel = document.getElementById('next-label');

    if (viewCtx.prevId && prevBtn) {
      prevBtn.style.display = 'flex';
      if (prevLabel) prevLabel.textContent = viewCtx.prevLabel;
      prevBtn.onclick = () => navigateToPhoto(viewCtx.prevId);
    }
    if (viewCtx.nextId && nextBtn) {
      nextBtn.style.display = 'flex';
      if (nextLabel) nextLabel.textContent = viewCtx.nextLabel;
      nextBtn.onclick = () => navigateToPhoto(viewCtx.nextId);
    }

    const posBar = document.getElementById('photo-pos-bar');
    if (posBar && viewCtx.position) {
      posBar.textContent = `${viewCtx.position} · ${viewCtx.label}`;
    }
  }

  function navigateToPhoto(targetId) {
    const params = new URLSearchParams(window.location.search);
    window.location.href = `/showcase/photos/${targetId}?${params.toString()}`;
  }

  // ── Load photo data ──
  async function loadPhoto() {
    try {
      const t = tok();
      const headers = t ? { 'Authorization': `Bearer ${t}` } : {};
      const res = await fetch(`${API}/gallery/photos/${photoId}`, { headers });
      if (!res.ok) {
        showPhotoError();
        return;
      }
      photoData = await res.json();
      renderPhoto();
    } catch {
      showPhotoError();
    }
  }

  function renderPhoto() {
    if (!photoData) return;

    // Title
    const titleMain = document.getElementById('photo-title-main');
    if (titleMain) titleMain.textContent = photoData.title || 'Untitled';

    // Photo image
    const imgUrl = photoData.urls?.original || photoData.urls?.medium || '';
    if (imgUrl) {
      const img = document.getElementById('photo-img');
      const skeleton = document.getElementById('photo-skeleton');
      if (img && skeleton) {
        img.onload = () => {
          skeleton.style.display = 'none';
          img.style.display = 'block';
          const captionEl = document.getElementById('photo-caption');
          if (captionEl) captionEl.style.display = 'block';
        };
        img.src = imgUrl;
        img.alt = photoData.title || 'Photograph';
      }
    }

    // Caption overlay
    const captionTitle = document.getElementById('caption-title');
    const captionMeta  = document.getElementById('caption-meta');
    if (captionTitle) captionTitle.textContent = photoData.title || '';
    if (captionMeta) {
      const parts = [];
      if (photoData.photographer?.name) parts.push(photoData.photographer.name);
      if (photoData.exif?.taken_at) {
        parts.push(new Date(photoData.exif.taken_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }));
      }
      captionMeta.innerHTML = parts.map((p, i) => i > 0 ? `<span style="margin:0 4px;opacity:0.4;">·</span>${p}` : p).join('');
    }

    // Photographer row
    const phName = photoData.photographer?.name || 'BCC Member';
    const phUser = photoData.photographer?.username || '';
    const initials = phName.split(' ').map(n => n[0]).slice(0, 2).join('').toUpperCase();

    const avatarEl = document.getElementById('ph-avatar');
    if (avatarEl) avatarEl.textContent = initials;

    const nameEl = document.getElementById('ph-name');
    if (nameEl) nameEl.textContent = phName;

    const linkEl = document.getElementById('ph-link');
    if (linkEl) {
      linkEl.textContent = phUser ? `/photographers/${phUser}` : '/photographers';
      linkEl.href = phUser ? `/photographers/${phUser}` : '/photographers';
    }

    const relPhLink = document.getElementById('related-ph-link');
    if (relPhLink && phUser) {
      relPhLink.href = `/photographers/${phUser}`;
    }
    const relPhTitle = document.getElementById('related-ph-title');
    if (relPhTitle) relPhTitle.textContent = `More from ${phName}`;

    // Caption text (info tab)
    const captionText = document.getElementById('caption-text');
    if (captionText) captionText.textContent = photoData.caption || 'No description provided.';

    // EXIF table
    renderExif(photoData.exif);

    // Tags
    renderTags();

    // Stats
    const uploadedEl = document.getElementById('stat-uploaded');
    if (uploadedEl && photoData.confirmed_at) {
      uploadedEl.textContent = new Date(photoData.confirmed_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
    }

    // Download button role-based
    updateDownloadButton();

    // Viewing context photo title
    renderViewingContext();
  }

  function showPhotoError() {
    const skeleton = document.getElementById('photo-skeleton');
    if (skeleton) skeleton.querySelector('.skeleton-label').textContent = 'Photograph not found or access restricted.';
  }

  function renderExif(exif) {
    if (!exif) return;
    const table = document.getElementById('exif-table');
    if (!table) return;

    const rows = [
      ['Camera Make',   exif.camera_make],
      ['Camera Model',  exif.camera_model],
      ['Lens',          exif.lens_model],
      ['Focal Length',  exif.focal_length ? `${exif.focal_length}mm` : null],
      ['Aperture',      exif.aperture ? `f/${exif.aperture}` : null],
      ['Shutter Speed', exif.shutter_speed],
      ['ISO',           exif.iso],
      ['Taken At',      exif.taken_at ? new Date(exif.taken_at).toLocaleString('en-IN') : null],
      ['GPS',           exif.gps_lat ? `${exif.gps_lat.toFixed(4)}° N, ${exif.gps_lng?.toFixed(4)}° E` : null],
    ].filter(([, v]) => v != null);

    if (!rows.length) {
      table.innerHTML = '<div class="exif-loading">No EXIF data available.</div>';
      return;
    }
    table.innerHTML = rows.map(([k, v]) =>
      `<div class="exif-row"><span class="exif-key">${k}</span><span class="exif-val">${v}</span></div>`
    ).join('');
  }

  function renderTags() {
    const cloud = document.getElementById('tags-cloud');
    if (!cloud) return;
    if (photoData?.genre) {
      cloud.innerHTML = `<span class="tag-item">${photoData.genre}</span>`;
    } else {
      cloud.innerHTML = '<span class="tag-item" style="color:var(--ink-light);font-style:italic;">No tags assigned.</span>';
    }

    const geoSection = document.getElementById('geo-section');
    const geoCoords  = document.getElementById('geo-coords');
    if (geoSection && geoCoords && photoData?.exif?.gps_lat) {
      geoSection.style.display = 'block';
      geoCoords.textContent = `${photoData.exif.gps_lat.toFixed(4)}° N, ${photoData.exif.gps_lng?.toFixed(4)}° E`;
    }
  }

  // ── Role + auth UI ──
  async function resolveRole() {
    if (!isAuthenticated()) {
      currentRole = 'guest';
      return;
    }
    // Default to 'user'; check for admin or member
    currentRole = 'user';
    try {
      const res = await fetch(`${API}/membership/hub/status`, { headers: { 'Authorization': `Bearer ${tok()}` } });
      if (res.ok) {
        const data = await res.json();
        if (data.lifecycle_state === 'ACTIVE') currentRole = 'member';
      }
    } catch { /* keep 'user' */ }
    // Admin check — attempt admin endpoint
    try {
      const res = await fetch(`${API}/membership/admin/pending?limit=1`, { headers: { 'Authorization': `Bearer ${tok()}` } });
      if (res.ok) currentRole = 'admin';
    } catch { /* not admin */ }
  }

  function applyRoleUI() {
    const guestPrompt     = document.getElementById('guest-prompt');
    const guestComment    = document.getElementById('guest-comment-prompt');
    const commentInput    = document.getElementById('comment-input-row');
    const adminPanel      = document.getElementById('admin-panel');
    const dlBtn           = document.getElementById('download-btn');
    const reactionBtns    = document.querySelectorAll('.reaction-btn');

    if (currentRole === 'guest') {
      if (guestPrompt)  guestPrompt.style.display  = 'flex';
      if (guestComment) guestComment.style.display = 'flex';
      if (commentInput) commentInput.style.display  = 'none';
      reactionBtns.forEach(b => b.setAttribute('disabled', 'true'));
    } else {
      if (guestPrompt)  guestPrompt.style.display  = 'none';
      if (guestComment) guestComment.style.display = 'none';
      if (commentInput) {
        commentInput.style.display = 'flex';
        // Set avatar initials from stored user
        try {
          const user = JSON.parse(localStorage.getItem('bcc_user') || '{}');
          const avatar = document.getElementById('comment-avatar-me');
          if (avatar) avatar.textContent = user.initials || '?';
        } catch {}
      }
    }
    if (currentRole === 'admin') {
      if (adminPanel) adminPanel.style.display = 'flex';
    }
  }

  function updateDownloadButton() {
    const btn     = document.getElementById('download-btn');
    const label   = document.getElementById('dl-label');
    const note    = document.getElementById('dl-note');
    const imgUrl  = photoData?.urls?.original || '';
    const prevUrl = photoData?.urls?.medium   || imgUrl;

    if (!btn || !label || !note) return;

    if (currentRole === 'member' || currentRole === 'admin') {
      btn.href = imgUrl;
      btn.classList.remove('preview');
      label.textContent = 'Download Original';
      note.textContent  = 'Full resolution · Members only';
    } else if (currentRole === 'user') {
      btn.href = prevUrl;
      btn.classList.add('preview');
      label.textContent = 'Preview Download';
      note.textContent  = 'Membership required for full resolution';
    } else {
      btn.href = '#';
      btn.classList.add('preview');
      btn.setAttribute('download', '');
      label.textContent = 'Sign in to Download';
      note.textContent  = '';
      btn.onclick = (e) => { e.preventDefault(); window.location.href = '/auth/signin'; };
    }
  }

  // ── Reactions ──
  async function loadReactions() {
    try {
      const headers = tok() ? { 'Authorization': `Bearer ${tok()}` } : {};
      const res = await fetch(`${API}/gallery/photos/${photoId}/reactions`, { headers });
      if (!res.ok) return;
      reactionsData = await res.json();
      renderReactions();
    } catch {}
  }

  function renderReactions() {
    const countLike = document.getElementById('count-like');
    const countFav  = document.getElementById('count-fav');
    const countBm   = document.getElementById('count-bm');
    const btnLike   = document.getElementById('btn-like');
    const btnFav    = document.getElementById('btn-fav');
    const btnBm     = document.getElementById('btn-bm');

    if (countLike) countLike.textContent = String(reactionsData.likes);
    if (countFav)  countFav.textContent  = String(reactionsData.favourites);
    if (countBm)   countBm.textContent   = String(reactionsData.bookmarks);

    if (reactionsData.userReactions.liked)      btnLike?.classList.add('active');    else btnLike?.classList.remove('active');
    if (reactionsData.userReactions.favourited) btnFav?.classList.add('active');     else btnFav?.classList.remove('active');
    if (reactionsData.userReactions.bookmarked) btnBm?.classList.add('active');      else btnBm?.classList.remove('active');
  }

  async function toggleReaction(type) {
    if (!isAuthenticated()) {
      window.location.href = '/auth/signin';
      return;
    }
    try {
      const res = await fetch(`${API}/gallery/photos/${photoId}/reactions`, {
        method: 'POST',
        headers: authHeaders(),
        body: JSON.stringify({ type }),
      });
      if (!res.ok) return;
      const data = await res.json();
      // Optimistic update
      if (type === 'LIKE')      { reactionsData.likes      = data.count; reactionsData.userReactions.liked      = data.active; }
      if (type === 'FAVOURITE') { reactionsData.favourites = data.count; reactionsData.userReactions.favourited = data.active; }
      if (type === 'BOOKMARK')  { reactionsData.bookmarks  = data.count; reactionsData.userReactions.bookmarked = data.active; }
      renderReactions();
    } catch {}
  }
  window.toggleReaction = toggleReaction;

  // ── Comments ──
  async function loadComments(reset = false) {
    if (reset) { commentOffset = 0; document.getElementById('comment-list').innerHTML = '<div class="comments-loading">Loading comments…</div>'; }
    try {
      const res = await fetch(`${API}/gallery/photos/${photoId}/comments?limit=${COMMENT_LIMIT}&offset=${commentOffset}`);
      if (!res.ok) return;
      const data = await res.json();
      totalComments = data.total;
      renderComments(data.comments, reset);
      document.getElementById('comment-count').textContent = String(totalComments);
      commentOffset += data.comments.length;
      const moreBtn = document.getElementById('comments-load-more');
      if (moreBtn) moreBtn.style.display = commentOffset < totalComments ? 'block' : 'none';
    } catch {}
  }

  function renderComments(comments, reset) {
    const list = document.getElementById('comment-list');
    if (!list) return;
    if (reset) list.innerHTML = '';

    if (!comments.length && reset) {
      list.innerHTML = '<div class="comments-loading" style="font-style:italic;">No comments yet. Be the first to comment.</div>';
      return;
    }

    comments.forEach(c => {
      const initials = (c.author_name || 'M').split(' ').map(n => n[0]).slice(0, 2).join('').toUpperCase();
      const timeStr  = c.created_at ? new Date(c.created_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) : '';
      const item = document.createElement('div');
      item.className = 'comment-item';
      item.innerHTML = `
        <div class="comment-avatar-item">${initials}</div>
        <div class="comment-body">
          <div class="comment-meta">
            <span class="comment-author">${c.author_name || 'BCC Member'}</span>
            <span class="comment-time">${timeStr}</span>
          </div>
          <p class="comment-text">${escapeHtml(c.body)}</p>
          <div class="comment-actions">
            <button class="comment-action">Reply</button>
            <button class="comment-action">Like</button>
          </div>
        </div>`;
      list.appendChild(item);
    });
  }

  async function postComment() {
    const ta = document.getElementById('comment-body');
    if (!ta || !ta.value.trim()) return;
    const body = ta.value.trim();
    try {
      const res = await fetch(`${API}/gallery/photos/${photoId}/comments`, {
        method: 'POST',
        headers: authHeaders(),
        body: JSON.stringify({ body }),
      });
      if (!res.ok) { alert('Failed to post comment. Please try again.'); return; }
      ta.value = '';
      await loadComments(true);
    } catch {}
  }
  window.postComment = postComment;

  function loadMoreComments() { loadComments(false); }
  window.loadMoreComments = loadMoreComments;

  // ── Containers ──
  async function loadContainers() {
    try {
      const res = await fetch(`${API}/gallery/photos/${photoId}/containers`);
      const containers = res.ok ? await res.json() : [];
      const el = document.getElementById('containers-list');
      if (!el) return;
      if (!containers.length) {
        el.innerHTML = '<span class="container-empty">Not added to any collection yet.</span>';
        return;
      }
      el.innerHTML = containers.map(c => `
        <div class="container-item">
          <div class="container-item-info">
            <div class="container-item-title">${c.title}</div>
            <div class="container-item-url">${c.url}</div>
          </div>
          <span class="container-type-badge">${c.type}</span>
        </div>`).join('');
    } catch {}
  }

  // ── Related photos ──
  async function loadRelated() {
    try {
      const res = await fetch(`${API}/gallery/photos/${photoId}/related/photographer?limit=6`);
      const photos = res.ok ? await res.json() : [];
      const grid = document.getElementById('related-ph-grid');
      if (!grid) return;
      if (!photos.length) {
        grid.innerHTML = '<div class="related-loading" style="color:rgba(255,255,255,0.12);font-style:italic;">No other photos from this photographer yet.</div>';
        return;
      }
      grid.innerHTML = photos.map(p => {
        const url  = p.urls?.medium || p.urls?.original || '';
        const href = `/showcase/photos/${p.uuid}`;
        return `
          <div class="related-photo-item" onclick="window.location.href='${href}'">
            ${url ? `<img src="${url}" alt="${p.title || ''}" loading="lazy" />` : ''}
            <div class="related-photo-label">${p.title || ''}</div>
          </div>`;
      }).join('');
    } catch {}
  }

  // ── Actions ──
  function sharePhoto() {
    const url = window.location.origin + CANONICAL;
    if (navigator.share) {
      navigator.share({ title: photoData?.title || 'BCC Photo', url });
    } else if (navigator.clipboard) {
      navigator.clipboard.writeText(url).then(() => alert('Link copied to clipboard.'));
    }
  }
  window.sharePhoto = sharePhoto;

  function copyCanonical() {
    const url = window.location.origin + CANONICAL;
    if (navigator.clipboard) {
      navigator.clipboard.writeText(url).then(() => {
        const btn = document.querySelector('.btn-copy');
        if (btn) { btn.textContent = 'Copied!'; setTimeout(() => { btn.textContent = 'Copy Link'; }, 1500); }
      });
    }
  }
  window.copyCanonical = copyCanonical;

  function reportPhoto() {
    alert('Thank you. Your report has been received and will be reviewed by our moderation team.');
  }
  window.reportPhoto = reportPhoto;

  function adminHide()   { if (confirm('Hide this photo from public view?')) alert('Photo hidden (stub — backend action required).'); }
  function adminFlag()   { alert('Photo flagged for review (stub).'); }
  function adminDelete() { if (confirm('Permanently delete this photo? This cannot be undone.')) alert('Photo deletion (stub — backend action required).'); }
  window.adminHide   = adminHide;
  window.adminFlag   = adminFlag;
  window.adminDelete = adminDelete;

  function escapeHtml(str) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ── Boot ──
  async function boot() {
    resolveViewingContext();
    await Promise.all([resolveRole(), loadPhoto()]);
    applyRoleUI();
    updateDownloadButton();
    await Promise.all([loadReactions(), loadComments(true), loadContainers(), loadRelated()]);
  }

  boot();
</script>
