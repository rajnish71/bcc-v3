---
/**
 * showcase/photos/[id].astro
 * Route: /showcase/photos/{id}
 *
 * V6 21 Canonical Photo Page — governed by PHOTO-ARCH-001 v1.0.
 * Every photograph resolves to this page via its permanent Canonical URL.
 * Viewing Context (breadcrumbs/nav) is transient and URL-param-driven.
 * Photo identity, EXIF, reactions, comments, and Canonical URL are invariant.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { BUILD_API_URL } from '../../../lib/api';

export async function getStaticPaths() {
  let photos: any[] = [];
  try {
    const res = await fetch(`${BUILD_API_URL}/gallery/photos/all-ids`);
    if (res.ok) photos = await res.json();
  } catch { /* silent */ }

  const paths = photos.map((p: any) => ({ params: { id: String(p.id) } }));
  // Always include the placeholder shell so Nginx try_files has a valid fallback
  // for photos uploaded after the last build.
  paths.push({ params: { id: 'placeholder' } });
  return paths;
}

const { id } = Astro.params;
---

<BaseLayout
  title="Canonical Photo — Bhopal Camera Club"
  description="Photograph detail page — Bhopal Camera Club Showcase"
>
  <!-- ══ VIEWING CONTEXT BAR ══ -->
  <div class="vcbar" id="vc-bar">
    <div class="vcbar-inner">
      <div class="vcbar-crumbs" id="vc-crumbs">
        <span class="crumb">Home</span>
        <span class="crumb-sep">›</span>
        <span class="crumb">Showcase</span>
        <span class="crumb-sep">›</span>
        <span class="crumb crumb-current" id="vc-photo-title">Loading…</span>
      </div>
    </div>
  </div>

  <!-- ══ PHOTO HERO ══ -->
  <div class="photo-zone" id="photo-zone">
    <div class="photo-zone-inner">
      <!-- Photo container — natural aspect ratio, no crop -->
      <div class="photo-box" id="photo-box">
        <div class="photo-skeleton" id="photo-skeleton">
          <div class="skeleton-label">Loading photograph…</div>
        </div>
        <img
          id="photo-img"
          src=""
          alt=""
          class="photo-img"
          style="display:none;"
        />
      </div>

      <!-- Nav arrows after photo-box so they render above it -->
      <button class="nav-arrow nav-prev" id="nav-prev" aria-label="Previous photo" style="display:none;">
        <span class="arrow-icon">←</span>
        <span class="arrow-label" id="prev-label"></span>
      </button>
      <button class="nav-arrow nav-next" id="nav-next" aria-label="Next photo" style="display:none;">
        <span class="arrow-icon">→</span>
        <span class="arrow-label" id="next-label"></span>
      </button>
    </div>

    <!-- Caption below the image, aligned to image width -->
    <div class="caption-area" id="caption-area" style="display:none;">
      <div class="caption-area-inner" id="caption-area-inner">
        <div class="caption-title" id="caption-title"></div>
        <div class="caption-meta" id="caption-meta"></div>
      </div>
    </div>

    <!-- Position bar (Entry Context Line) -->
    <div class="photo-pos-bar" id="photo-pos-bar"></div>
  </div>

  <!-- ══ CONTENT AREA: META + INTERACTION ══ -->
  <div class="content-area">

    <!-- LEFT — Photo Meta Panel (65%) -->
    <div class="meta-panel">

      <!-- Title -->
      <h1 class="photo-title" id="photo-title-main">Loading…</h1>

      <!-- Photographer row -->
      <div class="photographer-row" id="photographer-row">
        <div class="photographer-avatar" id="ph-avatar">—</div>
        <div class="photographer-info">
          <div class="photographer-name" id="ph-name">—</div>
          <a class="photographer-link" id="ph-link" href="#">—</a>
        </div>
        <div class="photographer-meta" id="ph-meta"></div>
      </div>

      <!-- Tabs -->
      <div class="tabs-row">
        <button class="tab tab-active" id="tab-info"  onclick="setTab('info')">Info</button>
        <button class="tab"            id="tab-exif"  onclick="setTab('exif')">EXIF</button>
        <button class="tab"            id="tab-tags"  onclick="setTab('tags')">Tags</button>
      </div>

      <!-- INFO tab -->
      <div class="tab-pane" id="pane-info">
        <p class="photo-caption-text" id="caption-text">Loading description…</p>
        <div class="containers-section">
          <div class="section-label">Appears In</div>
          <p class="containers-note">This photograph is featured in the following collections and activities.</p>
          <div class="containers-list" id="containers-list">
            <div class="container-loading">Loading…</div>
          </div>
        </div>
      </div>

      <!-- EXIF tab -->
      <div class="tab-pane" id="pane-exif" style="display:none;">
        <div class="section-label">EXIF Data</div>
        <div class="exif-table" id="exif-table">
          <div class="exif-loading">Loading EXIF…</div>
        </div>
      </div>

      <!-- TAGS tab -->
      <div class="tab-pane" id="pane-tags" style="display:none;">
        <div class="section-label">Tags &amp; Keywords</div>
        <div class="tags-cloud" id="tags-cloud">
          <span class="tag-item">Loading…</span>
        </div>
        <div class="geo-section" id="geo-section" style="display:none;">
          <div class="section-label" style="margin-top:20px;">Geolocation</div>
          <div class="geo-coords" id="geo-coords"></div>
        </div>
      </div>
    </div>

    <!-- RIGHT — Interaction Panel (35%, sticky) -->
    <aside class="interaction-panel" id="interaction-panel">

      <!-- Reaction buttons -->
      <div class="reaction-row">
        <button class="reaction-btn" id="btn-like" onclick="toggleReaction('LIKE')" title="Like this photo">
          <span class="reaction-icon">👍</span>
          <span class="reaction-count" id="count-like">0</span>
          <span class="reaction-label">Like</span>
        </button>
        <button class="reaction-btn" id="btn-fav" onclick="toggleReaction('FAVOURITE')" title="Add to favourites">
          <span class="reaction-icon">❤️</span>
          <span class="reaction-count" id="count-fav">0</span>
          <span class="reaction-label">Favourite</span>
        </button>
        <div class="reaction-btn reaction-views" id="views-display" title="Total views">
          <span class="reaction-icon">👁</span>
          <span class="reaction-count" id="count-views">—</span>
          <span class="reaction-label">Views</span>
        </div>
      </div>

      <!-- Guest sign-in prompt -->
      <div class="guest-prompt" id="guest-prompt" style="display:none;">
        <p>Sign in to interact with this photograph</p>
        <a href="/auth/signin" class="btn-signin">Sign In</a>
      </div>

      <!-- Action buttons -->
      <div class="action-btns">
        <a id="download-btn" href="#" class="btn-download" download>
          <span id="dl-label">Download</span>
          <span id="dl-note" class="btn-note"></span>
        </a>
        <button class="btn-share" onclick="sharePhoto()">Share Photo</button>
        <div class="report-link"><span onclick="reportPhoto()" class="report-text">Report this photo</span></div>
      </div>

      <!-- Admin moderation (admin only) -->
      <div class="admin-panel" id="admin-panel" style="display:none;">
        <div class="admin-panel-label">Moderation — Admin Only</div>
        <button class="btn-admin-action" onclick="adminHide()">Hide Photo (remove from public)</button>
        <button class="btn-admin-action" onclick="adminFlag()">Flag for Review</button>
        <button class="btn-admin-delete" onclick="adminDelete()">Delete Photo (irreversible)</button>
      </div>

      <!-- Photo stats -->
      <div class="stats-panel">
        <div class="stats-label">Photo Details</div>
        <div class="stat-row"><span class="stat-key">Downloads</span><span class="stat-val" id="stat-downloads">—</span></div>
        <div class="stat-row"><span class="stat-key">Uploaded</span><span class="stat-val" id="stat-uploaded">—</span></div>
      </div>
    </aside>
  </div>

  <!-- ══ COMMENTS ══ -->
  <div class="comments-section" id="comments-section">
    <div class="comments-header">
      <h3 class="comments-heading"><span id="comment-count">0</span> Comments</h3>
    </div>

    <!-- Authenticated comment input -->
    <div class="comment-input-row" id="comment-input-row" style="display:none;">
      <div class="comment-avatar-sm" id="comment-avatar-me"></div>
      <div class="comment-input-area">
        <textarea id="comment-body" class="comment-textarea" placeholder="Write a comment…" rows="3"></textarea>
        <div class="comment-input-actions">
          <button class="btn-post-comment" onclick="postComment()">Post Comment</button>
        </div>
      </div>
    </div>

    <!-- Guest comment prompt -->
    <div class="guest-comment-prompt" id="guest-comment-prompt">
      <span>Sign in to join the conversation.</span>
      <a href="/auth/signin" class="btn-signin-sm">Sign In</a>
    </div>

    <!-- Comment list -->
    <div class="comment-list" id="comment-list">
      <div class="comments-loading">Loading comments…</div>
    </div>
    <div class="comments-load-more" id="comments-load-more" style="display:none;">
      <button onclick="loadMoreComments()" class="btn-load-more">Load More Comments</button>
    </div>
  </div>

  <!-- ══ RELATED CONTENT ══ -->
  <div class="related-section">
    <div class="related-block" id="related-photographer-block">
      <div class="related-block-header">
        <h4 class="related-block-title" id="related-ph-title">More from this Photographer</h4>
        <a class="related-block-link" id="related-ph-link" href="#">View Portfolio →</a>
      </div>
      <div class="related-grid" id="related-ph-grid">
        <div class="related-loading">Loading…</div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
/* ── CSS Variables (mapping to design tokens) ── */
:root {
  --ink-dark:    #141210;
  --ink-mid:     #57514B;
  --ink-light:   #8B8378;
  --gold:        #C9A961;
  --gold-dark:   #A8843C;
  --warm-bg:     #F2EFE9;
  --warm-card:   #FAF8F4;
  --warm-rule:   #E7E1D6;
  --dark-zone:   #0A0908;
  --radius:      2px;
}

/* ── Viewing Context Bar ── */
.vcbar {
  background: #fff;
  border-bottom: 1px solid var(--warm-rule);
  padding: 0 32px;
  /* Offset the fixed site header (96px) so the breadcrumb isn't hidden behind it */
  margin-top: var(--nav-h, 96px);
}
.vcbar-inner {
  max-width: 1360px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  height: 52px;
}
.vcbar-crumbs {
  display: flex;
  align-items: center;
  gap: 0;
  font-size: 12px;
  min-width: 0;
  flex: 1;
  overflow: hidden;
}
:global(.crumb) {
  color: var(--ink-light);
  white-space: nowrap;
}
:global(.crumb-current) {
  color: var(--ink-dark);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
}
:global(.crumb-sep) {
  color: #D8D2C6;
  padding: 0 8px;
  font-size: 10px;
  flex-shrink: 0;
}

/* ── Photo Zone ── */
.photo-zone {
  background: var(--dark-zone);
  width: 100%;
}
.photo-zone-inner {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 48px 80px;
  min-height: 280px;
}
.photo-box {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  max-height: 70vh;
  width: 100%;
}
.photo-skeleton {
  width: 100%;
  min-height: 300px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.05);
}
.skeleton-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  color: rgba(255,255,255,0.2);
  letter-spacing: 0.12em;
}
.photo-img {
  max-width: 100%;
  max-height: 70vh;
  width: auto;
  height: auto;
  display: block;
  object-fit: contain;
}

/* Nav arrows — placed after photo-box in DOM, so they stack above it */
.nav-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  z-index: 10;
  background: none;
  border: none;
  cursor: pointer;
}
.nav-prev { left: 16px; }
.nav-next { right: 16px; }
.arrow-icon {
  width: 44px;
  height: 44px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.15);
  color: #fff;
  font-size: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(6px);
}
.arrow-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 8px;
  color: rgba(255,255,255,0.3);
  text-align: center;
  max-width: 72px;
  line-height: 1.4;
}

/* Caption below the photograph */
.caption-area {
  padding: 20px 80px 0;
}
.caption-area-inner {
  margin: 0 auto;
  /* width set dynamically via JS to match rendered image width */
}
.caption-title {
  font-family: 'Outfit', sans-serif;
  font-size: 16px;
  font-weight: 600;
  color: rgba(255,255,255,0.85);
  margin-bottom: 5px;
}
.caption-meta {
  font-size: 12px;
  color: rgba(255,255,255,0.45);
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.photo-pos-bar {
  text-align: center;
  padding: 12px 0 20px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: rgba(255,255,255,0.25);
  letter-spacing: 0.12em;
}

/* ── Content Area ── */
.content-area {
  display: grid;
  grid-template-columns: 1fr 360px;
  max-width: 1360px;
  margin: 0 auto;
  background: var(--warm-bg);
  border-left: 1px solid var(--warm-rule);
  border-right: 1px solid var(--warm-rule);
}

/* ── Meta Panel ── */
.meta-panel {
  padding: 40px 36px;
  border-right: 1px solid var(--warm-rule);
  min-width: 0;
}
.photo-title {
  font-family: 'Outfit', sans-serif;
  font-size: clamp(24px, 3.5vw, 32px);
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: 14px;
  line-height: 1.1;
  color: var(--ink-dark);
}

/* Photographer row */
.photographer-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 24px;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--warm-rule);
}
.photographer-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(135deg, #3E5A48, #2A3E32);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Outfit', sans-serif;
  font-size: 13px;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}
.photographer-info { display: flex; flex-direction: column; gap: 2px; }
.photographer-name { font-size: 14px; font-weight: 600; color: var(--ink-dark); }
.photographer-link { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--gold-dark); text-decoration: none; }
.photographer-link:hover { text-decoration: underline; }
.photographer-meta { margin-left: auto; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--ink-light); }

/* Tabs */
.tabs-row {
  display: flex;
  gap: 0;
  border-bottom: 1px solid var(--warm-rule);
  margin-bottom: 28px;
}
.tab {
  padding: 12px 20px;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.03em;
  color: var(--ink-light);
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  cursor: pointer;
  transition: all 0.15s;
}
.tab:hover { color: var(--ink-dark); }
.tab-active { color: var(--ink-dark); border-bottom-color: var(--gold-dark); }

/* Tab panes */
.tab-pane { display: block; }
.section-label {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--ink-light);
  font-weight: 600;
  margin-bottom: 14px;
}
.photo-caption-text {
  font-size: 14px;
  line-height: 1.85;
  color: var(--ink-mid);
  margin-bottom: 28px;
}

/* Containers */
.containers-section { border-top: 1px solid var(--warm-rule); padding-top: 22px; }
.containers-note { font-size: 11px; font-style: italic; color: var(--ink-light); margin-bottom: 12px; }
.containers-list { display: flex; flex-direction: column; gap: 8px; }
.container-loading { font-size: 12px; color: var(--ink-light); padding: 12px 0; }
:global(.container-item) {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 16px;
  background: #fff;
  border: 1px solid var(--warm-rule);
}
:global(.container-item-info) { display: flex; flex-direction: column; gap: 2px; }
:global(.container-item-title) { font-size: 13px; font-weight: 500; color: var(--ink-dark); }
:global(.container-item-url) { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--ink-light); }
:global(.container-type-badge) {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  background: var(--warm-card);
  border: 1px solid var(--warm-rule);
  color: var(--gold-dark);
  padding: 3px 8px;
}
:global(.container-empty) { font-size: 13px; color: var(--ink-light); font-style: italic; }

/* EXIF */
.exif-table { background: #fff; border: 1px solid var(--warm-rule); }
:global(.exif-loading) { padding: 16px; font-size: 12px; color: var(--ink-light); }
:global(.exif-row) {
  display: grid;
  grid-template-columns: 160px 1fr;
  padding: 10px 18px;
  border-bottom: 1px solid #F0EBE0;
  gap: 12px;
  align-items: baseline;
}
:global(.exif-row:last-child) { border-bottom: none; }
:global(.exif-key) { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--ink-light); text-transform: uppercase; letter-spacing: 0.1em; }
:global(.exif-val) { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--ink-dark); font-weight: 500; }

/* Tags */
.tags-cloud { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; }
:global(.tag-item) { font-family: 'JetBrains Mono', monospace; font-size: 11px; background: #fff; border: 1px solid var(--warm-rule); color: var(--ink-mid); padding: 6px 12px; }
.geo-coords { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--ink-mid); line-height: 1.7; }

/* ── Interaction Panel ── */
.interaction-panel {
  padding: 32px 28px;
  background: #fff;
  display: flex;
  flex-direction: column;
  gap: 16px;
  position: sticky;
  top: 0;
  align-self: start;
  max-height: 100vh;
  overflow-y: auto;
}

/* Reactions */
.reaction-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
.reaction-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 14px 8px;
  border: 1px solid var(--warm-rule);
  background: var(--warm-card);
  cursor: pointer;
  transition: all 0.15s;
}
.reaction-btn:not(.reaction-views):hover { border-color: var(--gold-dark); }
.reaction-btn.active {
  border-color: var(--gold-dark);
  background: #FEF9EE;
}
.reaction-btn.active .reaction-icon { filter: saturate(1.5); }
.reaction-views {
  cursor: default;
  opacity: 0.85;
}
.reaction-icon { font-size: 20px; line-height: 1; }
.reaction-count { font-family: 'JetBrains Mono', monospace; font-size: 16px; font-weight: 600; color: var(--ink-dark); }
.reaction-label { font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-light); }

/* Guest prompt */
.guest-prompt {
  background: var(--warm-card);
  border: 1px solid var(--warm-rule);
  padding: 14px 16px;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 8px;
  align-items: center;
}
.guest-prompt p { font-size: 12px; color: var(--ink-mid); }
.btn-signin {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.05em;
  border: 1px solid var(--ink-dark);
  color: var(--ink-dark);
  padding: 9px 16px;
  text-decoration: none;
  display: inline-block;
}

/* Action buttons */
.action-btns { display: flex; flex-direction: column; gap: 8px; border-bottom: 1px solid var(--warm-rule); padding-bottom: 16px; }
.btn-download {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  padding: 12px 16px;
  background: linear-gradient(135deg, var(--gold), var(--gold-dark));
  color: #fff;
  border: none;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-decoration: none;
  cursor: pointer;
  transition: opacity 0.15s;
}
.btn-download:hover { opacity: 0.9; }
.btn-download.preview {
  background: none;
  border: 1px solid var(--warm-rule);
  color: var(--ink-mid);
}
.btn-note { font-size: 10px; opacity: 0.7; }
.btn-share {
  width: 100%;
  padding: 11px 16px;
  border: 1px solid var(--warm-rule);
  background: #fff;
  color: var(--ink-mid);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.04em;
  cursor: pointer;
}
.btn-share:hover { border-color: var(--ink-dark); color: var(--ink-dark); }
.report-link { text-align: center; padding-top: 4px; }
.report-text { font-size: 11px; color: var(--ink-light); cursor: pointer; border-bottom: 1px solid #D8D2C6; }

/* Admin panel */
.admin-panel {
  border: 1px solid rgba(163,73,59,0.3);
  background: #FDF5F5;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.admin-panel-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.14em; color: #A3493B; font-weight: 600; margin-bottom: 6px; }
.btn-admin-action {
  padding: 9px 14px;
  border: 1px solid rgba(163,73,59,0.4);
  background: #fff;
  color: #A3493B;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-align: left;
  cursor: pointer;
}
.btn-admin-delete {
  padding: 9px 14px;
  border: 1px solid #A3493B;
  background: #A3493B;
  color: #fff;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-align: left;
  cursor: pointer;
}

