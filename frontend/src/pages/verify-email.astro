---
/**
 * verify-email.astro -- Email verification page
 * Route: /verify-email/
 *
 * This path is generated by the backend's issueEmailVerification():
 *   `${FRONTEND_BASE_URL}/verify-email?token=<rawToken>`
 *
 * Two modes:
 *   A. Landing (no token): post-registration prompt -- "check your inbox"
 *   B. Verification (token present): consume the token, show result
 *
 * Token consumption: POST /api/v1/registration/email-password/verify { token }
 * Returns 204 on success. 404 = invalid. 410 = used or expired.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Verify Your Email" description="Verify your Bhopal Camera Club email address." bodyClass="auth-page">
  <section class="auth-section">
    <div class="auth-card">

      <a href="/" class="auth-logo" aria-label="Bhopal Camera Club home">
        <img src="/images/bcc-logo-default.png" alt="Bhopal Camera Club" width="160" height="44" loading="eager" />
      </a>

      <!-- State: Checking (shown while JS runs) -->
      <div id="state-checking">
        <div class="vef-dots" aria-label="Checking" role="status">
          <span class="vef-dot"></span>
          <span class="vef-dot"></span>
          <span class="vef-dot"></span>
        </div>
      </div>

      <!-- State: Prompt (no token -- after registration) -->
      <div id="state-prompt" hidden>
        <div class="vef-icon" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m2 8 10 6 10-6"/>
          </svg>
        </div>
        <h1 class="vef-heading">Check your inbox</h1>
        <p class="vef-body">
          We sent a verification link to your email address. Click the link to activate your BCC account.
        </p>
        <p class="vef-hint">Can't find it? Check your spam folder. The link expires in 24 hours.</p>
        <a href="/hub/" class="btn btn-outline btn-md vef-btn">Continue to Member Hub</a>
      </div>

      <!-- State: Success -->
      <div id="state-success" hidden>
        <div class="vef-icon vef-icon--success" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </div>
        <h1 class="vef-heading">Email verified!</h1>
        <p class="vef-body">
          Your BCC email address has been verified. Your platform identity is now fully active.
        </p>
        <a href="/hub/" class="btn btn-gold btn-md vef-btn">Continue to Member Hub</a>
      </div>

      <!-- State: Error -->
      <div id="state-error" hidden>
        <div class="vef-icon vef-icon--error" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <line x1="15" y1="9" x2="9" y2="15"/>
            <line x1="9" y1="9" x2="15" y2="15"/>
          </svg>
        </div>
        <h1 class="vef-heading">Verification failed</h1>
        <p class="vef-body" id="error-detail">The link may be expired or already used.</p>
        <a href="/auth/register/" class="btn btn-outline btn-md vef-btn">Register again</a>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
.auth-page { background: var(--surface-1); }

.auth-section {
  min-height: calc(100vh - 96px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--s-8) var(--s-3);
}

.auth-card {
  background: var(--surface-0);
  border: 1px solid var(--hairline);
  border-radius: var(--r-1);
  box-shadow: var(--e-2);
  padding: var(--s-8) var(--s-6);
  width: 100%;
  max-width: 440px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--s-3);
}

.auth-logo {
  display: block;
  margin: 0 auto;
  width: fit-content;
}

/* Loading dots */
.vef-dots {
  display: flex;
  gap: 6px;
  justify-content: center;
  padding: var(--s-4) 0;
}
.vef-dot {
  width: 10px; height: 10px;
  background: var(--gold-600);
  border-radius: var(--r-full);
  animation: vef-pulse 1.2s ease-in-out infinite both;
}
.vef-dot:nth-child(2) { animation-delay: 0.2s; }
.vef-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes vef-pulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40%           { transform: scale(1);   opacity: 1;   }
}

/* Icon states */
.vef-icon {
  color: var(--gold-600);
  margin-bottom: var(--s-1);
}
.vef-icon--success { color: #16A34A; }
.vef-icon--error   { color: #EF4444; }

/* Text */
.vef-heading {
  font-size: var(--text-h3);
  font-weight: 700;
  color: var(--ink-900);
  text-align: center;
  margin: 0;
}

.vef-body {
  font-size: 14px;
  color: var(--ink-600);
  text-align: center;
  line-height: 1.65;
  margin: 0;
  font-family: var(--font-body);
}

.vef-hint {
  font-size: 12px;
  color: var(--ink-400);
  text-align: center;
  margin: calc(-1 * var(--s-2)) 0 0;
  font-family: var(--font-body);
}

.vef-btn {
  margin-top: var(--s-1);
  width: 100%;
  justify-content: center;
}

@media (max-width: 480px) {
  .auth-card { padding: var(--s-6) var(--s-3); border: none; box-shadow: none; }
}
</style>

<script>
  const API = '/api/v1';

  function show(id: string): void {
    document.querySelectorAll<HTMLElement>('[id^="state-"]').forEach(el => { el.hidden = true; });
    const el = document.getElementById(id);
    if (el) el.hidden = false;
  }

  async function init(): Promise<void> {
    const token = new URLSearchParams(window.location.search).get('token');

    if (!token) {
      // Mode A: post-registration prompt
      show('state-prompt');
      return;
    }

    // Mode B: consume the verification token
    show('state-checking');

    try {
      const res = await fetch(`${API}/registration/email-password/verify`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token }),
      });

      if (res.status === 204 || res.ok) {
        // Remove token from URL (clean up)
        history.replaceState(null, '', '/verify-email/');
        show('state-success');
        return;
      }

      // Error cases
      const detail = document.getElementById('error-detail');
      if (res.status === 404) {
        if (detail) detail.textContent = 'This verification link is invalid.';
      } else if (res.status === 410) {
        if (detail) detail.textContent = 'This link has already been used or has expired.';
      }
      show('state-error');

    } catch {
      show('state-error');
    }
  }

  init();
</script>
